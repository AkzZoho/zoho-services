# ============================================================================
# DS Analyzer — environment template
# Copy to `.env` and fill in only the keys you want to use.
#
# Two supported operating modes:
#
#   ┌──────────────────┬─────────────────────────────────────────────────────┐
#   │ Mode             │ How to enable                                       │
#   ├──────────────────┼─────────────────────────────────────────────────────┤
#   │ OpenAI (ChatGPT) │ Set OPENAI_API_KEY. Leave the others blank.         │
#   │ Anthropic        │ Set ANTHROPIC_API_KEY. Leave OPENAI_API_KEY blank.  │
#   │ No-AI (stub)     │ Leave ALL keys blank. Endpoints return deterministic│
#   │                  │ placeholder JSON the UI renders without errors.     │
#   │                  │ Useful for offline demos / tests.                   │
#   └──────────────────┴─────────────────────────────────────────────────────┘
# ============================================================================

# ----- LLM provider keys (configure what you use) -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Preferred provider order (comma-separated). Providers without a configured
# key are automatically skipped, so it is safe to leave the default.
LLM_PREFERENCE=openai,anthropic,stub

# ----- Server -----
PORT=3001
NODE_ENV=development
MAX_UPLOAD_MB=25

# Optional: comma-separated list of allowed CORS origins.
# Leave blank to allow all origins.
CORS_ALLOWED_ORIGINS=

# ----- Admin -----
# Required by POST /api/admin/* endpoints — most importantly
# /api/admin/tool-visibility, which persists the Admin Panel's tool-visibility
# toggles into client/.env. Must match VITE_ADMIN_PASSWORD in client/.env so
# the panel can authenticate against this API.
# Leave blank to disable server-side write-back (toggles remain in-memory /
# localStorage only).
ADMIN_PASSWORD=
