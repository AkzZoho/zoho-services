												tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&Tenant.ID=" + Tenant_Screening[Tenant.Role == "Tenants" && Tenant.Tenant_Status == "Screening In Process" && Tenant.Name.contains(input.Search) || Tenant.Email.contains(input.Search)].ID.getAll() + "&Tenant.ID_op=18");
