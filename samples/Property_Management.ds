										{
											complaint = Raise_a_Complaint[ID == input.Compliant_No];
											complaint.Complaint_Status="Paid";
										}
										else if(input.Billing_ID != null)
										{
											payment = Add_Payment_Notes[ID == input.Billing_ID.ID];
											payment.Status="Paid";
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Vacate_Request=payment.Vacate_Request
												Action_field="Security Deposit Paid"
											];
										}
										openUrl("#Script:page.reload","same Window");
						)
					}
				}

			}
			Onvalidate as "Onvalidate"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.Alert();
										if(input.Grace_Days_For_Monthly_Payment < input.After_Due_Date)
										{
											alert language.get("zcpm.config.alert1");
											cancel submit;
										}
										if((input.Do_You_Want_Configure_Manager_Commission == "Yes" && input.Category.size() == 0) || (input.Do_You_Want_Configure_Manager_Commission == "Yes" && input.Category.contains("Rental Monthly") && input.Rental_Monthly == null || input.Rental_Monthly <= 0) || (input.Do_You_Want_Configure_Manager_Commission == "Yes" && input.Category.contains("Complaint") && input.Complaint == null || input.Complaint <= 0) || (input.Do_You_Want_Configure_Manager_Commission == "Yes" && input.Category.contains("Agreement") && input.Agreement <= 0 || input.Agreement == null))
										{
											alert language.get("zcpm.config.alert2");
											cancel submit;
										}
										if(input.Do_you_want_configure_penalty == "Yes" && input.Grace_Days_For_Monthly_Payment == null || input.Grace_Days_For_Monthly_Payment < 0)
										{
											alert language.get("zcpm.config.alert3");
											cancel submit;
										}
										if(input.Do_you_want_configure_penalty == "Yes" && input.Penalty_Payment_Method.isEmpty())
										{
											alert language.get("zcpm.config.alert3");
											cancel submit;
										}
										if(input.Do_you_want_configure_penalty == "Yes" && input.Penalty_Payment_Method == "Fixed Amount" && input.Fixed_Penalty_Amount == null)
										{
											alert language.get("zcpm.config.alert3");
											cancel submit;
										}
										if(input.Do_you_want_configure_penalty == "Yes" && input.Penalty_Payment_Method == "%" && input.Penalty == null || input.Penalty < 1)
										{
											alert language.get("zcpm.config.alert3");
											cancel submit;
										}
										if(input.Do_you_want_configure_penalty == "Yes" && input.After_Due_Date < 1 || input.After_Due_Date == null)
										{
											alert language.get("zcpm.config.alert4");
											cancel submit;
										}
										if(input.Do_you_want_configure_Additional_Payment_Monthly == "Yes" && input.Additional_Payment_Monthly.count() == 0)
										{
											alert language.get("zcpm.config.alert5");
											cancel submit;
										}
						)
					}
				}

			}
