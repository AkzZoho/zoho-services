		default custom All_Email_Templates
		{
			displayName = "Email Templates"
			show all rows from Email_Template  [Enable_This_Mail_Notification == true]  
			(
				Send_To as "Send To"
				Template_Name as "Template Name"
				Subject_field as "Subject"
				Message
				Enable_This_Mail_Notification as "Enable This Mail Notification"
				(
						displaytrue = "Enabled"
						displayfalse = "Disabled"
				)
			)
			group by
			(
				Send_To ascending
			)
			conditional formatting
			(
				"Enabled"
				{
				condition = (Enable_This_Mail_Notification == true)
				fields = [Enable_This_Mail_Notification]
				format = "color:#04a268;"
				}
				"Disabled"
				{
				condition = (Enable_This_Mail_Notification == false)
				fields = [Enable_This_Mail_Notification]
				format = "color:##fe455d;"
				}
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Email Template"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '16px'\n	bgColor = '#F9FAFE'\n\n		width = '100%'\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n		width = '90%'\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#131635'\n	size = '16px'\n	type = 'field'\n\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Template_Name'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginBottom = '0px'\n	marginTop = '6px'\n	color = '#868686'\n	size = '14px'\n	type = 'field'\n\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Enable_This_Mail_Notification'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '0px'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n		width = '10%'\n		hAlign = 'right'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<image  \n	\n	color = '#828286'\n	width = '24px'\n	height = '24px'\n	type = 'icon'\n	value = 'arrows-2-small-right'\n	size = '22px'\n	cornerRadius = '12px'\n	iconType = 'outline'\n/>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
