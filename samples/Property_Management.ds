                 	return style_txt;
                 }
				 string Styles.Vertical_Tab()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	style_txt = ".zc-prop-vertical-tabpanel { } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead, .zc-prop-vertical-tabpanel .zc-prop-vertical-tabbody { height: 100%; overflow: auto; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead { width: 250px; padding: 20px; border-right: 1px solid " + color_codes.get("zc-prop-border-color") + "; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabbody { width: calc(100% - 250px); } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li { list-style-type: none; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li input { display: none; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li a { width: 100%; display: block; border-radius: 4px; padding: 10px 12px; margin: 2px 0px; font-size: 14px; font-weight: 400; line-height: 21px; color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li a:hover { color: var(--theme_brand_color); } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li ul.zc-prop-vertical-tabsubmenu { background-color: var(--left_pane_section); border-radius: 4px; display: none; animation-duration: .25s; animation-name: animation-fade-up; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li ul.zc-prop-vertical-tabsubmenu li a { padding-left: 20px; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead .zc-prop-vertical-tab-comp>label>a:after { content: '\f105'; font: normal normal normal 14px/21px FontAwesome; float: right; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li input:checked~ul.zc-prop-vertical-tabsubmenu { display: block; } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead .zc-prop-vertical-tab-comp>input:checked~label>a:after { content: '\f107'; transform: rotate(0deg); } .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li a.zc-prop-active-tab { background-color: var(--theme_brand_color); font-weight: 600; color: var(--primary_bg_text_color); }";
                 	rtl_style = ".zc-rtl-wrapper .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead { border-right: 0px; border-left: 1px solid " + color_codes.get("zc-prop-border-color") + "; } .zc-rtl-wrapper .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead li ul.zc-prop-vertical-tabsubmenu li a { padding-left: 12px; padding-right: 20px; } .zc-rtl-wrapper .zc-prop-vertical-tabpanel .zc-prop-vertical-tabhead .zc-prop-vertical-tab-comp>label>a:after { float: left; transform: rotate(180deg); }";
                 	style_txt = style_txt + rtl_style;
                 	return style_txt;
                 }
				 string Styles_Page.Add_Property()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	style_txt = thisapp.Styles.Stepper(3) + ".zc-prop-add_property .zc-prop-page-header { padding: 24px 30px; } .zc-prop-add_property .zc-prop-page-content { width: 100%; height: calc(100% - 71px); padding: 0px 30px 24px; } .zc-prop-add_property .zc-prop-card { overflow: hidden; } .zc-prop-add_property .zc-prop-stepper-wrapper { border-bottom: 1px solid " + color_codes.get("zc-prop-border-color") + "; } .zc-prop-add_property .zc-prop-form { width: 100%; height: calc(100% - 107px); border-radius: 0px 0px 8px 8px;/* overflow: auto;*/ } .zc-prop-form .zc-form-fullheight, .zc-prop-form .zc-form-fullheight .form-outer-wrapper, .zc-prop-form .zc-form-fullheight .form-outer-wrapper .row, .zc-prop-form .zc-form-fullheight .form-outer-wrapper .row form { /* width: 100%; */ height: 100%; } .zc-prop-form .zc-form-fullheight .form-outer-wrapper .row form .formContainer { height: calc(100% - 73px) !important; overflow: auto; } .zc-prop-form .zc-form-fullheight .form-outer-wrapper .row form .formContainer, .zc-prop-form .formbutton { padding: 20px 30px; } .zc-prop-form .statelessFormWidth .zc-live-primary-btn { margin-bottom: 0px; }";
                 	new = ".zc-dem-container .inner .form-outer-wrapper { height: calc(100% - 0px) !important; }";
                 	return style_txt + new;
                 }
				 string Styles_Page.Add_Record(string page_link_name)
                 {
