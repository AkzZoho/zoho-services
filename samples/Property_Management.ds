	reports
	{
		list Tenant_Screening_for_Tenant
		{
			displayName = "Tenant Screening for Tenant"
			show all rows from Tenant_Screening  [Tenant.Email == zoho.loginuserid]  
			(
				Tenant
				custom action "Update"
				(
	  			workflow = Update_Tenant_Screening_f
				show action in edit record menu = true
				column header = "Update"
				)
				Current_Owner_Name  as "Owner"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Current_Owner_Contact_Number as "Current Owner Contact  Number"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Current_Address  as "Current Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				Occupant_Type as "Occupant Type"
				Monthly_Rental as "Monthly Rental"
				Lease_Type as "Lease Type"
				Lease_Amount as "Lease Amount"
			)
		}
		default list All_Properties
		{
			displayName = "All Properties"
			show all rows from Add_Property    
			(
				Property_Name as "Property Name"
				Size as "Size (in Sq . ft)"
				No_of_Blocks as "No of Blocks"
				Location
				custom action "Add Block"
				(
	  			workflow = Add_Block_All_Properties
				show action in edit record menu = true
				column header = "Add Block"
				)
				Property_Address  as "Property Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				Property_Type as "Property Type"
				Amenities
				Units
				Units.Manager
				No_of_Parking_Slots as "No of Parking Slots(if Available)"
				No_of_Parking_Occupied as "No of Parking Occupied"
			)
			custom actions
			(
				"Detail View"
				(
	  			workflow = Open_Detail_View_Properti
				show action in edit record menu = true
				)
