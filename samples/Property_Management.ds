				 list Data_Map.Email_Templates()
                 {
                 	email_template_Contents = {{"SendTo":"Tenant","TemplateName":"Move to Screening","Subject":"Update Profile for Screening","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Update Profile for screening </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Tenant_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> We kindly request you to update your profile at your earliest to move on tenant agreement. </p> </div> </div> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box;\"> <span style=\"display: block; font-size: 15px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 8px;\"> Greetings, </span> <span style=\"display: block; font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 4px;\"> ${Admin_User} </span> </div> </div> </div> </div>"},{"SendTo":"Tenant","TemplateName":"Tenant Profile Approved","Subject":"Tenant Profile Approved","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Tenant Profile Approved </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Tenant_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> Congratulations! We are pleased to inform you that your profile has been successfully approved. </p> </div> </div> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box;\"> <span style=\"display: block; font-size: 15px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 8px;\"> Greetings, </span> <span style=\"display: block; font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 4px;\"> ${Admin_User} </span> </div> </div> </div> </div>"},{"SendTo":"Tenant","TemplateName":"Tenant Profile Rejected","Subject":"Tenant Profile Rejected","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Tenant Profile Rejected </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Tenant_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> We regret to inform you that your profile has been rejected. We understand that this maybe disappointing news, and we would like to provide you with more information to help you understand our decision and guide you on the next steps. </p> </div> </div> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box;\"> <span style=\"display: block; font-size: 15px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 8px;\"> Greetings, </span> <span style=\"display: block; font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 4px;\"> ${Admin_User} </span> </div> </div> </div> </div>"},{"SendTo":"Approver","TemplateName":"Waiting for Tenant Approval","Subject":"Waiting for Tenant Approval","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Waiting for Tenant Approval </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Approver_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> We wanted to inform you that tenent profile has been successfully updated. we kindly request your review and approval. <br> <br> Tenant details are below: </p> </div> <div> <table style=\"width: 100%; line-height: normal; border-collapse: collapse; margin-bottom: 20px;\"> <tbody> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Tenant Name </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Tenant_Name} </td> </tr> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Email </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Tenant_Email} </td> </tr> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Phone Number </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Phone_Number} </td> </tr> </tbody> </table> </div> <div style=\"margin-top: 20px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> <a href=\"\" style=\"font-size: 15px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #FFF; display: inline-block; vertical-align: top; padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 20px; box-sizing: border-box; border-radius: 1px 1px 1px 1px; text-decoration: none; background-color: #38BB78;\">View Detail</a> </div> </div> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box;\"> <span style=\"display: block; font-size: 15px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 8px;\"> Greetings, </span> <span style=\"display: block; font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 4px;\"> ${Admin_User} </span> </div> </div> </div> </div>"},{"SendTo":"Owner","TemplateName":"Agreement Waiting for Owner Approval","Subject":"Tenant Agreement Waiting for Approval","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Waiting for Tenant Approval </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Approver_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> We wanted to inform you that tenent profile has been successfully updated. we kindly request your review and approval. <br> <br> Tenant details are below: </p> </div> <div> <table style=\"width: 100%; line-height: normal; border-collapse: collapse; margin-bottom: 20px;\"> <tbody> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Tenant Name </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Tenant_Name} </td> </tr> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Email </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Tenant_Email} </td> </tr> <tr> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #131635; text-align: left;\"> Phone Number </td> <td style=\"padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 0px; box-sizing: border-box; font-size: 16px; line-height: 1.3; font-weight: 600; letter-spacing: 0.1px; color: #131635; text-align: left;\"> ${Phone_Number} </td> </tr> </tbody> </table> </div> <div style=\"margin-top: 20px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> <a href=\"\" style=\"font-size: 15px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #FFF; display: inline-block; vertical-align: top; padding-top: 10px; padding-right: 20px; padding-bottom: 10px; padding-left: 20px; box-sizing: border-box; border-radius: 1px 1px 1px 1px; text-decoration: none; background-color: #38BB78;\">View Detail</a> </div> </div> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box;\"> <span style=\"display: block; font-size: 15px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 8px;\"> Greetings, </span> <span style=\"display: block; font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-bottom: 4px;\"> ${Admin_User} </span> </div> </div> </div> </div>"},{"SendTo":"Owner","TemplateName":"Agreement Waiting for Owner Approval","Subject":"Tenant Agreement Waiting for Approval","Message":"<div style=\"width: 750px; font-family: 'Lato', Arial, Helvetica, sans-serif, Roboto, -apple-system, BlinkMacSystemFont;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 0px; padding-right: 20px; padding-bottom: 0px; padding-left: 20px; box-sizing: border-box;\"> <div style=\"padding-top: 30px; padding-right: 0px; padding-bottom: 30px; padding-left: 0px; box-sizing: border-box; border-width: 0px 0px 1px 0px; border-style: dashed; border-color: #DDE1E5;\"> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 500; letter-spacing: 0.1px; color: #131635; text-align: center; margin-top: 0px; margin-right: 0px; margin-bottom: 24px; margin-left: 0px;\"> Agreement Waiting for Owner Approval </h6> <div> <h6 style=\"font-size: 16px; line-height: 1.3; font-weight: 400; letter-spacing: 0.1px; color: #131635; margin-top: 0px; margin-right: 0px; margin-bottom: 12px; margin-left: 0px;\"> Hi ${Owner_Name}, </h6> <p style=\"font-size: 14px; line-height: 1.5; font-weight: 400; letter-spacing: 0.1px; color: #3C3E44; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;\"> We wanted to inform you that the submitted Tenant agreement is currently under review. Kindly review and approve. </p> </div> <div style=\"border: 1px solid #EBECF0;border-radius: 8px;margin-top: 24px;margin-right: 0px;margin-bottom: 0px;margin-left: 0px;\"> <table style=\"width: 100%; line-height: normal; border-collapse: collapse;\"> <tbody> <tr> <td style=\"vertical-align: top;padding-top: 10px;padding-right: 20px;padding-bottom: 10px;padding-left: 20px;border-bottom: 1px solid #EBECF0;\" colspan=\"4\"> <span style=\"font-size: 15px;font-weight: 400;line-height: 1.3;color: #131635;float: left;\">Agreement Details </span> </td> </tr> <tr> <td style=\"vertical-align: top;padding-top: 12px;padding-right: 20px;padding-bottom: 12px;padding-left: 20px;\"> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #131635;display: block;\">Agreement No </span> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #3C3E44;display: block;margin-top: 8px;margin-right: 0px;margin-bottom: 0px;margin-left: 0px;\">${Agreement_No} </span> </td> <td style=\"vertical-align: top;padding-top: 12px;padding-right: 20px;padding-bottom: 12px;padding-left: 20px;\"> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #3C3E44;display: block;\">Agreement Type </span> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #131635;display: block;margin-top: 8px;margin-right: 0px;margin-bottom: 0px;margin-left: 0px;\">${Agreement_Type} </span> </td> <td style=\"vertical-align: top;padding-top: 12px;padding-right: 20px;padding-bottom: 12px;padding-left: 20px;\"> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #3C3E44;display: block;\">Property </span> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #131635;display: block;margin-top: 8px;margin-right: 0px;margin-bottom: 0px;margin-left: 0px;\">${Property_Name} </span> </td> <td style=\"vertical-align: top;padding-top: 12px;padding-right: 20px;padding-bottom: 12px;padding-left: 20px;\"> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #3C3E44;display: block;\">Unit </span> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #131635;display: block;margin-top: 8px;margin-right: 0px;margin-bottom: 0px;margin-left: 0px;\"> ${Unit_Name} </span> </td> </tr> <tr> <td style=\"vertical-align: top;padding-top: 12px;padding-right: 20px;padding-bottom: 12px;padding-left: 20px;\"> <span style=\"font-size: 14px;font-weight: 400;line-height: 1.5;color: #131635;display: block;\">Security Deposit </span> <span style=\"font-size: 14px;