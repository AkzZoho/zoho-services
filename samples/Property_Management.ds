	  			workflow = Detail_View_Payment_Direc
				)
			)
			conditional formatting
			(
				"Cancel & Unpaid"
				{
				condition = (Status == "Cancel" || Status == "Unpaid")
				fields = [Status]
				format = "color:#fe455d;"
				}
				"Paid & Received"
				{
				condition = (Status == "Paid" || Status == "Received")
				fields = [Status]
				format = "color:#187822;"
				}
			)
		}
