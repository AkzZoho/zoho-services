			Total_Cost as "Total Cost"
			{
				type =  form
				form = Inspection_Form
				record event = on add or edit
					status = inactive

				on user input of Complaints.Cost
				{
					actions 
					{
						custom deluge script
						(
											input.Complaints_Amount = input.Complaints.sum(Cost);
										input.Complaints_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Complaints.sum(Cost));
						)
					}
				}

