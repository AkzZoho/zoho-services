t&lt;\/div&gt; &lt;span style=&apos;color:&lt;%=color%&gt;;&apos; class=&apos;zc-prop-flt-right&apos;&gt;&lt;%=language.get(mp_key)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tfor each  agreement in outdated_agreements\n\t\t\t\t{\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(agreement.Tenant.ID,agreement.Tenant.Profile_Photo,&quot;New_Users_Report&quot;,&quot;Profile_Photo&quot;,agreement.Tenant.Name.toString(),false);\n\t\t\t\t\tcolor = if(agreement.Agreement_Type == &quot;Rent&quot;,&quot;#2A6FFC&quot;,&quot;#179E6C&quot;);\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-fw zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-atxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=agreement.Tenant.Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=agreement.Property.Property_Name + &quot; - &quot; + agreement.Unit.Unit_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt; \n\t\t\t\t\t\t\t\t&lt;span style=&apos;color:&lt;%=color%&gt;;&apos; class=&apos;zc-prop-flt-right&apos;&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;!---&lt;div class=&apos;zc-prop-flt-left zc-prop-card zc-prop-property-list-wrapper&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.dashboard.recent.complaints&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n&lt;%\n\t\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\trecent_complaint_property = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id] sort by Added_Time desc range from 0 to 2;\n\t\t\trecent_complaint = Raise_a_Complaint[ID != 0] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\telse if(login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\trecent_complaint_property = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t\trecent_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\telse if(login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\trecent_complaint_property = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t\trecent_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\tif((input.rec_id != null &amp;&amp; recent_complaint_property.count() == 0) || recent_complaint.count() == 0)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;ul&gt;\n&lt;%\n\t\t\tif(input.rec_id != null &amp;&amp; getProp &gt; 0)\n\t\t\t{\n\t\t\t\tfor each  comp in recent_complaint_property\n\t\t\t\t{\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(comp.ID,comp.Photo,complaint_report,&quot;Photo&quot;,comp.Complaint_About,false);\n\t\t\t\t\tcolor = &quot;&quot;;\n\t\t\t\t\tif(comp.Complaint_Status == &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#2A6FFC&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status != &quot;Completed&quot; || comp.Complaint_Status != &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#B8770D&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#179E6C&quot;;\n\t\t\t\t\t}\n\t\t\t\t\tmp_key = &quot;zcpm.dashboard.requested&quot;;\n\t\t\t\t\tif(comp.Complaint_Status == &quot;Complaint Reviewed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.reviewed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Vendor Assigned&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.vendor.assigned&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;In Progress&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.inprogress&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Manager Rejected&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.manager.rejected&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Work Order Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.work.order.completed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Waiting for Payment&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.waiting.for.payment&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Paid&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.paid&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.completed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-fw zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-atxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;h6&gt;  &lt;%=comp.Complaint_About%&gt;  &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=comp.Unit.Address%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt; \n\t\t\t\t\t\t\t\t&lt;span style=&apos;color:&lt;%=color%&gt;;&apos; class=&apos;zc-prop-flt-right&apos;&gt;&lt;%=language.get(mp_key)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tfor each  comp in recent_complaint\n\t\t\t\t{\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(comp.ID,comp.Photo,complaint_report,&quot;Photo&quot;,comp.Complaint_About,false);\n\t\t\t\t\tcolor = &quot;&quot;;\n\t\t\t\t\tif(comp.Complaint_Status == &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#2A6FFC&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status != &quot;Completed&quot; &amp;&amp; comp.Complaint_Status != &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#B8770D&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tcolor = &quot;#179E6C&quot;;\n\t\t\t\t\t}\n\t\t\t\t\tmp_key = &quot;zcpm.dashboard.requested&quot;;\n\t\t\t\t\tif(comp.Complaint_Status == &quot;Complaint Reviewed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.reviewed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Vendor Assigned&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.vendor.assigned&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;In Progress&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.inprogress&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Manager Rejected&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.manager.rejected&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Work Order Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.work.order.completed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Waiting for Payment&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.waiting.for.payment&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Paid&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.complaint.paid&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(comp.Complaint_Status == &quot;Completed&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tmp_key = &quot;zcpm.dashboard.completed&quot;;\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-fw zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-atxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;h6&gt;  &lt;%=comp.Complaint_About%&gt;  &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=comp.Unit.Address%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt; \n\t\t\t\t\t\t\t\t&lt;span style=&apos;color:&lt;%=color%&gt;;&apos; class=&apos;zc-prop-flt-right&apos;&gt;&lt;%=comp.Complaint_Status%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;---&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Properties(string action, string occupancy_type, int rec_id, string search, int step, string subtab, string tab, int user_id)
		{
			displayname = "Properties"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet13' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet13()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tCommon_language = thisapp.Localization.common();\n\t\tpage_link_name = &quot;Properties&quot;;\n\t\tno_data_component_params = {&quot;is_img&quot;:true,&quot;header_txt&quot;:&quot;No Data&quot;,&quot;Secondary_header_txt&quot;:true};\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;).getPrefix(&quot;&amp;subtab=&quot;).toNumber();\n\t\t\tinput.subtab = input.action.getSuffix(&quot;subtab=&quot;);\n\t\t\tinput.tab = input.action.getSuffix(&quot;tab=&quot;).getPrefix(&quot;&amp;rec_id&quot;);\n\t\t\tinput.action = input.action.getPrefix(&quot;&amp;rec_id=&quot;);\n\t\t\tinput.action = input.action.getPrefix(&quot;&amp;tab=&quot;);\n\t\t}\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\tgetuser = New_User[Email == zoho.loginuserid];\n\t\treport_filter = &quot;&quot;;\n\t\tcolor = &quot;&quot;;\n\t\tinput.search = if(input.search == null,&quot;&quot;,input.search);\n\t\tcontent = if(input.tab.isEmpty() || input.tab == &quot;properties&quot;,language.get(&quot;zcpm.property.filter&quot;),if(input.tab == &quot;units&quot;,language.get(&quot;zcpm.unit.filter1&quot;),language.get(&quot;zcpm.parking.filter&quot;)));\n\t\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tproperty = Add_Property[ID == input.rec_id];\n\t\t\tunit = Add_Unit[ID == input.rec_id];\n\t\t\tparking = Add_Parking[ID == input.rec_id];\n\t\t}\n\t\telse\n\t\t{\n\t\t\tproperty = Add_Property[ID == input.rec_id &amp;&amp; Unit_Owners.Email.contains(zoho.loginuserid) || Manager.Email == zoho.loginuserid || Units.Manager == thisapp.get_user_id()];\n\t\t\tunit = Add_Unit[ID == input.rec_id &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid || Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()];\n\t\t}\n\t\tconfig = User_Configuration[ID != 0];\n\t\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tview_properties = Add_Property[ID != 0];\n\t\t\tview_units = Add_Unit[ID != 0 &amp;&amp; Owner_Approval_Status != &quot;Requested&quot;];\n\t\t\tview = Add_Unit[Unit_Type == &quot;Parking&quot;];\n\t\t\tview_parking = Add_Parking[ID != 0];\n\t\t\tif(!input.search.isEmpty())\n\t\t\t{\n\t\t\t\tview_units = Add_Unit[Owner_Approval_Status != &quot;Requested&quot; &amp;&amp; Unit_Name.contains(input.search) || Property.Property_Name.contains(input.search) || Availability.contains(input.search)];\n\t\t\t\tview = Add_Unit[Unit_Type == &quot;Parking&quot;];\n\t\t\t}\n\t\t\tif(!input.occupancy_type.isEmpty())\n\t\t\t{\n\t\t\t\tview_units = Add_Unit[ID == view_units.ID.getall() &amp;&amp; Occupancy_Type == input.occupancy_type &amp;&amp; Owner_Approval_Status != &quot;Requested&quot;];\n\t\t\t}\n\t\t}\n\t\telse\n\t\t{\n\t\t\tview_properties = Add_Property[ID != 0 &amp;&amp; Property_Name.contains(input.search) || Property_Type.contains(input.search) || Location.Location.contains(input.search) &amp;&amp; Unit_Owners.Email.contains(zoho.loginuserid) || Manager.Email == zoho.loginuserid || Units.Manager == thisapp.get_user_id()];\n\t\t\tview_units = Add_Unit[ID != 0 &amp;&amp; Owner_Approval_Status != &quot;Requested&quot; &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid || Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()];\n\t\t\tview_parking = Add_Parking[ID != 0];\n\t\t\tif(!input.search.isEmpty())\n\t\t\t{\n\t\t\t\tview_units = Add_Unit[ID == view_units.ID.getall() &amp;&amp; Owner_Approval_Status != &quot;Requested&quot; &amp;&amp; Unit_Name.contains(input.search) || Property.Property_Name.contains(input.search) || Availability.contains(input.search)];\n\t\t\t}\n\t\t\tif(!input.occupancy_type.isEmpty())\n\t\t\t{\n\t\t\t\tview_units = Add_Unit[ID == view_units.ID.getall() &amp;&amp; Owner_Approval_Status != &quot;Requested&quot; &amp;&amp; Occupancy_Type == input.occupancy_type];\n\t\t\t}\n\t\t}\n\t\tif(!input.search.isEmpty())\n\t\t{\n\t\t\tview_properties = Add_Property[ID in view_properties &amp;&amp; Property_Name.contains(input.search) || Property_Type.contains(input.search) || Location.Location.contains(input.search)];\n\t\t}\n\t\tuser_role = New_User[ID == input.user_id &amp;&amp; Role != &quot;Admin&quot;];\n\t\tif(user_role.count() &gt; 0 &amp;&amp; input.user_id != null &amp;&amp; !input.user_id.isEmpty())\n\t\t{\n\t\t\tview_units = Add_Unit[ID in view_units &amp;&amp; Owner_Approval_Status != &quot;Requested&quot; &amp;&amp; Owner_Mail_ID == input.user_id || Manager == input.user_id || Current_Tenant == input.user_id];\n\t\t}\n\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\tagreement = Tenant_Agreement[Property == unit.Property &amp;&amp; Unit.ID == input.rec_id || Parking_No.ID == input.rec_id &amp;&amp; Status == &quot;Tenant Approved&quot;];\n\t\taddition_payment = Agreement_Additional_Payment[Tenant_Agreement == agreement.ID];\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n\/* Popup Related Styles *\/\n.zcform_Renew_Agreement_Request,\n.zcform_Vacate_Request {\n    width: 550px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action == &quot;propertydetail&quot; || input.action.contains(&quot;properties&quot;) &amp;&amp; !input.action.contains(&quot;propertyadd&quot;) &amp;&amp; !input.action.contains(&quot;propertyedit&quot;) &amp;&amp; input.rec_id != null &amp;&amp; property.count() != 0)\n\t\t{\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(property.ID,property.Image,&quot;Properties_Report&quot;,&quot;Image&quot;,property.Property_Name,true);\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-property-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-flt-left zc-prop-clearfix&apos;&gt;\n                &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:Properties?tab=properties&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=property.Property_Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n            &lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n&lt;%\n\t\t\tif(login_profile != &quot;Owner&quot; &amp;&amp; login_profile != &quot;Manager&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Properties?rec_id=&lt;%=property.ID%&gt;&amp;action=propertyedit&amp;tab=&lt;%=input.tab%&gt;&amp;subtab=&lt;%=input.subtab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\tif(property.Mark_it_as_single_unit_property1 == false)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-live-primary-btn&apos; href=&apos;#Page:Properties?rec_id=&lt;%=property.ID%&gt;&amp;action=unitadd&amp;tab=&lt;%=input.tab%&gt;&amp;subtab=&lt;%=input.subtab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-simple-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.add.unit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n        &lt;\/div&gt;\n&lt;%\n\t\t\tprop_manager = if(property.Manager != null,property.Manager.Email,&quot;-&quot;);\n\t\t\tprop_amenities = if(property.Amenities.size() &gt; 0,property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,property.Property_Type,prop_manager,property.Location.Location,prop_amenities,property.Property_Address,property.Size)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n&lt;%\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name + &quot;_Detail_View&quot;);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.subtab = if(input.subtab == &quot;&quot; || input.subtab == null,tab_keys.get(0),input.subtab);\n\t\t\tinput.subtab = if(!tab_keys.contains(input.subtab),tab_keys.get(0),input.subtab);\n\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\tcurrent_params_values = current_params_values + if(input.tab.isEmpty(),&quot;&amp;tab=&quot; + tab_keys.get(0),&quot;&amp;tab=&quot; + input.tab);\n\t\t\t%&gt;\n&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.subtab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_li