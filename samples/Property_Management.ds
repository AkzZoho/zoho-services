		list All_Tenants
		{
			displayName = "All Tenants"
			show all rows from New_User  [Role == "Tenant" && Unit.Owner_Mail_ID == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id() || Property.Admins == thisapp.get_user_id()]  
			(
				Name 
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Email
				Phone_Number as "Phone"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Address 
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				Role
				Gender
				Date_of_Birth as "Date of Birth"
				Profile_Photo as "Profile Photo"
				Location
				Occupation
				User
				Comments
				Reason
				Tenant_Status as "Tenant Status"
				Status
				Role_Admin as "Role Admin"
				ID
				Location.ID
				Unit.Manager
				Unit.Owner_Mail_ID as "Owner"
				Property.Admins
				Tenant_Screening as "Tenant Screening"
			)
			custom actions
			(
				"Edit 1"
				(
	  			workflow = Edit_All_Tenants
				show action in edit record menu = true
				condition = (Tenant_Status == "Waiting for Approval" || Tenant_Status == "Approved")
				)
				"Detail View - All_Tenants"
				(
	  			workflow = Detail_View_All_Tenants
				show action in edit record menu = true
				)
			)
			conditional formatting
			(
				"Active"
				{
				condition = (Status == "Active")
				fields = [Status]
				format = "color:#187822;"
				}
				"Inactive"
				{
				condition = (Status == "Inactive")
				fields = [Status]
				format = "color:#fe455d;"
				}
				"Waiting For Approval"
				{
				condition = (Tenant_Status == "Waiting for Approval")
				fields = [Tenant_Status]
				format = "color:#b8770d;"
				}
				"Screening in Process"
				{
				condition = (Tenant_Status == "Screening In Process")
				fields = [Tenant_Status]
				format = "color:#1c63b4;"
				}
				"Approved"
				{
				condition = (Tenant_Status == "Approved")
				fields = [Tenant_Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Tenant_Status == "Rejected")
				fields = [Tenant_Status]
				format = "color:#fe455d;"
				}
			)
		}
		list Tenant_Approval_Report_Direct
		{
			displayName = "Tenant Approval Report Direct"
			show all rows from New_User  [Role == "Tenant" && Status == "Inactive" && Tenant_Status == "Waiting for Approval" || Tenant_Status == "Screening In Process"]  
			(
				Name 
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				custom action "Upload Documents"
				(
	  			workflow = Move_to_Screening_Tenant_
				show action in edit record menu = true
				column header = "Upload Documents"
				condition = (Tenant_Status == "Waiting for Approval")
				)
				custom action "Approve"
				(
	  			workflow = Approve_Tenant_Approval_R
				show action in edit record menu = true
				column header = "Approve"
				)
				Address 
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				custom action "Reject"
				(
	  			workflow = Reject_Tenant_Approval_Re
				show action in edit record menu = true
				column header = "Reject"
				condition = (Tenant_Status == "Waiting for Approval" || (Tenant_Status == "Screening In Process" && Tenant_Screening.Status == "Updated"))
				)
				Email
				Phone_Number as "Phone"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Role
				Gender
				Date_of_Birth as "Date of Birth"
				Profile_Photo as "Profile Photo"
				Location
				Occupation
				User
				Comments
				Reason
				Tenant_Status as "Tenant Status"
				Status
				Role_Admin as "Role Admin"
				ID
			)
			custom actions
			(
				"Detail View - Tenant_Approval_Report_Direct"
				(
	  			workflow = Detail_View_Tenant_Approv1
				)
				"Edit 1"
				(
	  			workflow = Edit_Tenant_Approval_Repo1
				show action in edit record menu = true
				condition = (Tenant_Status == "Waiting for Approval")
				)
			)
		}
