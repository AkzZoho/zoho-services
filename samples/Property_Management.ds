			OnLoad5 as "OnLoad"
			{
				type =  form
				form = Approve_Confirmation
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.Alert();
										login_profile = thisapp.permissions.loginUserProfile();
										if(input.New_User != null && input.Action_field == "Screening" && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.New_User.Unit.Owner_Mail_ID.Email == zoho.loginuserid) || (login_profile == "Manager" && input.New_User.Unit.Manager == thisapp.get_user_id()))
										{
											screening = Tenant_Screening[Tenant == input.New_User];
											amount = if(screening.Monthly_Rental == null,screening.Lease_Amount_Display,screening.Monthly_Rental_Display);
											text = if(screening.Occupant_Type == "Rent",language.get('zcpm.rent'),language.get('zcpm.lease'));
											address = if(screening.Current_Address.isEmpty(),"-",screening.Current_Address);
											owner_phone = if(screening.Current_Owner_Contact_Number == null,"-",screening.Current_Owner_Contact_Number);
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>" + thisapp.Styles_Popup.Agreement_Approval() + "</style><div class='zc-prop-notes-field'> <div class='zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4'> <ul> <li class='zc-prop-flt-left zc-prop-subheader'> <h5>" + language.get('zcpm.Tenant.Details') + "</h5> </li> <li class='zc-prop-flt-left'> <label> " + language.get('zcpm.tenant.name') + " </label> <h6> " + input.New_User.Name + " </h6> </li> <li class='zc-prop-flt-left'> <label>" + language.get('zcpm.tenant.email') + "</label> <h6> " + input.New_User.Email + " </h6> </li> <li class='zc-prop-flt-left'> <label> " + language.get('zcpm.location') + " </label> <h6> " + input.New_User.Location.Location + " </h6> </li> </ul> <ul> <li class='zc-prop-flt-left zc-prop-subheader'> <h5> " + language.get('zcpm.Previous.Occupant.Details') + "</h5> </li> <li class='zc-prop-flt-left'> <label>" + language.get('zcpm.previous.Owner') + "</label> <h6> " + screening.Current_Owner_Name + " </h6> </li> <li class='zc-prop-flt-left'> <label> " + language.get('zcpm.address') + " </label> <h6> " + address + " </h6> </li> <li class='zc-prop-flt-left'> <label>" + language.get('zcpm.Phone.Number') + "</label> <h6> " + owner_phone + " </h6> </li> <li class='zc-prop-flt-left'> <label>" + language.get('zcpm.Occupant.Type') + "</label> <h6> " + text + " </h6> </li> <li class='zc-prop-flt-left'> <label>" + language.get('zcpm.amount') + "</label> <h6> " + amount + " </h6> </li> </ul> </div> </div>";
										}
										else if(input.New_User != null && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.New_User.Unit.Owner_Mail_ID.Email == zoho.loginuserid) || (login_profile == "Manager" && input.New_User.Unit.Manager == thisapp.get_user_id()))
										{
											input.Property = input.New_User.Property;
											unit = Add_Unit[Property == input.Property && Owner_Approval_Status == "Approved" && Occupancy_Type != "Owned" && Availability == "Vacant"].ID.getAll();
											input.Unit:ui.add(unit);
											input.Unit = input.New_User.Unit;
											show Unit;
											show Property;
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.tenant.name') + "</td> <td class='zc-prop-blue'>" + input.New_User.Name + "</td> </tr> <tr> <td>" + language.get('zcpm.tenant.email') + "</td> <td class='zc-prop-green'>" + input.New_User.Email + " </td> </tr> <tr> <td>" + language.get('zcpm.location') + "</td> <td>" + input.New_User.Location.Location + "</td> </tr> </tbody> </table> </div> </div>";
										}
										else if(input.Renew_Agreement_Request != null && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.Renew_Agreement_Request.Unit.Owner_Mail_ID.Email == zoho.loginuserid))
										{
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody>  <tr> <td>" + language.get('zcpm.renew.property') + "</td> <td class='zc-prop-blue'>" + input.Renew_Agreement_Request.Property.Property_Name + "</td> </tr><tr> <td>" + language.get('zcpm.renew.unit') + "</td> <td class='zc-prop-green'>" + input.Renew_Agreement_Request.Unit.Unit_Name + "</td> </tr><tr> <td>" + language.get('zcpm.renew.agreement') + "</td> <td  class='zc-prop-yellow'>" + input.Renew_Agreement_Request.Base_Agreement.Agreement_No + "</td> </tr> <tr> <td>" + language.get('zcpm.tenant.name') + "</td> <td>" + input.Renew_Agreement_Request.Base_Agreement.Tenant.Name + " </td> </tr></tbody> </table> </div> </div>";
										}
										else if(input.Raise_a_Complaint != null && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.Raise_a_Complaint.Unit.Owner_Mail_ID.Email == zoho.loginuserid))
										{
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.complaint.Work.Order.No') + "</td> <td>" + input.Raise_a_Complaint.Complaints_No + "</td> </tr> <tr> <td>" + language.get('zcpm.complaint.Date.of.Reporting') + "</td> <td>" + input.Raise_a_Complaint.Date_of_Reporting + " </td> </tr> <tr> <td> " + language.get('zcpm.complaint.Complaint.About') + "</td> <td>" + input.Raise_a_Complaint.Complaint_About + "</td> </tr> <tr> <td> " + language.get('zcpm.complaint.assigned.to') + "</td> <td>" + input.Raise_a_Complaint.Assigned_to.Vendor_Name + "</td> </tr> </tbody> </table> </div> </div>";
										}
										else if(input.Vacate_Request != null && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.Vacate_Request.Unit.Owner_Mail_ID.Email == zoho.loginuserid))
										{
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.renew.property') + "</td> <td class='zc-prop-blue'>" + input.Vacate_Request.Property.Property_Name + "</td> </tr><tr> <td>" + language.get('zcpm.renew.unit') + "</td> <td class='zc-prop-green'>" + input.Vacate_Request.Unit.Unit_Name + "</td> </tr> <tr> <td>" + language.get('zcpm.tenant.email') + "</td> <td>" + input.Vacate_Request.Tenant_Agreement.Tenant.Email + " </td> </tr> <tr> <td>" + language.get('zcpm.vacate.date') + "</td> <td class='zc-prop-yellow'>" + input.Vacate_Request.Vacate_Date + "</td> </tr> </tbody> </table> </div> </div>";
										}
										else if(input.Add_Unit != null && login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" || (login_profile == "Owner" && input.Add_Unit.Owner_Mail_ID.Email == zoho.loginuserid))
										{
											manager = if(input.Add_Unit.Manager == null,"-",input.Add_Unit.Manager.Name);
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.renew.property') + "</td> <td class='zc-prop-blue'>" + input.Add_Unit.Property.Property_Name + "</td> </tr><tr> <td>" + language.get('zcpm.renew.unit') + "</td> <td  class='zc-prop-green'>" + input.Add_Unit.Unit_Name + "</td> </tr> <tr> <td>" + language.get('zcpm.unit.size') + "</td> <td>" + input.Add_Unit.Size_in_Sq_ft + " </td> </tr> <tr> <td>" + language.get('zcpm.unit.manager') + "</td> <td>" + manager + "</td> </tr> </tbody> </table> </div> </div>";
										}
										else
										{
											display = language.get("zcpm.agreement.approval.alert3");
											if(input.Add_Unit != null)
											{
												display = input.Add_Unit.Unit_Name;
											}
											else if(input.New_User != null)
											{
												display = input.New_User.Name;
											}
											else if(input.Renew_Agreement_Request != null)
											{
												display = input.Renew_Agreement_Request.Base_Agreement.Agreement_No;
											}
											else if(input.Vacate_Request != null)
											{
												display = input.Vacate_Request.Tenant_Agreement.Agreement_No;
											}
											else if(input.Raise_a_Complaint != null)
											{
												display = input.Raise_a_Complaint.Complaints_No;
											}
											input.plain = thisapp.Styles_Popup.Alert() + "<style>" + thisapp.Styles_Popup.Permission() + "</style><div class='zc-prop-popup-content zc-prop-warning-popup'><div class='zc-prop-icon-wrapper'><i class='zc-li-outline ui-3-alert'></i></div><h4>" + display + "</h4><p>" + language.get("zcpm.agreement.approval.alert") + "</p></div>";
											hide Comments;
										}
										// hide Property;
										// hide Unit;
						)
					}
				}

			}
