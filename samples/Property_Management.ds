				 string Currency.Get_Currency()
                 {
                 	current_currency = General[ID != 0].Currency;
                 	currency = if(current_currency == null || current_currency == "","$",current_currency.getSuffix("(").getPrefix(")"));
                 	return currency;
                 }
				 string Currency.numberFormatAccurate(float number, string currency)
                 {
                 	all_currency_display_format = {"1,234,567.89":{"seperator_digits":"3","seperator":",","class":"format-1"},"12,34,567.89":{"seperator_digits":"2","seperator":",","class":"format-2"},"1 234 567.89":{"seperator_digits":"3","seperator":" ","class":"format-3"},"1.234.567,89":{"seperator_digits":"3","seperator":".","class":"format-4"}};
                 	settingsFormat = General[ID != 0].Currency_Format;
                 	currency_Format = all_currency_display_format.get(settingsFormat);
                 	number_cpy = number.round(2).toString();
                 	formatedNumber = "";
                 	if(number >= 1000)
                 	{
                 		decimalSuffix = "." + number_cpy.getSuffix(".");
                 		number_cpy = number_cpy.remove(decimalSuffix);
                 		decimalSuffix = if(settingsFormat == "1.234.567,89",decimalSuffix.replaceAll(".",",",true),decimalSuffix);
                 		suffixNumber = currency_Format.get("seperator") + number_cpy.subString(number_cpy.Length() - 3,number_cpy.Length());
                 		number_cpy = number_cpy.subString(0,number_cpy.Length() - 3);
                 		formatedNumber = number_cpy.replaceAll("(?<!\.\d)(?<=\d)(?=(?:\d{" + currency_Format.get("seperator_digits") + "})+\b)",currency_Format.get("seperator")) + suffixNumber + decimalSuffix;
                 	}
                 	else
                 	{
                 		number_cpy = number_cpy.toString();
                 		formatedNumber = if(settingsFormat == "1.234.567,89",number_cpy.replaceAll(".",",",true),number_cpy);
                 	}
                 	return currency + " " + formatedNumber;
                 }
