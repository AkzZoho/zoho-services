			User_input_of_Property4 as "User input of Property"
			{
				type =  form
				form = New_User
				record event = on add or edit

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(input.Property != null && input.Tenant_First_Agreement == false)
										{
											old_unit = if(input.Unit != null,input.Unit,null);
											if(login_profile == "Owner")
											{
												unit = Add_Unit[Property == input.Property && Owner_Mail_ID.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved" && Unit_Type == "Unit"].ID.getAll();
												input.Unit:ui.add(unit.distinct());
											}
											else if(login_profile == "Manager")
											{
												unit = Add_Unit[Property == input.Property && Manager.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved" && Unit_Type == "Unit"].ID.getAll();
												input.Unit:ui.add(unit.distinct());
											}
											else if(login_profile in {"Admin","Administrator","Developer"})
											{
												unit = Add_Unit[Property == input.Property && Availability == "Vacant" && Owner_Approval_Status == "Approved" && Unit_Type == "Unit"].ID.getAll();
												input.Unit:ui.add(unit.distinct());
											}
											input.Unit = if(unit.contains(old_unit),old_unit,null);
										}
						)
					}
				}

			}
