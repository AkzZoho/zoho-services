			Script_ValidationTenant as "Script:ValidationTenant"
			{
				type =  form
				form = New_User
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.Alert();
										if(input.Role == "Tenant")
										{
											if(input.Property == null || input.Unit == null)
											{
												alert language.get("zcpm.Role.Tenant");
												cancel submit;
											}
										}
						)
					}
				}

