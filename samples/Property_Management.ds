				 map Page.Get_Import_Details(string page)
                 {
                 	language = thisapp.Localization.common();
                 	page_language = thisapp.Localization.Pages();
                 	export_url = zoho.appuri + "csv/";
                 	import_url = zoho.appuri + "report/";
                 	scripts_text = language.get("zcpm.import.scripts_text") + "</b>";
                 	export_text = language.get("zcpm.import.export_text");
                 	common_notes = {language.get("zcpm.import.common_notes_1"),language.get("zcpm.import.common_notes_2")};
                 	export_note = language.get("zcpm.import.export_note");
                 	partial_note = language.get("zcpm.import.partial_note");
                 	mp = Map();
                 	page_note_lis = List();
                 	if(input.page == "Users")
                 	{
                 		mp.put("Title",page_language.get("zcpm.Users"));
                 		export_url = export_url + "New_Users_Report";
                 		import_url = import_url + "All_New_Users/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Rental")
                 	{
                 		mp.put("Title",page_language.get("zcpm.Rental"));
                 		export_url = export_url + "All_Admin_Rental_Agreements";
                 		import_url = import_url + "All_Admin_Rental_Agreements/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Lease")
                 	{
                 		mp.put("Title",page_language.get("zcpm.Lease"));
                 		export_url = export_url + "All_Admin_Lease_Agreements";
                 		import_url = import_url + "All_Admin_Lease_Agreements/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Vendors")
                 	{
                 		info page_language.get("zcpm.Vendors");
                 		mp.put("Title",page_language.get("zcpm.Vendors"));
                 		export_url = export_url + "Vendor_List";
                 		import_url = import_url + "Vendors_Report/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Properties")
                 	{
                 		mp.put("Title",page_language.get("zcpm.properties"));
                 		export_url = export_url + "All_Properties";
                 		import_url = import_url + "All_Properties/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Units")
                 	{
                 		mp.put("Title",page_language.get("zcpm.unit.filter"));
                 		export_url = export_url + "All_Units";
                 		import_url = import_url + "All_Units/import?nexturl=" + encodeUrl("#Page:Properties?tab=units");
                 	}
                 	else if(input.page == "Accounting")
                 	{
                 		mp.put("Title",page_language.get("zcpm.account.accounting"));
                 		export_url = export_url + "All_Payment_Notes";
                 		import_url = import_url + "All_Payment_Notes/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else if(input.page == "Complaints")
                 	{
                 		mp.put("Title",page_language.get("zcpm.dashboard.complaints"));
                 		export_url = export_url + "All_Complaints";
                 		import_url = import_url + "All_Complaints/import?nexturl=" + encodeUrl("#Page:" + page);
                 	}
                 	else
                 	{
                 		mp.put("key",language.get("zcpm.import.invalid"));
                 	}
                 	if(mp.keys().get(0) != "key")
                 	{
                 		page_note_lis.add(scripts_text);
                 		page_note_lis.add(export_note);
                 		page_note_lis.addAll(common_notes);
                 		mp.put("Import",import_url);
                 		mp.put("Export",export_text.replaceAll("\{.csv format\}","<a href='" + export_url + "'> .csv" + language.get("zcpm.import.csvformat.button") + "</a>"));
                 		mp.put("Notes",page_note_lis);
                 	}
                 	return mp;
                 }
				 map Page.Get_Tab1(string page_linkname)
                 {
                 	common = thisapp.Localization.Tab();
                 	login_profile = thisapp.permissions.loginUserProfile();
                 	mp = Map();
                 	if(page_linkname == "Properties")
