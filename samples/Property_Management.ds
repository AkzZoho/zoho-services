	pages
	{
		page Admin_Dashboard(int rec_id)
		{
			displayname = "Admin Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet14' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet14()\ncontent\n&lt;%{\n\tpage_link_name = &quot;Admin_Dashboard&quot;;\n\tgetAdmin = Organization[Email == zoho.loginuserid];\n\tlanguage = thisapp.Localization.Pages();\n\tgetuser = New_User[Email == zoho.loginuserid];\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tno_data_component_params = {&quot;is_img&quot;:true,&quot;header_txt&quot;:&quot;No Data&quot;,&quot;Secondary_header_txt&quot;:true};\n\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t{\n\t\tgetProp = Add_Property[ID == input.rec_id].count();\n\t}\n\telse\n\t{\n\t\tgetProp = Add_Property[ID == input.rec_id &amp;&amp; Unit_Owners.Email.contains(zoho.loginuserid) || Manager.Email == zoho.loginuserid || Units.Manager == thisapp.get_user_id()].count();\n\t}\n\tuser_config = User_Configuration[ID != 0];\n\tif(input.rec_id != null &amp;&amp; getProp != 0)\n\t{\n\t\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate &amp;&amp; Property == input.rec_id].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Property == input.rec_id].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; &amp;&amp; Property == input.rec_id].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Property == input.rec_id &amp;&amp; Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Property == input.rec_id].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot; &amp;&amp; Property == input.rec_id].count();\n\t\t\tcomplaint_report = &quot;All_Complaints&quot;;\n\t\t}\n\t\telse if(login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payer == thisapp.get_user_id() &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Unit.Owner_Mail_ID == thisapp.get_user_id() &amp;&amp; Property == input.rec_id &amp;&amp; Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tcomplaint_report = &quot;All_Complaints_Owner&quot;;\n\t\t}\n\t\telse if(login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate &amp;&amp; Due_Date != null &amp;&amp; Property == input.rec_id].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Payer == thisapp.get_user_id() &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Property == input.rec_id].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id() &amp;&amp; Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tcomplaint_report = &quot;All_Complaints_Manager&quot;;\n\t\t}\n\t}\n\telse\n\t{\n\t\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Status == &quot;Received&quot;].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot;].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot;].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot;].count();\n\t\t\t\/\/ \t\t\tcomplaint  report\n\t\t\tcomplaint_report = &quot;All_Complaints&quot;;\n\t\t}\n\t\telse if(login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Payer == thisapp.get_user_id() &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Unit.Owner_Mail_ID == thisapp.get_user_id() &amp;&amp; Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t\t\/\/ \t\t\tcomplaint  report\n\t\t\tcomplaint_report = &quot;All_Complaints_Owner&quot;;\n\t\t}\n\t\telse if(login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\t\/\/ \t\tpanel \n\t\t\tno_of_rental_unit = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_lease_unit = Add_Unit[Occupancy_Type == &quot;Lease&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_vacant_Unit = Add_Unit[Availability == &quot;Vacant&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tsum_of_due_amount = Add_Payment_Notes[Status == &quot;Unpaid&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt; zoho.currentdate &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\tsum_of_complaint_payment = Add_Payment_Notes[Pay_For == &quot;Complaint&quot; &amp;&amp; Payer == thisapp.get_user_id() &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].sum(Total_Amount);\n\t\t\t\/\/ \t\tchart\n\t\t\ttotal_complaint = Raise_a_Complaint[ID != 0 &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_req_complaint = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_in_prog_complaint = Raise_a_Complaint[Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id() &amp;&amp; Complaint_Status == &quot;Approved&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;].count();\n\t\t\tno_of_complete_complaint = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\tno_of_denied_complaint = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()].count();\n\t\t\t\/\/ \t\t\tcomplaint  report\n\t\t\tcomplaint_report = &quot;All_Complaints_Manager&quot;;\n\t\t}\n\t}\n\tcurrency = thisapp.Currency.Get_Currency();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\tif(getProp == 0 &amp;&amp; input.rec_id != null)\n\t{\n\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t}\n\telse if(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Admin_Dashboard()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-admin-dashboard&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; \n\t\t\t\t&lt;%=language.get(&quot;zcpm.dashboard.welcome&quot;)%&gt; &lt;span class=&apos;zc-prop-bold-txt&apos;&gt; &lt;%=getuser.Name%&gt;, &lt;\/span&gt;\n\t\t\t&lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Dropdown&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Focus=false&amp;Property=&lt;%=input.rec_id%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-panel-wrapper zc-prop-panel-count-5 zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Properties?tab=units&amp;occupancy_type=Rent&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-home&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=no_of_rental_unit%&gt; &lt;\/h4&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.rental.unit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-l_blue&apos;&gt;\n\t\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Properties?tab=units&amp;occupancy_type=Lease&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline envir-home&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=no_of_lease_unit%&gt; &lt;\/h4&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.lease.unit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-yellow&apos;&gt;\n\t\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Properties?tab=units&amp;search=Vacant&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-home-simple&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=no_of_vacant_Unit%&gt; &lt;\/h4&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.vacant.unit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-red&apos;&gt;\n\t\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=overduespayment&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-4-restore&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;