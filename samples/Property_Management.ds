\t\t\tfet = Add_Unit[ID == unit];\n\t\t\t\t\ttag_color = &quot;&quot;;\n\t\t\t\t\tif(fet.Availability == &quot;Sold Out&quot; &amp;&amp; fet.Occupancy_Type == &quot;Sale&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-red&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Available&quot; &amp;&amp; fet.Occupancy_Type == &quot;Sale&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-skyblue&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Vacant&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-green&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Occupied&quot; &amp;&amp; fet.Occupancy_Type == &quot;Owned&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-orange&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Occupied&quot; &amp;&amp; fet.Occupancy_Type == &quot;Rent&quot; || fet.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-blue&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Assigned&quot; &amp;&amp; fet.Occupancy_Type == &quot;Rent&quot; || fet.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-grey&quot;;\n\t\t\t\t\t}\n\t\t\t\t\tif(!input.user_id.isEmpty())\n\t\t\t\t\t{\n\t\t\t\t\t\tuserid = &quot;&amp;user_id=&quot; + input.user_id;\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-overlay&apos; href=&apos;#Page:Properties?action=unitdetail&amp;tab=&lt;%=input.tab%&gt;&amp;rec_id=&lt;%=fet.ID%&gt;&lt;%=userid%&gt;&apos;&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;%=thisapp.CommonFeatures.processImageUrl(fet.ID,fet.Parking_Image,&quot;Units_Report&quot;,&quot;Parking_Image&quot;,fet.Unit_Name,true)%&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(fet.Availability == &quot;Assigned&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=fet.Property.Property_Name%&gt; - &lt;%=fet.Unit_Name%&gt; -  &lt;%=fet.Parking_No.Unit_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t&lt;p&gt; &lt;%=fet.Address%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=fet.Property.Property_Name%&gt; - &lt;%=fet.Unit_Name%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t&lt;p&gt; &lt;%=fet.Address%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(fet.Availability == &quot;Rejected Unit&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tag &lt;%=tag_color%&gt;&apos;&gt; &lt;span&gt; &lt;%=fet.Availability%&gt; &lt;\/span&gt; &lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tag &lt;%=tag_color%&gt;&apos;&gt; &lt;span&gt;&lt;%=fet.Occupancy_Type%&gt; \/ &lt;%=fet.Availability%&gt; &lt;\/span&gt; &lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(fet.Availability != &quot;Rejected Unit&quot; &amp;&amp; fet.Availability != &quot;Sold Out&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-more-options zc-prop-rounded&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-hover-extend&apos;&gt;&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;fa fa-ellipsis-h&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?action=parkingedit&amp;rec_id=&lt;%=fet.ID%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\tif(fet.Availability == &quot;Vacant&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif(fet.Occupancy_Type == &quot;Rent&quot;)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tpage_name = &quot;Rental&quot;;\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\telse if(fet.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tpage_name = &quot;Lease&quot;;\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:&lt;%=page_name%&gt;?action=add&amp;rec_id=&lt;%=fet.ID%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-simple-add&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.Add.Agreement&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;!--&lt;a href=&apos;#Form:Sales_Form?Property=&lt;%=fet.Property%&gt;&amp;Unit=&lt;%=fet.ID%&gt;&amp;Owner=&lt;%=fet.Owner_Mail_ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline shopping-tag-sale&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.Sale&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;--&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(fet.Availability == &quot;Occupied&quot; &amp;&amp; fet.Occupancy_Type == &quot;Lease&quot; || fet.Occupancy_Type == &quot;Rent&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Form:Renew_Agreement_Request?Property=&lt;%=fet.Property%&gt;&amp;Unit=&lt;%=fet.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-refresh&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.Renew&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Form:Vacate_Request?Unit=&lt;%=fet.ID%&gt;&amp;Property=&lt;%=fet.Property%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.vacate.request&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Sold Out&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-more-options zc-prop-rounded&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-hover-extend&apos;&gt;&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;fa fa-ellipsis-h&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?action=saleedit&amp;rec_id=&lt;%=fet.ID%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Communication_Detail_View(int rec_id)
		{
			displayname = "Communication Detail View"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet15' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet15()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tcommunity_post = Post[ID == input.rec_id];\n\t\tpost_img_src = thisapp.CommonFeatures.processImageUrl(community_post.ID,community_post.Image,&quot;Posts_Report&quot;,&quot;Image&quot;,community_post.Title,true);\n\t\tprofile_img_src = thisapp.CommonFeatures.processImageUrl(community_post.Post_By.ID,community_post.Post_By.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,community_post.Post_By.Name.first_name + &quot; &quot; + community_post.Post_By.Name.last_name,false);\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Feeds_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-popup-container zc-prop-feed-detailview&apos;&gt;\n    &lt;div class=&apos;zc-prop-popup-container-inner&apos;&gt;\n        &lt;div class=&apos;zc-prop-popup-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-flt-left zc-prop-basic-info zc-prop-clearfix&apos;&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n                    &lt;%=profile_img_src%&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n                    &lt;h6&gt; &lt;%=community_post.Post_By.Name%&gt; &lt;\/h6&gt;\n                    &lt;span&gt; &lt;%=community_post.Added_Time%&gt; &lt;\/span&gt;\n                &lt;\/div&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\tif(community_post.Post_By == thisapp.get_user_id())\n\t\t{\n\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-right zc-prop-options zc-prop-option-edit&apos; href=&apos;#Page:Communication?action=editpost&amp;rec_id=&lt;%=input.rec_id%&gt;&apos;&gt;\n\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t&lt;\/a&gt;\n\t\t\t&lt;a class=&apos;zc-prop-flt-right zc-prop-options zc-prop-option-delete&apos; href=&apos;#Form:Delete_Confirmation?Post=&lt;%=input.rec_id%&gt;&amp;zc_Header=false&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-trash-simple&apos;&gt;&lt;\/i&gt;\n\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t}\n\t\tif(!community_post.Url.isEmpty())\n\t\t{\n\t\t\tlink = community_post.Url.getSuffix(&quot;&lt;a href=&quot;).getPrefix(&quot;&gt;&quot;);\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-popup-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-category-wrapper&apos;&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\tif(!community_post.Image.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-img-wrapper zc-prop-feed-img-wrapper&apos;&gt;\n                &lt;%=post_img_src%&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=community_post.Title%&gt; &lt;\/h5&gt;\n&lt;%\n\t\tif(!community_post.Url.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-left zc-prop-icon&apos; href=&lt;%=link%&gt;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-2-link-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t&lt;p class=&apos;zc-prop-feed-desc&apos;&gt; &lt;%=community_post.Description%&gt; &lt;\/p&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Agreement_Templates(string action, string agreement_type)
		{
			displayname = "Agreement Templates"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet18' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet18()\ncontent\n&lt;%{\n\tlanguage = thisapp.Localization.Pages();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Agreement_Templates()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-template-wrapper zc-prop-fwh&apos;&gt;\n    &lt;!-- div class=&apos;zc-prop-subheader zc-prop-clearfix zc-prop-fw&apos;&gt;\n        &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Agreement.Templates&quot;)%&gt; &lt;\/h5&gt;\n        &lt;div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.property.Add.Agreement.Templates&quot;),&quot;#Page:Preferences?action=addAgreementTemplate&amp;tab=agreement-templates&quot;)%&gt;\n        &lt;\/div&gt;\n    &lt;\/div --&gt;\n    &lt;div class=&apos;zc-prop-subcontent zc-prop-fwh&apos;&gt;\n        &lt;ul class=&apos;zc-prop-clearfix zc-prop-fwh&apos;&gt;\n&lt;%\n\tfor each  template in Agreement_Template[ID != 0 &amp;&amp; Agreement_Type == input.agreement_type]\n\t{\n\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                &lt;div class=&apos;zc-prop-tem-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n                    &lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=template.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\tif(template.Mark_as_Default_Template == true)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-tag&apos;&gt;\n\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.Default&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-tem-content&apos;&gt;\n\t\t\t\t\t&lt;div style=&quot;padding: 16px 30px 0px; box-sizing: border-box;&quot;&gt;\n\t\t\t\t\t\t&lt;%=template.Template%&gt;\n\t\t\t\t\t&lt;\/div&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-tem-footer zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\tif(template.Mark_as_Default_Template == false)\n\t\t{\n\t\t\t%&gt;\n&lt;a href=&apos;#Form:Set_as_Default?Agreement_Template=&lt;%=template.ID%&gt;&amp;zc_LoadIn=dialog&amp;zc_Header=false&apos; class=&apos;zc-prop-flt-left zc-prop-tem-btn&apos;&gt; Set As Default &lt;\/a&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n                        &lt;a href=&apos;#Page:Preferences?action=editAgreementTemplate&amp;rec_id=&lt;%=template.ID%&gt;&amp;tab=agreement-templates&amp;agreement_type=&lt;%=template.Agreement_Type%&gt;&apos; class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;i class=&apos;zc-prop-tem-view zc-li-outline ui-1-edit-72&apos;&gt; &lt;\/i&gt;\n                        &lt;\/a&gt;\n                        &lt;a href=&apos;#Page:Agreement_Template_Detail_View?rec_id=&lt;%=template.ID%&gt;&amp;zc_LoadIn=dialog&apos; class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;i class=&apos;zc-prop-tem-view zc-li-outline ui-1-eye-17&apos;&gt; &lt;\/i&gt;\n                        &lt;\/a&gt;\n                    &lt;\/div&gt;\n                &lt;\/div&gt;\n            &lt;\/li&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/ul&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Agreement_Template_Detail_View(int rec_id)
		{
			displayname = "Agreement Template Detail View"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet22' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet22()\ncontent\n&lt;%{\n\ttemp = Agreement_Template[ID == input.rec_id];\n\t%&gt;\n&lt;div style=&apos;width: 850px; padding: 16px 30px 0px; box-sizing: border-box;&apos;&gt;\n\t&lt;%=temp.Template%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Each_Agreement_Template(string action, int rec_id)
		{
			displayname = "Each Agreement Template"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet23' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet23()\ncontent\n&lt;%{\n\tagreement = Tenant_Agreement[ID == input.rec_id];\n\ttemplate = Agreement_Template[Agreement_Type == agreement.Agreement_Type &amp;&amp; Mark_as_Default_Template == true];\n\tlanguage = thisapp.Localization.Pages();\n\t%&gt;\n&lt;style&gt;\n.zcpopup.compact .popupbox-wrapper .popupbox .popupboxOuter {\n    padding: 0px;\n    width: 850px;\n}\n.zcpopup.compact .popupbox-wrapper .popupbox .popupClose {\n\ttop: 24px;\n}\n.zc-prop-agreement-header {\n\tpadding: 14px 50px 14px 30px;\n\tborder-bottom: 1px solid rgb(235, 239, 239);\n}\n.zc-prop-agreement-header h5 {\n\tfont-size: 18px;\n    font-weight: 400;\n    line-height: 36px;\n    letter-spacing: 0.1px;\n    color: rgb(34, 35, 38);\n}\n.zc-prop-agreement-content {\n\tpadding: 16px 30px 0px;\n\tbox-sizing: border-box;\n}\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-agreement-view-container&apos;&gt;\n\t&lt;div class=&apos;zc-prop-agreement-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; Agreement Template &lt;\/h5&gt;\n&lt;%\n\tif(input.action.isEmpty())\n\t{\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t&lt;%=thisapp.Components.Button(&quot;PDF&quot;,language.get(&quot;zcpm.property.Download&quot;),&quot;\/export&quot; + zoho.appuri + &quot;pdf\/Each_Agreement_Template\/?action=pdf&amp;rec_id=&quot; + agreement.ID + &quot;&amp;isc5page=true&quot;)%&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t&lt;div class=&apos;zc-prop-agreement-content&apos;&gt;\n\t\t&lt;%=thisapp.Template_Making(agreement.ID,template.ID)%&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Agreement_History(string param, string view_link_name)
		{
			displayname = "Agreement History"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet6' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet6()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n.zcpopup.compact .popupbox-wrapper .popupbox .popupboxOuter { padding: 0px; } .zc-prop-view-popup { width: 100%; max-height: calc(90vh - 5px); padding: 0px 20px 20px; } .zc-prop-view-popup .zc-prop-report { padding-top: 0px; } .zcpopup.compact .popupbox-wrapper .popupbox .popupboxOuter .view-outer-wrapper .view-header { border-bottom-width: 0px; padding: 0px; } .zc-prop-view-popup .view-outer-wrapper .view-header .zc-reportnameheader { padding: 2px 0px; } .zc-prop-view-popup .list-view-inner { margin-top: 5px; background-color: #FFFFFF; border: 1px solid #EBECF0; border-radius: 12px; } .zc-design-switch .zc-prop-view-popup .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th { border-top-width: 0px !important; }\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-view-popup&apos;&gt;\n\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=input.view_link_name%&gt;&apos; params=&apos;zc_ReportName=true&amp;zc_Search=false&amp;zc_AddRec=false&amp;zc_MoreAction=false&amp;zc_ColMenu=false&amp;zc_Footer=false&amp;zc_SecHeader=false&amp;&lt;%=input.param%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
