			)
			conditional formatting
			(
				"Low"
				{
				condition = (Priority == "Low")
				fields = [Priority]
				format = "color:#f4c01a;background-color:#fae9c4;"
				}
				"Medium"
				{
				condition = (Priority == "Medium")
				fields = [Priority]
				format = "color:#f39c12;background-color:#f9e0b1;"
				}
				"High"
				{
				condition = (Priority == "High")
				fields = [Priority]
				format = "color:#f4603e;background-color:#f9b7a8;"
				}
				"Very High"
				{
				condition = (Priority == "Very High")
				fields = [Priority]
				format = "color:#c0392b;background-color:#e2a6a0;"
				}
				"Requested"
				{
				condition = (Complaint_Status == "Requested")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Vendor Assigned"
				{
				condition = (Complaint_Status == "Vendor Assigned")
				fields = [Complaint_Status]
				format = "color:#5051f9;"
				}
				"In Progress"
				{
				condition = (Complaint_Status == "In Progress")
				fields = [Complaint_Status]
				format = "color:#1c63b4;background-color:#ffffff;"
				}
				"Complaint Reviewed"
				{
				condition = (Complaint_Status == "Complaint Reviewed")
				fields = [Complaint_Status]
				format = "color:#1fbac6;"
				}
				"Rejected"
				{
				condition = (Complaint_Status == "Rejected")
				fields = [Complaint_Status]
				format = "color:#fe455d;"
				}
				"Work Order Completed"
				{
				condition = (Complaint_Status == "Work Order Completed")
				fields = [Complaint_Status]
				format = "color:#187822;"
				}
				"Waiting for Payment"
				{
				condition = (Complaint_Status == "Waiting for Payment")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Paid"
				{
				condition = (Complaint_Status == "Paid" || Complaint_Status == "Completed")
				fields = [Complaint_Status]
				format = "color:#187822;"
				}
			)
		}
