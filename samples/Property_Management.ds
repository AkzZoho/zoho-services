		list Vacate_Request_Tenant
		{
			displayName = "Vacate Request - Tenant"
			show all rows from Vacate_Request  [Requested_By_Email == zoho.loginuserid || Unit.Current_Tenant == thisapp.get_user_id()]  
			(
				Unit
				Property
				custom action "Review"
				(
	  			workflow = Review_Vacate_Request_Ten
				show action in edit record menu = true
				column header = "Review"
				condition = (Requested_By_Email != zoho.loginuserid && Vacate_Status == "Waiting for Tenant Approval")
				)
				Unit.Owner_Mail_ID as "Owner"
				Property.ID
				Unit.ID
				Tenant_Agreement.Agreement_No as "Agreement No"
				ID
				Tenant_Agreement.ID
				Added_Time as "Added Time"
				Tenant_Agreement.Start_Date as "Start Date"
				Tenant_Agreement.End_Date as "End Date"
				Tenant_Agreement.Security_Deposit_Display as "Security Deposit"
				Vacate_Status as "Status"
				Vacate_Reason as "Vacate Reason"
				custom action "Agree"
				(
	  			workflow = _Agree_Vacate_Request_Ten
				show action in edit record menu = true
				column header = "Agree"
				condition = (Vacate_Status == "Waiting for Tenant Approval")
				)
			)
			sort by
			(
				Added_Time descending
			)
			custom actions
			(
				"Detail View - Vacate_Request_Tenant"
				(
	  			workflow = Detail_View_Vacate_Reques1
				show action in edit record menu = true
				)
				"Edit 1"
				(
	  			workflow = Edit_Vacate_Request_Tenan
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Vacate_Status == "Requested" || Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Waiting for Tenant Approval")
				fields = [Vacate_Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Vacate_Status == "Owner Approved" || Vacate_Status == "Tenant Approved")
				fields = [Vacate_Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Vacate_Status == "Rejected By Owner" || Vacate_Status == "Admin Rejected")
				fields = [Vacate_Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Vacate_Status == "Tenant Vacated")
				fields = [Vacate_Status]
				format = "color:#5051f9;"
				}
			)
		}
