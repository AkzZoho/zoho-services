&quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date &gt;= form_date &amp;&amp; Payment_Date &lt;= end_date].count();\n\t\t}\n\t\telse if(input.rec_id == null &amp;&amp; login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\tdata_count = Add_Payment_Notes[Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date in this year &amp;&amp; Unit.Manager == thisapp.get_user_id()].count();\n\t\t}\n\t\telse if(input.rec_id == null &amp;&amp; login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\tdata_count = Add_Payment_Notes[Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date in this year &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()].count();\n\t\t}\n\t\telse if(input.rec_id != null &amp;&amp; getProp &gt; 0 &amp;&amp; login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tdata_count = Add_Payment_Notes[Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date in this year &amp;&amp; Property == input.rec_id].count();\n\t\t}\n\t\telse if(input.rec_id != null &amp;&amp; getProp &gt; 0 &amp;&amp; login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\tdata_count = Add_Payment_Notes[Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date in this year &amp;&amp; Unit.Manager == thisapp.get_user_id()].count();\n\t\t}\n\t\telse if(input.rec_id != null &amp;&amp; getProp &gt; 0 &amp;&amp; login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\tdata_count = Add_Payment_Notes[Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Pay_For != &quot;Vacate&quot; &amp;&amp; Payment_Date in this year &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id() &amp;&amp; Property == input.rec_id].count();\n\t\t}\n\t\tif(data_count &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;ul class=&apos;zc-prop-flt-right zc-prop-legent-info&apos;&gt;\n\t\t\t\t\t\t\t&lt;li&gt; &lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.income&quot;)%&gt; &lt;\/span&gt; &lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li&gt; &lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.expenses&quot;)%&gt; &lt;\/span&gt; &lt;\/li&gt;\n\t\t\t\t\t\t&lt;\/ul&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\n&lt;%=thisapp.Components.Bar_Chart(data_count,input.rec_id)%&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;!----&lt;div class=&apos;zc-prop-flt-left zc-prop-card&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.complaint.complaints&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left zc-prop-count&apos;&gt; &lt;%=total_complaint%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n&lt;%\n\t\tchart_name = language.get(&quot;zcpm.dashboard.complaints&quot;);\n\t\tComplaint_Chart_Inputs = {language.get(&quot;zcpm.dashboard.requested&quot;):no_of_req_complaint,language.get(&quot;zcpm.dashboard.inprogress&quot;):no_of_in_prog_complaint,language.get(&quot;zcpm.dashboard.completed&quot;):no_of_complete_complaint,language.get(&quot;zcpm.dashboard.denied&quot;):no_of_denied_complaint};\n\t\tcolors = {&quot;#FCA76C&quot;,&quot;#84E2C9&quot;,&quot;#A68DED&quot;,&quot;#77C4F4&quot;};\n\t\tComplaint_Chart = thisapp.Components.Custom_Donut(chart_name,Complaint_Chart_Inputs,colors,true);\n\t\t%&gt;\n&lt;%=Complaint_Chart%&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;---&gt;\n\t\t\t&lt;div class=&apos;zc-prop-split-col zc-prop-col3 zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-card zc-prop-property-list-wrapper&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.dashboard.current.tenants&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n&lt;%\n\t\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tcurrent_tenant = Tenant_Agreement[Status == &quot;Tenant Approved&quot;] sort by Added_Time desc range from 0 to 2;\n\t\t\tcurrent_tenant_property = Tenant_Agreement[Status == &quot;Tenant Approved&quot; &amp;&amp; Property == input.rec_id] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\telse if(login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\tcurrent_tenant = Tenant_Agreement[Status == &quot;Tenant Approved&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t\tcurrent_tenant_property = Tenant_Agreement[Status == &quot;Tenant Approved&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\telse if(login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\tcurrent_tenant = Tenant_Agreement[Status == &quot;Tenant Approved&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t\tcurrent_tenant_property = Tenant_Agreement[Status == &quot;Tenant Approved&quot; &amp;&amp; Property == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()] sort by Added_Time desc range from 0 to 2;\n\t\t}\n\t\tif((input.rec_id != null &amp;&amp; current_tenant_property.count() == 0) || current_tenant.count() == 0)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;ul&gt;\n&lt;%\n\t\t\tif(input.rec_id != null &amp;&amp; getProp &gt; 0)\n\t\t\t{\n\t\t\t\tfor each  tenant in current_tenant_property\n\t\t\t\t{\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(tenant.Tenant.ID,tenant.Tenant.Profile_Photo,&quot;New_Users_Report&quot;,&quot;Profile_Photo&quot;,tenant.Tenant.Name.toString(),false);\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-atxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=tenant.Tenant.Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=tenant.Property.Property_Name + &quot; - &quot; + tenant.Unit.Unit_Name%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt; &lt;span class=&apos;zc-prop-flt-right&apos;&gt; &lt;%=tenant.Start_Date%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tfor each  tenant in current_tenant\n\t\t\t\t{\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(tenant.Tenant.ID,tenant.Tenant.Profile_Photo,&quot;New_Users_Report&quot;,&quot;Profile_Photo&quot;,tenant.Tenant.Name.toString(),false);\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div 