			Delete_Row_of_Additional_ as "Delete Row of Additional Payment"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on delete row of Additional_Payment_Monthly
				{
					actions 
					{
						custom deluge script
						(
											if(row.Amount > 0)
										{
											if(input.Agreement_Type == "Rent")
											{
												input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount) - row.Amount;
											}
											else if(input.Agreement_Type == "Lease")
											{
												input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount) - row.Amount;
											}
										}
						)
					}
				}

			}
			User_input_of_Assign_Vend as "User input of Assign Vendor"
			{
				type =  form
				form = Review_Complaint
				record event = on add

				on user input of Assign_Vendor
				{
					actions 
					{
						custom deluge script
						(
											if(input.Assign_Vendor == true)
										{
											language = thisapp.Localization.Alert();
											show Expected_Date;
											show Maintenance_Service;
											show Assign_To;
											show Field_Alert;
											input.Field_Alert = "<div class=\"zc-prop-notes-wrapper\"><p><span>" + language.get("zcpm.Note") + "</span>" + language.get("zcpm.assign.vendor") + "</p></div>";
										}
										else
										{
											hide Field_Alert;
											hide Expected_Date;
											hide Maintenance_Service;
											hide Assign_To;
											input.Expected_Date = null;
											input.Maintenance_Service = null;
											input.Assign_To = null;
										}
						)
					}
				}

			}
			OnLoad21 as "OnLoad"
			{
				type =  form
				form = Vacate_Request
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Unit != null)
										{
											input.Tenant = input.Unit.Current_Tenant;
											input.Unit_Owner = input.Unit.Owner_Mail_ID;
											getTenantAgreement = Tenant_Agreement[Unit == input.Unit && Agreement_Status == "Active"];
											//info getTenantAgreement;
											input.Tenant_Agreement = getTenantAgreement.ID;
										}
										language = thisapp.Localization.Pages();
										property = if(input.Property == null,"-",input.Property.Property_Name);
										unit = if(input.Unit == null,"-",input.Unit.Unit_Name);
										tenant = if(input.Tenant == null,"-",input.Tenant.Name);
										owner = if(input.Unit_Owner == null,"-",input.Unit_Owner.Name);
										agreement_no = if(getTenantAgreement.count() > 0,getTenantAgreement.Agreement_No,"-");
										start_date = if(getTenantAgreement.count() > 0,getTenantAgreement.Start_Date,"-");
										end_date = if(getTenantAgreement.count() > 0,getTenantAgreement.End_Date,"-");
										parking = if(getTenantAgreement.count() > 0,input.Tenant_Agreement.Parking_No.Unit_Name,"-");
										input.Parking_No = input.Tenant_Agreement.Parking_No;
										language_alert = thisapp.Localization.Alert();
										pending_payment = Add_Payment_Notes[Status == "Unpaid" && Unit == input.Unit && Pay_For == "Monthly Payment" || Pay_For == "Complaint"];
										input.Pending_Amount = pending_payment.sum(Total_Amount);
										Pending_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Pending_Amount);
										if(input.Action_field != "Request_Page")
										{
											hide plain1;
											show plain;
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-plain-group .zc-prop-notes-field {width: 475px;}</style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr>";
											if(parking != null)
											{
												input.plain = input.plain + "<tr><td>" + language.get("zcpm.property.parkingslot") + "</td><td class='zc-prop-green'>" + parking + "</td> </tr>";
											}
											input.plain = input.plain + "<tr><td>" + language.get("zcpm.user.tenant") + "</td> <td>" + tenant + "</td></tr><tr><td>" + language.get("zcpm.agreement.no") + "</td><td class='zc-prop-blue-green'>" + agreement_no + "</td></tr><tr><td>" + language.get("zcpm.renew.Agreement_Duration") + "</td><td class='zc-prop-yellow'>" + start_date + " " + language.get("zcpm.renew.to") + " " + end_date + "</td></tr><tr> <td>" + language_alert.get("zcpm.security.deposit") + "</td><td class='zc-prop-orange'>" + input.Tenant_Agreement.Security_Deposit_Display + "</td> </tr>";
										}
										if(input.Pending_Amount > 0)
										{
											input.plain = input.plain + "<tr> <td>" + language_alert.get("zcpm.pending.amount") + "</td><td class='zc-prop-red'>" + Pending_Amount_Display + "</td> </tr>";
										}
										input.plain = input.plain + " </tbody> </table> </div> </div>";
										hide Parking_No;
						)
					}
				}

			}
