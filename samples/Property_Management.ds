			Script_Subform_Validation as "Script:Subform Validation Check"
			{
				type =  form
				form = Add_Payment_Notes
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_Details.count() == 0)
										{
											alert "Invalid entry: Please enter valid payment details";
											cancel submit;
										}
										amoun = input.Payment_Details.sum(Amount);
										if(amoun != input.Total_Amount)
										{
											alert "Amount mismatch! The total in the Payment_Details must be equal to the overall total amount. Please correct it before proceeding";
											cancel submit;
										}
						)
					}
				}

			}
			Script_Separate_Pay_For as "Script:Separate Pay For"
			{
				type =  form
				form = Add_Payment_Notes
				record event = on add or edit

				on user input of Payment_Type
				{
					actions 
					{
						custom deluge script
						(
											lis = List();
										if(input.Payment_Type == "Income" || input.Payment_Type == "")
										{
											lis.add("Security Deposit");
											lis.add("Monthly Payment");
											lis.add("Vacate");
											input.Pay_For:ui.add(lis);
										}
										else if(input.Payment_Type == "Expense")
										{
											lis.add("Vacate");
											input.Pay_For:ui.add(lis);
										}
										else
										{
											input.Pay_For = null;
										}
						)
					}
				}

			}
			Script_Onload as "Script:Onload"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Property;
										hide Unit;
										hide Owner;
										hide rec_id;
										//hide Parking_No;
										language = thisapp.Localization.Pages();
										property = if(input.Property == null,"-",input.Property.Property_Name);
										unit = if(input.Unit == null,"-",input.Unit.Unit_Name);
										Unit_Owner = if(input.Owner == null,"-",input.Unit.Owner_Mail_ID.Name);
										parking = Add_Unit[Unit_Type == "Parking" && Occupancy_Type == "Owned" || (Occupancy_Type == "Sale" && Availability == "Available") || (Occupancy_Type == "Rent" || Occupancy_Type == "Lease" && Availability == "Vacant")].ID.getAll();
										input.Parking_No:ui.add(parking);
										if(input.Buyer_Tenant == null)
										{
											new_user = New_User[ID != null].ID.getAll();
											lis = new_user.toList();
											if(lis.contains(input.Owner))
											{
												lis.removeElement(input.Owner);
											}
											input.Buyer_Tenant:ui.add(lis);
										}
										else if(input.Buyer_Tenant != null)
										{
											disable Buyer_Tenant;
											disable Parking_No;
										}
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-form-fullheight .formContainer .column-block .formColumn { width: 100%; }</style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr><tr><td>" + language.get("zcpm.Owner.Name") + "</td><td class='zc-prop-yellow'>" + Unit_Owner + "</td></tr></tbody></table></div></div>";
						)
					}
				}

			}
