			OnLoad_Create as "OnLoad - Create"
			{
				type =  form
				form = New_User
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(!input.Role.isEmpty())
										{
											hide Role;
										}
										if(input.Role == "Tenant" && input.Tenant_First_Agreement == true)
										{
											hide Unit;
											hide Property;
											if(input.Tenant_Units.size() > 0)
											{
												show Tenant_Units;
												disable Tenant_Units;
											}
										}
										if(input.Role == "Tenant")
										{
											hide Role;
										}
										if(input.Role == "Owner")
										{
											show Owner_Units;
											disable Owner_Units;
										}
										else if(input.Role == "Manager")
										{
											show Manager_Units;
											// 	disable Manager_Units ;
										}
						)
					}
				}

			}
