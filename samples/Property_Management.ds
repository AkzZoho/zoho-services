		{
			displayname = "Tenants"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet3' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet3()\ncontent\n&lt;%{\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t{\n\t\ttenant = New_User[ID == input.rec_id];\n\t}\n\telse\n\t{\n\t\ttenant = New_User[ID == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id()];\n\t}\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;%\n\tif(input.action == &quot;DetailView&quot; || input.action == &quot;detailTenantScreening&quot;)\n\t{\n\t\t%&gt;\n\/* Popup Related Styles *\/\n.zcform_Reject_Confirmation {\n    width: 550px;\n}\n&lt;%\n\t}\n\tif(tenant.Tenant_Status != &quot;Screening In Process&quot; &amp;&amp; input.action == &quot;DetailView&quot; || input.action == &quot;detailTenantScreening&quot;)\n\t{\n\t\t%&gt;\n.zcform_Approve_Confirmation {\n    width: 550px;\n}\n&lt;%\n\t}\n\t%&gt;\n&lt;\/style&gt;\n&lt;%\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tCommon_language = thisapp.Localization.common();\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\t\tinput.action = &quot;DetailView&quot;;\n\t\t}\n\t\tif(!input.rec_id.isEmpty())\n\t\t{\n\t\t\tgetTenantAgree = Tenant_Agreement[ID == input.rec_id];\n\t\t\tgetTenant = New_User[ID == getTenantAgree.Tenant &amp;&amp; Role == &quot;Tenant&quot;];\n\t\t\tgetUnit = Add_Unit[ID == getTenantAgree.Unit];\n\t\t\tgetProperty = Add_Property[ID == getUnit.Property];\n\t\t}\n\t\tpage_link_name = &quot;Tenants&quot;;\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\t\tinput.action = input.action.getPrefix(&quot;&amp;rec_id=&quot;);\n\t\t}\n\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\ttab_keys = tab_map.keys();\n\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\t\tif(login_profile in {&quot;Admin&quot;,&quot;Administrator&quot;,&quot;Developer&quot;})\n\t\t{\n\t\t\ttenant_screening = Tenant_Screening[Tenant.ID == input.rec_id];\n\t\t\ttenant = New_User[ID == input.rec_id];\n\t\t\tedit_tenant = New_User[ID == input.rec_id];\n\t\t}\n\t\telse\n\t\t{\n\t\t\ttenant_screening = Tenant_Screening[Tenant.ID == input.rec_id &amp;&amp; Tenant_Unit.Owner_Mail_ID == thisapp.get_user_id() || Tenant_Unit.Manager == thisapp.get_user_id()];\n\t\t\ttenant = New_User[ID == input.rec_id &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id()];\n\t\t\tedit_tenant = New_User[ID == input.rec_id &amp;&amp; Tenant_Status == &quot;Waiting for Approval&quot; || Tenant_Status == &quot;Screening In Process&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id()];\n\t\t}\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_View()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n    content: &apos;&lt;%=language.get(&quot;zcpm.name.email.filter&quot;)%&gt;&apos;; \n}\n&lt;%\n\t\t\tif(input.tab.isEmpty() || input.tab == &quot;new-tenants&quot; || input.tab == &quot;screening-tenants&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Styles.Custom_Action_Btn()%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-view zc-prop-withoutpanel zc-prop-tenant-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.tenant.tenants&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t&lt;div class=&quot;zc-prop-flt-right zc-prop-clearfix&quot; style=&quot;display:flex; gap:10px; align-items:center;&quot;&gt;\n\t\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.tenant.add_tenant&quot;),&quot;#Page:Tenants?action=add&amp;tab=&quot; + input.tab)%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody zc-prop-card-content&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;Page=&lt;%=page_link_name%&gt;&amp;tab=&lt;%=input.tab%&gt;&amp;zc_Footer=false&amp;Report=&lt;%=report_name%&gt;&amp;Search=&lt;%=input.search%&gt;&apos;&gt;&lt;\/div&gt;\n\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;add&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.tenant.add_tenant&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;New_User&quot;,&quot;zc_Header=false&amp;Role=Tenant&amp;zc_NextUrl=#Page:Tenants?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;edittenant&quot; &amp;&amp; edit_tenant.count() &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.tenant.edit.tenant&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;New_User&quot;,&quot;zc_Header=false&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?tab&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if((input.action == &quot;detailTenantScreening&quot; &amp;&amp; tenant_screening.count() &gt; 0 &amp;&amp; tenant.count() &gt; 0) || (login_profile in {&quot;Admin&quot;,&quot;Administrator&quot;,&quot;Developer&quot;} &amp;&amp; tenant_screening.count() &gt; 0) || (input.action == &quot;DetailView&quot; &amp;&amp; tenant.count() &gt; 0))\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Styles.Property_Info()%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\ttenant_proof = Screening_File[Tenant_Screening == tenant_screening.ID];\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(tenant.ID,tenant.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,tenant.Name,true);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-tenant-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:Tenants?tab=&lt;%=input.tab%&gt;&apos;&gt;\n                   &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=tenant.Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n            &lt;!-- span class=&apos;zc-prop-flt-left zc-prop-badge zc-prop-badge-green&apos;&gt; &lt;%=tenant.Tenant_Status%&gt; &lt;\/span --&gt;\n&lt;%\n\t\t\tif(tenant.Tenant_Status == &quot;Waiting for Approval&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Form:Tenant_Screening?Tenant=&lt;%=tenant.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-2-square-upload&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.upload.documents&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Approve_Confirmation?New_User=&lt;%=tenant.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?New_User=&lt;%=tenant.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(tenant.Tenant_Status == &quot;Screening In Process&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Approve_Confirmation?New_User=&lt;%=tenant.ID%&gt;&amp;Action_field=Screening&amp;Unit=&lt;%=tenant.Unit%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?New_User=&lt;%=tenant.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-property-info zc-prop-card zc-prop-clearfix zc-prop-fw&apos;&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-label-value-wrapper&apos;&gt;\n                    &lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=tenant.Email%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Phone_Number.isEmpty(),tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=tenant.Location.Location%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Address.isEmpty(),tenant.Address,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Gender&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Gender.isEmpty(),tenant.Gender,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Date.of.Birth&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=if(tenant.Date_of_Birth != null,tenant.Date_of_Birth,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                    &lt;\/ul&gt;\n                &lt;\/div&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\t\tif(tenant.Tenant_Status == &quot;Approved&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n                    &lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\t\tpage_detail_name = &quot;TenantsDetailView&quot;;\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\t\ttab_keys = tab_map.keys();\n\t\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t\tfor each  sub_tab in tab_keys\n\t\t\t\t{\n\t\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;tenantdetail&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Name.isEmpty(),tenant_screening.Current_Owner_Name,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Contact.Number&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Contact_Number.isEmpty(),tenant_screening.Current_Owner_Contact_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Address.isEmpty(),tenant_screening.Current_Address,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Occupant.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Occupant_Type.isEmpty(),tenant_screening.Occupant_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(tenant_screening.Occupant_Type == &quot;Rent&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Monthly.Rental&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Monthly_Rental &gt; 0,tenant_screening.Monthly_Rental_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Lease_Type.isEmpty(),tenant_screening.Lease_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Lease_Amount &gt; 0,tenant_screening.Lease_Amount_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t\tif(proof.File_upload == null)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; - &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\telse\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;a href=&quot;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&quot;&gt; &lt;%=proof.File_upload%&gt;&lt;\/a&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;units&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&amp;Current_Tenant.ID=&lt;%=input.rec_id%&gt;&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-mono-wrapper&apos;&gt;\n                &lt;div class=&apos;zc-prop-card-header&apos;&gt;\n                    &lt;h6&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screeing.Details&quot;)%&gt; &lt;\/h6&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Name.isEmpty(),tenant_screening.Current_Owner_Name,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Contact.Number&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Contact_Number.isEmpty(),tenant_screening.Current_Owner_Contact_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Address.isEmpty(),tenant_screening.Current_Address,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Occupant.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Occupant_Type.isEmpty(),tenant_screening.Occupant_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(tenant_screening.Occupant_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Monthly.Rental&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Monthly_Rental &gt; 0,tenant_screening.Monthly_Rental_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Lease_Type.isEmpty(),tenant_screening.Lease_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Lease_Amount &gt; 0,tenant_screening.Lease_Amount_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\tif(proof.File_upload == null)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; - &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=proof.File_upload%&gt;&lt;\/a&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page ID_Configuration
		{
			displayname = "ID Configuration"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet20' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet20()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage_common = thisapp.Localization.common();\n\t\tlanguage_pages = thisapp.Localization.Pages();\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.ID_Setup()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\tid_setup = ID_Setup[ID != 0];\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-ids-setup-wrapper zc-prop-fwh&apos;&gt;\n\t&lt;div class=&apos;zc-prop-subheader zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language_pages.get(&quot;zcpm.ID.Setup&quot;)%&gt; &lt;\/h5&gt;\n\t\t&lt;div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t&lt;%=thisapp.Components.Button(&quot;Edit&quot;,language_common.get(&quot;zcpm.common.edit&quot;),&quot;#Form:ID_Setup?recLinkID=&quot; + id_setup.ID + &quot;&amp;zc_LoadIn=dialog&amp;viewLinkName=All_Id_Setups&amp;zc_NextUrl=#Script:page.reload&quot;)%&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&apos;zc-prop-subcontent&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-label-value-wrapper zc-prop-with-bg zc-prop-count-3&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;label&gt; &lt;%=language_pages.get(&quot;zcpm.pdf.bill.no&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=id_setup.Bill_No%&gt; &lt;h6&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;label&gt; &lt;%=language_pages.get(&quot;zcpm.complaint.search&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=id_setup.Work_Order_No%&gt; &lt;h6&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;label&gt;&lt;%=language_pages.get(&quot;zcpm.Agreement.ID&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=id_setup.Agreement_ID%&gt; &lt;h6&gt;\n\t\t\t\t&lt;\/li&gt;\n\t\t\t&lt;\/ul&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Organization_Page
		{
			displayname = "Organization"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet21' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet21()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tlanguage_common = thisapp.Localization.common();\n\t\torg = Organization[ID != 0];\n\t\timg_src = thisapp.CommonFeatures.processImageUrl(org.ID,org.Logo,&quot;All_Organizations&quot;,&quot;Logo&quot;,org.Org_Name,false);\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Organization()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-company-detail-wrapper zc-prop-fwh&apos;&gt;\n\t&lt;div class=&apos;zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-subheader&apos;&gt;\n\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.vendor.org&quot;)%&gt; &lt;\/h5&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-company-common-detail zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-with-text&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-text-wrapper&apos;&gt;\n\t\t\t\t\t&lt;h4&gt; &lt;%=org.Org_Name%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;a href=&apos;mailto:&lt;%=org.Email%&gt;&apos; class=&apos;zc-prop-icon-with-text zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-email-83 zc-prop-flt-left&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=org.Email%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Edit&quot;,language_common.get(&quot;zcpm.common.edit&quot;),&quot;#Form:Organization?recLinkID=&quot; + org.ID + &quot;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&amp;viewLinkName=All_Organizations&quot;)%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;ul class=&apos;zc-prop-company-other-detail zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.phone&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline ui-3-phone-call&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=org.Phone_Number%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.website&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline business-globe&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Website_Address.isEmpty(),&quot;-&quot;,org.Website_Address)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.registor&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline design-todo&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Register_Number.isEmpty(),&quot;-&quot;,org.Register_Number)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline location-pin&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Head_Office_Address.isEmpty(),&quot;-&quot;,org.Head_Office_Address)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.Tenant&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline users-single-01&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Tenant.isEmpty(),&quot;-&quot;,org.Tenant)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.Vendor&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline users-single-01&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Vendor.isEmpty(),&quot;-&quot;,org.Vendor)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos; style=&apos;width: 100%;&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.request.description&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline files-single-folded-content&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Description.isEmpty(),&quot;-&quot;,org.Description)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos; style=&apos;width: 100%;&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.term&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline files-single-folded-content&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Terms_and_conditions.isEmpty(),&quot;-&quot;,org.Terms_and_conditions)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos; style=&apos;width: 100%;&apos;&gt;\n\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.orgz.notes&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-icon-with-text&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline files-single-folded-content&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(org.Notes.isEmpty(),&quot;-&quot;,org.Notes)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/li&gt;\n\t\t&lt;\/ul&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Automatic_Rental_PDF(int rec_id)
		{
			displayname = "Automatic Rental PDF"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet19' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet19()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tpayment_note = Add_Payment_Notes[ID == input.rec_id];\n\t\t}\n\t\telse\n\t\t{\n\t\t\tpayment_note = Add_Payment_Notes[ID == input.rec_id &amp;&amp; Unit.Current_Tenant == thisapp.get_user_id() || Unit.Owner_Mail_ID == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id()];\n\t\t}\n\t\torg_details = Organization[ID != 0];\n\t\timg_src = thisapp.CommonFeatures.processImageUrl(org_details.ID,org_details.Logo,&quot;All_Organizations&quot;,&quot;Logo&quot;,org_details.Org_Name,false);\n\t\tpage_language = thisapp.Localization.Pages();\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;%=thisapp.Styles_Page.Payment_Receipt()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-popup-container zc-prop-payment-receipt-popup&apos;&gt;\n\t&lt;div class=&apos;zc-prop-popup-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-popup-header&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-popup-center-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-popup-img-wrapper&apos;&gt;\n\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;p&gt; &lt;%=org_details.Org_Name%&gt;, &lt;%=org_details.Head_Office_Address%&gt; &lt;\/p&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-popup-txt-wrapper&apos;&gt; \n\t\t\t\t\t&lt;label&gt; &lt;%=page_language.get(&quot;zcpm.pdf.phone&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=org_details.Phone_Number%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-popup-txt-wrapper&apos;&gt; \n\t\t\t\t\t&lt;label&gt; &lt;%=page_language.get(&quot;zcpm.pdf.email&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=org_details.Email%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-popup-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-vertical-table-wrapper&apos;&gt;\n\t\t\t\t&lt;table&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.bill.no&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=payment_note.Billing__ID%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.property.unit&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=payment_note.Property.Property_Name%&gt; \/ &lt;%=payment_note.Unit.Unit_Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=payment_note.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.due.date&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment_note.Due_Date == null,&quot;-&quot;,payment_note.Due_Date)%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.date.of.payment&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment_note.Payment_Date == null,&quot;-&quot;,payment_note.Payment_Date)%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.month.year&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment_note.Month_Year.isEmpty(),&quot;-&quot;,payment_note.Month_Year)%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\tclass_name = &quot;zc-prop-color-green&quot;;\n\t\tif(payment_note.Status == &quot;Unpaid&quot;)\n\t\t{\n\t\t\tclass_name = &quot;zc-prop-color-red&quot;;\n\t\t}\n\t\telse if(payment_note.Status == &quot;Paid&quot;)\n\t\t{\n\t\t\tclass_name = &quot;zc-prop-color-yellow&quot;;\n\t\t}\n\t\telse if(payment_note.Status == &quot;Cancel&quot;)\n\t\t{\n\t\t\tclass_name = &quot;zc-prop-color-red&quot;;\n\t\t}\n\t\t%&gt;\n&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.status&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;td class=&apos;&lt;%=class_name%&gt;&apos;&gt; &lt;%=payment_note.Status%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t&lt;\/table&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t&lt;table&gt;\n\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.s.no&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t&lt;th&gt; &lt;%=page_language.get(&quot;zcpm.pdf.charge.description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t&lt;th class=&apos;zc-prop-align-right&apos;&gt; &lt;%=page_language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\ts_no = 1;\n\t\tfor each  paymentsubform in payment_note.Payment_Details\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt; &lt;%=s_no%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;td&gt; &lt;%=paymentsubform.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right&apos;&gt; &lt;%=paymentsubform.Amount_Display%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\ts_no = s_no + 1;\n\t\t}\n\t\t%&gt;\n&lt;tr class=&apos;zc-prop-bold-tr&apos;&gt;\n\t\t\t\t\t\t\t&lt;td colspan=&apos;2&apos; class=&apos;zc-prop-align-right&apos;&gt; &lt;%=page_language.get(&quot;zcpm.pdf.total&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right&apos;&gt; &lt;%=payment_note.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;\/tbody&gt;\n\t\t\t\t&lt;\/table&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-popup-txt-wrapper&apos;&gt;\n                &lt;h6&gt; &lt;%=page_language.get(&quot;zcpm.pdf.notes&quot;)%&gt; &lt;\/h6&gt;\n                &lt;p&gt; &lt;%=org_details.Notes%&gt; &lt;\/p&gt;\n            &lt;\/div&gt;\n            &lt;div class=&apos;zc-prop-popup-txt-wrapper&apos;&gt;\n                &lt;h6&gt; &lt;%=page_language.get(&quot;zcpm.pdf.terms.conditions&quot;)%&gt; &lt;\/h6&gt;\n                &lt;p&gt; &lt;%=org_details.Terms_and_conditions%&gt; &lt;\/p&gt;\n            &lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Setup_Wizard
		{
			displayname = "Setup Wizard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet2' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet2()\ncontent\n&lt;%{\n\tpage_link_name = &quot;Setup_Wizard&quot;;\n\tcommon = thisapp.Localization.Tab();\n\t\/\/ \tif(User_Configuration.count() == 0)\n\t\/\/ \t{\n\t\/\/ \t\topenURL(&quot;#Page:User_Configuration_Page&quot;,&quot;same window&quot;);\n\t\/\/ \t}\n\ttab_map = Map();\n\tgetUser = New_User[ID != 0].count();\n\tconfig = User_Configuration[ID != 0];\n\tcurrent_tab = &quot;completed&quot;;\n\tcurrent_tab = if(Configure.count() == 0,&quot;account-setup&quot;,current_tab);\n\tcurrent_tab = if(Add_Unit.count() == 0,&quot;unit&quot;,current_tab);\n\tcurrent_tab = if(Add_Property.count() == 0,&quot;property&quot;,current_tab);\n\tif(config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Manager&quot;)\n\t{\n\t\tcurrent_tab = if(New_User.count() == 1,&quot;new-user&quot;,current_tab);\n\t}\n\tcurrent_tab = if(Organization.count() == 0,&quot;org-details&quot;,current_tab);\n\ttab_map.put(&quot;org-details&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.setup.organization&quot;),&quot;Form Link&quot;:&quot;Organization&quot;});\n\tif(config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Manager&quot;)\n\t{\n\t\ttab_map.put(&quot;new-user&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.setup.add.Owner&quot;),&quot;Form Link&quot;:&quot;New_User&quot;});\n\t}\n\ttab_map.put(&quot;property&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.setup.property&quot;),&quot;Form Link&quot;:&quot;Add_Property&quot;});\n\ttab_map.put(&quot;unit&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.setup.unit&quot;),&quot;Form Link&quot;:&quot;Add_Unit&quot;});\n\ttab_map.put(&quot;account-setup&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.setup.configure&quot;),&quot;Form Link&quot;:&quot;Configure&quot;});\n\ttab_map.put(&quot;email-template&quot;,{&quot;Display&quot;:common.get(&quot;zcpm.email.template&quot;),&quot;viewLinkName&quot;:&quot;All_Email_Templates&quot;});\n\ttab_keys = tab_map.keys();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;%=thisapp.Styles_Page.Setup_Wizard_Style()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-setup-wizard&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-fwh&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-stepper-wrapper&apos;&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\tfor each  tab_id in tab_keys\n\t{\n\t\threfLink = if(current_tab == &quot;completed&quot;,&quot;href=&apos;#Page:Setup_Wizard&apos;&quot;,&quot;&quot;);\n\t\tif(tab_id == current_tab &amp;&amp; current_tab != &quot;completed&quot;)\n\t\t{\n\t\t\tclass = &quot;zc-prop-stepper-active&quot;;\n\t\t\threfLink = &quot;href=&apos;#Page:Setup_Wizard&apos;&quot;;\n\t\t}\n\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=class%&gt;&apos;&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-stepper-status&apos;&gt; &lt;%=tab_keys.indexOf(tab_id) + 1%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-stepper-name&apos;&gt; &lt;%=tab_map.get(tab_id).get(&quot;Display&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-content zc-prop-card&apos; name=&apos;onboard_Data&apos;&gt;\n&lt;%\n\tif(current_tab != &quot;completed&quot;)\n\t{\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-setup-form zc-prop-fwh&apos;&gt;\n\t\t\t\t\t&lt;div elName=&apos;zc-component&apos; formLinkName=&apos;&lt;%=tab_map.get(current_tab).get(&quot;Form Link&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;Page_Link_Name=&lt;%=page_link_name%&gt;&amp;zc_NextUrl=#Script:page.reload&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&apos;zc-prop-nodata zc-prop-fwh&apos; name=&apos;onboard_Data&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-nodata-content&apos;&gt;\n\t\t\t\t\t\t&lt;img src=&apos;data:image\/svg+xml;base64,&apos;\/&gt;\n\t\t\t\t\t\t&lt;h4&gt; &lt;%=common.get(&quot;zcpm.setup.successfully&quot;)%&gt;&lt;\/h4&gt;\n\t\t\t\t\t\t&lt;h6&gt; &lt;%=common.get(&quot;zcpm.setup.congrats&quot;)%&gt; &lt;br&gt;&lt;%=common.get(&quot;zcpm.setup.we.have.successfully&quot;)%&gt; &lt;br&gt; &lt;%=common.get(&quot;zcpm.setup.you.can.now&quot;)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-nodata-btns&apos;&gt;\n\t\t\t\t\t\t\t&lt;a class=&apos;zc-live-primary-btn&apos; href=&apos;#Page:Admin_Dashboard&apos;&gt; &lt;%=common.get(&quot;zcpm.setup.start.property&quot;)%&gt;&lt;\/a&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Rental(string action, int rec_id, string subtab, string tab, string tab_detail)
		{
			displayname = "Rental"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet4' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet4()\ncontent\n&lt;%{\n\tlanguage = thisapp.Localization.Pages();\n\tCommon_language = thisapp.Localization.common();\n\tif(input.action.contains(&quot;&amp;&quot;))\n\t{\n\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\tinput.action = &quot;detail&quot;;\n\t}\n\tpage_link_name = &quot;Rental&quot;;\n\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\ttab_keys = tab_map.keys();\n\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\tif(!input.rec_id.isEmpty())\n\t{\n\t\tgetTenant = Tenant_Agreement[ID == input.rec_id];\n\t\tgetUnit = Add_Unit[ID == getTenant.Unit];\n\t\tgetProperty = Add_Property[ID == getUnit.Property];\n\t}\n\tback_url = if(!input.tab.isEmpty(),&quot;#Page:&quot; + page_link_name + &quot;?tab=&quot; + input.tab,&quot;#Page:&quot; + page_link_name);\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tuser_config = User_Configuration[ID != 0];\n\tif(login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t{\n\t\ttotal_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot;];\n\t\tavailable_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Availability == &quot;Vacant&quot;];\n\t\toccupied_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Availability == &quot;Occupied&quot;];\n\t\trenewal_request = Renew_Agreement_Request[Unit.Occupancy_Type == &quot;Rent&quot;];\n\t\tvacate_request = Vacate_Request[Unit.Occupancy_Type == &quot;Rent&quot; &amp;&amp; Vacate_Status != &quot;Rejected By Owner&quot; &amp;&amp; Vacate_Status != &quot;Admin Rejected&quot; &amp;&amp; Vacate_Status != &quot;Tenant Approved&quot;];\n\t}\n\telse if(login_profile == &quot;Owner&quot;)\n\t{\n\t\ttotal_units = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Occupancy_Type == &quot;Rent&quot;];\n\t\tavailable_units = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Occupancy_Type == &quot;Rent&quot; &amp;&amp; Availability == &quot;Vacant&quot;];\n\t\toccupied_units = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Occupancy_Type == &quot;Rent&quot; &amp;&amp; Availability == &quot;Occupied&quot;];\n\t\trenewal_request = Renew_Agreement_Request[Unit.Owner_Mail_ID == thisapp.get_user_id() &amp;&amp; Unit.Occupancy_Type == &quot;Rent&quot;];\n\t\tvacate_request = Vacate_Request[Unit.Owner_Mail_ID == thisapp.get_user_id() &amp;&amp; Unit.Occupancy_Type == &quot;Rent&quot; &amp;&amp; Vacate_Status != &quot;Rejected By Owner&quot; &amp;&amp; Vacate_Status != &quot;Admin Rejected&quot; &amp;&amp; Vacate_Status != &quot;Tenant Approved&quot;];\n\t}\n\telse if(login_profile == &quot;Manager&quot;)\n\t{\n\t\ttotal_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()];\n\t\tavailable_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Availability == &quot;Vacant&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()];\n\t\toccupied_units = Add_Unit[Occupancy_Type == &quot;Rent&quot; &amp;&amp; Owner_Approval_Status == &quot;Approved&quot; &amp;&amp; Availability == &quot;Occupied&quot; &amp;&amp; Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id()];\n\t\trenewal_request = Renew_Agreement_Request[Unit.Occupancy_Type == &quot;Rent&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\tvacate_request = Vacate_Request[Unit.Occupancy_Type == &quot;Rent&quot; &amp;&amp; Vacate_Status != &quot;Rejected By Owner&quot; &amp;&amp; Vacate_Status != &quot;Admin Rejected&quot; &amp;&amp; Vacate_Status != &quot;Tenant Approved&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t}\n\tcontent = if(input.tab == &quot;availableunits&quot;,language.get(&quot;zcpm.unit.filter&quot;),language.get(&quot;zcpm.agreement.no&quot;));\n\trenew_id = Renew_Agreement_Request[ID == input.rec_id].Base_Agreement.ID;\n\tvacate_id = Vacate_Request[ID == input.rec_id].Tenant_Agreement.ID;\n\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t{\n\t\tagreement = Tenant_Agreement[Agreement_Type == &quot;Rent&quot; &amp;&amp; ID == input.rec_id || ID == renew_id || ID == vacate_id];\n\t\trenew = Renew_Agreement_Request[Base_Agreement.Agreement_Type == &quot;Rent&quot; &amp;&amp; ID == input.rec_id];\n\t\tvacate_req = Vacate_Request[Tenant_Agreement.Agreement_Type == &qu