			Received_Payment_Direct_A as "Received - Payment_Direct_Approval"
			{
				type =  functions
				form = Add_Payment_Notes
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						if(input.Pay_For == "Complaint" && input.Raise_a_Complaint != null)
										{
											if(input.Raise_a_Complaint != null)
											{
												complaint = Raise_a_Complaint[ID == input.Raise_a_Complaint.ID];
												complaint.Complaint_Status="Completed";
											}
											openUrl("#Form:Received_Popup_Form?zc_Header=false&Billing_ID=" + input.ID + "&Compliant_No=" + complaint.ID,"popup window");
										}
										else
										{
											openUrl("#Form:Received_Popup_Form?zc_Header=false&Action_field=direct_approval&Billing_ID=" + input.ID,"popup window");
										}
					)
					}
				}
			}
