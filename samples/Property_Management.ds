				 void mail.SendToUserAdded(int user_rec_id)
                 {
                 	new_user = New_User[ID == input.user_rec_id];
                 	vendor = Add_Vendor[ID == input.user_rec_id];
                 	mail_template = Email_Template[Template_Name == "New User Added" && Send_To == "Property Management" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("href=\"\"","",true);
                 		if(new_user.count() > 0)
                 		{
                 			msg = msg.replaceAll("${User_Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 			msg = msg.replaceAll("${Role}",new_user.Role,true);
                 			msg = msg.replaceAll("${Email}",new_user.Email,true);
                 			msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 			subject = mail_template.Subject_field.replaceAll("${Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 			if(new_user.Role == "Tenant")
                 			{
                 				msg = msg.replaceAll(">Access the Property Management"," href='" + thisapp.Get_Base_Url() + "#Page:Tenant_Profile'>Access the Property Management");
                 			}
                 			else
                 			{
                 				msg = msg.replaceAll(">Access the Property Management"," href='" + thisapp.Get_Base_Url() + "#Page:Dashboard'>Access the Property Management");
                 			}
                 			thisapp.mail.sendMailTask(new_user.Email.toList(),subject,msg);
                 		}
                 		else if(vendor.count() > 0)
                 		{
                 			msg = msg.replaceAll("${User_Name}",vendor.Vendor_Name,true);
                 			msg = msg.replaceAll("${Role}","Vendor",true);
                 			msg = msg.replaceAll("${Email}",vendor.Vendor_Email,true);
                 			msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 			subject = mail_template.Subject_field.replaceAll("${Name}",vendor.Vendor_Name,true);
                 			msg = msg.replaceAll(">Access the Property Management"," href='" + thisapp.Get_Base_Url() + "#Page:Vendor_Profile'>Access the Property Management");
                 			thisapp.mail.sendMailTask(vendor.Vendor_Email.toList(),subject,msg);
                 		}
                 	}
                 }
				 void mail.SendToUserRemoved(int user_rec_id)
                 {
                 	new_user = New_User[ID == input.user_rec_id];
                 	new_vendor = Add_Vendor[ID == input.user_rec_id];
                 	mail_template = Email_Template[Template_Name == "User Removed to Property Management To User" && Send_To == "Property Management" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0 && new_user.count() > 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("${User_Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 		msg = msg.replaceAll("${Role}",new_user.Role,true);
                 		msg = msg.replaceAll("${Email}",new_user.Email,true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		thisapp.mail.sendMailTask(new_user.Email.toList(),mail_template.Subject_field,msg);
                 	}
                 	else if(mail_template.count() != 0 && new_vendor.count() > 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("${User_Name}",new_vendor.Vendor_Name,true);
                 		msg = msg.replaceAll("${Role}","Vendor",true);
                 		msg = msg.replaceAll("${Email}",new_vendor.Vendor_Email,true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		thisapp.mail.sendMailTask(new_vendor.Vendor_Email.toList(),mail_template.Subject_field,msg);
                 	}
                 }
