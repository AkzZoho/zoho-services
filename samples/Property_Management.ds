			Script_ParkingNumber as "Script:ParkingNumber"
			{
				type =  form
				form = Add_Unit
				record event = on add

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											property = Add_Property[ID == input.Property];
										if(property.No_of_Parking_Slots != null)
										{
											parking = Add_Unit[Property == input.Property && Unit_Type == "Parking"].count();
											if(parking == property.No_of_Parking_Slots && input.Unit_Type == "Parking")
											{
												alert "If you wish to add the parking to this property, Please Configure the Parking Count in the Property.";
												input.Property = null;
											}
										}
						)
					}
				}

			}
			UpdateCapacity as "UpdateCapacity"
			{
				type =  form
				form = Extend_Parking_Capacity
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Extend != null)
										{
											property = Add_Property[ID == input.Property];
											if(property.No_of_Parking_Slots == null)
											{
												property.No_of_Parking_Slots=0;
											}
											property.No_of_Parking_Slots=property.No_of_Parking_Slots + input.Extend;
										}
										openUrl("#Script:page.parent.refresh ","parent window");
						)
					}
				}

			}
			Disable_Fields3 as "Disable Fields"
			{
				type =  form
				form = Extend_Parking_Capacity
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Property;
										disable Existing_Parking_Capacity;
										hide Property;
										hide Existing_Parking_Capacity;
						)
					}
				}

			}
			Validation as "Validation"
			{
				type =  form
				form = Extend_Parking_Capacity
				record event = on add or edit

				on user input of Extend
				{
					actions 
					{
						custom deluge script
						(
											if(input.Extend <= 0)
										{
											alert "Please Enter Valid Number";
											input.Extend = null;
										}
						)
					}
				}

			}
			Popup as "Popup"
			{
				type =  form
				form = Extend_Parking_Capacity
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.Pages();
										property = if(input.Property == null,"-",input.Property.Property_Name);
										exist = if(input.Existing_Parking_Capacity == null,"-",input.Existing_Parking_Capacity.No_of_Parking_Slots);
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-form-fullheight .formContainer .column-block .formColumn { width: 100%; }</style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr>";
										if(exist != null)
										{
											input.plain = input.plain + "<tr><td>" + language.get("zcpm.exist.parking") + "</td><td class='zc-prop-green'>" + exist + "</td></tr>";
										}
										else
										{
											input.plain = input.plain + "<tr><td class='zc-prop-red';  colspan='2'>There is no existing parking for this property.</td></tr></tbody></table></div></div>";
										}
						)
					}
				}

			}
			Validation1 as "Validation"
			{
				type =  form
				form = Sales_Form
				record event = on add or edit

				on user input of Date_field
				{
					actions 
					{
						custom deluge script
						(
											if(input.Date_field > zoho.currentdate)
										{
											alert "Please Enter Valid Date";
											input.Date_field = null;
										}
						)
					}
				}

			}
		}

		schedule
		{
			Penalty_Amount_Generate as "Penalty Amount Generate"
			{
				type =  schedule
				form = Add_Payment_Notes[Status == "Un Paid"]
				start = Due_Date at "11:00:00"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						getConfig = Configure[Unit == input.Unit];
										getDefaultConfig = Configure[Configure1 == "Default"];
										// penalty_day = if(getConfig.count() == 1,getConfig.Grace_Days_For_Monthly_Payment,getDefaultConfig.Grace_Days_For_Monthly_Payment);
										payforpenalty = Pay_For_Monthly[Pay_For == "Pentalty"];
										if(input.Pay_For == "Monthly Payment" && getConfig.Do_you_want_configure_penalty != "No" || getDefaultConfig.Do_you_want_configure_penalty != "No")
										{
											if(getConfig.count() > 0 && getConfig.Penalty_Payment_Method == "Fixed Amount")
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforpenalty.ID
													Amount=getConfig.Fixed_Penalty_Amount
													Amount_Display=thisapp.Currency.currencyDisplayFormat(getConfig.Fixed_Penalty_Amount)
													Add_Payment_Notes=input.ID
												];
												input.Total_Amount = input.Total_Amount + getConfig.Fixed_Penalty_Amount;
												input.Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Total_Amount);
											}
											else if(getConfig.count() > 0 && getConfig.Penalty_Payment_Method == "%")
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforpenalty.ID
													Amount=(input.Total_Amount * getConfig.Penalty) / 100
													Amount_Display=thisapp.Currency.currencyDisplayFormat((input.Total_Amount * getConfig.Penalty) / 100)
													Add_Payment_Notes=input.ID
												];
												input.Total_Amount = input.Total_Amount + (input.Total_Amount * getConfig.Penalty) / 100;
												input.Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Total_Amount);
											}
											else if(getDefaultConfig.count() == 1 && getDefaultConfig.Penalty_Payment_Method == "Fixed Amount")
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforpenalty.ID
													Amount=getDefaultConfig.Fixed_Penalty_Amount
													Amount_Display=thisapp.Currency.currencyDisplayFormat(getDefaultConfig.Fixed_Penalty_Amount)
													Add_Payment_Notes=input.ID
												];
												input.Total_Amount = input.Total_Amount + getDefaultConfig.Fixed_Penalty_Amount;
												input.Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Total_Amount);
											}
											else if(getDefaultConfig.count() == 1 && getDefaultConfig.Penalty_Payment_Method == "%")
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforpenalty.ID
													Amount=(input.Total_Amount * getDefaultConfig) / 100
													Amount_Display=thisapp.Currency.currencyDisplayFormat((input.Total_Amount * getDefaultConfig) / 100)
													Add_Payment_Notes=input.ID
												];
												input.Total_Amount = input.Total_Amount + (input.Total_Amount * getDefaultConfig) / 100;
												input.Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Total_Amount);
											}
											thisapp.mail.SendTenantPenaltyAmountAdded(input.ID);
										}
					)
					}
				}
			}
			Inactive_Agreements as "Inactive Agreements"
			{
				type =  schedule
				form = Tenant_Agreement[Agreement_Status == "Active"]
				start = End_Date at "11:00:00"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						input.Agreement_Status = "Inactive";
					)
					}
				}
			}
			Tenant_Agreement_Expire_S as "Tenant Agreement Expire Send Email"
			{
				type =  schedule
				form = Tenant_Agreement[Agreement_Status == "Active"]
				start = before 2 weeks from End_Date at "11:00:00"
				time zone = "UTC"
				on start
				{
					actions 
					{
					on load
					(
						thisapp.mail.SendToTenantAgreementExpireSoon(input.ID);
					)
					}
				}
			}
			Tenant_Vacate_Process as "Tenant Vacate Process"
			{
				type =  schedule
				form = Vacate_Request[Vacate_Date is today || Vacate_Date < zoho.currentdate && Vacate_Status == "Tenant Approved"]
				start = Vacate_Date at "11:00:00"
				time zone = "IST"
				on start
				{
					actions 
					{
					on load
					(
						inspection = Inspection_Form[Vacate_Request.ID == input.ID];
										unit = Add_Unit[ID == input.Unit];
										unit.Current_Tenant=null;
										unit.Availability="Vacant";
										agreement = Tenant_Agreement[Unit == input.Unit && Agreement_Status == "Active"];
										agreement.Status="Vacated";
										agreement.Agreement_Status="Inactive";
										vacate = Vacate_Request[ID == input.ID];
										vacate.Vacate_Status="Tenant Vacated";
										if(input.Parking_No != null)
										{
											unit.Parking_No=null;
											for each  i in agreement.Parking_No
											{
												parking_unit = Add_Unit[ID == i];
												parking_unit.Current_Tenant=null;
												parking_unit.Availability="Vacant";
												parking_unit.Parking_No=null;
											}
										}
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Vacate_Request=vacate.ID
											Action_field="Tenant Vacated"
										];
										thisapp.Change_User_Post_Viewer();
					)
					}
				}
			}
			Monthly_Payment_Generator as "Monthly Payment Generator"
			{
				type =  schedule
				form = Tenant_Agreement[Agreement_Status == "Active" && Status == "Tenant Approved"]
				start = Next_Bill_Generate_Date at "11:00:00"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						org = Organization[ID != 0];
										id = ID_Setup[ID != 0];
										monthName = zoho.currentdate.tostring("MMMM");
										yearname = zoho.currentdate.tostring("YYYY");
										getConfig = Configure[Unit == input.Unit];
										getDefaultConfig = Configure[Configure1 == "Default"];
										after_due_date = 0;
										before_due_date = 0;
										if(getConfig.count() > 0 && getConfig.Do_you_want_configure_penalty == "Yes")
										{
											after_due_date = if(getConfig.count() == 1,getConfig.After_Due_Date,getConfig.After_Due_Date);
											before_due_date = if(getConfig.count() == 1,getConfig.Grace_Days_For_Monthly_Payment,getConfig.Grace_Days_For_Monthly_Payment);
										}
										else if(getDefaultConfig.Do_you_want_configure_penalty == "Yes")
										{
											after_due_date = if(getDefaultConfig.count() == 1,getDefaultConfig.After_Due_Date,getDefaultConfig.After_Due_Date);
											before_due_date = if(getDefaultConfig.count() == 1,getDefaultConfig.Grace_Days_For_Monthly_Payment,getDefaultConfig.Grace_Days_For_Monthly_Payment);
										}
										if(input.Agreement_Type == "Rent")
										{
											Add_Monthly_Payment = insert into Add_Payment_Notes
											[
												Tenant_Agreement=input.ID
												Unit=input.Unit
												Property=input.Property
												Pay_For="Monthly Payment"
												Payer=input.Tenant
												Added_User=zoho.loginuser
												Status="Unpaid"
												Organization=org.ID
												Due_Date=input.Next_Pay_Date
												Reminder_date=input.Next_Pay_Date.addDay(after_due_date)
												Penalty_Date=input.Next_Pay_Date.addDay(before_due_date)
												Payment_Type="Income"
												Month_Year=monthName + "-" + yearname
												Total_Amount=input.Monthly_Payable
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Monthly_Payable)
											];
											bill = Add_Payment_Notes[ID == Add_Monthly_Payment];
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											for each  add_payment_monthly in Agreement_Additional_Payment[Tenant_Agreement.ID == input.ID]
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Add_Payment_Notes=Add_Monthly_Payment
													Add_Property=input.Property
													Add_Unit=input.Unit
													Pay_For=add_payment_monthly.Pay_For
													Amount=add_payment_monthly.Amount
													Amount_Display=add_payment_monthly.Amount_Display
													Description=add_payment_monthly.Description
												];
											}
											pay_for = Pay_For_Monthly[Pay_For == "Rent"];
											base_rent = insert into Payment_Details
											[
												Added_User=zoho.loginuser
												Pay_For=pay_for.ID
												Add_Property=input.Property
												Add_Unit=input.Unit
												Amount=input.Base_Rent
												Amount_Display=input.Base_Rent_Display
												Add_Payment_Notes=Add_Monthly_Payment
												Description="Monthly Rental on " + monthName + "-" + yearname
											];
										}
										else if(input.Agreement_Type == "Lease" && input.Additional_Payment_Monthly.count() > 0)
										{
											Add_Monthly_Payment = insert into Add_Payment_Notes
											[
												Tenant_Agreement=input.ID
												Unit=input.Unit
												Property=input.Property
												Pay_For="Monthly Payment"
												Payer=input.Tenant
												Added_User=zoho.loginuser
												Status="Unpaid"
												Organization=org.ID
												Due_Date=input.Next_Pay_Date
												Reminder_date=input.Next_Pay_Date.addDay(after_due_date)
												Penalty_Date=input.Next_Pay_Date.addDay(before_due_date)
												Payment_Type="Income"
												Month_Year=monthName + "-" + yearname
											];
											bill = Add_Payment_Notes[ID == Add_Monthly_Payment];
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											for each  add_payment_monthly in Agreement_Additional_Payment[Tenant_Agreement.ID == input.ID]
											{
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Add_Payment_Notes=Add_Monthly_Payment
													Add_Property=input.Property
													Add_Unit=input.Unit
													Pay_For=add_payment_monthly.Pay_For
													Amount=add_payment_monthly.Amount
													Amount_Display=add_payment_monthly.Amount_Display
													Description=add_payment_monthly.Description
												];
											}
											bill.Total_Amount=input.Additional_Payment_Monthly.sum(Amount);
											bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Additional_Payment_Monthly.sum(Amount));
											// 	info Add_Monthly_Payment ;
										}
										thisapp.mail.SendToTenantPaymentReminder(Add_Monthly_Payment);
										input.Next_Pay_Date = input.Next_Pay_Date.addMonth(1);
										next_bill_days = if(getConfig.count() == 1,getConfig.Bill_Generation,getDefaultConfig.Bill_Generation);
										input.Next_Bill_Generate_Date = input.Next_Pay_Date.subDay(next_bill_days);
					)
					}
				}
			}
			Reminder_After_Due_Date as "Reminder After Due Date"
			{
				type =  schedule
				form = Add_Payment_Notes[Status == "Unpaid"]
				start = Due_Date at "11:00:00"
				end   = Reminder_date
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						getConfig = Configure[Unit == input.Unit];
										getDefaultConfig = Configure[Configure1 == "Default"];
										after_Due_date = if(getConfig.count() == 1,getConfig.After_Due_Date,getDefaultConfig.After_Due_Date);
										if(after_Due_date > 0)
										{
											thisapp.mail.SendTenantPaymentDueDateReminder(input.ID);
										}
					)
					}
				}
			}
		}




