				)
				custom action "Reject"
				(
	  			workflow = Reject_Vacate_Direct_Appr
				show action in edit record menu = true
				column header = "Reject"
				condition = (Vacate_Status == "Waiting for Owner Approval")
				)
				ID
				Property.ID
				Unit.ID
				custom action "Approve"
				(
	  			workflow = Approve_Vacate_Direct_App
				show action in edit record menu = true
				column header = "Approve"
				condition = (Vacate_Status == "Waiting for Owner Approval")
				)
			)
			custom actions
			(
				"Detail View - Vacate_Direct_Approval"
				(
	  			workflow = Detail_View_Vacate_Direct
				)
				"Edit 1"
				(
	  			workflow = Edit_Vacate_Direct_Approv
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Vacate_Status == "Requested" || Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Waiting for Tenant Approval")
				fields = [Vacate_Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Vacate_Status == "Owner Approved" || Vacate_Status == "Tenant Approved")
				fields = [Vacate_Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Vacate_Status == "Rejected By Owner" || Vacate_Status == "Admin Rejected")
				fields = [Vacate_Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Vacate_Status == "Tenant Vacated")
				fields = [Vacate_Status]
				format = "color:#5051f9;"
				}
			)
		}
		list Renew_Agreement_Direct_Approval_Owner
		{
			displayName = "Renew Agreement Direct Approval Owner"
			show all rows from Renew_Agreement_Request  [Status == "Requested" && Unit.Owner_Mail_ID == thisapp.get_user_id()]  
			(
				Unit
				Description
				Property
				Status
				Base_Agreement as "Base Agreement"
				Base_Agreement.Tenant
				Base_Agreement.Security_Deposit_Display as "Security Deposit"
				Base_Agreement.Start_Date as "Start Date"
				Base_Agreement.End_Date as "End Date"
				Base_Agreement.Agreement_No as "Agreement No"
				custom action "Extend Agreement"
				(
	  			workflow = Extend_Agreement_Renew_Ag
				show action in edit record menu = true
				column header = "Extend Agreement"
				condition = (Property.Admins == thisapp.get_user_id() && Status == "Owner Approved")
				)
				Added_Time as "Added Time"
				ID
				Unit.ID
				Property.ID
				custom action "Approve"
				(
	  			workflow = Approve_Renew_Agreement_D
				show action in edit record menu = true
				column header = "Approve"
				condition = (Status == "Requested")
				)
				custom action "Reject"
				(
	  			workflow = Reject_Renew_Agreement_Di
				show action in edit record menu = true
				column header = "Reject"
				condition = (Status == "Requested")
				)
			)
			custom actions
			(
				"Detail View - Renew_Agreement_Direct_Approval"
				(
	  			workflow = Detail_View_Renew_Agreeme
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Status == "Requested")
				fields = [Status]
				format = "color:#b8770d;"
				}
				"Owner Approved"
				{
				condition = (Status == "Owner Approved")
				fields = [Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Status == "Owner Rejected")
				fields = [Status]
				format = "color:#fe455d;"
				}
				"Agreement Renewed"
				{
				condition = (Status == "Agreement Renewed")
				fields = [Status]
				format = "color:#1fbac6;"
				}
			)
		}
		list Complaints_Direct_Approval_Owner
		{
			displayName = "Complaints Direct Approval Owner"
			show all rows from Raise_a_Complaint  [Complaint_Status == "Requested" && Unit.Owner_Mail_ID == thisapp.get_user_id()]  
			(
				Date_of_Reporting as "Date of Reporting"
				Work_Order_Number as "Work Order Number"
				Property
				Unit
				Tenant_Email as "Tenant"
				Location
				Owner_Email as "Owner Email"
				Manager
				Assigned_to as "Assigned to"
				Maintenance_Service as "Maintenance Service"
				Complaint_Status as "Status"
				Resolved_Date as "Resolved Date"
				Complaint_About as "Complaint About"
				Photo
				Complaint_Details as "Complaint Details"
				Vendor_Update as "Vendor Update"
				Payment_By as "Payment By"
				Complaint_Amount as "Complaint Amount"
				Complaints_No as "Work Order"
				Vendor_Assigned_Date as "Vendor Assigned Date"
				Complaint_Amount_Display as "Complaint Amount"
				custom action "Review Complaint"
				(
	  			workflow = Review_Complaint_Complain
				show action in edit record menu = true
				column header = "Review Complaint"
				condition = (Complaint_Status == "Requested")
				)
				custom action "Complete"
				(
	  			workflow = Complete_Complaints_Direc
				show action in edit record menu = true
				column header = "Complete"
				condition = (Complaint_Status == "Vendor Assigned" || Complaint_Status == "Complaint Reviewed" || Complaint_Status == "In Progress")
				)
				ID
				Property.ID
				Unit.ID
				custom action "Approve"
				(
	  			workflow = Approve_Complaints_Direct
				show action in edit record menu = true
				column header = "Approve"
				condition = (Complaint_Status == "Requested")
				)
				custom action "Reject"
				(
	  			workflow = Reject_Complaints_Direct_
				show action in edit record menu = true
				column header = "Reject"
				condition = (Complaint_Status == "Requested")
				)
			)
			custom actions
			(
				"Mark as Complete"
				(
	  			workflow = Mark_as_Complete_Complain
				show action in edit record menu = true
				condition = (Property.Admins == thisapp.get_user_id())
				)
				"Edit 1"
				(
	  			workflow = Edit_Complaints_Direct_Ap
				show action in edit record menu = true
				condition = (Complaint_Status == "Requested")
				)
				"Detail View - Complaints_Direct_Approval"
				(
	  			workflow = Detail_View_Complaints_Di
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Complaint_Status == "Requested")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Vendor Assigned"
				{
				condition = (Complaint_Status == "Vendor Assigned")
				fields = [Complaint_Status]
				format = "color:#5051f9;"
				}
				"In Progress"
				{
				condition = (Complaint_Status == "In Progress")
				fields = [Complaint_Status]
				format = "color:#1c63b4;"
				}
				"Rejected"
				{
				condition = (Complaint_Status == "Rejected")
				fields = [Complaint_Status]
				format = "color:#fe455d;"
				}
				"Work Order Completed & Paid & Completed"
				{
				condition = (Complaint_Status == "Work Order Completed" || Complaint_Status == "Paid" || Complaint_Status == "Completed" || Complaint_Status == "Approved")
				fields = [Complaint_Status]
				format = "color:#187822;"
				}
				"Waiting For Payment"
				{
				condition = (Complaint_Status == "Waiting for Payment")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Complaint Reviewed"
				{
				condition = (Complaint_Status == "Complaint Reviewed")
				fields = [Complaint_Status]
				format = "color:#1fbac6;"
				}
				"Approved"
				{
				condition = (Complaint_Status == "Approved")
				fields = [Complaint_Status]
				format = "color:#04a267;"
				}
			)
		}
		list Owner_Unit_Approvals
		{
