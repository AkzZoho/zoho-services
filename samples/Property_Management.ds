				 bool Page.Is_Onboard_Completed()
                 {
                 	getOrg = Organization[ID != 0];
                 	config = User_Configuration[ID != 0];
                 	bol = true;
                 	if(config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner")
                 	{
                 		bol = false;
                 	}
                 	else
                 	{
                 		user = New_User[ID != 0 && Role == "Owner"].count();
                 		if(user >= 1)
                 		{
                 			bol = false;
                 		}
                 	}
                 	if(Organization.count() == 0 || Add_Property.count() == 0 || Add_Unit.count() == 0 || Configure.count() == 0)
                 	{
                 		return false;
                 	}
                 	else
                 	{
                 		return true;
                 	}
                 }
				 string Styles.Badge()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	style_txt = ".zc-prop-badge { display: inline-block; vertical-align: top; font-size: 14px; font-weight: 400; line-height: 21px; padding: 2px 10px; border-radius: 4px; } .zc-prop-badge-green { background-color: " + color_codes.get("zc-prop-bg_green") + "; border: 1px solid " + color_codes.get("zc-prop-green") + "; color: " + color_codes.get("zc-prop-green") + "; } .zc-prop-badge-red { background-color: " + color_codes.get("zc-prop-bg_red") + "; border: 1px solid " + color_codes.get("zc-prop-red") + "; color: " + color_codes.get("zc-prop-red") + "; } .zc-prop-badge-grey { background-color: " + color_codes.get("zc-prop-white") + "; border: 1px solid " + color_codes.get("zc-prop-border-color") + "; color: " + color_codes.get("zc-prop-primary-text-color") + "; }.zc-prop-badge-yellow { background-color: #FCF4E6; border: 1px solid #B8770D; color: #B8770D; } .zc-prop-badge-l_blue { background-color: #E8EFFF; border: 1px solid #2A6FFC; color: #2A6FFC; } .zc-prop-badge-d_blue { background-color: #EAF2FF; border: 1px solid #1652BB; color: #1652BB; } .zc-prop-badge-orange { background-color: #F8F0EB; border: 1px solid #FA9961; color: #FA9961; }.zc-prop-badge-grey { background-color: " + color_codes.get("zc-prop-bg_grey") + "; border: 1px solid " + color_codes.get("zc-prop-grey") + "; color: " + color_codes.get("zc-prop-grey") + "; }.zc-prop-badge-skyblue { background-color: " + color_codes.get("zc-prop-bg_white") + "; border: 1px solid " + color_codes.get("zc-prop-skyblue") + "; color: " + color_codes.get("zc-prop-skyblue") + "; }";
                 	return style_txt;
                 }
				 string Styles.Banner()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	default_style = ".zc-prop-banner { background-color: " + color_codes.get("zc-prop-banner-bg") + "; border-radius: 4px; padding: 12px 16px; } .zc-prop-banner i { width: 14px; font-style: normal; line-height: 21px; margin-right: 8px; color: " + color_codes.get("zc-prop-primary-txt") + "; } .zc-prop-banner .zc-prop-banner-msg { width: calc(100% - 22px); } .zc-prop-banner p { font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-txt") + "; } .zc-prop-banner div p:not(:last-child) { margin-bottom: 2px; } .zc-prop-banner p a { cursor: pointer } .zc-prop-banner b { font-weight: 600; }";
                 	with_border = ".zc-prop-banner.zc-prop-banner-with-border { border: 1px solid var(--theme_brand_color); } .zc-prop-banner.zc-prop-banner-with-border i { color: var(--theme_brand_color); }";
                 	// 	header_banner = ".zc-prop-header-banner { position: fixed; top: 0px; right: 100px; z-index: 100; padding: 12px 8px; display: inline-block; vertical-align: top; } .zc-prop-header-banner p, .zc-prop-header-banner .zc-prop-upgrade-btn { float: left; font-size: 13px; font-weight: 400; line-height: 1.5; letter-spacing: 0.1px; color: #ebebece6; padding: 2px 8px; } .zc-prop-header-banner .zc-prop-upgrade-btn { font-size: 12px; border: 1px solid var(--theme_brand_color); color: var(--theme_brand_color); border-radius: 2px; } /* With live_adminbar */ .zc_live_adminbar .zc-prop-header-banner { top: 31px; right: 144px; } /* RTL */ .zc-rtl-wrapper .zc-prop-header-banner { right: auto; left: 100px; } .zc-rtl-wrapper .zc-prop-header-banner p, .zc-prop-header-banner .zc-prop-upgrade-btn { float: right; } /* With live_adminbar */ .zc-rtl-wrapper.zc_live_adminbar .zc-prop-header-banner { right: auto; left: 144px; }";
                 	rtl_txt = ".zc-rtl-wrapper .zc-prop-banner i { margin-right: 0px; margin-left: 8px; }";
                 	style_txt = default_style + with_border + rtl_txt;
                 	return style_txt;
                 }
				 map Styles.Color_Codes()
                 {
                 	color_map = Map();
                 	color_map.put("zc-prop-white","#FFFFFF");
                 	color_map.put("zc-prop-bg-color","rgb(18 19 43 / 5%)");
                 	color_map.put("zc-prop-border-color","#EBEFEF");
                 	color_map.put("zc-prop-primary-text-color","#222326");
                 	color_map.put("zc-prop-secondary-text-color","#7a8481");
                 	color_map.put("zc-prop-box-shadow","0 2px 9px 0 #d8d8d880");
                 	color_map.put("zc-prop-more-option-hover-bg","#EAECF0");
                 	// 	Table colors
                 	color_map.put("zc-prop-table-header-bg","#F9FAFE");
                 	color_map.put("zc-prop-table-header-text-color","#3E4650");
                 	color_map.put("zc-prop-table-list-hover","#F9FAFE");
                 	// 	tooptip colors
                 	color_map.put("zc-prop-tooltip-bg","#0C1621");
                 	// Banner colors
                 	color_map.put("zc-prop-banner-bg","#F0F5FF");
                 	// 	(Conditional formate, Delete, Active, Inactive)
                 	color_map.put("zc-prop-red","#FE455D");
                 	color_map.put("zc-prop-grey","#766969");
                 	color_map.put("zc-prop-skyblue","#0095ff");
                 	color_map.put("zc-prop-bg_red","#FDE3E6");
                 	color_map.put("zc-prop-green","#179E6C");
                 	color_map.put("zc-prop-bg_green","#E4FCF3");
                 	color_map.put("zc-prop-bg_grey","#F0F0F0");
                 	color_map.put("zc-prop-bg_skyblue","#add7ff");
                 	// More Options
                 	color_map.put("zc-prop-more-icon-hover","#EAECF0");
                 	color_map.put("zc-prop-more-option-red-txt","#E71F43");
                 	color_map.put("zc-prop-more-option-red-bg","#E71F431A");
                 	// 	Star Colors
                 	color_map.put("zc-prop-star-color","#FDCC0D");
                 	return color_map;
                 }
				 string Styles.Common_Styles()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
