				on click
				{
					actions 
					{
					on click
					(
						if(input.Action_field == "renewRentalReject" || input.Action_field == "renewLeaseReject")
										{
											config = User_Configuration[ID != 0];
											if(config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner")
											{
												renew = Renew_Agreement_Request[ID == input.Renew_Agreement_Request.ID];
												renew.Status="Owner Rejected";
												renew.Reason=input.Reason;
												timeline_adding = insert into Timeline_Form
												[
													Added_User=zoho.loginuser
													New_User=thisapp.get_user_id()
													Renew_Agreement_Request=renew.ID
													Action_field="Owner Rejected"
												];
											}
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Action_field == "vacateRentalReject" || input.Action_field == "vacateLeaseReject")
										{
											vacate_req = Vacate_Request[ID == input.Vacate_Request.ID];
											vacate_req.Reason=input.Reason;
											login_profile = thisapp.permissions.loginUserProfile();
											if(login_profile == "Admin" || login_profile == "Administrator")
											{
												vacate_req.Vacate_Status="Admin Rejected";
											}
											else if(login_profile == "Owner")
											{
												vacate_req.Vacate_Status="Rejected By Owner";
												timeline_adding = insert into Timeline_Form
												[
													Added_User=zoho.loginuser
													New_User=thisapp.get_user_id()
													Vacate_Request=vacate_req.ID
													Action_field="Owner Rejected"
												];
											}
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Action_field == "direct_reject")
										{
											inspection = Inspection_Form[Vacate_Request == input.Vacate_Request.ID];
											inspection.Status="Admin Rejected";
											Vacate_Status = "Admin Rejected";
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Vacate_Request=input.Vacate_Request.ID
												Action_field=Vacate_Status
											];
											openUrl("#Script:page.reload","same window");
										}
										else if(input.New_User != null)
										{
											user = New_User[ID == input.New_User];
											user.Reason=input.Reason;
											user.Status="Inactive";
											user.Tenant_Status="Rejected";
											thisapp.mail.SendTenantReject(input.New_User.ID);
											openUrl("#Page:Tenants?tab=reject-tenants","same window");
										}
										else if(input.Tenant_Agreement != null && input.Action_field.isEmpty())
										{
											agreement = Tenant_Agreement[ID == input.Tenant_Agreement.ID];
											agreement.Reason=input.Reason;
											agreement.Status="Auto Rejected";
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Tenant_Agreement != null && input.Action_field == "TenantReject")
										{
											thisapp.mail.SendToOwnerAgreementRejectByTenant(input.Tenant_Agreement.ID);
											agreement = Tenant_Agreement[ID == input.Tenant_Agreement.ID];
											agreement.Tenant_Reason=input.Reason;
											agreement.Status="Tenant Rejected";
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Tenant_Agreement != null && input.Action_field == "OwnerReject")
										{
											thisapp.mail.SendToOwnerAgreementRejectByTenant(input.Tenant_Agreement.ID);
											agreement = Tenant_Agreement[ID == input.Tenant_Agreement.ID];
											agreement.Reason=input.Reason;
											agreement.Status="Owner Rejected";
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Raise_a_Complaint != null)
										{
											complaint = Raise_a_Complaint[ID == input.Raise_a_Complaint.ID];
											complaint.Complaint_Status="Rejected";
											complaint.Reason=input.Reason;
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Add_Unit != null)
										{
											unit = Add_Unit[ID == input.Add_Unit.ID];
											unit.Owner_Approval_Status="Rejected";
											unit.Availability="Rejected Unit";
											unit.Owner_Reject_Reason=input.Reason;
											openUrl("#Page:Approval?tab=units","same window");
										}
					)
					}
				}
			}
			Alert_Inprogress_Vacate as "Alert Inprogress Vacate"
			{
				type =  form
				form = Vacate_Request
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Unit == null)
										{
											alert language_alert.get("zcpm.select.unit.alert");
											cancel submit;
										}
										vacate = Vacate_Request[Unit == input.Unit && Vacate_Status == "Requested" || Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Owner Approved" || Vacate_Status == "Waiting for Tenant Approval"];
										if(vacate.count() > 0)
										{
											alert language_alert.get("zcpm.request.already.inprogress");
											cancel submit;
										}
										payment = Add_Payment_Notes[Unit == input.Unit && Pay_For == "Security Deposit" && Status == "Unpaid"];
										if(payment.count() == 1 && input.Unit != null)
										{
											alert language_alert.get("zcpm.vacate.security.deposit");
											cancel submit;
										}
										pending_payment = Add_Payment_Notes[Status == "Unpaid" && Unit == input.Unit && Pay_For == "Monthly Payments" || Pay_For == "Complaint"];
										if(input.Tenant_Agreement.Security_Deposit < pending_payment.sum(Total_Amount))
										{
											alert language_alert.get("zcpm.pending.amount.alert");
											cancel submit;
										}
										//------------changes made-------------------------
										input.Balance_Amount = input.Tenant_Agreement.Security_Deposit;
										if(input.Balance_Amount < input.Pending_Amount)
										{
											alert "Pending amount exceeds security deposit. Please clear or pay at least a partial amount to vacate";
											cancel submit;
										}
						)
					}
				}

			}
			Alert_Renewal_Request as "Alert Renewal Request"
			{
				type =  form
				form = Renew_Agreement_Request
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Unit == null)
										{
											alert language_alert.get("zcpm.select.unit.alert");
											cancel submit;
										}
										renewal = Renew_Agreement_Request[Unit == input.Unit && Property == input.Property && Status == "Requested" || Status == "Owner Approved"];
										if(renewal.count() > 0)
										{
											alert language_alert.get("zcpm.already.inprogress");
											cancel submit;
										}
										payment = Add_Payment_Notes[Unit == input.Unit && Pay_For == "Security Deposit" && Status == "Unpaid"];
										if(payment.count() == 1 && input.Unit != null)
										{
											alert language_alert.get("zcpm.vacate.security.deposit");
											cancel submit;
										}
						)
					}
				}

			}
