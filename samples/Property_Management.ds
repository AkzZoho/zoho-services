			Item_Details as "Item Details"
			{
				type =  form
				form = Inspection_Form
				record event = on add
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											unit = Tenant_Agreement[ID == input.Tenant_Agreement];
										unit_items = Collection();
										input.Complaints.clear();
										for each  unit_items_subform in unit.Unit_Appliancias
										{
											addition_row1 = Inspection_Form.Complaints();
											addition_row1.Items=unit_items_subform.Items;
											addition_row1.Condition_field=unit_items_subform.Condition_field;
											addition_row1.Description=unit_items_subform.Description;
											addition_row1.Tenant_Agreement=input.Tenant_Agreement;
											unit_items.insert(addition_row1);
										}
										hide Complaints.Tenant_Agreement;
										hide Complaints.Image;
										input.Complaints.insert(unit_items);
						)
					}
				}

			}
			User_input_of_user_status as "User input of user status"
			{
				type =  form
				form = Property_Filter_Form
				record event = on add

				on user input of User_Status
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.common();
										export_url = zoho.appuri + "csv/";
										import_url = "#Page:" + input.Page + "?action=import";
										if(input.Page == "Users" || input.Page == "Tenants")
										{
											reportURL = "#Report:" + input.Report + "?zc_Header=false&zc_AddRec=false&zc_ColMenu=false&zc_Footer=false";
											search_result = New_User[Name.first_name.containsIgnoreCase(input.Search) || Name.last_name.containsIgnoreCase(input.Search) || Email.containsIgnoreCase(input.Search) || Phone_Number.containsIgnoreCase(input.Search)].ID.getAll();
											if(input.tab == "screening-tenants")
											{
												peram = if(!input.User_Status.isEmpty(),"&Tenant.Status=" + input.User_Status,"");
											}
											else
											{
												peram = if(!input.User_Status.isEmpty(),"&Status=" + input.User_Status,"");
											}
											if(input.Page == "Tenants")
											{
												tenants_ids = "?Role=Tenant&Role_op=18";
												if(input.tab.isEmpty() || input.tab == "new-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Waiting for Approval" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else if(input.tab == "screening-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&Tenant.ID=" + Tenant_Screening[Tenant.Role == "Tenants" && Tenant.Tenant_Status == "Screening In Process" && Tenant.Name.contains(input.Search) || Tenant.Email.contains(input.Search)].ID.getAll() + "&Tenant.ID_op=18");
												}
												else if(input.tab == "approved-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Approved" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else if(input.tab == "reject-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Rejected" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Approved" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
													tenants_ids = tenants_ids + if(input.User_Status.isEmpty(),"","&Status=" + input.User_Status + "&Status_op=18");
												}
												tenants_ids = tenants_ids + if(input.Location == null,"","&Location.ID" + input.Location.ID + "&Location.ID_op=18");
												export_url = export_url + input.Report + tenants_ids;
											}
											else
											{
												peram = peram + if(input.Location != null,"&Location.ID=" + input.Location.ID + "&Location.ID_op=18","");
												peram = peram + if(!input.Role.isEmpty(),"&Role=" + input.Role + "&Role_op=18","");
												search_result = if(search_result.size() == 0,1234,search_result);
												peram = peram + if(!input.Search.isEmpty(),"&ID=[" + search_result + "]&ID_op=72","");
												export_url = zoho.appuri + "csv/";
												import_url = "#Page:" + input.Page + "?action=import";
												role = "?Role=" + input.Role + "&Role_op=18";
												search = if(input.Search.isEmpty(),"","&ID=" + search_result + "&ID_op=18");
												status = if(input.User_Status.isEmpty(),"","&Status=" + input.User_Status + "&Status_op=18");
												export_url = export_url + input.Report + role + search + status;
											}
										}
										else if(input.Page == "Vendors")
										{
											reportURL = "#Report:" + input.Report + "?zc_Header=false&zc_AddRec=false&zc_ColMenu=false&zc_Footer=false";
											search_result = Add_Vendor[Vendor_Name.containsIgnoreCase(input.Search) || Vendor_Email.containsIgnoreCase(input.Search) || Phone_Number.containsIgnoreCase(input.Search) || Organization.containsIgnoreCase(input.Search)].ID.getAll();
											peram = if(!input.User_Status.isEmpty(),"&Status=" + input.User_Status,"");
											peram = peram + if(!input.Role.isEmpty(),"&Role=" + input.Role + "&Role_op=18","");
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = peram + if(!input.Search.isEmpty(),"&ID=[" + search_result + "]&ID_op=72","");
											language = thisapp.Localization.common();
											search = if(input.Search.isEmpty(),"?","?ID=" + search_result + "&ID_op=18&");
											status = if(input.User_Status.isEmpty(),"","Status=" + input.User_Status + "&Status_op=18");
											export_url = export_url + input.Report + search + status;
										}
										input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
