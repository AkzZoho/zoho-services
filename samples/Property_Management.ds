 * Version      : 1.0
 */
 application "Property Management - 2.0"
 {
 	date format = "dd-MMM-yy"
 	time zone = "Asia/Istanbul"
 	time format = "24-hr"
 	forms
	{
		form Active_Form
		{
			displayname = "Active Form"
			store data in zc = false
			success message = ""
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			plain
			(
    			type = plaintext
				value = "<div><br /></div>"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Hidden
			(
				type = section
	 			row = 2
	 			column = 0   
				width = medium
			)
			Add_Vendor
			(
				type = picklist	
				displayname = "Add Vendor"
				values  = Add_Vendor.ID
    			displayformat = [Vendor_Name]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
			New_User
			(
				type = picklist	
				displayname = "New User"
				values  = New_User.ID
    			displayformat = [" " + Name.prefix + " " + Name.first_name + " " + Name.last_name + " " + Name.suffix]
				sortorder = ascending
	 			row = 2
	 			column = 1   
				width = medium
			)
	
			actions
			{
				Active
				(
   					type = button
   					displayname = "Active"
				)
			}
		}
		form Add_Block
		{
			displayname = "Add Block"
			success message = "Block Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Property
			(
				type = picklist	
				values  = Add_Property.ID
    			bidirectional = Blocks
    			displayformat = [Property_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Block_Name
			(
    			type = text
				displayname = "Block Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			No_of_Units
			(
				type = number
				displayname = "No of Units"
				initial value = 0
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Add"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
				}
			}
		}
		form Add_Parking
		{
			displayname = "Add Parking"
			success message = "Car Parking Management Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Property
			(
				type = picklist	
				values  = Add_Property.ID
    			displayformat = [Property_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Unit
			(
				type = picklist	
				values  = Add_Unit[Property.ID == input.Property].ID
    			displayformat = [Unit_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have unique Parking_ID
			(
    			type = text
				displayname = "Parking ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Image
			(
    			type = image
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = radiobuttons
				maxchar = 100
				values = {"Occupied","Available"}
				initial value = "Available"
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Add_Payment_Notes
		{
			displayname = "Add Payment Note"
			success message = "Payment Note Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Bill_No
			(
    			type = autonumber
				displayname = "Bill No"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			Payment_Type
			(
				type = picklist
				displayname = "Payment Type"
				maxchar = 100
				values = {"Income","Expense"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Property
			(
				type = picklist	
				values  = Add_Property.ID
    			displayformat = [Property_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Unit
			(
				type = picklist	
				values  = Add_Unit[Property.ID == input.Property.ID && Owner_Approval_Status == "Approved"].ID
    			displayformat = [Unit_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Parking_No
			(
				type = list	
				displayname = "Parking No"
				values  = Add_Unit.ID
    			displayformat = [Unit_Name]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Payment_Date
			(
    			type = date
				displayname = "Payment Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Payer
			(
				type = picklist	
				values  = New_User[Role == "Tenant" || Role == "Owner"].ID
    			displayformat = [Name.first_name + " " + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Pay_For
			(
				type = picklist
				displayname = "Pay For"
				maxchar = 100
				values = {"Monthly Payment","Security Deposit","Complaint","Vacate","Vacate Complaints"}
				others option = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Amount
			(
				type = decimal
				displayname = "Total Amount"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Description
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			Bill
			(
    			type = upload file
				browse = local_drive
	 			row = 1
	 			column = 2   
				width = medium
			)
			Books_ID
			(
    			type = text
				displayname = "Books ID"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Payment_Details
			(
				type = grid
				displayname = "Payment Details"
				values  = Payment_Details.ID
    			bidirectional = Add_Payment_Notes
	 			row = 2
	 			column = 1   
				width = medium
			)
			Hide
			(
				type = section
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Billing__ID
			(
    			type = text
				displayname = "Billing NO"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Tenant_Agreement
			(
				type = picklist	
				displayname = "Tenant Agreement"
				values  = Tenant_Agreement.ID
    			displayformat = [Start_Date + " - " + End_Date]
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Raise_a_Complaint
			(
				type = picklist	
				displayname = "Raise a Complaint"
				values  = Raise_a_Complaint.ID
    			bidirectional = Add_Payment_Notes
    			displayformat = [Work_Order_Number]
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Vacate_Request
			(
				type = picklist	
				displayname = "Vacate Request"
				values  = Vacate_Request.ID
    			displayformat = [Vacate_Request_ID]
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Due_Date
			(
    			type = date
				displayname = "Due Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 3
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Unpaid","Paid","Received","Cancel","No Due"}
				initial value = "Unpaid"
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Month_Year
			(
    			type = text
				displayname = "Month-Year"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Organization
			(
				type = picklist	
				values  = Organization.ID
    			displayformat = [Org_Name]
				sortorder = ascending
	 			row = 3
	 			column = 1   
				width = medium
			)
			Penalty_Date
			(
    			type = date
				displayname = "Penalty Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 3
	 			column = 1   
				width = medium
			)
			Reminder_date
			(
    			type = date
				displayname = "Reminder date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 3
	 			column = 1   
				width = medium
			)
			Amount_Display
			(
    			type = richtext
				displayname = "Amount"
				height = 200px
				toolbar = enable
				[
					style, font-color, background-color, alignment, link, table, bullets-and-numbering, 
					font-size : {1, 2, 3, 4, 5, 6, 7},
					font-family : {"Serif", "Arimo", "Ptmono", "Heuristica", "OpenSans", "Tinos", "Lato", "DejaVuSans", "ComicNeue", "EBGaramond", "RobotoCondensed", "ArchivoBlack", "Carlito", "Barlow", "Comfortaa", "Montserrat", "Nunito", "Poppins", "Quicksand", "Raleway", "Rubik", "SourceSansPro"}
				]
	 			row = 3
	 			column = 2   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
				}
			}
		print template
			{
				Automatic_Rental_PDF
				{
