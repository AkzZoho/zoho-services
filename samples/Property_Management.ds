				 void mail.SendToApproverComplaintPayementDecision(int complaint_rec_id)
                 {
                 	mail_template = Email_Template[Template_Name == "Complaint Payment Decision To Approver" && Send_To == "Approver" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0)
                 	{
                 		complaint = Raise_a_Complaint[ID == input.complaint_rec_id];
                 		timeline = Timeline_Form[Raise_a_Complaint.ID == complaint.ID];
                 		subject = mail_template.Subject_field.replaceAll("${Unit_Name}",complaint.Unit.Unit_Name,true);
                 		msg = mail_template.Message;
                 		general = General[ID != 0];
                 		msg = msg.replaceAll("${Assigned_Name}",timeline.New_User.Name.first_name + " " + timeline.New_User.Name.last_name,true);
                 		msg = msg.replaceAll("${Unit_Name}",complaint.Unit.Unit_Name,true);
                 		msg = msg.replaceAll("${Work_Order_Number}",complaint.Complaints_No,true);
                 		msg = msg.replaceAll("${Date_of_Completion}",complaint.Resolved_Date.toString(),true);
                 		msg = msg.replaceAll("${Complaint_Amount}",thisapp.Currency.numberFormatAccurate(complaint.Complaint_Amount,general.Currency),true);
                 		msg = msg.replaceAll("${Vendor_Name}",complaint.Assigned_to.Vendor_Name,true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		thisapp.mail.sendMailTask(timeline.New_User.Email.toList(),subject,msg);
                 	}
                 }
				 void mail.SendToApproverWaitingTenent(int rec_id)
                 {
                 	new_user = New_User[ID == input.rec_id];
                 	mail_template = Email_Template[Template_Name == "Waiting for Tenant Approval" && Send_To == "Approver" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("${Approver_Name}",new_user.Unit.Owner_Mail_ID.Name.first_name + " " + new_user.Unit.Owner_Mail_ID.Name.last_name,true);
                 		msg = msg.replaceAll("${Tenant_Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 		msg = msg.replaceAll("${Tenant_Email}",new_user.Email,true);
                 		msg = msg.replaceAll("${Phone_Number}",new_user.Phone_Number,true);
                 		msg = msg.replaceAll("href=\"\"","",true);
                 		msg = msg.replaceAll(">View Details"," href='" + thisapp.Get_Base_Url() + "#Page:Tenants'>View Details");
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		mail = new_user.Unit.Owner_Mail_ID.Email;
                 		thisapp.mail.sendMailTask(mail.toList(),mail_template.Subject_field,msg);
                 		if(new_user.Unit.Manager != null)
                 		{
                 			msg = mail_template.Message;
                 			msg = msg.replaceAll("${Approver_Name}",new_user.Unit.Manager.Name.first_name + " " + new_user.Unit.Manager.Name.last_name,true);
                 			msg = msg.replaceAll("${Tenant_Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 			msg = msg.replaceAll("${Tenant_Email}",new_user.Email,true);
                 			msg = msg.replaceAll("${Phone_Number}",new_user.Phone_Number,true);
                 			msg = msg.replaceAll("href=\"\"","",true);
                 			msg = msg.replaceAll(">View Details"," href='" + thisapp.Get_Base_Url() + "#Page:Tenants'>View Details");
                 			msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 			mail = new_user.Unit.Manager.Email;
                 			thisapp.mail.sendMailTask(mail.toList(),mail_template.Subject_field,msg);
                 		}
                 	}
                 }
