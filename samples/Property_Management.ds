											input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
											openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
										else if(input.Page == "Complaints")
										{
											search_result = Raise_a_Complaint[Complaints_No.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
										else if(input.Page == "Requests")
										{
											if(input.tab == "vacate-requests" || input.tab.isEmpty())
											{
												search_result = Vacate_Request[Tenant_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
												search_result = if(search_result.size() == 0,1234,search_result);
												peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
												openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
											}
											else
											{
												search_result = Renew_Agreement_Request[Base_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
												search_result = if(search_result.size() == 0,1234,search_result);
												peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
												openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
											}
										}
										if(input.Page in {"Rental","Lease","Accounting"})
										{
											perPeram = if(input.Page == "Accounting","?Bill_No=00&Bill_No_op=19","");
											perPeram = if(input.Page == "Rental" || input.Page == "Lease","?Agreement_No=00&Agreement_No_op=19","");
											export_url = export_url + input.Report + perPeram + peram.replaceAll(" ","%20");
											input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
											openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
						)
					}
				}

			}
			User_input_of_Property1 as "User input of Property"
			{
				type =  form
				form = Property_Filter_Form
				record event = on add

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.common();
										if(input.Property != null)
										{
											login_profile = thisapp.permissions.loginUserProfile();
											if(login_profile == "Tenant")
											{
												unit = Add_Unit[Current_Tenant.Email == zoho.loginuserid && Owner_Approval_Status == "Approved" && Property == input.Property];
												input.Unit:ui.add(unit.ID.getall());
											}
											else if(login_profile == "Owner")
											{
												unit = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid && Owner_Approval_Status == "Approved" && Property == input.Property];
												input.Unit:ui.add(unit.ID.getall());
											}
											else if(login_profile == "Manager")
											{
												property = Add_Property[ID == input.Property && Manager.Email == zoho.loginuserid || Units.Manager == thisapp.get_user_id()];
												input.Unit:ui.add(property.Units.getall());
											}
											else
											{
												unit = Add_Unit[Property == input.Property];
												input.Unit:ui.add(unit.ID.getall());
											}
										}
										else
										{
											clear Unit;
										}
										export_url = zoho.appuri + "csv/";
										import_url = "#Page:" + input.Page + "?action=import";
										reportURL = "#Report:" + input.Report + "?zc_Header=false&zc_AddRec=false&zc_ColMenu=false&zc_Footer=false";
										peram = if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
										peram = peram + if(!input.Agreement_Status.isEmpty(),"&Status=" + input.Agreement_Status + "&Status_op=18","");
										peram = peram + if(!input.Complaint_Status.isEmpty(),"&Complaint_Status=" + input.Complaint_Status + "&Complaint_Status_op=18","");
										if(input.Page == "Requests")
										{
											if(input.tab == "vacate-requests" || input.tab.isEmpty())
											{
												search_result = Vacate_Request[Tenant_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else
											{
												search_result = Renew_Agreement_Request[Base_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
										}
										else if(input.Page == "Complaints")
										{
											search_result = Raise_a_Complaint[Complaints_No.containsIgnoreCase(input.Search)].ID.getAll();
										}
										else if(input.Page == "Approval")
										{
											if(input.tab == "units" || input.tab.isEmpty())
											{
												peram = if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
												peram = peram + if(input.Unit != null,"&ID=" + input.Unit.ID + "&ID_op=18","");
												peram = peram + if(!input.Search.isEmpty(),"&Property.Location=" + input.Search + "&Property.Location_op=26","");
											}
											else if(input.tab == "tenants")
											{
												search_result = New_User[Role == "Tenant" && Name.containsIgnoreCase(input.Search) || Email.containsIgnoreCase(input.Search) || Phone_Number.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else if(input.tab == "new-agreements")
											{
												search_result = Tenant_Agreement[Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else if(input.tab == "vacate-requests")
											{
												search_result = Vacate_Request[Tenant_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else if(input.tab == "renew-requests")
											{
												search_result = Renew_Agreement_Request[Base_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else if(input.tab == "complaints")
											{
												search_result = Raise_a_Complaint[Complaints_No.containsIgnoreCase(input.Search)].ID.getAll();
											}
											else if(input.tab == "payments")
											{
												search_result = Add_Payment_Notes[Billing__ID.containsIgnoreCase(input.Search)].ID.getAll();
											}
											if(input.tab != "units")
											{
												search_result = if(search_result.size() == 0,1234,search_result);
												peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											}
											openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
										else if(input.Page == "Accounting" && input.tab == "commission")
										{
											peram = if(input.Property != null,"&Add_Property.ID=" + input.Property.ID + "&Add_Property.ID_op=72","");
											peram = peram + if(!input.Payment_Status.isEmpty(),"&Add_Payment_Notes.Status=" + input.Payment_Status + "&Add_Payment_Notes.Status_op=18","");
											peram = peram + if(!input.Search.isEmpty(),"&Add_Payment_Notes.Billing__ID=" + input.Search + "&Add_Payment_Notes.Billing__ID_op=26","");
										}
										else if(input.Page == "Accounting")
										{
											search_result = Add_Payment_Notes[Billing__ID.containsIgnoreCase(input.Search)].ID.getAll();
											peram = peram + if(!input.Payment_Status.isEmpty(),"&Status=" + input.Payment_Status + "&Status_op=18","");
										}
										else if(input.tab == "renewrequests")
										{
											search_result = Renew_Agreement_Request[Base_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											peram = peram + if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
											peram = peram + if(input.Unit != null,"&Unit.ID=" + input.Unit.ID + "&Unit.ID_op=18","");
											// 	openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
										else if(input.tab == "vacaterequests")
										{
											search_result = Vacate_Request[Tenant_Agreement.Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											peram = peram + if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
											peram = peram + if(input.Unit != null,"&Unit.ID=" + input.Unit.ID + "&Unit.ID_op=18","");
											// 	openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
										else if(input.Page == "Rental" || input.Page == "Lease")
										{
											search_result = Tenant_Agreement[Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=18","");
										}
										else
										{
											search_result = Tenant_Agreement[Agreement_No.containsIgnoreCase(input.Search)].ID.getAll();
										}
										// if(input.tab != "commission")
										// {
										// 	search_result = if(search_result.size() == 0,1234,search_result);
										// 	peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
										// 	perPeram = if(input.Page == "Accounting","?Bill_No=00&Bill_No_op=19","");
										// }
										if(input.Page != "Rental" && input.Page != "Lease")
										{
											export_url = export_url + input.Report + peram;
										}
										else if(input.Page in {"Rental","Lease"})
										{
											perPeram = if(input.Page == "Rental" || input.Page == "Lease","?Agreement_No=00&Agreement_No_op=19","");
											export_url = export_url + input.Report + perPeram + peram;
										}
										export_url = export_url.replaceAll(" ","%20");
										input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
										if(input.Page != "Approval")
										{
											openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
										}
						)
					}
				}

			}
