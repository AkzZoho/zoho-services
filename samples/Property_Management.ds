			Run_Scripts_While_submit_1 as "Run Scripts - While submit the record"
			{
				type =  form
				form = Add_Property
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(Add_Property.count() == 1)
										{
											openUrl("#Page:Setup_Wizard","same window");
										}
										else if(Add_Property.count() > 1)
										{
											openUrl("#Page:Properties?action=propertyadd&step=2&rec_id=" + input.ID,"same window");
										}
						)
					}
				}

			}
			Run_Scripts_While_submit_2 as "Run Scripts - While submit the record"
			{
				type =  form
				form = Add_Unit
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											units = Add_Unit[Property == input.Property];
										input.Unit_Status = "Active";
										for each  prop in Add_Property[ID == input.Property]
										{
											oldunit = prop.Units;
											oldunit.add(input.ID);
											prop.Units=oldunit;
											oldowner = prop.Unit_Owners;
											oldowner.add(input.Owner_Mail_ID);
											prop.Unit_Owners=oldowner;
										}
										// if(input.Owner_Mail_ID.Email == zoho.loginuserid)
										// {
										input.Owner_Approval_Status = "Approved";
										input.Owner_Approve_Comment = "Auto Approved";
										if(input.Availability != "Occupied")
										{
											input.Availability = "Vacant";
										}
										// }
										if(units.count() == 1)
										{
											openUrl("#Page:Properties?action=propertyadd&step=3&rec_id=" + input.Property,"same window");
										}
										else
										{
											openUrl("#Page:Properties?action=configureadd&rec_id=" + input.ID,"same window");
										}
										if(input.Occupancy_Type == "Sale" || input.Occupancy_Type == "Owned")
										{
											openUrl("#Script:page.parent.refresh ","same window");
										}
										input.Bed_Rooms = if(input.Bed_Rooms == null,0,input.Bed_Rooms);
										input.Rest_Rooms = if(input.Rest_Rooms == null,0,input.Rest_Rooms);
										input.Hall = if(input.Hall == null,0,input.Hall);
										property = Add_Property[ID == input.Property];
										if(input.Unit_Type == "Parking")
										{
											if(property.No_of_Parking_Occupied == null)
											{
												property.No_of_Parking_Occupied=0;
											}
											property.No_of_Parking_Occupied=property.No_of_Parking_Occupied + 1;
										}
						)
					}
				}

			}
			Onload_field_rule1 as "Onload - field rule"
			{
				type =  form
				form = Review_Complaint
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Complaint;
										hide Action_field;
										hide Field_Alert;
										language = thisapp.Localization.Alert();
										pages_language = thisapp.Localization.Pages();
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.complaint.Work.Order.No') + "</td> <td class='zc-prop-blue'>" + input.Complaint.Complaints_No + "</td> </tr> <tr> <td>" + language.get('zcpm.complaint.Date.of.Reporting') + "</td> <td class='zc-prop-green'>" + input.Complaint.Date_of_Reporting + " </td> </tr> <tr> <td> " + language.get('zcpm.complaint.Complaint.About') + "</td> <td class='zc-prop-yellow'>" + input.Complaint.Complaint_About + "</td> </tr> <tr> <td> " + pages_language.get('zcpm.complaint.compliant_detail') + "</td> <td>" + if(input.Complaint.Complaint_Details.isEmpty(),"-",input.Complaint.Complaint_Details) + "</td> </tr> </tbody> </table> </div> </div>";
										if(input.Assign_Vendor == true)
										{
											hide Assign_Vendor;
											show Field_Alert;
											if(input.Complaint.Complaint_Status == "Requested")
											{
												show Assign_Vendor;
											}
											input.Field_Alert = "Please enter below details must to approval and assign vendor.";
										}
										else if(input.Action_field != "reapprove")
										{
											hide Expected_Date;
											hide Maintenance_Service;
											hide Assign_To;
										}
										if(input.Complaint.Complaint_Status == "Approved")
										{
											hide Field_Alert;
										}
										// if(input.Action_field == "reapprove")
										// {
										// 	show Field_Alert;
										// 	input.Field_Alert = "Please enter below details must to approval and assign vendor.";
										// }
						)
					}
				}

			}
			On_Click_Submit_Data_addi as "On Click Submit - Data adding"
			{
				type =  form
				form = Review_Complaint
				button = Approve
				on click
				{
					actions 
					{
					on click
					(
						getComplaint = Raise_a_Complaint[ID == input.Complaint.ID];
										timeline = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Action_field="Complaint Approved"
											Raise_a_Complaint=input.Complaint
										];
										if(input.Assign_Vendor == true && input.Expected_Date != null && input.Maintenance_Service != null && input.Assign_To != null)
										{
											getComplaint.Assigned_to=input.Assign_To;
											getComplaint.Maintenance_Service=input.Maintenance_Service;
											getComplaint.Complaint_Status="Vendor Assigned";
											getComplaint.Expected_Date=input.Expected_Date;
											openUrl("#Script:page.reload","same window");
										}
										else if(input.Assign_Vendor == false)
										{
											getComplaint.Complaint_Status="Approved";
											openUrl("#Script:page.reload","same window");
										}
										if(input.Assign_Vendor == true && input.Expected_Date == null || input.Maintenance_Service == null || input.Assign_To == null)
										{
											input.Field_Alert = "Please enter below details must to approval and assign vendor.";
											openUrl("#Script:dialog.closeAll","popup window");
											expect_date = if(input.Expected_Date == null,"",input.Expected_Date);
											openUrl("#Form:Review_Complaint?Complaint=" + input.Complaint + "&Action_field=reapprove&Assign_Vendor=true&Expected_Date=" + expect_date + "&Maintenance_Service=" + input.Maintenance_Service + "&Assign_To=" + input.Assign_To,"popup window");
										}
					)
					}
				}
			}
