			OnLoad18 as "OnLoad"
			{
				type =  form
				form = Complaint_Admin_Complete
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Hidden;
										if(input.Add_Unit.Current_Tenant == null)
										{
											input.Payment_By = "Owner";
											disable Payment_By;
										}
										language = thisapp.Localization.Alert();
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class=\"zc-prop-notes-field\"> <div class=\"zc-prop-keyvalue-view zc-prop-with-bg\"> <table class=\"zc-prop-table\"> <tbody> <tr> <td>" + language.get('zcpm.renew.property') + "</td> <td class='zc-prop-blue'>" + input.Complaint.Property.Property_Name + "</td> </tr><tr> <td>" + language.get('zcpm.renew.unit') + "</td> <td  class='zc-prop-green'>" + input.Complaint.Unit.Unit_Name + "</td> </tr><tr> <td>" + language.get('zcpm.complaint.Work.Order.No') + "</td> <td class='zc-prop-yellow'>" + input.Complaint.Complaints_No + "</td> </tr> <tr> <td>" + language.get('zcpm.complaint.Date.of.Reporting') + "</td> <td>" + input.Complaint.Date_of_Reporting + " </td> </tr> <tr> <td> " + language.get('zcpm.complaint.Complaint.About') + "</td> <td>" + input.Complaint.Complaint_About + "</td> </tr> ";
										complaint = Raise_a_Complaint[ID == input.Complaint];
										input.Add_Property = complaint.Property;
										input.Add_Unit = complaint.Unit;
										if(complaint.Maintenance_Service != null && complaint.Assigned_to != null)
										{
											input.plain = input.plain + "<tr> <td> " + language.get('zcpm.complaint.Maintenance_Service') + "</td> <td>" + complaint.Maintenance_Service.Maintenance_Service_Name + "</td> </tr><tr> <td> " + language.get('zcpm.complaint.assigned.to') + "</td> <td>" + complaint.Assigned_to.Vendor_Name + "</td> </tr>";
											hide Maintenance_Service;
											hide Assign_To;
										}
										if(complaint.Start_Time != null)
										{
											input.plain = input.plain + "<tr> <td> " + language.get('zcpm.complaint.Start.Date') + "</td> <td>" + complaint.Start_Time + "</td> </tr>";
											hide Start_Date;
										}
										if(complaint.Resolved_Date != null && complaint.Complaint_Amount != null)
										{
											input.plain = input.plain + "<tr> <td> " + language.get('zcpm.complaint.Resolved.Date') + "</td> <td>" + complaint.Resolved_Date + "</td> </tr><tr> <td> " + language.get('zcpm.complaint.Work.Order.Amount') + "</td> <td>" + complaint.Complaint_Amount_Display + "</td> </tr>";
											hide Resolved_Date;
											hide Work_Order_Amount;
											unit_config = Configure[Unit == input.Add_Unit];
											default_config = Configure[Configure1 == "Default"];
											if(unit_config.count() > 0 && unit_config.Do_You_Want_Configure_Manager_Commission == "Yes" && unit_config.Category.contains("Complaint"))
											{
												input.Commission = (complaint.Complaint_Amount * unit_config.Complaint) / 100;
											}
											else if(default_config.count() > 0 && default_config.Do_You_Want_Configure_Manager_Commission == "Yes" && default_config.Category.contains("Complaint"))
											{
												input.Commission = (complaint.Complaint_Amount * default_config.Complaint) / 100;
											}
										}
										input.plain = input.plain + "</tbody> </table> </div> </div>";
						)
					}
				}

			}
