			Script_AmountCalculation as "Script:AmountCalculation"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Parking_No
				{
					actions 
					{
						custom deluge script
						(
											if(input.Parking_No != null)
										{
											agreementparking1 = 0;
											agreementparking2 = 0;
											unit_configure = Configure[Unit == input.Unit];
											main_configure = Configure[Configure1 == "Default"];
											rent = 0;
											lease = 0;
											security = 0;
											for each  i in input.Parking_No
											{
												parking_configure = Configure[Unit == i];
												if(main_configure.count() == 1)
												{
													rent = rent + main_configure.Base_Rental_Monthly_Amount;
													lease = lease + main_configure.Base_Lease_Amount;
													security = security + main_configure.Security_Deposit;
												}
												else if(i.count() > 0)
												{
													rent = rent + parking_configure.Base_Rental_Monthly_Amount;
													lease = lease + parking_configure.Base_Lease_Amount;
													security = security + parking_configure.Security_Deposit;
												}
											}
											if(input.Agreement_Type == "Rent" && unit_configure.count() == 1)
											{
												input.Base_Rent = main_configure.Base_Rental_Monthly_Amount + rent;
												input.Security_Deposit = unit_configure.Security_Deposit + security;
											}
											if(input.Agreement_Type == "Rent" && main_configure.count() == 1)
											{
												input.Base_Rent = main_configure.Base_Rental_Monthly_Amount + rent;
												input.Security_Deposit = main_configure.Security_Deposit + security;
											}
											if(input.Agreement_Type == "Lease" && unit_configure.count() == 1)
											{
												Base_lease = unit_configure.Base_Lease_Amount + lease;
											}
											else if(input.Agreement_Type == "Lease" && main_configure.count() == 1)
											{
												input.Base_Lease = main_configure.Base_Lease_Amount + lease;
											}
											//Unit Additional Payment Monthly
											items = Add_Unit[ID == input.Unit];
											addition_collection = Collection();
											input.Additional_Payment_Monthly.clear();
											if(main_configure.count() > 0 && unit_configure.count() == 0)
											{
												for each  main_configure_subform in main_configure.Additional_Payment_Monthly
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													addition_row.Pay_For=main_configure_subform.Pay_For;
													addition_row.Amount=main_configure_subform.Amount;
													addition_row.Amount_Display=main_configure_subform.Amount_Display;
													addition_row.Description=main_configure_subform.Description;
													addition_collection.insert(addition_row);
												}
												if(input.Agreement_Type == "Rent" && main_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && main_configure.Category.contains("Rental Monthly"))
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													payfor = Pay_For_Monthly[Pay_For == "Commission"];
													addition_row.Pay_For=payfor.ID;
													addition_row.Amount=input.Base_Rent * main_configure.Rental_Monthly / 100;
													addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
													addition_row.Description="Commission";
													addition_collection.insert(addition_row);
												}
												a = main_configure.Agreement;
												b = main_configure.Agreement_Display;
											}
											else if(unit_configure.count() > 0)
											{
												for each  unit_configure_subform in unit_configure.Additional_Payment_Monthly
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													addition_row.Pay_For=unit_configure_subform.Pay_For;
													addition_row.Amount=unit_configure_subform.Amount;
													addition_row.Amount_Display=unit_configure_subform.Amount_Display;
													addition_row.Description=unit_configure_subform.Description;
													addition_collection.insert(addition_row);
												}
												if(input.Agreement_Type == "Rent" && unit_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && unit_configure.Category.contains("Rental Monthly"))
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													payfor = Pay_For_Monthly[Pay_For == "Commission"];
													addition_row.Pay_For=payfor.ID;
													addition_row.Amount=input.Base_Rent * unit_configure.Rental_Monthly / 100;
													addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
													addition_row.Description="Commission";
													addition_collection.insert(addition_row);
												}
												a = unit_configure.Agreement;
												b = unit_configure.Agreement_Display;
											}
											//Parking No Additional Payment Monthly
											for each  parking in input.Parking_No
											{
												parkings = Configure[Unit == parking];
												if(main_configure.count() > 0 && parkings.count() == 0)
												{
													for each  main_configure_subform in main_configure.Additional_Payment_Monthly
													{
														addition_row = Tenant_Agreement.Additional_Payment_Monthly();
														addition_row.Pay_For=main_configure_subform.Pay_For;
														addition_row.Amount=main_configure_subform.Amount;
														addition_row.Amount_Display=main_configure_subform.Amount_Display;
														addition_row.Description=main_configure_subform.Description;
														addition_collection.insert(addition_row);
													}
													if(input.Agreement_Type == "Rent" && main_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && main_configure.Category.contains("Rental Monthly"))
													{
														addition_row = Tenant_Agreement.Additional_Payment_Monthly();
														payfor = Pay_For_Monthly[Pay_For == "Commission"];
														addition_row.Pay_For=payfor.ID;
														addition_row.Amount=input.Base_Rent * main_configure.Rental_Monthly / 100;
														addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
														addition_row.Description="Commission";
														addition_collection.insert(addition_row);
													}
													if(main_configure.Agreement != null)
													{
														agreementparking1 = agreementparking1 + main_configure.Agreement;
														agreementparking2 = agreementparking2 + main_configure.Agreement_Display;
													}
												}
												else if(parkings.count() > 0)
												{
													for each  unit_configure_subform in parkings.Additional_Payment_Monthly
													{
														addition_row = Tenant_Agreement.Additional_Payment_Monthly();
														addition_row.Pay_For=unit_configure_subform.Pay_For;
														addition_row.Amount=unit_configure_subform.Amount;
														addition_row.Amount_Display=unit_configure_subform.Amount_Display;
														addition_row.Description=unit_configure_subform.Description;
														addition_collection.insert(addition_row);
													}
													if(input.Agreement_Type == "Rent" && parkings.Do_You_Want_Configure_Manager_Commission == "Yes" && parkings.Category.contains("Rental Monthly"))
													{
														addition_row = Tenant_Agreement.Additional_Payment_Monthly();
														payfor = Pay_For_Monthly[Pay_For == "Commission"];
														addition_row.Pay_For=payfor.ID;
														addition_row.Amount=input.Base_Rent * parkings.Rental_Monthly / 100;
														addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
														addition_row.Description="Commission";
														addition_collection.insert(addition_row);
													}
													if(parkings.Agreement != null)
													{
														agreementparking1 = agreementparking1 + parkings.Agreement;
														agreementparking2 = agreementparking2 + parkings.Agreement_Display;
													}
												}
											}
											input.Additional_Payment_Monthly.insert(addition_collection);
											if(a != null && agreementparking1 != null)
											{
												input.Agreement_Commission = a + agreementparking1;
											}
											if(b != null && agreementparking2 != null)
											{
												input.Agreement_Commission_Display = b + agreementparking2;
											}
											if(input.Agreement_Type == "Rent")
											{
												input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount);
											}
											else if(input.Agreement_Type == "Lease")
											{
												input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount);
											}
											//Adding Unit Appliances
											unit_items = Collection();
											input.Unit_Appliancias.clear();
											for each  unit_items_subform in items.Unit_Items
											{
												addition_row1 = Tenant_Agreement.Unit_Appliancias();
												addition_row1.Items=unit_items_subform.Item;
												addition_row1.Condition_field=unit_items_subform.Condition_field;
												addition_row1.Description=unit_items_subform.Description;
												unit_items.insert(addition_row1);
											}
											for each  units in input.Parking_No
											{
												items2 = Add_Unit[ID == units];
												for each  units_subform in items2.Unit_Items
												{
													addition_row2 = Tenant_Agreement.Unit_Appliancias();
													addition_row2.Items=units_subform.Item;
													addition_row2.Condition_field=units_subform.Condition_field;
													addition_row2.Description=units_subform.Description;
													unit_items.insert(addition_row2);
												}
											}
											input.Unit_Appliancias.insert(unit_items);
										}
						)
					}
				}

			}
			Script_Showparking as "Script:Showparking"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Unit_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.Unit_Type == "Both")
										{
											show Parking_No;
										}
										else
										{
											hide Parking_No;
										}
										if(input.Unit == null && input.Tenant == null && input.Property != null && input.Renew_Base_Agreement == null && input.Unit_Type == "Unit")
										{
											clear Unit;
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant" && Unit_Status == "Active" && Owner_Approval_Status == "Approved" && Unit_Type == "Unit"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
										else if(input.Unit == null && input.Tenant == null && input.Property != null && input.Renew_Base_Agreement == null && input.Unit_Type == "Parking")
										{
											clear Unit;
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant" && Unit_Status == "Active" && Owner_Approval_Status == "Approved" && Unit_Type == "Parking"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
										else if(input.Unit == null && input.Tenant == null && input.Property != null && input.Renew_Base_Agreement == null && input.Unit_Type == "Both")
										{
											clear Unit;
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant" && Unit_Status == "Active" && Owner_Approval_Status == "Approved" && Unit_Type == "Unit"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
										if(input.Property != null && input.Renew_Base_Agreement == null && input.Unit_Type == "Both")
										{
											clear Parking_No;
											getUnit1 = Add_Unit[Occupancy_Type == input.Agreement_Type && Availability == "Vacant" && Unit_Status == "Active" && Owner_Approval_Status == "Approved" && Unit_Type == "Parking"].ID.getAll();
											input.Parking_No:ui.add(getUnit1);
										}
						)
					}
				}

			}
			Script_subform as "Script:subform"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Do_you_want_configure_Additional_Payment_Monthly
