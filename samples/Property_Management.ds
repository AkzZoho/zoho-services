				{
				condition = (Complaint_Status == "Complaint Reviewed")
				fields = [Complaint_Status]
				format = "color:#1fbac6;"
				}
				"Rejected"
				{
				condition = (Complaint_Status == "Rejected")
				fields = [Complaint_Status]
				format = "color:#fe455d;"
				}
