			show all rows from Tenant_Agreement  [Agreement_Status == "Inactive" && Agreement_Type == "Lease" && Property.Manager == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id() && Status == "Owner Rejected" || Status == "Tenant Rejected" || Status == "Auto Rejected" || Status == "Admin Rejected"]  
			(
				Agreement_ID as "Agreement ID"
				Property
				Unit
				Tenant
				Agreement_Type as "Agreement Type"
				Base_Rent as "Base Rent"
				Base_Lease as "Base Lease"
				Start_Date as "Start Date"
				End_Date as "End Date"
				Next_Pay_Date as "Next Pay Date"
				Monthly_Payable as "Monthly Payable"
				Security_Deposit as "Security Deposit"
				Document
				Agreement_No as "Agreement No"
				Agreement_Status as "Agreement Status"
				Renew_Base_Agreement as "Renew Base Agreement"
				Renew_Agreement_Request as "Renew Agreement Request"
				Base_Rent_Display as "Base Rent"
				Base_Lease_Display as "Base Lease"
				Status
				Net_Payable_Display as "Net Payable"
				Security_Deposit_Display as "Security Deposit"
				Property.ID
				Unit.ID
				ID
			)
			custom actions
			(
				"Detail View - Lease_Rejected_Tenant_Agreements_Manager"
				(
	  			workflow = Detail_View_Lease_Rejecte
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Status == "Requested" || Status == "Vacate Requested")
				fields = [Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Status == "Owner Approved" || Status == "Tenant Approved")
				fields = [Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Status == "Owner Rejected" || Status == "Tenant Rejected" || Status == "Auto Rejected" || Status == "Admin Rejected")
				fields = [Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Status == "Vacated")
				fields = [Status]
				format = "color:#5051f9;"
				}
				"Agreement Renewed"
				{
				condition = (Status == "Agreement Renewed")
				fields = [Status]
				format = "color:#1fbac6;"
				}
			)
		}
