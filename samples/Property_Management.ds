			On_Success_Submit1 as "On Success Submit"
			{
				type =  form
				form = Renew_Agreement_Request
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Owner")
										{
											openUrl("#Form:Tenant_Agreement?Renew_Agreement=" + input.Base_Agreement,"popup window");
										}
										else if(login_profile != "Tenant")
										{
											pageName = "";
											if(input.Base_Agreement.Agreement_Type == "Rent")
											{
												pageName = "Rental";
											}
											else
											{
												pageName = "Lease";
											}
											openUrl("#Page:" + pageName + "?tab=renewrequests","same window");
										}
										else if(login_profile == "Tenant")
										{
											openUrl("#Page:Requests?tab=renew-requests","same window");
										}
										//changes made for action field zcmpm
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Renew_Agreement_Request=input.ID
											Action_field="Owner Approved"
										];
						)
					}
				}

			}
			On_Success_Submit_Auto_ap as "On Success Submit - Auto approve"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											id = ID_Setup[ID != 0];
										unit = Add_Unit[ID == input.Unit];
										if(input.Unit_Type == "Both")
										{
											unit.Parking_No=input.Parking_No;
											for each  parkings in input.Parking_No
											{
												unitpark = Add_Unit[ID == parkings];
												unitpark.Parking_No=input.Unit;
											}
										}
										user = New_User[ID == unit.Owner_Mail_ID];
										input.Agreement_No = id.Agreement_ID + input.Agreement_ID;
										if(input.Agreement_Type == "Lease")
										{
											input.Security_Deposit = input.Base_Lease;
										}
										login_profile = thisapp.permissions.loginUserProfile();
										userConfig = User_Configuration[ID != 0];
										// if(login_profile == "Owner" || (login_profile == "Admin" || login_profile == "Administrator" && userConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner"))
										// {
										// 	input.Status = "Owner Approved";
										// 	thisapp.mail.SendToTenantAgreementApproval(input.ID);
										// }
										// else
										// {
										// 	thisapp.mail.SendToOwnerTenantAgreementApproval(input.ID);
										// }
										if(input.Renew_Base_Agreement != null)
										{
											oldAgreement = Tenant_Agreement[ID == input.Renew_Base_Agreement];
											oldAgreement.Agreement_Status="Inactive";
											oldAgreement.Status="Agreement Renewed";
											renew = Renew_Agreement_Request[ID == input.Renew_Agreement_Request];
											renew.Status="Agreement Renewed";
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Renew_Agreement_Request=renew.ID
												Action_field="Agreement Renewed"
											];
											page_link = "";
											if(input.Agreement_Type == "Rent")
											{
												page_link = "Rental";
											}
											else
											{
												page_link = "Lease";
											}
											openUrl("#Page:" + page_link + "?tab=allagreement","same window");
										}
										getConfig = Configure[Unit == input.Unit];
										getDefaultConfig = Configure[Configure1 == "Default"];
										next_bill_date_days = if(getConfig.count() == 1,getConfig.Bill_Generation,getDefaultConfig.Bill_Generation);
										input.Next_Bill_Generate_Date = input.Next_Pay_Date.subDay(next_bill_date_days);
										agreement = Tenant_Agreement[Tenant == input.Tenant];
										tenant = New_User[ID == input.Tenant];
										if(agreement.count() == 1)
										{
											tenant.Tenant_First_Agreement=true;
										}
										//
										//-------------------------Direct Agreement approval flow zcmpm------------------
										id = ID_Setup[ID != 0];
										login_profile = thisapp.permissions.loginUserProfile();
										input.Status = "Tenant Approved";
										input.Agreement_Status = "Active";
										getUnit = Add_Unit[ID == input.Unit];
										getUnit.Current_Tenant=input.Tenant;
										getUnit.Availability="Occupied";
										for each  i in input.Parking_No
										{
											getparking = Add_Unit[ID == i];
											getparking.Current_Tenant=input.Tenant;
											getparking.Availability="Assigned";
										}
										if(input.Security_Deposit != null && input.Security_Deposit > 0)
										{
											payforSecurity = Pay_For_Monthly[Pay_For == "Security Deposit"];
											tenant_security_amt = if(input.Renew_Base_Agreement != null && input.Renew_Base_Agreement.Security_Deposit < input.Security_Deposit,input.Security_Deposit - input.Renew_Base_Agreement.Security_Deposit,0);
											if(input.Renew_Base_Agreement != null && tenant_security_amt > 0)
											{
												add_advance_amount = insert into Add_Payment_Notes
												[
													Tenant_Agreement=input.ID
													Unit=input.Unit
													Property=input.Property
													Parking_No=input.Parking_No
													Pay_For="Security Deposit"
													Due_Date=zoho.currentdate
													Payer=input.Tenant
													Added_User=zoho.loginuser
													Status="Unpaid"
													Due_Date=input.Start_Date
													Total_Amount=tenant_security_amt
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Security_Deposit)
													Payment_Type="Income"
												];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforSecurity.ID
													Add_Property=input.Property
													Add_Unit=input.Unit
													Add_Parking=input.Parking_No
													Amount=tenant_security_amt
													Amount_Display=input.Security_Deposit_Display
													Description="Security Deposit"
													Add_Payment_Notes=add_advance_amount
												];
												bill = Add_Payment_Notes[ID == add_advance_amount];
												bill.Billing__ID=id.Bill_No + bill.Bill_No;
												bill.Total_Amount=tenant_security_amt + if(input.Agreement_Commission > 0,input.Agreement_Commission,0);
												bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
											}
											else if(input.Renew_Base_Agreement != null && input.Security_Deposit == input.Renew_Base_Agreement.Security_Deposit && input.Agreement_Commission > 0)
											{
												add_advance_amount = insert into Add_Payment_Notes
												[
													Tenant_Agreement=input.ID
													Unit=input.Unit
													Property=input.Property
													Parking_No=input.Parking_No
													Pay_For="Security Deposit"
													Due_Date=zoho.currentdate
													Payer=input.Tenant
													Added_User=zoho.loginuser
													Status="Unpaid"
													Due_Date=input.Start_Date
													Total_Amount=0
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Security_Deposit)
													Payment_Type="Income"
												];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforSecurity.ID
													Add_Property=input.Property
													Add_Unit=input.Unit
													Add_Parking=input.Parking_No
													Amount=0
													Amount_Display=input.Security_Deposit_Display
													Description="Security Deposit"
													Add_Payment_Notes=add_advance_amount
												];
												bill = Add_Payment_Notes[ID == add_advance_amount];
												bill.Billing__ID=id.Bill_No + bill.Bill_No;
												bill.Total_Amount=if(input.Agreement_Commission > 0,input.Agreement_Commission,0);
												bill.Amount_Display=if(bill.Total_Amount > 0,thisapp.Currency.currencyDisplayFormat(bill.Total_Amount),"");
											}
											else if(input.Renew_Base_Agreement == null)
											{
												add_advance_amount = insert into Add_Payment_Notes
												[
													Tenant_Agreement=input.ID
													Unit=input.Unit
													Property=input.Property
													Parking_No=input.Parking_No
													Pay_For="Security Deposit"
													Due_Date=zoho.currentdate
													Payer=input.Tenant
													Added_User=zoho.loginuser
													Status="Unpaid"
													Due_Date=input.Start_Date
													Total_Amount=input.Security_Deposit
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Security_Deposit)
													Payment_Type="Income"
												];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payforSecurity.ID
													Add_Property=input.Property
													Add_Unit=input.Unit
													Add_Parking=input.Parking_No
													Amount=input.Security_Deposit
													Amount_Display=input.Security_Deposit_Display
													Description="Security Deposit"
													Add_Payment_Notes=add_advance_amount
												];
												bill = Add_Payment_Notes[ID == add_advance_amount];
												bill.Billing__ID=id.Bill_No + bill.Bill_No;
												bill.Total_Amount=input.Security_Deposit + if(input.Agreement_Commission > 0,input.Agreement_Commission,0);
												bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
											}
											if(input.Agreement_Commission > 0)
											{
												payfor_commission = Pay_For_Monthly[Pay_For == "Commission"];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payfor_commission.ID
													Add_Property=input.Property
													Add_Unit=input.Unit
													Add_Parking=input.Parking_No
													Amount=input.Agreement_Commission
													Amount_Display=input.Agreement_Commission_Display
													Description="Commission"
													Add_Payment_Notes=add_advance_amount
												];
											}
											if(add_advance_amount != null)
											{
												thisapp.mail.SendToTenantSecurityDepositPayment(add_advance_amount);
											}
											for each  payment_note in Add_Payment_Notes[ID != add_advance_amount && Unit == getUnit.ID && Tenant_Agreement != input.ID && Pay_For == "Security Deposit" && Status == "Unpaid"]
											{
												payment_note.Status="Cancel";
											}
										}
										//thisapp.mail.SendToOwnerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
										thisapp.mail.SendToTenantAgreementApproved(input.ID);
										openUrl("#Page:Rental?tab=currentoccupant","same window");
										// 	if(input.Unit.Manager != null)
										// 	{
										// 		thisapp.mail.SendToManagerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
										// 	}
						)
					}
				}

			}
			SuccessFul_Submit as "SuccessFul Submit"
			{
				type =  form
				form = Vacate_Request
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.Requested_By_Email = zoho.loginuserid;
										login_profile = thisapp.permissions.loginUserProfile();
										// if(login_profile == "Manager")
										// {
										// 	input.Vacate_Status = "Waiting for Owner Approval";
										// }
										// else if(login_profile == "Tenant")
										// {
										// 	input.Vacate_Status = "Requested";
										// }
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Vacate_Request=input.ID
											Action_field="Requested"
										];
										// if(login_profile == "Tenant")
										// {
										// 	thisapp.mail.SendToOwnerVacateRequest(input.ID);
										// 	thisapp.mail.SendToTenantVacateRequest(input.ID);
										// 	if(input.Unit.Manager != null)
										// 	{
										// 		thisapp.mail.SendToManagerVacateRequest(input.ID);
										// 	}
										// 	openUrl("#Page:Requests?tab=vacate-requests","same window");
										// }
										// else
										// {
										// 	openUrl("#Script:page.reload","same window");
										// }
										//---------------------Direct Vacate Request Flow by zcmpm------------------------------------
										//inspec = Inspection_Form[Vacate_Request = input.Vacate_Request.ID];
										//vacate = Vacate_Request[ID == input.Vacate_Request.ID];
										input.Vacate_Status = "Tenant Approved";
										//inspection = Inspection_Form[ID == inspec.ID];
										//inspection.Status="Tenant Agree";
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Vacate_Request=input.ID
											Action_field="Tenant Approved"
										];
										thisapp.mail.SentToTenantVacateRequestApprovedByOwner(input.ID);
										id = ID_Setup[ID != 0];
										agreement = Tenant_Agreement[Unit == input.Unit && Agreement_Status == "Active"];
										input.Balance_Amount = input.Tenant_Agreement.Security_Deposit;
										if(input.Pending_Amount > 0 && input.Pending_Amount <= input.Balance_Amount)
										{
											input.Balance_Amount = input.Balance_Amount - input.Pending_Amount;
											advance = insert into Add_Payment_Notes
											[
												Total_Amount=input.Balance_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Balance_Amount)
												Unit=input.Unit
												Parking_No=input.Parking_No
												Property=input.Property
												Added_User=zoho.loginuser
												Payment_Type="Expense"
												Payment_Date=zoho.currentdate
												Vacate_Request=input.ID
												Status="Unpaid"
												Pay_For="Vacate"
												Payer=input.Unit.Owner_Mail_ID
												Tenant_Agreement=agreement.ID
											];
										}
										else if(input.Pending_Amount == 0)
										{
											advance = insert into Add_Payment_Notes
											[
												Total_Amount=input.Balance_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Balance_Amount)
												Unit=input.Unit
												Property=input.Property
												Parking_No=input.Parking_No
												Added_User=zoho.loginuser
												Payment_Type="Expense"
												Payment_Date=zoho.currentdate
												Vacate_Request=input.ID
												Status="Unpaid"
												Pay_For="Vacate"
												Payer=input.Unit.Owner_Mail_ID
												Tenant_Agreement=agreement.ID
											];
										}
										bill = Add_Payment_Notes[ID == advance];
										bill.Billing__ID=id.Bill_No + bill.Bill_No;
										payfor = Pay_For_Monthly[Pay_For == "Vacate"];
										payment_details = insert into Payment_Details
										[
											Added_User=zoho.loginuser
											Pay_For=payfor.ID
											Add_Property=input.Property
											Add_Unit=input.Unit
											Add_Parking=input.Parking_No
											Amount=input.Balance_Amount
											Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Balance_Amount)
											Description="Vacate on Security Deposit"
											Add_Payment_Notes=advance
										];
										openUrl("#Script:page.reload","same window");
						)
					}
				}

			}
			Approve_Button as "Approve Button"
			{
				type =  form
				form = Vacate_Request_Review
				button = Approve
				on click
				{
					actions 
					{
					on click
					(
						login_profile = thisapp.permissions.loginUserProfile();
										getVacateRequest = Vacate_Request[ID == input.Vacate_Request];
										getVacateRequest.Vacate_Status="Waiting for Owner Approval";
										for each  getOtherAgreement in Tenant_Agreement[Unit == getVacateRequest.Unit && ID != input.Tenant_Agreement]
										{
											getOtherAgreement.Status="Rejected By " + login_profile;
										}
										openUrl("#Script:page.reload","same window");
					)
					}
				}
			}
			Reject_Button as "Reject Button"
			{
				type =  form
				form = Vacate_Request_Review
				button = Reject
				on click
				{
					actions 
					{
					on click
					(
						login_profile = thisapp.permissions.loginUserProfile();
										getVacateRequest = Vacate_Request[ID == input.Vacate_Request];
										if(login_profile == "Manager")
										{
											getVacateRequest.Vacate_Status="Rejected By Manager";
										}
										else if(login_profile == "Tenant")
										{
											getVacateRequest.Vacate_Status="Rejected By Tenant";
										}
										openUrl("#Script:page.reload","same window");
					)
					}
				}
			}
