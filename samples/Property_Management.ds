		list Lease_Vacate_Request_Admin
		{
			displayName = "Lease Vacate Request Admin"
			show all rows from Vacate_Request  [Tenant_Agreement.Agreement_Type == "Lease"]  
			(
				Vacate_Request_ID as "Vacate Request ID"
				Property
				Unit
				Tenant
				Unit_Owner as "Unit Owner"
				Vacate_Date as "Vacate Date"
				Tenant_Agreement as "Tenant Agreement"
				Vacate_Status as "Vacate Status"
				Requested_By_Email as "Requested By Email"
				Tenant_Agreement.Base_Lease_Display as "Base Lease"
				Tenant_Agreement.Start_Date as "Start Date"
				Tenant_Agreement.End_Date as "End Date"
				Property.ID
				ID
				Tenant_Agreement.Agreement_No as "Agreement No"
			)
			custom actions
			(
				"Reject"
				(
	  			workflow = Reject_Lease_Vacate_Reque
				show action in edit record menu = true
				condition = (Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval")
				)
				"Detail View"
				(
	  			workflow = Detail_View_Lease_Vacate_
				show action in edit record menu = true
				)
				"Inspection"
				(
	  			workflow = Inspection_Lease_Vacate_R
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
				"Edit 1"
				(
	  			workflow = Edit_Lease_Vacate_Request2
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
				"Approve"
				(
	  			workflow = Approve_Lease_Vacate_Requ
				show action in edit record menu = true
				condition = (Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Waiting for Manager Approval")
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Vacate_Status == "Requested" || Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Waiting for Tenant Approval")
				fields = [Vacate_Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Vacate_Status == "Owner Approved" || Vacate_Status == "Tenant Approved")
				fields = [Vacate_Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Vacate_Status == "Rejected By Owner" || Vacate_Status == "Admin Rejected")
				fields = [Vacate_Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Vacate_Status == "Tenant Vacated")
				fields = [Vacate_Status]
				format = "color:#5051f9;"
				}
			)
		}
