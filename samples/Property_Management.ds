    			displayformat = [Name.first_name + " - " + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Manager
			(
				type = picklist	
				values  = New_User[Role == "Manager" || Role_Admin == "Manager"].ID
    			bidirectional = Manager_Units
    			displayformat = [Name.first_name + " - " + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Occupancy_Type
			(
				type = radiobuttons
				displayname = "Occupancy Type"
				maxchar = 100
				values = {"Owned","Sale","Rent","Lease"}
