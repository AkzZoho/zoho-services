			OnLoad as "OnLoad"
			{
				type =  form
				form = New_User
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(!input.Role.isEmpty())
										{
											hide Role;
										}
										getUserConfig = User_Configuration[ID != 0];
										if(getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner" && New_User.count() == 1 && input.Role.isEmpty() && thisapp.Get_Logged_In_Profile() != "Administrator" && login_profile != "Admin")
										{
											clear Role;
											input.Role:ui.append("Manager");
											input.Role = "Manager";
											disable Role;
										}
										else if(getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager" && New_User.count() == 1 && input.Role.isEmpty() && thisapp.Get_Logged_In_Profile() != "Administrator" && login_profile != "Admin")
										{
											clear Role;
											input.Role:ui.append("Owner");
											input.Role = "Owner";
											disable Role;
										}
										getUser = New_User[ID != 0];
										lst = List();
										if(getUser.count() > 1 && getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager" && input.Role.isEmpty() && thisapp.Get_Logged_In_Profile() != "Administrator" && login_profile != "Admin")
										{
											clear Role;
											lst.add("Owner");
											lst.add("Tenant");
											input.Role:ui.append(lst);
											enable Role;
										}
										else if(getUser.count() > 1 && getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner" && input.Role.isEmpty() && thisapp.Get_Logged_In_Profile() != "Administrator" && login_profile != "Admin")
										{
											clear Role;
											lst.add("Manager");
											lst.add("Tenant");
											enable Role;
											input.Role:ui.append(lst);
										}
										if(thisapp.Get_Logged_In_Profile() == "Administrator" || login_profile == "Developer" && input.Role.isEmpty() && New_User.count() < 1)
										{
											clear Role;
											input.Role:ui.append("Admin");
										}
										else if(getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager" && New_User.count() == 1 && input.Role.isEmpty() && thisapp.Get_Logged_In_Profile() == "Administrator" || login_profile == "Admin" || login_profile == "Developer")
										{
											clear Role;
											input.Role:ui.append("Owner");
											input.Role = "Owner";
											disable Role;
										}
										else if(thisapp.Get_Logged_In_Profile() == "Administrator" || login_profile == "Admin" || login_profile == "Developer" && input.Role.isEmpty() && New_User.count() >= 1)
										{
											clear Role;
											lst.add("Manager");
											if(getUserConfig.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager")
											{
												lst.add("Owner");
											}
											lst.add("Tenant");
											if(login_profile != "Admin")
											{
												lst.add("Admin");
											}
											enable Role;
											input.Role:ui.append(lst);
										}
										login_profile = thisapp.permissions.loginUserProfile();
										if(input.Role == "Tenant" && input.Tenant_First_Agreement == false)
										{
											show Unit;
											show Property;
											if(login_profile == "Owner")
											{
												property = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
											else if(login_profile == "Manager")
											{
												property = Add_Unit[Manager.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
											else if(login_profile in {"Admin","Administrator","Developer"})
											{
												property = Add_Unit[Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
										}
						)
					}
				}

			}
