		{
			displayName = "Work Orders Owner"
			show all rows from Raise_a_Complaint  [Owner_Email.Email == zoho.loginuserid && Complaint_Status == "Vendor Assigned" || Complaint_Status == "In Progress"]  
			(
				Date_of_Reporting as "Date of Reporting"
				Property
				Location
				Unit
				Maintenance_Service as "Maintenance Service"
				Complaint_About as "Complaint About"
				Photo
