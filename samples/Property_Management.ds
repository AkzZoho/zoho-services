			onClick as "onClick"
			{
				type =  form
				form = Pickup_Popup
				button = Pick
				on click
				{
					actions 
					{
					on click
					(
						complaint = Raise_a_Complaint[ID == input.Raise_a_Complaint];
										complaint.Complaint_Status="In Progress";
										complaint.Start_Time=zoho.currenttime;
										openUrl("#Page:Vendor_Profile?tab=inprogress","same window");
					)
					}
				}
			}
