			Amount_Display as "Amount Display"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Base_Rent != null)
										{
											input.Base_Rent_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Rent);
										}
										if(input.Base_Lease != null)
										{
											input.Base_Lease_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Lease);
										}
										if(input.Monthly_Payable != null)
										{
											input.Net_Payable_Display = thisapp.Currency.currencyDisplayFormat(input.Monthly_Payable);
										}
										if(input.Security_Deposit != null)
										{
											input.Security_Deposit_Display = thisapp.Currency.currencyDisplayFormat(input.Security_Deposit);
										}
										if(input.Agreement_Commission != null)
										{
											input.Agreement_Commission_Display = thisapp.Currency.currencyDisplayFormat(input.Agreement_Commission);
										}
										for each  additionalpayment in Agreement_Additional_Payment[Tenant_Agreement == input.ID]
										{
											additionalpayment.Amount_Display=thisapp.Currency.currencyDisplayFormat(additionalpayment.Amount);
										}
										for each  item in input.Unit_Appliancias
										{
											Unit_item = insert into Unit_Items
											[
												Added_User=zoho.loginuser
												Add_Unit=input.Unit
												Item=item.Items
												Condition_field=item.Condition_field
												Description=item.Description
											];
										}
						)
					}
				}

			}
			Amount_Display1 as "Amount Display"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Base_Rental_Monthly_Amount != null)
										{
											input.Base_Rental_Monthly_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Rental_Monthly_Amount);
										}
										if(input.Fixed_Penalty_Amount != null)
										{
											input.Fixed_Penalty_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Fixed_Penalty_Amount);
										}
										if(input.Base_Rental_Monthly_Amount != null)
										{
											input.Base_Rental_Monthly_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Rental_Monthly_Amount);
										}
										if(input.Base_Lease_Amount != null)
										{
											input.Base_Lease_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Lease_Amount);
										}
										if(input.Security_Deposit != null)
										{
											input.Security_Deposit_Display = thisapp.Currency.currencyDisplayFormat(input.Security_Deposit);
										}
										for each  additionalpayment in Configure_Additional_Payment[Configure == input.ID]
										{
											additionalpayment.Amount_Display=thisapp.Currency.currencyDisplayFormat(additionalpayment.Amount);
										}
										if(input.Agreement > 0)
										{
											input.Agreement_Display = thisapp.Currency.currencyDisplayFormat(input.Agreement);
										}
										delete from Configure_Additional_Payment[Configure == input.ID && ID != input.Additional_Payment_Monthly.ID.getall()];
										delete from Configure_Additional_Payment[Configure == null];
						)
					}
				}

			}
			Hide_fields8 as "Hide fields"
			{
				type =  form
				form = Inspection_Form
				record event = on add or edit
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Hide;
										hide Balance_Amount;
										hide Property;
										hide Unit;
										hide Advance_Amount;
										hide Lease_Amount;
										agreement = Tenant_Agreement[ID == input.Tenant_Agreement];
										if(agreement.Agreement_Type == "Rent")
										{
											hide Vacate_Request;
											hide Tenant_Agreement;
											hide Complaints.Cost_Display;
											hide Lease_Amount;
											input.Advance_Amount = agreement.Security_Deposit;
											disable Advance_Amount;
											disable Complaints_Amount;
										}
										else if(agreement.Agreement_Type == "Lease")
										{
											hide Vacate_Request;
											hide Tenant_Agreement;
											hide Complaints.Cost_Display;
											disable Property;
											disable Unit;
											hide Advance_Amount;
											input.Lease_Amount = agreement.Base_Lease;
											disable Lease_Amount;
											disable Complaints_Amount;
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										pending_payment = Add_Payment_Notes[Status == "Unpaid" && Unit == input.Vacate_Request.Unit && Pay_For == "Monthly Payment" || Pay_For == "Complaint"];
										input.Pending_Amount = pending_payment.sum(Total_Amount);
										input.Pending_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Pending_Amount);
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-prop-notes-field { width: 500px; }</style><div class='zc-prop-notes-field'> <div class='zc-prop-keyvalue-view zc-prop-with-bg'> <table class='zc-prop-table'> <tbody> <tr> <td>Property</td> <td class='zc-prop-blue'>" + input.Property.Property_Name + " </td> </tr> <tr> <td>Unit</td> <td class='zc-prop-green'>" + input.Unit.Unit_Name + "</td> </tr> <tr> <td>" + language_alert.get("zcpm.security.deposit") + "</td><td class='zc-prop-yellow'>" + input.Tenant_Agreement.Security_Deposit_Display + "</td> </tr>";
										if(input.Pending_Amount > 0)
										{
											input.plain = input.plain + "<tr> <td>" + language_alert.get("zcpm.pending.amount") + "</td><td>" + input.Pending_Amount_Display + "</td> </tr>";
										}
										input.plain = input.plain + " </tbody> </table> </div> </div>";
						)
					}
				}

			}
			Status_Update as "Status Update"
			{
				type =  form
				form = Inspection_Form
				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											vacate = Vacate_Request[ID == input.Vacate_Request];
										login_profile = thisapp.permissions.loginUserProfile();
										config = User_Configuration[ID != 0];
										if(Unit.Occupancy_Type == "Rent" && input.Complaints_Amount > 0)
										{
											input.Balance_Amount = input.Tenant_Agreement.Security_Deposit - input.Complaints_Amount;
										}
										else if(input.Complaints_Amount > 0)
										{
											input.Balance_Amount = input.Tenant_Agreement.Base_Lease - input.Complaints_Amount;
										}
										else
										{
											input.Balance_Amount = input.Tenant_Agreement.Security_Deposit;
										}
										if(input.Pending_Amount > 0)
										{
											input.Balance_Amount = input.Balance_Amount - input.Pending_Amount;
										}
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Vacate_Request=vacate.ID
											Action_field="Inspection Done"
										];
										if(login_profile == "Owner")
										{
											vacate.Vacate_Status="Waiting for Tenant Approval";
											input.Status = "Owner Approved";
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Vacate_Request=vacate.ID
												Action_field="Owner Approved"
											];
										}
										else if(login_profile == "Administrator" || login_profile == "Admin" || login_profile == "Developer" && input.Page_Link_Name == "Approval")
										{
											unit = Add_Unit[ID == input.Unit];
											id = ID_Setup[ID != 0];
											unit.Current_Tenant=null;
											unit.Availability="Vacant";
											agreement = Tenant_Agreement[Unit == input.Unit && Agreement_Status == "Active"];
											input.Status = "Tenant Agree";
											agreement.Status="Vacated";
											agreement.Agreement_Status="Inactive";
											vacate = Vacate_Request[ID == input.Vacate_Request];
											vacate.Vacate_Status="Tenant Approved";
											advance = insert into Add_Payment_Notes
											[
												Total_Amount=input.Balance_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Balance_Amount)
												Unit=input.Unit
												Property=input.Property
												Added_User=zoho.loginuser
												Payment_Type="Expense"
												Payment_Date=zoho.currentdate
												Vacate_Request=input.Vacate_Request
												Status="Unpaid"
												Pay_For="Vacate"
												Payer=input.Unit.Owner_Mail_ID
												Tenant_Agreement=agreement.ID
											];
											payfor = Pay_For_Monthly[Pay_For == "Vacate"];
											payment_details = insert into Payment_Details
											[
												Added_User=zoho.loginuser
												Pay_For=payfor.ID
												Add_Property=input.Property
												Add_Unit=input.Unit
												Amount=input.Balance_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Balance_Amount)
												Description="Vacate on Security Deposit"
												Add_Payment_Notes=advance
											];
											if(input.Complaints_Amount != null && input.Complaints_Amount > 0)
											{
												pay1 = insert into Add_Payment_Notes
												[
													Total_Amount=input.Complaints_Amount
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaints_Amount)
													Unit=input.Unit
													Property=input.Property
													Added_User=zoho.loginuser
													Payment_Type="Income"
													Payment_Date=zoho.currentdate
													Vacate_Request=input.Vacate_Request
													Status="Paid"
													Pay_For="Vacate Complaints"
													Payer=input.Tenant_Agreement.Tenant
													Total_Amount=input.Complaints_Amount
												];
												bill = Add_Payment_Notes[ID == pay1];
												bill.Billing__ID=id.Bill_No + bill.Bill_No;
												payfor = Pay_For_Monthly[Pay_For == "Vacate"];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payfor.ID
													Add_Property=input.Property
													Add_Unit=input.Unit
													Amount=input.Balance_Amount
													Amount_Display=input.Balance_Amount_Display
													Description="Vacate Complaints"
													Add_Payment_Notes=pay1
												];
											}
											for each  vac in Vacate_Request[Unit == input.Unit && Tenant_Agreement.Agreement_Status == "Active" && ID != vacate.ID]
											{
												vac.Vacate_Status="Tenant Approved";
											}
										}
										else if(login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" && config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager")
										{
											vacate.Vacate_Status="Waiting for Owner Approval";
											input.Status = "Inspection Complete";
										}
										else if(login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer" && config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner")
										{
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Vacate_Request=vacate.ID
												Action_field="Owner Approved"
											];
											vacate.Vacate_Status="Waiting for Tenant Approval";
											input.Status = "Inspection Complete";
										}
										else if(login_profile == "Manager")
										{
											vacate.Vacate_Status="Waiting for Owner Approval";
											input.Status = "Inspection Complete";
										}
										if(input.Complaints_Amount != null)
										{
											input.Complaints_Amount = if(input.Complaints_Amount > 0,input.Complaints_Amount,0);
											input.Complaints_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Complaints_Amount);
										}
										if(input.Balance_Amount != null)
										{
											input.Balance_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Balance_Amount);
										}
										if(input.Complaints.count() > 0 && input.Complaints.sum(Cost) > 0)
										{
											thisapp.mail.SendToOwnerInspectionReportWithComplaints(input.ID);
										}
										else
										{
											thisapp.mail.SendToOwnerInspectionReportWithOutComplaints(input.ID);
										}
						)
					}
				}

			}
			Validate_Next_Payment_Dat as "Validate Next Payment Date"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of End_Date
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.End_Date < input.Next_Pay_Date)
										{
											input.Next_Pay_Date = null;
											alert language_alert.get("zcpm.next.pay.date");
										}
										if(input.Start_Date > input.End_Date)
										{
											input.Start_Date = null;
											alert language_alert.get("zcpm.before.end.date");
										}
						)
					}
				}

			}
