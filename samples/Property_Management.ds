			Property_User_input as "Property User input"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											if(input.Property != null)
										{
											for each  reec in input.Other_Occupants_Details
											{
												reec.Property=input.Property;
											}
										}
										if(input.Unit == null && input.Tenant == null && input.Property != null && input.Renew_Base_Agreement == null)
										{
											clear Unit;
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant" && Unit_Status == "Active" && Owner_Approval_Status == "Approved"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
						)
					}
				}

			}
			User_input_of_Property as "User input of Property"
			{
				type =  form
				form = Raise_a_Complaint
				record event = on add or edit

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										unit = Add_Unit[Current_Tenant.Email == zoho.loginuserid];
										if(login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer")
										{
											if(input.Property != null)
											{
												getAllUnit = Add_Unit[Property == input.Property && Owner_Approval_Status == "Approved"];
												input.Unit:ui.add(getAllUnit.ID.getall());
											}
										}
										else if(login_profile == "Owner")
										{
											if(input.Property != null)
											{
												getAllUnit = Add_Unit[Property == input.Property && Owner_Mail_ID.Email == zoho.loginuserid && Owner_Approval_Status == "Approved"];
												input.Unit:ui.add(getAllUnit.ID.getall());
											}
										}
										else if(login_profile == "Manager")
										{
											if(input.Property != null)
											{
												getAllproperty = Add_Property[ID == input.Property && Units.Owner_Approval_Status == "Approved" && Manager.Email == zoho.loginuserid || Units.Manager == thisapp.get_user_id()];
												input.Unit:ui.add(getAllproperty.Units.ID.getall());
											}
										}
										else if(login_profile == "Tenant" && input.Property != null && unit.count() > 1)
										{
											getUnit = Add_Unit[Current_Tenant.Email == zoho.loginuserid && Property == input.Property && Owner_Approval_Status == "Approved"];
											input.Unit:ui.add(getUnit.ID.getall());
										}
						)
					}
				}

			}
			User_input_of_Unit as "User input of Unit"
			{
				type =  form
				form = Raise_a_Complaint
				record event = on add or edit

				on user input of Unit
				{
					actions 
					{
						custom deluge script
						(
											if(input.Property != null && input.Unit != null)
										{
											input.Location = input.Unit.Property.Location;
											input.Manager = input.Unit.Manager;
											getUnit = Add_Unit[Property == input.Property && ID == input.Unit];
											input.Tenant_Email = getUnit.Current_Tenant;
											input.Owner_Email = getUnit.Owner_Mail_ID;
											disable Tenant_Email;
											disable Location;
										}
										else
										{
											input.Tenant_Email = null;
											enable Tenant_Email;
										}
						)
					}
				}

			}
