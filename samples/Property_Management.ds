			Validate_Next_pay_date as "Validate Next pay date"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Next_Pay_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.Next_Pay_Date != null && input.Next_Pay_Date <= zoho.currentdate)
										{
											input.Next_Pay_Date = null;
											alert "Kindly enter the valid Next Pay Date";
										}
