				"Detail View Completed_Complaints"
				(
	  			workflow = Detail_View_Completed_Com2
				show action in edit record menu = true
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Complaint_Status == "Requested" || Complaint_Status == "Waiting for Payment")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Vendor Assigned"
				{
				condition = (Complaint_Status == "Vendor Assigned")
				fields = [Complaint_Status]
				format = "color:#5051f9;"
