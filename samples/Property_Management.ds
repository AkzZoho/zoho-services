					}
				}

			}
			OnLoad1 as "OnLoad"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Manager")
										{
											unit = Add_Unit[Availability == "Vacant" && Owner_Approval_Status == "Approved" && Manager == thisapp.get_user_id() && Occupancy_Type == input.Agreement_Type];
											input.Property:ui.add((unit.Property.ID.getall()).distinct());
										}
										else if(login_profile == "Owner")
										{
											unit = Add_Unit[Availability == "Vacant" && Owner_Approval_Status == "Approved" && Owner_Mail_ID.Email == zoho.loginuserid && Occupancy_Type == input.Agreement_Type];
											input.Property:ui.add((unit.Property.ID.getall()).distinct());
										}
										else if(login_profile in {"Admin","Administrator","Developer"})
										{
											unit = Add_Unit[Availability == "Vacant" && Owner_Approval_Status == "Approved" && Occupancy_Type == input.Agreement_Type];
											input.Property:ui.add((unit.Property.ID.getall()).distinct());
										}
										if(!Agreement_Type.isEmpty())
										{
											disable Agreement_Type;
											if(input.Agreement_Type == "Rent")
											{
												// 	null the Lease based values
												input.Base_Lease = null;
												input.Start_Date = null;
												input.End_Date = null;
												hide Base_Lease;
												show Base_Rent;
												show Security_Deposit;
											}
											else if(input.Agreement_Type == "Lease")
											{
												// 	null the rent based values
												input.Base_Rent = null;
												show Base_Lease;
												hide Base_Rent;
											}
										}
										if(input.Tenant != null)
										{
											if(input.Agreement_Type == "Rent" && input.Tenant.Unit.Occupancy_Type == "Rent")
											{
												input.Property = input.Tenant.Unit.Property;
												input.Unit = input.Tenant.Unit;
												disable Tenant;
												disable Property;
												disable Unit;
											}
											else if(input.Agreement_Type == "Lease" && input.Tenant.Unit.Occupancy_Type == "Lease")
											{
												input.Property = input.Tenant.Unit.Property;
												input.Unit = input.Tenant.Unit;
												disable Tenant;
												disable Property;
												disable Unit;
											}
										}
										if(input.Unit != null)
										{
											input.Unit = input.Unit;
											input.Unit_Type = input.Unit.Unit_Type;
											if(input.Agreement_Type == "Rent" && input.Unit.Occupancy_Type == "Rent")
											{
												input.Property = input.Unit.Property;
												disable Property;
												disable Unit;
											}
											else if(input.Agreement_Type == "Lease" && input.Unit.Occupancy_Type == "Lease")
											{
												input.Property = input.Unit.Property;
												disable Property;
												disable Unit;
											}
										}
										if(input.Unit == null)
										{
											unit = Add_Unit[Property == input.Property && Availability == "Vacant" && Unit_Status == "Active"];
											input.Unit:ui.add(unit.ID.getall());
										}
										if(input.Renew_Base_Agreement != null)
										{
											// 	show plain ;
											input.Property = input.Renew_Base_Agreement.Property;
											input.Unit = input.Renew_Base_Agreement.Unit;
											input.Unit_Type = input.Renew_Base_Agreement.Unit_Type;
											input.Tenant = input.Renew_Base_Agreement.Tenant;
											input.Agreement_Type = input.Renew_Base_Agreement.Agreement_Type;
											input.Security_Deposit = input.Renew_Base_Agreement.Security_Deposit;
											// 	input.plain = thisapp.Styles_Popup.NotesField() +"<div class='zc-prop-notes-field'> <div class='zc-prop-keyvalue-view zc-prop-with-bg'> <table class='zc-prop-table'> <tbody> <tr><td>Old Security Deposit </td> <td>"+ input.Security_Deposit +" </td></tr></tbody> </table> </div> </div>";
											other_occupant_sub_form = Collection();
											for each  other_occupant in Other_Occupants_Details[Tenant_Agreement == input.Renew_Base_Agreement]
											{
												row1 = Tenant_Agreement.Other_Occupants_Details();
												row1.Name=other_occupant.Name;
												row1.Age=other_occupant.Age;
												row1.Mobile_Number=other_occupant.Mobile_Number;
												row1.Relationship=other_occupant.Relationship;
												row1.Date_of_Birth=other_occupant.Date_of_Birth;
												row1.Gender=other_occupant.Gender;
												row1.Main_Tenant=other_occupant.Main_Tenant;
												row1.Property=other_occupant.Property;
												row1.Email=other_occupant.Email;
												other_occupant_sub_form.insert(row1);
											}
											disable Property;
											disable Unit;
											disable Tenant;
											disable Agreement_Type;
											input.Other_Occupants_Details.insert(other_occupant_sub_form);
											unit_configure = Configure[Unit == input.Unit];
											main_configure = Configure[Configure1 == "Default"];
											if(input.Agreement_Type == "Rent" && unit_configure.count() == 1)
											{
												input.Base_Rent = unit_configure.Base_Rental_Monthly_Amount;
												input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount);
											}
											else if(input.Agreement_Type == "Rent" && main_configure.count() == 1)
											{
												input.Base_Rent = main_configure.Base_Lease_Amount;
												input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount);
											}
											if(input.Agreement_Type == "Lease" && unit_configure.count() == 1)
											{
												Base_lease = unit_configure.Base_Lease_Amount;
												input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount);
											}
											else if(input.Agreement_Type == "Lease" && main_configure.count() == 1)
											{
												input.Base_Lease = main_configure.Base_Lease_Amount;
												input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount);
											}
											addition_collection = Collection();
											input.Additional_Payment_Monthly.clear();
											if(main_configure.count() > 0 && unit_configure.count() == 0)
											{
												for each  main_configure_subform in main_configure.Additional_Payment_Monthly
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													addition_row.Pay_For=main_configure_subform.Pay_For;
													addition_row.Amount=main_configure_subform.Amount;
													addition_row.Amount_Display=main_configure_subform.Amount_Display;
													addition_row.Description=main_configure_subform.Description;
													addition_collection.insert(addition_row);
												}
												if(input.Agreement_Type == "Rent" && main_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && main_configure.Category.contains("Rental Monthly"))
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													payfor = Pay_For_Monthly[Pay_For == "Commission"];
													addition_row.Pay_For=payfor.ID;
													addition_row.Amount=input.Base_Rent * main_configure.Rental_Monthly / 100;
													addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
													addition_row.Description="Commission";
													addition_collection.insert(addition_row);
												}
												input.Additional_Payment_Monthly.insert(addition_collection);
												input.Agreement_Commission = main_configure.Agreement;
												input.Agreement_Commission_Display = main_configure.Agreement_Display;
											}
											else if(unit_configure.count() > 0)
											{
												for each  unit_configure_subform in unit_configure.Additional_Payment_Monthly
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													addition_row.Pay_For=unit_configure_subform.Pay_For;
													addition_row.Amount=unit_configure_subform.Amount;
													addition_row.Amount_Display=unit_configure_subform.Amount_Display;
													addition_row.Description=unit_configure_subform.Description;
													addition_collection.insert(addition_row);
												}
												if(input.Agreement_Type == "Rent" && unit_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && unit_configure.Category.contains("Rental Monthly"))
												{
													addition_row = Tenant_Agreement.Additional_Payment_Monthly();
													payfor = Pay_For_Monthly[Pay_For == "Commission"];
													addition_row.Pay_For=payfor.ID;
													addition_row.Amount=input.Base_Rent * unit_configure.Rental_Monthly / 100;
													addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
													addition_row.Description="Commission";
													addition_collection.insert(addition_row);
												}
												input.Additional_Payment_Monthly.insert(addition_collection);
												input.Agreement_Commission = unit_configure.Agreement;
												input.Agreement_Commission_Display = unit_configure.Agreement_Display;
											}
											unit_items = Collection();
											items = Add_Unit[ID == input.Unit];
											input.Unit_Appliancias.clear();
											for each  unit_items_subform in items.Unit_Items
											{
												addition_row1 = Tenant_Agreement.Unit_Appliancias();
												addition_row1.Items=unit_items_subform.Item;
												addition_row1.Condition_field=unit_items_subform.Condition_field;
												addition_row1.Description=unit_items_subform.Description;
												unit_items.insert(addition_row1);
											}
											input.Unit_Appliancias.insert(unit_items);
											input.Monthly_Payable = input.Monthly_Payable + input.Additional_Payment_Monthly.sum(Amount);
										}
						)
					}
				}

			}
			On_Load1 as "On Load"
			{
				type =  form
				form = Renew_Agreement_Request
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Tenant" && input.Action_field == "Request_Page")
										{
											show Property;
											show Unit;
											property = Add_Unit[Current_Tenant == thisapp.get_user_id()].Property.ID.getAll();
											input.Property:ui.add(property);
										}
										if(login_profile == "Tenant" && input.Base_Agreement != null)
										{
											input.Unit = input.Base_Agreement.Unit;
											input.Property = input.Base_Agreement.Property;
											disable Unit;
											hide plain;
										}
										else if(login_profile == "Tenant" && input.Unit == null)
										{
											unit = Add_Unit[Availability == "Occupied" && Unit_Status == "Active" && Current_Tenant.Email == zoho.loginuserid].ID.getAll();
											input.Unit:ui.add(unit);
											if(unit.size() == 1)
											{
												input.Unit = unit.get(0);
												disable Unit;
											}
											hide plain;
										}
										if(input.Unit != null)
										{
											agreement = Tenant_Agreement[Unit == input.Unit && Status == "Tenant Approved"];
											input.Base_Agreement = agreement.ID;
										}
										language = thisapp.Localization.Pages();
										unit = if(input.Unit == null,"-",input.Unit.Unit_Name);
										agreement_no = if(input.Base_Agreement == null,"-",input.Base_Agreement.Agreement_No);
										tenant = if(input.Base_Agreement == null,"-",input.Base_Agreement.Tenant.Name);
										start = if(input.Base_Agreement == null,"-",input.Base_Agreement.Start_Date);
										end = if(input.Base_Agreement == null,"-",input.Base_Agreement.End_Date);
										property = if(input.Property == null,"-",input.Property.Property_Name);
										parking = if(input.Parking_No == null,"-",input.Base_Agreement.Parking_No.Unit_Name);
										if(login_profile != "Tenant" || input.Action_field == "my_unit")
										{
											show plain;
											// <tr> <td>" + language.get("zcpm.rental.end_date") + " </td> <td> " + end + "</td> </tr>
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-form-fullheight .formContainer .column-block .formColumn { width: 100%; }</style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr>";
											if(parking != null)
											{
												input.plain = input.plain + "<tr><td>" + language.get("zcpm.property.parkingslot") + "</td><td class='zc-prop-green'>" + parking + "</td></tr>";
											}
											input.plain = input.plain + "<tr><td>" + language.get("zcpm.user.tenant") + "</td><td>" + tenant + "</td></tr><tr><td>" + language.get("zcpm.agreement.no") + "</td><td class='zc-prop-blue-green'>" + agreement_no + "</td></tr><tr><td>" + language.get("zcpm.renew.Agreement_Duration") + "</td><td class='zc-prop-yellow'>" + start + " " + language.get("zcpm.renew.to") + " " + end + "</td></tr></tbody></table></div></div>";
										}
										else if(input.Action_field != "Request_Page")
										{
											show plain1;
											input.plain1 = thisapp.Styles_Popup.Notes_Field() + "<div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr><tr><td>";
											if(parking != null)
											{
												input.plain1 = input.plain1 + "<tr><td>" + language.get("zcpm.property.parkingslot") + "</td><td class='zc-prop-green'>" + parking + "</td></tr>";
											}
											input.plain1 = input.plain1 + "<tr><td>" + language.get("zcpm.user.tenant") + "</td><td>" + tenant + "</td></tr><tr><td>" + language.get("zcpm.agreement.no") + "</td><td>" + agreement_no + "</td></tr><tr><td>" + language.get("zcpm.renew.Agreement_Duration") + "</td><td class='zc-prop-yellow'>" + start + " " + language.get("zcpm.renew.to") + " " + end + "</td></tr></tbody></table></div></div>";
										}
										hide Parking_No;
						)
					}
				}

			}
			Balance_Amount_Calculatio as "Balance Amount Calculation"
			{
				type =  form
				form = Inspection_Form
				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											agreement = Tenant_Agreement[ID == input.Tenant_Agreement];
										if(agreement.Agreement_Type == "Rent" && input.Complaints_Amount > 0)
										{
											input.Balance_Amount = input.Advance_Amount - input.Complaints_Amount;
										}
										else if(agreement.Agreement_Type == "Lease" && input.Complaints_Amount > 0)
										{
											input.Balance_Amount = input.Lease_Amount - input.Complaints_Amount;
										}
										if(input.Advance_Amount > 0)
										{
											input.Advance_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Advance_Amount);
										}
										input.Balance_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Balance_Amount);
						)
					}
				}

			}
			Hide_fields6 as "Hide fields"
			{
				type =  form
				form = Post
				record event = on add or edit
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Properties;
										if(input.Post_To.contains("Properties"))
										{
											show Properties;
										}
										disable Date_field;
										input.Post_By = thisapp.get_user_id();
										hide Hide;
										if(input.Users.size() == 0)
										{
											hide Users;
										}
										else
										{
											show Users;
										}
						)
					}
				}

			}
			Load_Action as "Load Action"
			{
				type =  form
				form = Property_Filter_Form
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.common();
										if(input.Page != "Properties")
										{
											input.plain = language.get("zcpm.dashboards.filiterby.text");
										}
										if(input.Search.isEmpty())
										{
											hide Decision_box;
										}
										else
										{
											show Decision_box;
										}
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile != "Admin" && login_profile != "Administrator")
										{
											property = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid || Manager.Email == zoho.loginuserid || Property.Manager == thisapp.get_user_id() || Current_Tenant.Email == zoho.loginuserid].Property.ID.getAll().distinct();
											clear Property;
											input.Property:ui.add(property);
										}
										clear Unit;
										language = thisapp.Localization.common();
										export_url = zoho.appuri + "csv/";
										import_url = "#Page:" + input.Page + "?action=import";
										if(input.Page == "Properties" || input.Page == "Tenants")
										{
											show Search;
											show Option_Notes;
											import_url = "#Page:" + input.Page + "?action=import&tab=" + input.tab;
											if(input.tab.isEmpty() || input.tab == "properties")
											{
												property_ids = if(input.Search.isEmpty(),"","?ID=" + Add_Property[Property_Name.contains(input.Search) || Property_Type.contains(input.Search) || Location.Location.contains(input.Search)].ID.getAll() + "&ID_op=18");
												export_url = export_url + "All_Properties" + property_ids;
											}
											if(input.tab == "units")
											{
												show Occupancy_Type;
												ids = Add_Unit[Unit_Name.contains(input.Search) || Property.Property_Name.contains(input.Search) || Availability.contains(input.Search)].ID.getAll();
												unit_ids = "?Unit_Type=Unit&Owner_Approval_Status=Requested&Owner_Approval_Status_op=19";
												unit_ids = unit_ids + if(input.Search.isEmpty(),"","&ID=" + encodeUrl("[" + ids + "]") + "&ID_op=72");
												unit_ids = unit_ids + if(input.Occupancy_Type.isEmpty(),"","&Occupancy_Type=" + input.Occupancy_Type + "&Occupancy_Type_op=18");
												export_url = export_url + "All_Units" + unit_ids;
											}
											if(input.tab == "Parking")
											{
												ids = Add_Unit[Unit_Name.contains(input.Search) || Property.Property_Name.contains(input.Search) || Availability.contains(input.Search)].ID.getAll();
												unit_ids = "?Unit_Type=Parking&Owner_Approval_Status=Requested&Owner_Approval_Status_op=19";
												unit_ids = unit_ids + if(input.Search.isEmpty(),"","&ID=" + encodeUrl("[" + ids + "]") + "&ID_op=72");
												unit_ids = unit_ids + if(input.Occupancy_Type.isEmpty(),"","&Occupancy_Type=" + input.Occupancy_Type + "&Occupancy_Type_op=18");
												export_url = export_url + "All_Units" + unit_ids;
											}
											if(input.Page == "Tenants" && input.tab == "current-tenants" || input.tab == "approved-tenants")
											{
												show User_Status;
											}
											if(input.Page == "Tenants" && input.tab != "current-tenants")
											{
												show Location;
											}
											if(input.Page == "Tenants")
											{
												tenants_ids = "?Role=Tenant&Role_op=18";
												if(input.tab.isEmpty() || input.tab == "new-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Waiting for Approval" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else if(input.tab == "screening-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&Tenant.ID=" + Tenant_Screening[Tenant.Role == "Tenants" && Tenant.Tenant_Status == "Screening In Process" && Tenant.Name.contains(input.Search) || Tenant.Email.contains(input.Search)].ID.getAll() + "&Tenant.ID_op=18");
												}
												else if(input.tab == "approved-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Approved" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else if(input.tab == "reject-tenants")
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Rejected" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
												}
												else
												{
													tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Approved" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
													tenants_ids = tenants_ids + if(input.User_Status.isEmpty(),"","&Status=" + input.User_Status + "&Status_op=18");
												}
												tenants_ids = tenants_ids + if(input.Location == null,"","&Location.ID" + input.Location.ID + "&Location.ID_op=18");
												export_url = export_url + input.Report + tenants_ids;
											}
										}
										else if(input.Page == "Rental" || input.Page == "Lease")
										{
											show Search;
											show Property;
											show Unit;
											show Option_Notes;
											export_url = export_url + input.Report;
											if(input.tab == "allagreement")
											{
												show Agreement_Status;
											}
										}
										else if(input.Page == "Maintenance")
										{
											show Search;
											show Property;
											show Unit;
											show Maintenance_Service;
										}
										else if(input.Page == "Accounting")
										{
											show Search;
											show Property;
											show Unit;
											show Payment_Status;
											show Option_Notes;
											if(input.tab == "all" && login_profile != "Tenant")
											{
												show Pay_For;
												show Payment_Type;
												hide Property;
												hide Unit;
											}
											if(input.tab == "commission")
											{
												peram = if(input.Property != null,"&Add_Property.ID=[" + input.Property.ID + "]&Add_Property.ID_op=18","");
												peram = peram + if(input.Unit != null,"&Add_Unit.ID=[" + input.Unit.ID + "]&Add_Unit.ID_op=18","");
												peram = peram + if(!input.Payment_Status.isEmpty(),"&Add_Payment_Notes.Status=" + input.Payment_Status + "&Add_Payment_Notes.Payment_Type_op=72","");
												peram = peram + if(!input.Search.isEmpty(),"&Add_Payment_Notes.Billing__ID=" + input.Search + "&Add_Payment_Notes.Billing__ID_op=26","");
											}
											else
											{
												peram = if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
												peram = peram + if(input.Unit != null,"&Unit.ID=" + input.Unit.ID + "&Unit.ID_op=18","");
												peram = peram + if(!input.Payment_Status.isEmpty(),"&Status=" + input.Payment_Status + "&Payment_Type_op=18","");
												search_result = Add_Payment_Notes[Billing__ID.containsIgnoreCase(input.Search)].ID.getAll();
												search_result = if(search_result.size() == 0,1234,search_result);
												peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											}
											export_url = export_url + input.Report + peram;
										}
										else if(input.Page == "Requests")
										{
											show Search;
											show Property;
											show Unit;
										}
										else if(input.Page == "Approval")
										{
											show Search;
											if(input.tab == "tenants")
											{
												hide Property;
												hide Unit;
												show Tenant_Status;
											}
											else
											{
												show Property;
												show Unit;
											}
										}
										else if(input.Page == "Complaints")
										{
											show Search;
											show Property;
											show Unit;
											show Option_Notes;
											if(input.tab == "finishedcomplaints")
											{
												show Complaint_Status;
											}
											peram = if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
											peram = peram + if(input.Unit != null,"&Unit.ID=" + input.Unit.ID + "&Unit.ID_op=18","");
											search_result = Raise_a_Complaint[Complaints_No.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
											export_url = export_url + input.Report + peram;
										}
										else if(input.Page == "Users")
										{
											show Search;
											show User_Status;
											show Option_Notes;
											role = "?Role=" + input.Role + "&Role_op=18";
											export_url = export_url + input.Report + role;
										}
										else if(input.Page == "Vendors")
										{
											show Search;
											show User_Status;
											show Option_Notes;
											language = thisapp.Localization.common();
											export_url = export_url + input.Report;
										}
										input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
										lis = {"Security Deposit","Monthly Payment","Vacate"};
										input.Pay_For:ui.add(lis);
						)
					}
				}

			}
			OnLoad2 as "OnLoad"
			{
				type =  form
				form = Agreement_Approval
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.common();
										hide Hide;
										language_alert = thisapp.Localization.Alert();
										tenant_screening = Tenant_Screening[Tenant == input.Tenant_Agreement.Tenant];
										other_occupant = Other_Occupants_Details[Tenant_Agreement == input.Tenant_Agreement];
										report_name = "Unit_Image";
										login_profile = thisapp.permissions.loginUserProfile();
										if((login_profile == "Admin" && input.Tenant_Agreement.Status == "Requested" || input.Tenant_Agreement.Status == "Owner Approved") || (login_profile == "Administrator" && input.Tenant_Agreement.Status == "Requested" || input.Tenant_Agreement.Status == "Owner Approved") || (input.Tenant_Agreement.Status == "Owner Approved" && input.Tenant_Agreement.Tenant == thisapp.get_user_id()) || (input.Unit.Owner_Mail_ID == thisapp.get_user_id() && input.Tenant_Agreement.Status == "Requested"))
										{
											if(login_profile == "Tenant")
											{
												input.Comments = input.Tenant_Agreement.Comments;
												disable Comments;
											}
											img_src = thisapp.CommonFeatures.processImageUrl(input.Unit.ID,input.Unit.Unit_Image,report_name,"Unit_Image",input.Unit.Unit_Name,true);
											input.plain = "<style>" + thisapp.Styles_Popup.Agreement_Approval() + "</style>";
											input.plain = input.plain + "<div class='zc-prop-notes-field'><div class='zc-prop-clearfix zc-prop-fw'><div class='zc-prop-flt-left zc-prop-img-wrapper-outer'><div class='zc-prop-img-wrapper'>" + img_src + "</div></div><div class='zc-prop-flt-left zc-prop-label-value-wrapper zc-prop-count-4'><ul class='zc-prop-clearfix zc-prop-fw'><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.property") + " </label><h6> " + input.Property.Property_Name + " </h6></li><li class='zc-prop-flt-left'><label>" + language.get("zcpm.common.unit") + "</label><h6> " + input.Unit.Unit_Name + " </h6></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.start.date") + " </label><h6> " + input.Tenant_Agreement.Start_Date + " </h6></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.end.date") + " </label><h6> " + input.Tenant_Agreement.End_Date + " </h6></li>";
											if(input.Tenant_Agreement.Agreement_Type == "Rent")
											{
												input.plain = input.plain + "<li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.base.rent") + " </label><h6> " + input.Tenant_Agreement.Base_Rent_Display + " </h6></li>";
											}
											else if(input.Tenant_Agreement.Agreement_Type == "Lease")
											{
												input.plain = input.plain + "<li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.base.lease") + " </label><h6> " + input.Tenant_Agreement.Base_Lease_Display + " </h6></li>";
											}
											if(input.Tenant_Agreement.Security_Deposit != null && input.Tenant_Agreement.Security_Deposit > 0 && input.Tenant_Agreement.Agreement_Type == "Rent")
											{
												input.plain = input.plain + "<li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.security.deposit") + "  </label><h6> " + input.Tenant_Agreement.Security_Deposit_Display + " </h6></li>";
											}
											if(input.Tenant_Agreement.Monthly_Payable != null && input.Tenant_Agreement.Monthly_Payable > 0)
											{
												input.plain = input.plain + "<li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.monthly.payable") + "  </label><h6> " + input.Tenant_Agreement.Monthly_Payable + " </h6></li>";
											}
											input.plain = input.plain + "</ul></div></div><div class='zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4'><ul><li class='zc-prop-flt-left zc-prop-subheader'><h5>" + language.get("zcpm.common.tenant.details") + "</h5></li><li class='zc-prop-flt-left'><label> Name </label><h6> " + input.Tenant_Agreement.Tenant.Name + " </h6></li><li class='zc-prop-flt-left'><label>" + language.get("zcpm.common.email") + "</label><h6> " + input.Tenant_Agreement.Tenant.Email + " </h6></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.phone.number") + " </label><h6> " + input.Tenant_Agreement.Tenant.Phone_Number + " </h6></li></ul><ul><li class='zc-prop-flt-left zc-prop-subheader'><h5> " + language.get("zcpm.common.previous.occupant") + "</h5></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.owner.name") + " </label><h6> ";
											if(tenant_screening.Current_Owner_Name.isEmpty())
											{
												input.plain = input.plain + "-";
											}
											else
											{
												input.plain = input.plain + tenant_screening.Current_Owner_Name;
											}
											input.plain = input.plain + " </h6></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.address") + " </label><h6> ";
											if(tenant_screening.Current_Address.isEmpty())
											{
												input.plain = input.plain + "-";
											}
											else
											{
												input.plain = input.plain + tenant_screening.Current_Address;
											}
											input.plain = input.plain + " </h6></li><li class='zc-prop-flt-left'><label>" + language.get("zcpm.common.phone.number") + " </label><h6> ";
											if(tenant_screening.Current_Owner_Contact_Number.isEmpty())
											{
												input.plain = input.plain + "-";
											}
											else
											{
												input.plain = input.plain + tenant_screening.Current_Owner_Contact_Number;
											}
											input.plain = input.plain + " </h6></li><li class='zc-prop-flt-left'><label>" + language.get("zcpm.common.occupancy.type") + "</label><h6> ";
											if(tenant_screening.Occupant_Type.isEmpty())
											{
												input.plain = input.plain + "-";
											}
											else
											{
												input.plain = input.plain + tenant_screening.Occupant_Type;
											}
											input.plain = input.plain + " </h6></li>";
											if(tenant_screening.Occupant_Type == "Lease")
											{
												input.plain = input.plain + " <li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.lease.type") + " </label><h6>" + tenant_screening.Lease_Type + "</h6></li><li class='zc-prop-flt-left'><label> " + language.get("zcpm.common.lease.amount") + "</label><h6>" + tenant_screening.Lease_Amount_Display + "</h6></li>";
											}
											input.plain = input.plain + "</ul></div>";
											if(other_occupant.count() > 0)
											{
												input.plain = input.plain + "<div class='zc-prop-field-group'> <div class='zc-prop-label'><label class='zc-prop-label-txt'>" + language.get("zcpm.common.other.occupants") + "</label></div> <div class='zc-prop-table-wrapper'> <table class='zc-prop-table'> <thead> <tr> <th>" + language.get("zcpm.common.name") + "</th><th>" + language.get("zcpm.common.phone.number") + "</th><th>" + language.get("zcpm.common.gender") + "</th> <th>" + language.get("zcpm.common.relationship") + "</th> </tr> </thead> <tbody> ";
											}
											input.plain = input.plain + "<style>" + thisapp.Styles_Popup.Notes_Field() + "</style>";
											for each  rec in other_occupant
											{
												input.plain = input.plain + "<tr> <td>" + rec.Name + "</td>";
												if(rec.Mobile_Number != null)
												{
													input.plain = input.plain + " <td>" + rec.Mobile_Number + "</td>";
												}
												else
												{
													input.plain = input.plain + " <td>-</td>";
												}
												input.plain = input.plain + " <td>" + rec.Gender + "</td> <td>" + rec.Relationship.Relationship + "</td> </tr> ";
											}
											input.plain = input.plain + "</tbody> </table> </div> </div></div>";
										}
										else
										{
											input.plain = thisapp.Styles_Popup.Alert() + "<style>" + thisapp.Styles_Popup.Permission() + "</style><div class='zc-prop-popup-content zc-prop-warning-popup'><div class='zc-prop-icon-wrapper'><i class='zc-li-outline ui-3-alert'></i></div><h4>" + input.Tenant_Agreement.Agreement_No + "</h4><p>" + language_alert.get("zcpm.agreement.approval.alert") + "</p></div>";
											hide Comments;
										}
						)
					}
				}

			}
			On_click_Approve as "On click Approve"
			{
				type =  form
				form = Agreement_Approval
					status = inactive
				button = Approve
				on click
				{
					actions 
					{
					on click
					(
						tenant_agreement = Tenant_Agreement[ID == input.Tenant_Agreement];
										id = ID_Setup[ID != 0];
										login_profile = thisapp.permissions.loginUserProfile();
										// 
										// for administrator
										if(input.Page_Link_Name == "Approval" && input.Action_field.isEmpty() && login_profile == "Administrator" || login_profile == "Admin")
										{
											tenant_agreement.Comments=input.Comments;
											tenant_agreement.Status="Tenant Approved";
											tenant_agreement.Agreement_Status="Active";
											getUnit = Add_Unit[ID == input.Unit];
											getUnit.Current_Tenant=input.Tenant_Agreement.Tenant;
											getUnit.Availability="Occupied";
											for each  getTenantAgreements in Tenant_Agreement[Unit == getUnit.ID && ID != input.Tenant_Agreement.ID && Status != "Owner Rejected" && Status != "Tenant Rejected" && Status != "Vacate Requested" && Status != "Vacated"]
											{
												getTenantAgreements.Status="Auto Rejected";
											}
											if(input.Tenant_Agreement.Security_Deposit != null && input.Tenant_Agreement.Security_Deposit > 0)
											{
												payforSecurity = Pay_For_Monthly[Pay_For == "Security Deposit"];
												agreement = Tenant_Agreement[ID == input.Tenant_Agreement];
												tenant_security_amt = if(agreement.Renew_Base_Agreement != null && agreement.Renew_Base_Agreement.Security_Deposit < agreement.Security_Deposit,agreement.Security_Deposit - agreement.Renew_Base_Agreement.Security_Deposit,0);
												if(agreement.Renew_Base_Agreement != null && tenant_security_amt > 0)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=tenant_security_amt
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=tenant_security_amt
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=tenant_security_amt + if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
												}
												else if(agreement.Renew_Base_Agreement != null && agreement.Security_Deposit == agreement.Renew_Base_Agreement.Security_Deposit && input.Tenant_Agreement.Agreement_Commission > 0)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=0
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=0
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=if(bill.Total_Amount > 0,thisapp.Currency.currencyDisplayFormat(bill.Total_Amount),"");
												}
												else if(agreement.Renew_Base_Agreement == null)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=input.Tenant_Agreement.Security_Deposit
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=input.Tenant_Agreement.Security_Deposit
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=input.Tenant_Agreement.Security_Deposit + if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
												}
												if(input.Tenant_Agreement.Agreement_Commission > 0)
												{
													payfor_commission = Pay_For_Monthly[Pay_For == "Commission"];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payfor_commission.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=input.Tenant_Agreement.Agreement_Commission
														Amount_Display=input.Tenant_Agreement.Agreement_Commission_Display
														Description="Commission"
														Add_Payment_Notes=add_advance_amount
													];
												}
												if(add_advance_amount != null)
												{
													thisapp.mail.SendToTenantSecurityDepositPayment(add_advance_amount);
												}
												for each  payment_note in Add_Payment_Notes[ID != add_advance_amount && Unit == getUnit.ID && Tenant_Agreement != input.Tenant_Agreement.ID && Pay_For == "Security Deposit" && Status == "Unpaid"]
												{
													payment_note.Status="Cancel";
												}
											}
											thisapp.mail.SendToOwnerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
											thisapp.mail.SendToTenantAgreementApproved(input.Tenant_Agreement.ID);
											if(input.Unit.Manager != null)
											{
												thisapp.mail.SendToManagerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
											}
										}
										else if(tenant_agreement.Status == "Requested")
										{
											thisapp.mail.SendToTenantAgreementApproval(input.Tenant_Agreement.ID);
											tenant_agreement.Status="Owner Approved";
											tenant_agreement.Comments=input.Comments;
										}
										else if(Tenant_Agreement.Status == "Owner Approved")
										{
											tenant_agreement.Status="Tenant Approved";
											tenant_agreement.Agreement_Status="Active";
											getUnit = Add_Unit[ID == input.Unit];
											getUnit.Current_Tenant=input.Tenant_Agreement.Tenant;
											getUnit.Availability="Occupied";
											for each  getTenantAgreements in Tenant_Agreement[Unit == getUnit.ID && ID != input.Tenant_Agreement.ID && Status != "Owner Rejected" && Status != "Tenant Rejected" && Status != "Vacate Requested" && Status != "Vacated"]
											{
												getTenantAgreements.Status="Auto Rejected";
											}
											if(input.Tenant_Agreement.Security_Deposit != null && input.Tenant_Agreement.Security_Deposit > 0)
											{
												payforSecurity = Pay_For_Monthly[Pay_For == "Security Deposit"];
												agreement = Tenant_Agreement[ID == input.Tenant_Agreement];
												tenant_security_amt = if(agreement.Renew_Base_Agreement != null && agreement.Renew_Base_Agreement.Security_Deposit < agreement.Security_Deposit,agreement.Security_Deposit - agreement.Renew_Base_Agreement.Security_Deposit,0);
												if(agreement.Renew_Base_Agreement != null && tenant_security_amt > 0)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=tenant_security_amt
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=tenant_security_amt
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=tenant_security_amt + if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
												}
												else if(agreement.Renew_Base_Agreement != null && agreement.Security_Deposit == agreement.Renew_Base_Agreement.Security_Deposit && input.Tenant_Agreement.Agreement_Commission > 0)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=0
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=0
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
												}
												else if(agreement.Renew_Base_Agreement == null)
												{
													add_advance_amount = insert into Add_Payment_Notes
													[
														Tenant_Agreement=input.Tenant_Agreement
														Unit=input.Unit
														Property=input.Property
														Pay_For="Security Deposit"
														Due_Date=zoho.currentdate
														Payer=input.Tenant_Agreement.Tenant
														Added_User=zoho.loginuser
														Status="Unpaid"
														Due_Date=input.Tenant_Agreement.Start_Date
														Total_Amount=input.Tenant_Agreement.Security_Deposit
														Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Tenant_Agreement.Security_Deposit)
														Payment_Type="Income"
													];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payforSecurity.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=input.Tenant_Agreement.Security_Deposit
														Amount_Display=input.Tenant_Agreement.Security_Deposit_Display
														Description="Security Deposit"
														Add_Payment_Notes=add_advance_amount
													];
													bill = Add_Payment_Notes[ID == add_advance_amount];
													bill.Billing__ID=id.Bill_No + bill.Bill_No;
													bill.Total_Amount=input.Tenant_Agreement.Security_Deposit + if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0);
													bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(bill.Total_Amount);
												}
												if(input.Tenant_Agreement.Agreement_Commission > 0)
												{
													payfor_commission = Pay_For_Monthly[Pay_For == "Commission"];
													payment_details = insert into Payment_Details
													[
														Added_User=zoho.loginuser
														Pay_For=payfor_commission.ID
														Add_Property=input.Property
														Add_Unit=input.Unit
														Amount=if(input.Tenant_Agreement.Agreement_Commission > 0,input.Tenant_Agreement.Agreement_Commission,0)
														Amount_Display=input.Tenant_Agreement.Agreement_Commission_Display
														Description="Commission"
														Add_Payment_Notes=add_advance_amount
													];
												}
												if(add_advance_amount != null)
												{
													thisapp.mail.SendToTenantSecurityDepositPayment(add_advance_amount);
												}
												for each  payment_note in Add_Payment_Notes[ID != add_advance_amount && Unit == getUnit.ID && Tenant_Agreement != input.Tenant_Agreement.ID && Pay_For == "Security Deposit" && Status == "Unpaid"]
												{
													payment_note.Status="Cancel";
												}
											}
											thisapp.mail.SendToOwnerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
											thisapp.mail.SendToTenantAgreementApproved(input.Tenant_Agreement.ID);
											if(input.Unit.Manager != null)
											{
												thisapp.mail.SendToManagerAgreementApprovedByTenant(input.Tenant_Agreement.ID);
											}
											openUrl("#Page:Accounting?tab=security-deposit","same window");
										}
										// status changing in old agreement and renew request
										if(tenant_agreement.Renew_Base_Agreement != null)
										{
											getOldAgreement = Tenant_Agreement[ID == tenant_agreement.Renew_Base_Agreement.ID];
											getOldAgreement.Status="Agreement Renewed";
											getOldAgreement.Agreement_Status="Inactive";
											for each  renew_request in Renew_Agreement_Request[Base_Agreement == tenant_agreement.Renew_Base_Agreement.ID]
											{
												renew_request.Status="Agreement Renewed";
											}
										}
										if(login_profile != "Tenant")
										{
											openUrl("#Script:page.reload","same window");
										}
					)
					}
				}
			}
			On_Success_Submit7 as "On Success Submit"
			{
				type =  form
				form = Tenant_Screening
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										unit = Add_Unit[ID == input.Tenant.Unit];
										if((login_profile == "Admin" && input.Status == "Not Update") || (login_profile == "Administrator" && input.Status == "Not Update") || (login_profile == "Developer" && input.Status == "Not Update") || (login_profile == "Owner" && input.Status == "Not Update" && unit.Owner_Mail_ID == thisapp.get_user_id()) || input.Tenant == thisapp.get_user_id())
										{
											input.Location = input.Tenant.Location;
											if(input.Lease_Amount != null)
											{
												input.Lease_Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Lease_Amount);
											}
											if(input.Monthly_Rental != null)
											{
												input.Monthly_Rental_Display = thisapp.Currency.currencyDisplayFormat(input.Monthly_Rental);
											}
											// 	if(login_profile == "Tenant")
											// 	{
											// 		input.Status = "Updated";
											// 		thisapp.mail.SendToApproverWaitingTenent(input.Tenant.ID);
											// 	}
											// 	if(login_profile != "Tenant" && input.Screening_Process == "My Self")
											// 	{
											input.Status = "Updated";
											user = New_User[ID == input.Tenant];
											user.Status="Active";
											user.Tenant_Status="Approved";
											user.Comments="Auto Approved";
											thisapp.mail.SendTenantApproved(input.Tenant.ID);
											if(user.Unit.Occupancy_Type == "Rent")
											{
												openUrl("#Page:Rental?action=add&rec_id=" + user.ID,"same window");
											}
											else if(user.Unit.Occupancy_Type == "Lease")
											{
												openUrl("#Page:Lease?action=add&rec_id=" + user.ID,"same window");
											}
											//openUrl("#Page:Tenants?tab=approved-tenants","same window");
											//	}
											// 	else if(login_profile != "Tenant")
											// 	{
											// 		tenant = New_User[ID == input.Tenant];
											// 		tenant.Tenant_Status="Screening In Process";
											// 		thisapp.mail.SendToTenantMoveToScreening(input.ID);
											// 		openUrl("#Page:Tenants?tab=screening-tenants","same window");
											// 	}
										}
										else
										{
											if(input.Page_Name == "Approval" && login_profile != "Owner")
											{
												openUrl("#Page:Approval?tab=tenants","same window");
											}
											else
											{
												openUrl("#Page:Tenants?tab=new-tenants","same window");
											}
											success message "";
										}
						)
					}
				}

			}
			User_input_post_to as "User input post to"
			{
				type =  form
				form = Post
				record event = on add or edit
					status = inactive

				on user input of Post_To
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(input.Post_To == "Properties")
										{
											show Properties;
											hide Users;
											clear Users;
											tenantUnit = Add_Unit[Current_Tenant.Email == zoho.loginuserid];
											if(login_profile != "Admin" || login_profile != "Administrator")
											{
												property = Add_Property[Unit_Owners.Email.contains(zoho.loginuserid) || Manager.Email == zoho.loginuserid || ID == tenantUnit.Property.ID.getall()];
											}
											else
											{
												property = Add_Property[ID != 0];
											}
											input.Properties:ui.add(property.ID.getall());
											for each  prop in property
											{
												Properties.select(prop);
											}
										}
										else if(input.Post_To == "Individual")
										{
											users = List();
											tenants = List();
											owner = List();
											managers = List();
											admins = New_User[Role == "Admin"].ID.getAll();
											users.addAll(admins);
											allUser = List();
											if(login_profile == "Tenant")
											{
												unit = Add_Unit[Current_Tenant == thisapp.get_user_id()];
												another_tenants = Add_Unit[ID == unit.ID.getall()];
												tenants = another_tenants.Current_Tenant.ID.getall();
												owner = unit.Owner_Mail_ID.ID.getall();
												managers = unit.Manager.ID.getall();
												users.addAll(tenants);
												users.addAll(owner);
												users.addAll(managers);
												input.Users:ui.add(users.distinct());
											}
											else if(login_profile == "Owner")
											{
												unit = Add_Unit[Owner_Mail_ID == thisapp.get_user_id()];
												another_owner = Add_Unit[ID == unit.ID.getall()];
												owner = another_owner.Owner_Mail_ID.ID.getall();
												tenants = unit.Current_Tenant.ID.getall();
												managers = unit.Manager.ID.getall();
												users.addAll(tenants);
												users.addAll(owner);
												users.addAll(managers);
												input.Users:ui.add(users.distinct());
											}
											else if(login_profile == "Manager")
											{
												unit = Add_Unit[Manager == thisapp.get_user_id()];
												another_manager = Add_Unit[ID == unit.ID.getall()];
												tenants = another_manager.Manager.ID.getall();
												managers = unit.Current_Tenant.ID.getall();
												owner = unit.Owner_Mail_ID.ID.getall();
												users.addAll(tenants);
												users.addAll(owner);
												users.addAll(managers);
												input.Users:ui.add(users.distinct());
											}
											show Users;
											clear Properties;
											hide Properties;
										}
						)
					}
				}

			}
			Onload_vendor_profile_fie as "Onload - vendor profile field validation"
			{
				type =  form
				form = Add_Vendor
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Hide;
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Vendor")
										{
											disable Vendor_Email;
											disable Properties;
										}
						)
					}
				}

			}
			User_input_of_Penalty_pay as "User_input_of_Penalty_pay"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Penalty_Payment_Method
				{
					actions 
					{
						custom deluge script
						(
											hide Penalty;
										hide Fixed_Penalty_Amount;
										if(input.Penalty_Payment_Method == "Fixed Amount")
										{
											show Fixed_Penalty_Amount;
											hide Penalty;
											input.Penalty = null;
										}
										else if(input.Penalty_Payment_Method == "%")
										{
											show Penalty;
											hide Fixed_Penalty_Amount;
											input.Fixed_Penalty_Amount = null;
										}
						)
					}
				}

			}
			OnSuccess1 as "OnSuccess"
			{
				type =  form
				form = Add_Payment_Notes
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Total_Amount > 0)
										{
											input.Amount_Display = thisapp.Currency.currencyDisplayFormat(input.Total_Amount);
										}
										for each  paymentdetails in Payment_Details[Add_Payment_Notes == input.ID]
										{
											paymentdetails.Amount_Display=thisapp.Currency.currencyDisplayFormat(paymentdetails.Amount);
										}
						)
					}
				}

			}
			Hide_Show_Field as "Hide/Show Field"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Do_you_want_configure_penalty
				{
					actions 
					{
						custom deluge script
						(
											if(input.Do_you_want_configure_penalty == "Yes")
										{
											show Penalty_Payment_Method;
											show Grace_Days_For_Monthly_Payment;
											show After_Due_Date;
										}
										else
										{
											hide Grace_Days_For_Monthly_Payment;
											input.Grace_Days_For_Monthly_Payment = null;
											hide Penalty_Payment_Method;
											hide After_Due_Date;
											input.Penalty_Payment_Method = null;
											input.Penalty = null;
											input.Fixed_Penalty_Amount = null;
											input.After_Due_Date = null;
										}
						)
					}
				}

			}
			ID_Generate as "ID Generate"
			{
				type =  form
				form = Raise_a_Complaint
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											id = ID_Setup[ID != 0];
										input.Complaints_No = id.Work_Order_No + input.Work_Order_Number;
										if(input.Unit.Manager != null)
										{
											thisapp.mail.SendToManagerComplaint(input.ID);
										}
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Owner" || login_profile == "Admin" || login_profile == "Administrator" || login_profile == "Developer")
										{
											input.Complaint_Status = "Approved";
										}
						)
					}
				}

			}
			OnLoadEdit as "OnLoadEdit"
			{
				type =  form
				form = Configure
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Configure1;
										if(input.Property == null && input.Unit == null)
										{
											hide Property;
											hide Unit;
										}
										else if(input.Property != null && input.Unit != null)
										{
											disable Property;
											disable Unit;
										}
						)
					}
				}

			}
			User_input_of_Search as "User input of Search"
			{
				type =  form
				form = Property_Filter_Form
				record event = on add

				on user input of Search
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.common();
										if(input.Search.isEmpty())
										{
											hide Decision_box;
										}
										else
										{
											show Decision_box;
										}
										export_url = zoho.appuri + "csv/";
										import_url = "#Page:" + input.Page + "?action=import";
										reportURL = "#Report:" + input.Report + "?zc_Header=false&zc_AddRec=false&zc_ColMenu=false&zc_Footer=false";
										if(input.Page == "Properties")
										{
											link = "#Page:" + input.Page + "?tab=" + input.tab;
											link = link + if(!input.Search.isEmpty(),"&search=" + input.Search,"");
											link = link + if(!input.Occupancy_Type.isEmpty(),"&occupancy_type=" + input.Occupancy_Type,"");
											link = link + if(!input.New_User.isEmpty(),"&user_id=" + input.New_User,"");
											if(input.tab.isEmpty() || input.tab == "properties")
											{
												property_ids = if(input.Search.isEmpty(),"","?ID=" + Add_Property[Property_Name.contains(input.Search) || Property_Type.contains(input.Search) || Location.Location.contains(input.Search)].ID.getAll() + "&ID_op=18");
												export_url = export_url + "All_Properties" + property_ids;
												input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
											}
											else
											{
												ids = Add_Unit[Unit_Name.contains(input.Search) || Property.Property_Name.contains(input.Search) || Availability.contains(input.Search)].ID.getAll();
												unit_ids = "?Owner_Approval_Status=Requested&Owner_Approval_Status_op=19";
												unit_ids = unit_ids + if(input.Search.isEmpty(),"","&ID=" + encodeUrl("[" + ids + "]") + "&ID_op=72");
												unit_ids = unit_ids + if(input.Occupancy_Type.isEmpty(),"","&Occupancy_Type=" + input.Occupancy_Type + "&Occupancy_Type_op=18");
												export_url = export_url + "All_Units" + unit_ids;
												input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
											}
											openUrl(link,"same window");
										}
										else if(input.Page == "Tenants")
										{
											search_result = New_User[Name.first_name.containsIgnoreCase(input.Search) || Name.last_name.containsIgnoreCase(input.Search) || Email.containsIgnoreCase(input.Search) && Role = "Tenant"].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											if(input.tab == "screening-tenants")
											{
												peram = if(!input.Search.isEmpty(),"&Tenant.ID=" + encodeUrl("[" + search_result + "]") + "&Tenant.ID_op=18","");
											}
											else
											{
												peram = if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=18","");
											}
											peram = peram + if(input.Location != null,"&Location.ID=" + input.Location.ID + "&Location.ID_op=18","");
											tenants_ids = "?Role=Tenant&Role_op=18";
											if(input.tab.isEmpty() || input.tab == "new-tenants")
											{
												tenants_ids = tenants_ids + if(input.Search.isEmpty(),"","&ID=" + New_User[Role == "Tenants" && Tenant_Status == "Waiting for Approval" && Name.contains(input.Search) || Email.contains(input.Search)].ID.getAll() + "&ID_op=18");
											}
