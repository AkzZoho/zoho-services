btab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\tif(input.subtab == &quot;appliances&quot;)\n\t\t\t{\n\t\t\t\treport_filter = &quot;&amp;Add_Unit.ID=&quot; + input.rec_id;\n\t\t\t}\n\t\t\telse if((unitConfig.count() &gt; 0 &amp;&amp; input.subtab == &quot;payment-configure&quot;) || input.subtab == &quot;previousOccupant&quot;)\n\t\t\t{\n\t\t\t\tif(input.tab = &quot;Parking&quot;)\n\t\t\t\t{\n\t\t\t\t\tagreementno = Tenant_Agreement[Unit == input.rec_id || Parking_No == input.rec_id].Agreement_No.getAll();\n\t\t\t\t\treport_filter = &quot;&amp;Agreement_No=[&quot; + agreementno + &quot;]&amp;Agreement_No_op=72&quot;;\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t}\n\t\t\telse if(input.subtab == &quot;complaints&quot; || input.subtab == &quot;payments&quot;)\n\t\t\t{\n\t\t\t\tif(input.tab = &quot;Parking&quot;)\n\t\t\t\t{\n\t\t\t\t\tbilling = Add_Payment_Notes[Unit == input.rec_id || Parking_No == input.rec_id].Bill_No.getAll();\n\t\t\t\t\treport_filter = &quot;&amp;Bill_No=[&quot; + billing + &quot;]&amp;Bill_No_op=72&quot;;\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t}\n\t\t\telse if(input.subtab == &quot;buyer&quot;)\n\t\t\t{\n\t\t\t\tif(input.tab = &quot;Parking&quot;)\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Parking_No.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(input.subtab == &quot;payment-configure&quot;)\n\t\t\t{\n\t\t\t\tdefaultConfig = Configure[Configure1 == &quot;Default&quot;];\n\t\t\t\tunitConfig = Configure[Unit == input.rec_id];\n\t\t\t\tif(unitConfig.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\tconfig = unitConfig.Configure1;\n\t\t\t\t\tconfig_penalty = unitConfig.Do_you_want_configure_penalty;\n\t\t\t\t\tpenaltypaymentmethod = unitConfig.Penalty_Payment_Method;\n\t\t\t\t\tfixedamount = unitConfig.Fixed_Penalty_Amount;\n\t\t\t\t\tpercentage = unitConfig.Penalty;\n\t\t\t\t\tgracedays = unitConfig.Grace_Days_For_Monthly_Payment;\n\t\t\t\t\tbillgenaration = unitConfig.Bill_Generation;\n\t\t\t\t\tafterduedate = unitConfig.After_Due_Date;\n\t\t\t\t\tmanagercommissions = unitConfig.Do_You_Want_Configure_Manager_Commission;\n\t\t\t\t\tcategory = unitConfig.Category;\n\t\t\t\t\trentalmonthly = unitConfig.Rental_Monthly;\n\t\t\t\t\tcomplaint_config = unitConfig.Complaint;\n\t\t\t\t\tagreement_config = unitConfig.Agreement;\n\t\t\t\t\tallAdditionalPayment = unitConfig.Additional_Payment_Monthly;\n\t\t\t\t\tsecurityDeposit = unitConfig.Security_Deposit;\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tconfig = defaultConfig.Configure1;\n\t\t\t\t\tconfig_penalty = defaultConfig.Do_you_want_configure_penalty;\n\t\t\t\t\tpenaltypaymentmethod = defaultConfig.Penalty_Payment_Method;\n\t\t\t\t\tfixedamount = defaultConfig.Fixed_Penalty_Amount;\n\t\t\t\t\tpercentage = defaultConfig.Penalty;\n\t\t\t\t\tgracedays = defaultConfig.Grace_Days_For_Monthly_Payment;\n\t\t\t\t\tbillgenaration = defaultConfig.Bill_Generation;\n\t\t\t\t\tafterduedate = defaultConfig.After_Due_Date;\n\t\t\t\t\tmanagercommissions = defaultConfig.Do_You_Want_Configure_Manager_Commission;\n\t\t\t\t\tcategory = defaultConfig.Category;\n\t\t\t\t\trentalmonthly = defaultConfig.Rental_Monthly;\n\t\t\t\t\tcomplaint_config = defaultConfig.Complaint;\n\t\t\t\t\tagreement_config = defaultConfig.Agreement;\n\t\t\t\t\tallAdditionalPayment = defaultConfig.Additional_Payment_Monthly;\n\t\t\t\t\tsecurityDeposit = defaultConfig.Security_Deposit;\n\t\t\t\t}\n\t\t\t\tif(unit.Occupancy_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\tbaseamount = if(unitConfig.count() &gt; 0,unitConfig.Base_Rental_Monthly_Amount,defaultConfig.Base_Rental_Monthly_Amount);\n\t\t\t\t\toccupancy_Type = language.get(&quot;zcpm.property.base.rent&quot;);\n\t\t\t\t}\n\t\t\t\telse if(unit.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t{\n\t\t\t\t\tbaseamount = if(unitConfig.count() &gt; 0,unitConfig.Base_Lease_Amount,defaultConfig.Base_Lease_Amount);\n\t\t\t\t\toccupancy_Type = language.get(&quot;zcpm.property.base.lease&quot;);\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=config%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=occupancy_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(baseamount)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.Security.Deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(securityDeposit)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Additional.Payment.Monthly&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tcount = 1;\n\t\t\t\tfor each  additionalpayment in allAdditionalPayment\n\t\t\t\t{\n\t\t\t\t\tif(count.isOdd())\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=additionalpayment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=additionalpayment.Amount_Display%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\tcount = count + 1;\n\t\t\t\t\tif(count.isOdd())\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Monthly.Payment.Penalty&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.configure.penalty&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=config_penalty%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.penalty.payment.method&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=penaltypaymentmethod%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\tif(penaltypaymentmethod == &quot;Fixed Amount&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.fixed.penalty.amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=fixedamount%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.penalty.percentage&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=percentage%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.grace.days&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=gracedays%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Payment.Reminder.Notification&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.bill.generation&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=billgenaration%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.after.due.date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=afterduedate%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Commission&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.manager.commissions&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=managercommissions%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(managercommissions == &quot;Yes&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.Category&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=category%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(category.size() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\tif(category.contains(&quot;Rental Monthly&quot;))\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.rental.monthly&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=rentalmonthly%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(category.contains(&quot;Complaint&quot;))\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Complaint&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=complaint_config%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(category.size() &lt;= 2 &amp;&amp; category.contains(&quot;Agreement&quot;))\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Agreement&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(agreement_config)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(category.size() == 3 &amp;&amp; category.contains(&quot;Agreement&quot;))\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Agreement&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(agreement_config)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(agreement.count() &gt; 0 &amp;&amp; input.subtab == &quot;tenantdetails&quot; || input.subtab.isEmpty())\n\t\t\t{\n\t\t\t\tunit_agreement = Tenant_Agreement[Unit == input.rec_id &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + input.rec_id + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + agreement.ID + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Details&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Each_Agreement_Template?rec_id=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-eye-17&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.view&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\tif(unit_agreement.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Agreement_History?view_link_name=Unit_Agreement_History&amp;param=&lt;%=history_report_filter%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-copy-04&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.history&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Email%&gt; &lt;\/td&gt;\t\t\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Location.Location%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.mobile_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!agreement.Tenant.Phone_Number.isEmpty(),agreement.Tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Agreement.Details&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.unit.name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Unit.Unit_Name%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(agreement.Parking_No.Unit_Name != null)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.parking&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Parking_No.Unit_Name%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.subtab == &quot;tenantdetails&quot; &amp;&amp; agreement.count() == 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.subtab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&lt;%=report_filter%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if((input.action == &quot;propertydetail&quot; &amp;&amp; property.count() == 0) || (input.action == &quot;unitdetail&quot; &amp;&amp; unit.count() == 0))\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;propertyadd&quot;)\n\t\t{\n\t\t\tform_mp = {1:&quot;Add_Property&quot;,2:&quot;Add_Unit?Property=&quot; + input.rec_id,3:&quot;Configure&quot;};\n\t\t\tproperty_name = language.get(&quot;zcpm.property.property_details&quot;);\n\t\t\tUnit_Details = language.get(&quot;zcpm.property.unit_details&quot;);\n\t\t\tinput.step = if(input.step.isEmpty(),1,input.step);\n\t\t\tform_link = form_mp.get(input.step);\n\t\t\tsub_button_name = &quot;Next&quot;;\n\t\t\tif(input.step == 2 &amp;&amp; input.rec_id != null)\n\t\t\t{\n\t\t\t\tproperty_rec = Add_Property[ID == input.rec_id];\n\t\t\t\tproperty_name = property_rec.Property_Name;\n\t\t\t\tnextURL = &quot;&quot;;\n\t\t\t}\n\t\t\telse if(input.step == 3)\n\t\t\t{\n\t\t\t\tgetAddedUnit = Add_Unit[Property == input.rec_id];\n\t\t\t\tUnit_Details = getAddedUnit.Unit_Name;\n\t\t\t\tsub_button_name = &quot;Finish&quot;;\n\t\t\t\tnextURL = &quot;zc_NextUrl=#Page:Properties&quot;;\n\t\t\t\tparam = &quot;&amp;Property=&quot; + input.rec_id + &quot;&amp;Unit=&quot; + getAddedUnit.ID;\n\t\t\t}\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Add_Property()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-add_property&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:Properties&apos;&gt;\n                &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n            &lt;\/a&gt;\n            &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.property.add_property&quot;)%&gt; &lt;\/h5&gt;\n        &lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-fwh&apos;&gt;\n                &lt;div class=&apos;zc-prop-stepper-wrapper zc-prop-fw&apos;&gt;\n                    &lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n                        &lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=if(input.step == 1,&quot;zc-prop-stepper-active&quot;,&quot;&quot;)%&gt;&apos;&gt;\n                            &lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n                                &lt;h6&gt; &lt;%=language.get(&quot;zcpm.one&quot;)%&gt; &lt;\/h6&gt;\n                                &lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n                            &lt;\/div&gt;\n                            &lt;span&gt; &lt;%=property_name%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=if(input.step == 2,&quot;zc-prop-stepper-active&quot;,&quot;&quot;)%&gt;&apos;&gt;\n                            &lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n                                &lt;h6&gt; &lt;%=language.get(&quot;zcpm.two&quot;)%&gt; &lt;\/h6&gt;\n                                &lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n                            &lt;\/div&gt;\n                            &lt;span&gt; &lt;%=Unit_Details%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=if(input.step == 3,&quot;zc-prop-stepper-active&quot;,&quot;&quot;)%&gt;&apos;&gt;\n                            &lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n                                &lt;h6&gt; &lt;%=language.get(&quot;zcpm.three&quot;)%&gt; &lt;\/h6&gt;\n                                &lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n                            &lt;\/div&gt;\n                            &lt;span&gt; &lt;%=language.get(&quot;zcpm.property.payment_configure&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                    &lt;\/ul&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-form&apos; elName=&apos;zc-component&apos; name=&apos;embedForm&apos; formLinkName=&apos;&lt;%=form_link%&gt;&apos; params=&apos;zc_Header=false&amp;zc_SubmitVal=&lt;%=sub_button_name%&gt;&lt;%=param%&gt;&amp;&lt;%=nextURL%&gt;&apos;&gt;&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;propertyedit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Property.Edit&quot;),page_link_name,&quot;Add_Property&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Properties_Report&amp;zc_NextUrl=#Page:Properties?action=propertydetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;unitadd&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.property.add_unit&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;Property=&quot; + input.rec_id + &quot;&amp;Unit_Type=Unit&amp;zc_NextUrl=#Page:Properties?tab=units&quot;)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;parkingadd&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.property.add_parking&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;Property=&quot; + input.rec_id + &quot;&amp;Unit_Type=Parking&amp;zc_NextUrl=#Page:Properties?tab=units&quot;)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;unitedit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Unit.Edit&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + input.rec_id + &quot;&amp;subtab=&quot; + input.subtab,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Units_Report&amp;zc_NextUrl=#Page:Properties?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;parkingedit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Parking.Edit&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + input.rec_id + &quot;&amp;subtab=&quot; + input.subtab,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Units_Report&amp;zc_NextUrl=#Page:Properties?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;assign&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Unit.Assign&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + input.rec_id + &quot;&amp;subtab=&quot; + input.subtab,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Units_Report&amp;Unit_Type=Both&amp;zc_NextUrl=#Page:Properties?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;saleedit&quot;)\n\t\t{\n\t\t\tif(input.tab == &quot;Parking&quot;)\n\t\t\t{\n\t\t\t\tsale = Sales_Form[Parking_No.Unit_Name == unit.Unit_Name];\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tsale = Sales_Form[Unit.Unit_Name == unit.Unit_Name];\n\t\t\t}\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Sale.Edit&quot;),page_link_name + &quot;?action=saledetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + sale.ID + &quot;&amp;subtab=&quot; + input.subtab,&quot;Sales_Form&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + sale.ID + &quot;&amp;viewLinkName=All_Sales&amp;zc_NextUrl=#Page:Properties?action=saledetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + sale.ID + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;configureadd&quot;)\n\t\t{\n\t\t\tunit = Add_Unit[ID == input.rec_id];\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Configure&quot;),page_link_name + &quot;?tab=units&quot;,&quot;Configure&quot;,&quot;zc_Header=false&amp;Property=&quot; + unit.Property.ID + &quot;&amp;Unit=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:Properties?tab=units&quot;)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;createUnitConfig&quot;)\n\t\t{\n\t\t\tunit = Add_Unit[ID == input.rec_id];\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Unit.Configure&quot;),page_link_name + &quot;?action=unitdetail&amp;rec_id=&quot; + input.rec_id + &quot;&amp;tab=&quot; + input.tab + &quot;&amp;subtab=&quot; + input.subtab,&quot;Configure&quot;,&quot;zc_Header=false&amp;Configure1=Modified&amp;Property=&quot; + unit.Property.ID + &quot;&amp;Unit=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:Properties?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;paymentconfigedit&quot;)\n\t\t{\n\t\t\tunitConfig = Configure[ID == input.rec_id];\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Modified.Configuration&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + unitConfig.Unit + &quot;&amp;subtab=&quot; + input.subtab,&quot;Configure&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Configure_Report&amp;zc_NextUrl=#Page:Properties?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + unitConfig.Unit.ID + &quot;%26subtab=&quot; + input.subtab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;import&quot;)\n\t\t{\n\t\t\timport_tab = if(input.tab.isEmpty() || input.tab == &quot;properties&quot;,&quot;Properties&quot;,&quot;Units&quot;);\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Import(import_tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;complaintDetilView&quot;)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(complaint.ID,complaint.Photo,&quot;Unit_Complaints&quot;,&quot;Photo&quot;,complaint.Complaint_About,true);\n\t\t\tclass_name = &quot;&quot;;\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Complaints_Detail_View()%&gt;\n.zcform_Review_Complaint,\n.zcform_Work_Order_Payment {\n    width: 600px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\t\tlow_color = if(complaint.Priority == &quot;Low&quot;,&quot;zc-prop-badge-green&quot;,&quot;&quot;);\n\t\t\tmedium_color = if(complaint.Priority == &quot;Medium&quot;,&quot;zc-prop-badge-yellow&quot;,&quot;&quot;);\n\t\t\thigh_color = if(complaint.Priority == &quot;High&quot;,&quot;zc-prop-badge-orange&quot;,&quot;&quot;);\n\t\t\tveryhigh_color = if(complaint.Priority == &quot;Very High&quot;,&quot;zc-prop-badge-red&quot;,&quot;&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-complaints-detail-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-header-title&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_summary&quot;)%&gt; - &lt;%=complaint.Work_Order_Number%&gt;&lt;\/h5&gt;\n\t\t\t\t&lt;span class=&apos;zc-prop-badge &lt;%=low_color + medium_color + high_color + veryhigh_color%&gt; &apos;&quot;&gt;\n\t\t\t\t\t&lt;%=complaint.Priority%&gt;\n\t\t\t\t&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\ttop_bar_map = thisapp.Timeline.Get_Topbar(input.rec_id);\n\t\t\tkey_lis = top_bar_map.keys();\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-stepper-wrapper zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\t\tfor each  top_bar in key_lis\n\t\t\t{\n\t\t\t\tstyle = if(top_bar != 5,top_bar_map.get(top_bar).get(&apos;Style&apos;),&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=style%&gt;&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=top_bar%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n&lt;%\n\t\t\t\tif(top_bar == 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;%=top_bar_map.get(top_bar).get(&apos;Style&apos;)%&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=top_bar_map.get(top_bar).get(&apos;Display&apos;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\tif(top_bar != 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-complaints-info&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card-header&apos;&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.compliant_detail&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;\/div&gt;\t\n\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-img-txt-outer zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper-outer&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Complaint_About%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;p&gt; &lt;%=complaint.Complaint_Details%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4&apos;&gt;\n\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.property&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Property_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.unit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Unit.Unit_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt;  &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Location.Location%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Date_of_Reporting%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.duration&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.End_Time != null &amp;&amp; complaint.Start_Time != null)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=thisapp.Get_Duration_Time(complaint.ID)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.not.yet&quot;)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.Expected_Date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Expected_Date == null,&quot;-&quot;,complaint.Expected_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.resolved_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Resolved_Date == null,&quot;-&quot;,complaint.Resolved_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\t\tif(complaint.Complaint_Status != &quot;Rejected&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.comments&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Comments.isEmpty(),&quot;-&quot;,complaint.Comments)%&gt;&lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Reason.isEmpty(),&quot;-&quot;,complaint.Reason)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.vendor_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.name&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Name)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.email&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Email)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;&lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt;&lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Phone_Number)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Complaint_Amount == null,&quot;-&quot;,complaint.Complaint_Amount_Display)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_by&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.Payment_By == &quot;Owner&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Owner_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(complaint.Payment_By == &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Tenant_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; - &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Properties()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n\tcontent: &apos;&lt;%=content%&gt;&apos;; \n}\n&lt;%\n\t\t\tif(input.tab == &quot;units&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n.zc-prop-filter .formContainer .formColumn.second-column .form-group.zc-addnote-fld {\n    left: calc(275px + 115px + 190px);\n}\n.zc-rtl-wrapper .zc-prop-filter .formContainer .formColumn.second-column .form-group.zc-addnote-fld {\n    left: auto;\n\tright: calc(275px + 56px + 180px);\n}\n&lt;%\n\t\t\t}\n\t\t\tif(input.tab == &quot;Parking&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n.zc-prop-filter .formContainer .formColumn .form-group.zc-Option_Notes-group {\n    padding: 0px;\n    position: absolute;\n    left: calc(275px + 80px);\n    z-index: 1;\n}\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-properties-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;h5&gt; &lt;%=Common_language.get(&quot;zcpm.common.welcome&quot;)%&gt; &lt;%=getuser.Name%&gt;, &lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;Page=&lt;%=page_link_name%&gt;&amp;tab=&lt;%=input.tab%&gt;&amp;zc_Footer=false&amp;Search=&lt;%=input.search%&gt;&amp;Occupancy_Type=&lt;%=input.occupancy_type%&gt;&amp;New_User=&lt;%=input.user_id%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-toggle-wrapper&apos;&gt;\n\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(main_tab == input.tab,&quot;class=&apos;zc-prop-toggle-active&apos;&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li &lt;%=class_name%&gt;&gt;\n\t\t\t\t\t\t\t&lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\tif(input.tab.isEmpty() || input.tab == &quot;properties&quot; &amp;&amp; login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.property.add_property&quot;),&quot;#Page:Properties?action=propertyadd&amp;step=1&quot;)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;units&quot; &amp;&amp; login_profile != &quot;Manager&quot; &amp;&amp; login_profile != &quot;Owner&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.property.add_unit&quot;),&quot;#Page:Properties?action=unitadd&amp;tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;Parking&quot; &amp;&amp; login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.property.parkingslot&quot;),&quot;#Page:Properties?action=parkingadd&amp;tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n&lt;%\n\t\t\tlis = list();\n\t\t\tlis1 = list();\n\t\t\tfor each  var in view_units\n\t\t\t{\n\t\t\t\tif(var.Unit_Type == &quot;Parking&quot; || var.Unit_Type == &quot;Both&quot;)\n\t\t\t\t{\n\t\t\t\t\tlis.add(var.ID);\n\t\t\t\t}\n\t\t\t\tif(var.Unit_Type == &quot;Unit&quot; || var.Unit_Type == &quot;Both&quot;)\n\t\t\t\t{\n\t\t\t\t\tlis1.add(var.ID);\n\t\t\t\t}\n\t\t\t}\n\t\t\tif(input.tab == &quot;properties&quot; || input.tab.isEmpty() &amp;&amp; view_properties.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-properties-wrapper zc-prop-fwh&apos;&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-card-wrapper zc-prop-fwh&apos;&gt;\n&lt;%\n\t\t\t\tfor each  property in view_properties\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-overlay&apos; href=&apos;#Page:Properties?tab=&lt;%=input.tab%&gt;&amp;action=propertydetail&amp;rec_id=&lt;%=property.ID%&gt;&apos;&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;%=thisapp.CommonFeatures.processImageUrl(property.ID,property.Image,&quot;Properties_Report&quot;,&quot;Image&quot;,property.Property_Name,true)%&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=property.Property_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;p&gt; &lt;%=property.Property_Address.address_line_1%&gt;,&lt;%=property.Property_Address.address_line_2%&gt; &lt;%=property.Property_Address.district_city%&gt;,&lt;%=property.Property_Address.state_province%&gt;,&lt;%=property.Property_Address.postal_Code%&gt;,&lt;%=property.Property_Address.country%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-more-options zc-prop-rounded&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-hover-extend&apos;&gt;&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;fa fa-ellipsis-h&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\tif(login_profile != &quot;Owner&quot; &amp;&amp; login_profile != &quot;Manager&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?rec_id=&lt;%=property.ID%&gt;&amp;action=propertyedit&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(property.Mark_it_as_single_unit_property1 == false)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?rec_id=&lt;%=property.ID%&gt;&amp;action=unitadd&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-simple-add&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.add.unit&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(property.No_of_Parking_Slots != null &amp;&amp; property.No_of_Parking_Slots &gt; property.No_of_Parking_Occupied)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?rec_id=&lt;%=property.ID%&gt;&amp;action=parkingadd&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-simple-add&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.add_parking&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(property.No_of_Parking_Slots == property.No_of_Parking_Occupied || property.No_of_Parking_Slots == null)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Form:Extend_Parking_Capacity?Property=&lt;%=property.ID%&gt;&amp;Existing_Parking_Capacity=&lt;%=property.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-simple-add&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.extend.parking&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;units&quot; &amp;&amp; lis1.size() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-units-wrapper zc-prop-fwh&apos;&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-card-wrapper zc-prop-fwh&apos;&gt;\n&lt;%\n\t\t\t\tfor each  unit in lis1\n\t\t\t\t{\n\t\t\t\t\tfet = Add_Unit[ID == unit];\n\t\t\t\t\ttag_color = &quot;&quot;;\n\t\t\t\t\tif(fet.Availability == &quot;Sold Out&quot; &amp;&amp; fet.Occupancy_Type == &quot;Sale&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-red&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Available&quot; &amp;&amp; fet.Occupancy_Type == &quot;Sale&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-skyblue&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Vacant&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-green&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Occupied&quot; &amp;&amp; fet.Occupancy_Type == &quot;Owned&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-orange&quot;;\n\t\t\t\t\t}\n\t\t\t\t\telse if(fet.Availability == &quot;Occupied&quot; &amp;&amp; fet.Occupancy_Type == &quot;Rent&quot; || fet.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\ttag_color = &quot;zc-prop-tag-color-blue&quot;;\n\t\t\t\t\t}\n\t\t\t\t\tif(!input.user_id.isEmpty())\n\t\t\t\t\t{\n\t\t\t\t\t\tuserid = &quot;&amp;user_id=&quot; + input.user_id;\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-overlay&apos; href=&apos;#Page:Properties?action=unitdetail&amp;tab=&lt;%=input.tab%&gt;&amp;rec_id=&lt;%=fet.ID%&gt;&lt;%=userid%&gt;&apos;&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;%=thisapp.CommonFeatures.processImageUrl(fet.ID,fet.Unit_Image,&quot;Units_Report&quot;,&quot;Unit_Image&quot;,fet.Unit_Name,true)%&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(fet.Parking_No != null)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=fet.Property.Property_Name%&gt; - &lt;%=fet.Unit_Name%&gt; - &lt;%=fet.Parking_No.Unit_Name%&gt;  &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t&lt;p&gt; &lt;%=fet.Address%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=fet.Property.Property_Name%&gt; - &lt;%=fet.Unit_Name%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t&lt;p&gt; &lt;%=fet.Address%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(fet.Availability == &quot;Rejected Unit&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tag &lt;%=tag_color%&gt;&apos;&gt; &lt;span&gt; &lt;%=fet.Availability%&gt; &lt;\/span&gt; &lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tag &lt;%=tag_color%&gt;&apos;&gt; &lt;span&gt; &lt;%=fet.Occupancy_Type%&gt; \/ &lt;%=fet.Availability%&gt; &lt;\/span&gt; &lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(fet.Availability != &quot;Rejected Unit&quot; &amp;&amp; fet.Availability != &quot;Sold Out&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-more-options zc-prop-rounded&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-hover-extend&apos;&gt;&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;fa fa-ellipsis-h&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Properties?action=unitedit&amp;rec_id=&lt;%=fet.ID%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;!--line ---------------------------------------------------------------------------------------------------------added--&gt;\n&lt;%\n\t\t\t\t\t\tif(fet.Availability == &quot;Available&quot; || fet.Availability == &quot;Occupied&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif(fet.Occupancy_Type == &quot;Sale&quot; || fet.Occupancy_Type == &quot;Owned&quot;)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Form:Sales_Form?Property=&lt;%=fet.Property%&gt;&amp;Unit=&lt;%=fet.ID%&gt;&amp;Owner=&lt;%=fet.Owner_Mail_ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline shopping-tag-sale&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.