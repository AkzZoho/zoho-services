			User_input_of_Configure as "User input of Configure"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Configure1
				{
					actions 
					{
						custom deluge script
						(
											if(input.Configure1 == "Default")
										{
											hide Property;
											hide Unit;
											getDefaultConfig = Configure[ID != null && Configure1 == "Default"];
											// 	Rental
											input.Base_Rental_Monthly_Amount = getDefaultConfig.Base_Rental_Monthly_Amount;
											input.Security_Deposit = getDefaultConfig.Security_Deposit;
											// 	Lease
											input.Base_Lease_Amount = getDefaultConfig.Base_Lease_Amount;
											input.Do_you_want_configure_penalty = getDefaultConfig.Do_you_want_configure_penalty;
											input.Penalty_Payment_Method = getDefaultConfig.Penalty_Payment_Method;
											input.Fixed_Penalty_Amount = getDefaultConfig.Fixed_Penalty_Amount;
											input.Penalty = getDefaultConfig.Penalty;
											input.Grace_Days_For_Monthly_Payment = getDefaultConfig.Grace_Days_For_Monthly_Payment;
											input.Bill_Generation = getDefaultConfig.Bill_Generation;
											input.After_Due_Date = getDefaultConfig.After_Due_Date;
											input.Do_You_Want_Configure_Manager_Commission = getDefaultConfig.Do_You_Want_Configure_Manager_Commission;
											input.Do_you_want_configure_Additional_Payment_Monthly = getDefaultConfig.Do_you_want_configure_Additional_Payment_Monthly;
											input.Category = getDefaultConfig.Category;
											input.Rental_Monthly = getDefaultConfig.Rental_Monthly;
											input.Complaint = getDefaultConfig.Complaint;
											input.Agreement = getDefaultConfig.Agreement;
											additional_payment = Collection();
											input.Additional_Payment_Monthly.clear();
											for each  additional_subform in getDefaultConfig.Additional_Payment_Monthly
											{
												addition_row = Configure.Additional_Payment_Monthly();
												addition_row.Pay_For=additional_subform.Pay_For;
												addition_row.Amount=additional_subform.Amount;
												addition_row.Amount_Display=additional_subform.Amount_Display;
												addition_row.Description=additional_subform.Description;
												addition_row.Configure=additional_subform.Configure;
												additional_payment.insert(addition_row);
											}
											input.Additional_Payment_Monthly.insert(additional_payment);
											disable Do_you_want_configure_Additional_Payment_Monthly;
											disable Base_Rental_Monthly_Amount;
											disable Security_Deposit;
											disable Do_you_want_configure_penalty;
											disable Penalty_Payment_Method;
											disable Penalty;
											disable Fixed_Penalty_Amount;
											disable Base_Lease_Amount;
											disable Grace_Days_For_Monthly_Payment;
											disable Bill_Generation;
											disable After_Due_Date;
											disable Do_You_Want_Configure_Manager_Commission;
											disable Category;
											disable Rental_Monthly;
											disable Complaint;
											disable Agreement;
											disable Additional_Payment_Monthly.Pay_For;
											disable Additional_Payment_Monthly.Amount;
											disable Additional_Payment_Monthly.Description;
										}
										else if(input.Configure1 == "Modified")
										{
											clear Additional_Payment_Monthly;
											show Property;
											show Unit;
											enable Base_Rental_Monthly_Amount;
											enable Security_Deposit;
											enable Do_you_want_configure_penalty;
											enable Penalty_Payment_Method;
											enable Penalty;
											enable Fixed_Penalty_Amount;
											enable Base_Lease_Amount;
											enable Grace_Days_For_Monthly_Payment;
											enable Bill_Generation;
											enable After_Due_Date;
											enable Do_You_Want_Configure_Manager_Commission;
											enable Category;
											enable Rental_Monthly;
											enable Complaint;
											enable Agreement;
											hide Category;
											hide Rental_Monthly;
											hide Complaint;
											hide Agreement;
											enable Additional_Payment_Monthly.Pay_For;
											enable Additional_Payment_Monthly.Amount;
											enable Additional_Payment_Monthly.Description;
											// 	Rental
											input.Base_Rental_Monthly_Amount = null;
											input.Security_Deposit = null;
											// 	Lease
											input.Base_Lease_Amount = null;
											input.Do_you_want_configure_penalty = null;
											input.Penalty_Payment_Method = null;
											input.Fixed_Penalty_Amount = null;
											input.Penalty = null;
											input.Grace_Days_For_Monthly_Payment = null;
											input.Bill_Generation = null;
											input.After_Due_Date = null;
											input.Do_You_Want_Configure_Manager_Commission = null;
											input.Category = null;
											input.Rental_Monthly = null;
											input.Complaint = null;
											input.Agreement = null;
											enable Do_you_want_configure_Additional_Payment_Monthly;
											input.Do_you_want_configure_Additional_Payment_Monthly = null;
										}
						)
					}
				}

			}
			Add_data_in_complaints as "Add data in complaints"
			{
				type =  form
				form = Work_Order_Complete
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						complaint = Raise_a_Complaint[ID == input.Work_Order];
										complaint.Vendor_Update=input.Vendor_Update;
										complaint.Complaint_Amount=input.Work_Order_Amount;
										complaint.Complaint_Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Work_Order_Amount);
										complaint.Complaint_Status="Work Order Completed";
										complaint.Resolved_Date=zoho.currentdate;
										complaint.End_Time=zoho.currenttime;
										login_profile = thisapp.permissions.loginUserProfile();
										if(input.Action_field == "Direct_Approval")
										{
											complaint.Start_Time=input.Start_Date;
										}
										complaint.Duration=thisapp.Get_Duration_Time(complaint.ID);
										if(thisapp.Get_Logged_In_Profile() == "Administrator" || login_profile == "Admin")
										{
											openUrl("#Script:dialog.closeAll","same window");
											openUrl("#Form:Work_Order_Payment?Work_Order=" + complaint.ID + "&Property=" + complaint.Property + "&Unit=" + complaint.Unit + "&Vendor_Update=" + complaint.Vendor_Update + "&Complaint_Amount=" + complaint.Complaint_Amount + "&Page_Link_Name=Approval","popup window");
										}
										else
										{
											// 	thisapp.mail.SendToVendorComplaintCompleted(complaint.ID);
											// 	thisapp.mail.SendToApproverComplaintPayementDecision(complaint.ID);
											openUrl("#Page:Vendor_Profile?tab=vendor-payments","same window");
										}
					)
					}
				}
			}
