			Onload4 as "Onload"
			{
				type =  form
				form = Received_Popup_Form
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											language = thisapp.Localization.Alert();
										input.plain = thisapp.Styles_Popup.Active() + "<style>.zcform_Received_Popup_Form {width: 450px;}</style><div class='zc-prop-popup-content zc-prop-active-popup'><div class='zc-prop-icon-wrapper'><i class='zc-li-outline zc-li-outline ui-1-check-circle-08'></i></div><h4>" + language.get("zcpm.Received") + "</h4><p>" + language.get('zcpm.received.popup') + "<b>" + input.Billing_ID.Pay_For + input.Billing_ID.Amount_Display + language.get('zcpm.question.mark') + "<b></p></div>";
						)
					}
				}

			}
			Status_Update2 as "Status Update"
			{
				type =  form
				form = Received_Popup_Form
				button = Received
				on click
				{
					actions 
					{
					on click
					(
						bill = Add_Payment_Notes[ID == input.Billing_ID];
										bill.Status="Received";
										bill.Payment_Date=zoho.currentdate;
										login_profile = thisapp.permissions.loginUserProfile();
										if(input.Compliant_No != null)
										{
											complaint = Raise_a_Complaint[ID == input.Compliant_No];
											complaint.Complaint_Status="Completed";
											if(login_profile != "Vendor")
											{
												openUrl("#Script:page.reload","same Window");
											}
											else
											{
												openUrl("#Page:Vendor_Profile?tab=completed-complaints","same window");
											}
										}
										else if(input.Action_field == "direct_approval" && input.Compliant_No == null)
										{
											id = ID_Setup[ID != 0];
											bill = Add_Payment_Notes[ID == input.Billing_ID.ID];
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											bill.Payment_Date=zoho.currentdate;
											openUrl("#Script:page.reload","same Window");
										}
										else if(bill.Pay_For == "Security Deposit" || bill.Pay_For == "Vacate")
										{
											thisapp.mail.SendToTenantSecurityDepositPaymentConfirmation(bill.ID);
											timeline_adding = insert into Timeline_Form
											[
												Added_User=zoho.loginuser
												New_User=thisapp.get_user_id()
												Vacate_Request=bill.Vacate_Request
												Action_field="Security Deposit Refunded"
											];
											openUrl("#Script:page.reload","same Window");
										}
										else
										{
											thisapp.mail.SendToTenantPaymentConfir(bill.ID);
											openUrl("#Script:page.reload","same Window");
										}
					)
					}
				}
			}
			On_Success_Submit8 as "On Success Submit"
			{
				type =  form
				form = Agree_Popup_Form
				button = Agree
				on click
				{
					actions 
					{
					on click
					(
						vacate = Vacate_Request[ID == input.Inspection_Form.Vacate_Request];
										vacate.Vacate_Status="Tenant Approved";
										inspection = Inspection_Form[ID == input.Inspection_Form];
										inspection.Status="Tenant Agree";
										timeline_adding = insert into Timeline_Form
										[
											Added_User=zoho.loginuser
											New_User=thisapp.get_user_id()
											Vacate_Request=vacate.ID
											Action_field="Tenant Approved"
										];
										id = ID_Setup[ID != 0];
										agreement = Tenant_Agreement[Unit == inspection.Unit && Agreement_Status == "Active"];
										advance = insert into Add_Payment_Notes
										[
											Total_Amount=inspection.Balance_Amount
											Amount_Display=thisapp.Currency.currencyDisplayFormat(inspection.Balance_Amount)
											Unit=inspection.Unit
											Property=inspection.Property
											Added_User=zoho.loginuser
											Payment_Type="Expense"
											Payment_Date=zoho.currentdate
											Vacate_Request=inspection.Vacate_Request
											Status="Unpaid"
											Pay_For="Vacate"
											Due_Date=vacate.Vacate_Date
											Payer=inspection.Unit.Owner_Mail_ID
											Tenant_Agreement=agreement.ID
										];
										bill = Add_Payment_Notes[ID == advance];
										bill.Billing__ID=id.Bill_No + bill.Bill_No;
										payfor = Pay_For_Monthly[Pay_For == "Vacate"];
										payment_details = insert into Payment_Details
										[
											Added_User=zoho.loginuser
											Pay_For=payfor.ID
											Add_Property=inspection.Property
											Add_Unit=inspection.Unit
											Amount=inspection.Balance_Amount
											Amount_Display=inspection.Balance_Amount_Display
											Description="Vacate on Security Deposit"
											Add_Payment_Notes=advance
										];
										if(inspection.Pending_Amount > 0)
										{
											for each  pending_payment in Add_Payment_Notes[Status == "Unpaid" && Unit == inspection.Unit && Pay_For == "Monthly Payments" || Pay_For == "Complaint"]
											{
												pending_payment.Status="Received";
											}
										}
										if(inspection.Complaints_Amount != null && inspection.Complaints_Amount > 0)
										{
											pay1 = insert into Add_Payment_Notes
											[
												Total_Amount=inspection.Complaints_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(inspection.Complaints_Amount)
												Unit=inspection.Unit
												Property=inspection.Property
												Added_User=zoho.loginuser
												Payment_Type="Income"
												Payment_Date=zoho.currentdate
												Vacate_Request=inspection.Vacate_Request
												Status="Received"
												Pay_For="Vacate Complaints"
												Payer=inspection.Tenant_Agreement.Tenant
												Total_Amount=inspection.Complaints_Amount
											];
											bill = Add_Payment_Notes[ID == pay1];
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											payfor = Pay_For_Monthly[Pay_For == "Vacate Complaints"];
											payment_details = insert into Payment_Details
											[
												Added_User=zoho.loginuser
												Pay_For=payfor.ID
												Add_Property=inspection.Property
												Add_Unit=inspection.Unit
												Amount=inspection.Complaints_Amount
												Amount_Display=inspection.Complaints_Amount_Display
												Description="Vacate on Security Deposit"
												Add_Payment_Notes=pay1
											];
										}
										openUrl("#Script:page.reload","same window");
					)
					}
				}
			}
			Field_rules6 as "Field rules"
			{
				type =  form
				form = Agree_Popup_Form
				record event = on add

				field rules
				{
					actions 
					{
						hide Inspection_Form;
