		list Work_Order_Vendor
		{
			displayName = "Work Order Vendor"
			show all rows from Raise_a_Complaint  [Complaint_Status == "In Progress" && Assigned_to.Vendor_Email == zoho.loginuserid]  
			(
				Date_of_Reporting as "Date of Reporting"
				Property
				Unit
				Tenant_Email as "Tenant"
				Location
				Owner_Email as "Owner Email"
				Manager
				Assigned_to as "Assigned to"
				Maintenance_Service as "Maintenance Service"
				Complaint_Status as "Complaint Status"
				Resolved_Date as "Resolved Date"
				Complaint_About as "Complaint About"
				Photo
				Complaint_Details as "Complaint Details"
				Payment_By as "Payment By"
				Complaint_Amount as "Complaint Amount"
				custom action "Complete"
				(
	  			workflow = Complete
				show action in edit record menu = true
				column header = "Complete"
				condition = (Complaint_Status == "In Progress")
				)
				Property.ID
				Unit.ID
				ID
				Priority
			)
			conditional formatting
			(
				"Low"
				{
				condition = (Priority == "Low")
				fields = [Priority]
				format = "color:#f4c01a;"
				}
				"Medium"
				{
				condition = (Priority == "Medium")
				fields = [Priority]
				format = "color:#f39c12;"
				}
				"High"
				{
				condition = (Priority == "High")
				fields = [Priority]
				format = "color:#f4603e;"
				}
				"Very High"
				{
				condition = (Priority == "Very High")
				fields = [Priority]
				format = "color:#c0392b;"
				}
			)
		}
		list Work_Order_Completion
		{
			displayName = "Work Order Completion"
			show all rows from Raise_a_Complaint  [Complaint_Status == "Work Order Completed" || Complaint_Status == "Waiting for Payment" || Complaint_Status == "Paid" && Manager.Email == zoho.loginuserid]  
			(
				Date_of_Reporting as "Date of Reporting"
				Work_Order_Number as "Work Order Number"
				Property
				Unit
				Tenant_Email as "Tenant"
				Location
				Owner_Email as "Owner Email"
				Manager
				Assigned_to as "Assigned to"
				Maintenance_Service as "Maintenance Service"
				Complaint_Status as "Status"
				Resolved_Date as "Resolved Date"
				Complaint_About as "Complaint About"
				Photo
				Complaint_Details as "Complaint Details"
				Vendor_Update as "Vendor Update"
				Payment_By as "Payment By"
				Complaint_Amount as "Complaint Amount"
				custom action "Assign Pay"
				(
	  			workflow = Payment
				show action in edit record menu = true
				column header = "Assign Pay"
				condition = (Complaint_Status == "Work Order Completed")
				)
				Complaint_Amount_Display as "Complaint Amount"
				Property.ID
				Unit.ID
				Maintenance_Service.ID
				ID
				Assigned_to.Vendor_Name as "Vendor"
				Complaints_No as "Work Order"
			)
			custom actions
			(
				"Detail View-Work_Order_Completion"
				(
	  			workflow = Detail_View_Work_Order_Co
				show action in view header = true
				show action in edit record menu = true
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Complaint_Status == "Requested")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
				"Vendor Assigned"
				{
				condition = (Complaint_Status == "Vendor Assigned")
				fields = [Complaint_Status]
				format = "color:#1c63b4;"
				}
				"In Progress"
				{
				condition = (Complaint_Status == "In Progress")
				fields = [Complaint_Status]
				format = "color:#5051f9;"
				}
				"Complaint Reviewed"
				{
				condition = (Complaint_Status == "Complaint Reviewed")
				fields = [Complaint_Status]
				format = "color:#1fbac6;"
				}
				"Rejected"
				{
				condition = (Complaint_Status == "Rejected")
				fields = [Complaint_Status]
				format = "color:#fe455d;"
				}
				"Completed"
				{
				condition = (Complaint_Status == "Work Order Completed" || Complaint_Status == "Paid" || Complaint_Status == "Completed")
				fields = [Complaint_Status]
				format = "color:#187822;"
				}
				"Waiting for Payment"
				{
				condition = (Complaint_Status == "Waiting for Payment")
				fields = [Complaint_Status]
				format = "color:#b8770d;"
				}
			)
		}
