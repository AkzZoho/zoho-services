				 void mail.SendToOwnerInspectionReportWithComplaints(int inspection_rec_id)
                 {
                 	mail_template = Email_Template[Template_Name == "Vacate Inspection Report to Owner With Complaints" && Send_To == "Owner" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0)
                 	{
                 		inspection = Inspection_Form[ID == input.inspection_rec_id];
                 		complaint = Inspection_Complaints[Inspection_Form.ID == inspection.ID];
                 		unit = Add_Unit[ID == inspection.Unit];
                 		msg = mail_template.Message;
                 		general = General[ID != 0];
                 		msg = msg.replaceAll("${Owner_Name}",unit.Owner_Mail_ID.Name.first_name + " " + unit.Owner_Mail_ID.Name.last_name,true);
                 		msg = msg.replaceAll("${Unit_Name}",unit.Unit_Name,true);
                 		msg = msg.replaceAll("${Inspected_Date}",inspection.Inspection_Date.toString(),true);
                 		msg = msg.replaceAll("${Added_User}",inspection.Added_User,true);
                 		msg = msg.replaceAll("${Security_Deposit}",thisapp.Currency.numberFormatAccurate(inspection.Tenant_Agreement.Security_Deposit,general.Currency),true);
                 		msg = msg.replaceAll("${Complaint_Amount}",thisapp.Currency.numberFormatAccurate(inspection.Complaints_Amount,general.Currency),true);
                 		msg = msg.replaceAll("${Balance_Amount}",thisapp.Currency.numberFormatAccurate(inspection.Balance_Amount,general.Currency),true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		list_of_complaint = "";
                 		complaint = msg.getsuffix("<tr id=\"List_of_Complaints\">").getprefix("</tr>");
                 		for each  inspe_comp in inspection.Complaints
                 		{
                 			if(inspe_comp.Cost > 0)
                 			{
                 				temp_comp = complaint;
                 				temp_comp = temp_comp.replaceAll("${Complaint_About}",inspe_comp.Compliant_About,true);
                 				temp_comp = temp_comp.replaceAll("${Description}",if(inspe_comp.Description.isEmpty(),"-",inspe_comp.Description),true);
                 				temp_comp = temp_comp.replaceAll("${Amount}",thisapp.Currency.numberFormatAccurate(inspe_comp.Cost,general.Currency),true);
                 				list_of_complaint = list_of_complaint + "<tr>" + temp_comp + "</tr>";
                 			}
                 		}
                 		msg = msg.replaceAll("<tr id=\"List_of_Complaints\">" + complaint + "</tr>",list_of_complaint,true);
                 		thisapp.mail.sendMailTask(unit.Owner_Mail_ID.Email.toList(),mail_template.Subject_field,msg);
                 	}
                 }
