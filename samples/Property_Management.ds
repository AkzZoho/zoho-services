	      			enable = Link_to_Map,Show_As_Text
	 			)
				Owner_Mail_ID as "Owner"
				Occupancy_Type as "Occupancy Type"
				ID
				Owner_Approval_Status as "Owner Approval Status"
				Unit_Type as "Unit Type"
				Parking_Image as "Parking Image"
				Parking_No as "Parking No"
