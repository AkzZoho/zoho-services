				(
	  			workflow = Approve_Tenant
				show action in edit record menu = true
				column header = "Approve"
				condition = (Tenant_Status == "Waiting for Approval" && Unit.Owner_Mail_ID == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id() || Property.Admins == thisapp.get_user_id())
