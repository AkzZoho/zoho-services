ll; border: none; text-align: right\"><span>${Amount_Display}<\/span><span\n          style=\"color: rgb(34, 35, 38); font-family: Lato, Arimo, sans-serif; font-size: 14px; font-weight: 400; font-style: normal\">&nbsp;<\/span><br /><\/td>\n     <\/tr>\n     <tr>\n      <td\n          style=\"border-right: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); border-right: 1px solid rgb(51, 51, 51); border-bottom: 1px solid rgb(51, 51, 51); font-size: 14px; line-height: 1.5; letter-spacing: 0.1px; padding: 12px 16px; text-align: left; color: rgb(34, 35, 38); font-weight: 600; border-top: 1px solid rgb(235, 239, 239); word-break: break-all; border-width: 1px 0px 0px 0px; border-radius: 0px 0px 0px 3px\"><br /><\/td>\n      <td\n          style=\"border-bottom: 1px solid rgb(51, 51, 51); border-right: 1px solid rgb(51, 51, 51); font-size: 14px; line-height: 1.5; letter-spacing: 0.1px; padding: 12px 16px; text-align: left; color: rgb(34, 35, 38); font-weight: 600; border-top: 1px solid rgb(235, 239, 239); word-break: break-all; border-width: 1px 0px 0px 0px; text-align: right\">Total<\/td>\n      <td\n            style=\"border-bottom: 1px solid rgb(51, 51, 51); font-size: 14px; line-height: 1.5; letter-spacing: 0.1px; padding: 12px 16px; text-align: left; color: rgb(34, 35, 38); font-weight: 600; border-top: 1px solid rgb(235, 239, 239); word-break: break-all; border-width: 1px 0px 0px 0px; text-align: right; border-radius: 0px 0px 3px 0px\"><span>${Amount_Display}<\/span><span style=\"color: rgb(68, 68, 68); font-family: Lato, Arimo, sans-serif; font-size: 14px; font-weight: 400; font-style: normal\">&nbsp;<\/span><br /><\/td>\n     <\/tr>\n    <\/tbody>\n   <\/table>\n  <\/div>"}}]}]}},{"type":"columns","element":{"split":"100","id":"u_elem_3700275100000024","elemStyle":"","collayouts":[{"colElements":[{"type":"text","element":{"id":"u_elem_3700274699999988","fields":[],"content":"<div style=\"background: rgba(0, 0, 0, 0); padding: 0px\">\n   <p\n     