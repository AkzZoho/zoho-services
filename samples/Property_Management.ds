				 string Get_Duration_Time(int rec_id)
                 {
                 	// Define the two dates
                 	complaint = Raise_a_Complaint[ID == input.rec_id];
                 	start_time = complaint.Start_Time;
                 	end_time = complaint.End_Time;
                 	start_sec = start_time.toLong();
                 	end_sec = end_time.toTime().toLong();
                 	UnixSeconds = end_sec - start_sec;
                 	Days = floor((((UnixSeconds / 1000) / 60) / 60) / 24);
                 	UnixSeconds = UnixSeconds - Days * 1000 * 60 * 60 * 24;
                 	Hours = floor(((UnixSeconds / 1000) / 60) / 60);
                 	UnixSeconds = UnixSeconds - Hours * 1000 * 60 * 60;
                 	Minutes = floor((UnixSeconds / 1000) / 60);
                 	UnixSeconds = UnixSeconds - Minutes * 1000 * 60;
                 	Seconds = floor(UnixSeconds / 1000);
                 	startDateTime = complaint.Start_Time.toString("yyyy-MM-dd'T'HH:mm:ss");
                 	endDateTime = complaint.End_Time.toString("yyyy-MM-dd'T'HH:mm:ss");
                 	startYear = complaint.Start_Time.getYear();
                 	startMonth = complaint.Start_Time.getMonth();
                 	startDay = complaint.Start_Time.getDay();
                 	endYear = complaint.End_Time.getYear();
                 	endMonth = complaint.End_Time.getMonth();
                 	endDay = complaint.End_Time.getDay();
                 	yearDifference = endYear - startYear;
                 	monthDifference = endMonth - startMonth;
                 	if(monthDifference < 0)
                 	{
                 		yearDifference = yearDifference - 1;
                 		monthDifference = monthDifference + 12;
                 	}
                 	if(endDay < startDay)
                 	{
                 		monthDifference = monthDifference - 1;
                 	}
                 	output = "";
                 	// 	if(yearDifference > 0)
                 	// 	{
                 	// 		output = yearDifference + " Years, ";
                 	// 	}
                 	// 	if(monthDifference > 0)
                 	// 	{
                 	// 		output = output + monthDifference + " Months, ";
                 	// 	}
                 	if(Days > 1)
                 	{
                 		output = output + Days + " Days, ";
                 	}
                 	if(Days == 1)
                 	{
                 		output = output + Days + " Day, ";
                 	}
                 	if(Hours > 1)
                 	{
                 		output = output + Hours + " Hours";
                 		output = if(Minutes > 0,output + ", ",output + ".");
                 	}
                 	if(Hours == 1)
                 	{
                 		output = output + Hours + " Hour, ";
                 	}
                 	if(Minutes > 0)
                 	{
                 		output = output + Minutes + " Minutes.";
                 	}
                 	return output;
                 }
