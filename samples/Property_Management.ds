		form Add_Property
		{
			displayname = "Add Property"
			success message = "Property Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have unique Property_Name
			(
    			type = text
				displayname = "Property Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Property_Type
			(
				type = picklist
				displayname = "Property Type"
				maxchar = 100
				values = {"Residential","Commercial","Industrial","Office","Land"}
				sortorder = ascending
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Size
			(
				type = number
				displayname = "Size (in Sq . ft)"
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Location
			(
				type = picklist	
				values  = Location.ID
    			displayformat = [Location]
				allow new entries
				[
					displayname = "Add New Location"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Manager
			(
				type = picklist	
				displayname = "Manager Email ID"
				values  = New_User[Role == "Manager" || Role_Admin == "Manager"].ID
    			displayformat = [Name.first_name + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			No_of_Blocks
			(
				type = number
				displayname = "No of Blocks"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Property_Address
			(
    			type = address
				displayname = "Property Address"
     			capture_coordinates = true
     			adjust_using_map = false
     			address_line_1
     			(
	     			  type = address_line_1
	     			  displayname = "Address Line 1"
     			) 
     			address_line_2
     			(
	     			  type = address_line_2
	     			  displayname = "Address Line 2"
     			) 
     			district_city
     			(
	     			  type = district_city
	     			  displayname = "City / District"
     			) 
     			state_province
     			(
	     			  type = state_province
	     			  displayname = "State / Province"
     			) 
     			postal_Code
     			(
	     			  type = postal_Code
	     			  displayname = "Postal Code"
     			) 
     			country
     			(
	     			  type = country
	     			  displayname = "Country"
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "latitude"
	     			 visibility = false
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "longitude"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Image
			(
    			type = image
				source  = public_url,file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 2   
				width = medium
			)
			Amenities
			(
				type = list	
				values  = Amenities.ID
    			displayformat = [Amenities]
				allow new entries
				[
					displayname = "Add New Amenities"
				]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 2   
				width = medium
			)
			Mark_it_as_single_unit_property1
			(
    			type = checkbox
				displayname = "Mark it as single unit property"
				initial value = false
    			description
    			[
    				type = none
    			 	message = "This property will be considered as a unit."
    			]
	 			row = 1
	 			column = 2   
				width = medium
			)
			Documents_Document_Name
			(
				type = list	
				displayname = "Documents"
				values  = Documents.ID
    			bidirectional = Property
    			displayformat = [Document_Name]
				allow new entries
				[
					displayname = "Add New"
				]
				height = 60px
	 			row = 1
	 			column = 2   
				width = medium
			)
			Property_Vendors
			(
				type = list	
				displayname = "Property Vendors"
				values  = Add_Vendor.ID
    			bidirectional = Properties
    			displayformat = [Vendor_Name]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 2   
				width = medium
			)
			No_of_Parking_Slots
			(
				type = number
				displayname = "No of Parking Slots(if Available)"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Blocks
			(
				type = grid
				values  = Add_Block.ID
    			bidirectional = Property
	 			row = 2
	 			column = 1   
				width = medium
			)
			Hide
			(
				type = section
	 			row = 3
	 			column = 0   
				width = medium
			)
			Property_Status
			(
				type = picklist
				displayname = "Property Status"
				maxchar = 100
				values = {"Active","Inactive"}
				initial value = "Active"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Unit_Owners
			(
				type = list	
				displayname = "Unit Owners"
				values  = New_User.ID
    			displayformat = [Email]
				sortorder = ascending
				height = 60px
	 			row = 3
	 			column = 1   
				width = medium
			)
			Units
			(
				type = list	
				values  = Add_Unit.ID
    			bidirectional = Property
    			displayformat = [Unit_Name]
				sortorder = ascending
				height = 60px
	 			row = 3
	 			column = 1   
				width = medium
			)
			Admins
			(
				type = list	
				values  = New_User.ID
    			displayformat = [" " + Name.prefix + " " + Name.first_name + " " + Name.last_name + " " + Name.suffix]
				sortorder = ascending
				height = 60px
	 			row = 3
	 			column = 1   
				width = medium
			)
			No_of_Parking_Occupied
			(
				type = number
				displayname = "No of Parking Occupied"
				initial value = 0
	 			row = 3
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Add"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
				}
			}
		}
		form Add_Unit
		{
			displayname = "Add Unit"
			success message = "Unit Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Property
			(
				type = picklist	
				values  = Add_Property.ID
    			bidirectional = Units
    			displayformat = [Property_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Block
			(
				type = picklist	
				values  = Add_Block.ID
