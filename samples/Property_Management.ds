		list Rent_Vacate_Request_Manager
		{
			displayName = "Rent Vacate Request - Manager"
			show all rows from Vacate_Request  [Tenant_Agreement.Agreement_Type == "Rent" && Property.Manager == thisapp.get_user_id() || Unit.Manager == thisapp.get_user_id()]  
			(
				Property
				Unit
				Tenant
				Tenant_Agreement.Security_Deposit_Display as "Security Deposit"
				Tenant_Agreement.Base_Rent_Display as "Base Rent"
				Unit.ID
				Unit_Owner as "Owner"
				Vacate_Date as "Vacate Date"
				Tenant_Agreement.Agreement_No as "Agreement No"
				Vacate_Status as "Vacate Status"
				Property.ID
			)
			custom actions
			(
				"Detail View - Rent_Vacate_Request_Manager"
				(
	  			workflow = Detail_View_Rent_Vacate_R
				)
				"Inspection"
				(
	  			workflow = Inspection_Lease_Vacant_U
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
				"Edit 1"
				(
	  			workflow = Edit_Rent_Vacate_Request_
				show action in edit record menu = true
				condition = (Vacate_Status == "Requested")
				)
			)
			conditional formatting
			(
				"Requested"
				{
				condition = (Vacate_Status == "Requested" || Vacate_Status == "Waiting for Manager Approval" || Vacate_Status == "Waiting for Owner Approval" || Vacate_Status == "Waiting for Tenant Approval")
				fields = [Vacate_Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Vacate_Status == "Owner Approved" || Vacate_Status == "Tenant Approved")
				fields = [Vacate_Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Vacate_Status == "Rejected By Owner" || Vacate_Status == "Admin Rejected")
				fields = [Vacate_Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Vacate_Status == "Tenant Vacated")
				fields = [Vacate_Status]
				format = "color:#5051f9;"
				}
			)
		}
