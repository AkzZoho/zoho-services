			User_input_of_Configure_M as "User input of Configure  Manager Commission"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Do_You_Want_Configure_Manager_Commission
				{
					actions 
					{
						custom deluge script
						(
											if(input.Do_You_Want_Configure_Manager_Commission == "Yes")
										{
											show Category;
										}
										else if(input.Do_You_Want_Configure_Manager_Commission == "No")
										{
											hide Category;
											hide Rental_Monthly;
											hide Complaint;
											hide Agreement;
											category = List();
											input.Category = category;
											input.Rental_Monthly = null;
											input.Complaint = null;
											input.Agreement = null;
										}
						)
					}
				}

			}
			User_input_of_Category as "User input of Category"
			{
				type =  form
				form = Configure
				record event = on add or edit

				on user input of Category
				{
					actions 
					{
						custom deluge script
						(
											if(input.Category.contains("Rental Monthly"))
										{
											show Rental_Monthly;
										}
										else
										{
											hide Rental_Monthly;
											input.Rental_Monthly = null;
										}
										if(input.Category.contains("Complaint"))
										{
											show Complaint;
										}
										else
										{
											hide Complaint;
											input.Complaint = null;
										}
										if(input.Category.contains("Agreement"))
										{
											show Agreement;
										}
										else
										{
											hide Agreement;
											input.Agreement = null;
										}
						)
					}
				}

			}
