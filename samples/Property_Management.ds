											peram = peram + if(!input.Payment_Status.isEmpty(),"&Add_Payment_Notes.Status=" + input.Payment_Status + "&Add_Payment_Notes.Status_op=18","");
											peram = peram + if(!input.Pay_For.isEmpty(),"&Add_Payment_Notes.Pay_For=" + input.Pay_For + "&Add_Payment_Notes.Pay_For_op=18","");
											peram = peram + if(!input.Payment_Type.isEmpty(),"&Add_Payment_Notes.Payment_Type=" + input.Payment_Type + "&Add_Payment_Notes.Payment_Type_op=18","");
											peram = peram + if(!input.Search.isEmpty(),"&Add_Payment_Notes.Billing__ID=" + input.Search + "&Add_Payment_Notes.Billing__ID_op=26","");
										}
										else
										{
											peram = if(input.Property != null,"&Property.ID=" + input.Property.ID + "&Property.ID_op=18","");
											peram = peram + if(input.Unit != null,"&Unit.ID=" + input.Unit.ID + "&Unit.ID_op=18","");
											peram = peram + if(!input.Payment_Status.isEmpty(),"&Status=" + input.Payment_Status + "&Status_op=18","");
											peram = peram + if(!input.Payment_Type.isEmpty(),"&Payment_Type=" + input.Payment_Type + "&Payment_Type_op=18","");
											peram = peram + if(!input.Pay_For.isEmpty(),"&Pay_For=" + input.Pay_For + "&Pay_For_op=18","");
											search_result = Add_Payment_Notes[Billing__ID.containsIgnoreCase(input.Search)].ID.getAll();
											search_result = if(search_result.size() == 0,1234,search_result);
											peram = peram + if(!input.Search.isEmpty(),"&ID=" + encodeUrl("[" + search_result + "]") + "&ID_op=72","");
										}
										perPeram = if(input.Page == "Accounting","?Bill_No=00&Bill_No_op=19","");
										export_url = export_url + input.Report + perPeram + peram;
										input.Option_Notes = "<div class='zc-prop-more-options zc-prop-square'> <div class='zc-prop-hover-extend'></div> <i class='fa fa-bars'></i> <ul> <li> <a href='" + import_url + "'> <i class='zc-li-outline arrows-2-file-download-87'></i> <span>" + language.get("zcpm.common.import") + "</span> </a> </li> <li> <a href='" + export_url + "'> <i class='zc-li-outline arrows-2-file-upload-86'></i> <span>" + language.get("zcpm.common.export") + "</span> </a> </li> </ul> </div>";
										openUrl(reportURL + peram + "&zc_LoadIn=embed-" + input.Page,"same window");
						)
					}
				}

			}
			Disable_fields2 as "Disable fields"
			{
				type =  form
				form = New_User
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Email;
										hide Property;
										hide Unit;
										prop = input.Property;
										unit = input.Unit;
										login_profile = thisapp.permissions.loginUserProfile();
										if(input.Role == "Tenant" && input.Tenant_First_Agreement == false)
										{
											show Unit;
											show Property;
											if(login_profile == "Owner")
											{
												property = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
											else if(login_profile == "Manager")
											{
												property = Add_Unit[Manager.Email == zoho.loginuserid && Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
											else if(login_profile in {"Admin","Administrator","Developer"})
											{
												// 		alert "hello";
												property = Add_Unit[Availability == "Vacant" && Owner_Approval_Status == "Approved"].Property.ID.getAll();
												input.Property:ui.add(property.distinct());
											}
										}
										input.Property = prop;
										input.Unit = unit;
						)
					}
				}

			}
			Alert_new_user as "Alert new user"
			{
				type =  form
				form = New_User
				record event = on add
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										user = New_User[Role == "Tenant" && Email == zoho.loginuserid];
										if(user.Email == zoho.loginuserid)
										{
											alert language_alert.get("zcpm.permission.denied");
											cancel submit;
										}
										vendor = Add_Vendor[Vendor_Email == input.Email];
										if(vendor.count() > 0)
										{
											alert language_alert.get("zcpm.alert.email.already.in.vendor");
											cancel submit;
										}
										user = New_User[Email == input.Email && Role != "Tenant"];
										tenant_user = New_User[Email == input.Email && Role == "Tenant" && Tenant_Status == "Waiting for Approval" || Tenant_Status == "Screening In Process" || Tenant_Status == "Approved"];
										if(user.count() > 0 || tenant_user.count() > 0)
										{
											alert language_alert.get("zcpm.user.alert2");
											cancel submit;
										}
										if(input.Role == "Tenant" && input.Property == null)
										{
											alert language_alert.get("zcpm.select.property.tenant");
											cancel submit;
										}
										if(input.Role == "Tenant" && input.Unit == null)
										{
											alert language_alert.get("zcpm.select.unit.tenant");
											cancel submit;
										}
										org = Organization[ID != 0];
										if(input.Role == "Tenant" && org.Tenant == "Customer Portal")
										{
											try 
											{
												thisapp.portal.assignUserInProfile(input.Email,"Tenant");
											}
											catch (e)
											{
												alert "Customer Portal not created.";
												cancel submit;
											}
										}
										else
										{
											thisapp.permissions.assignUserInProfile(input.Email,input.Role,true);
										}
						)
					}
				}

			}
			Edit_On_load as "Edit On load"
			{
				type =  form
				form = Add_Unit
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Property;
										disable Occupancy_Type;
										unit = Add_Unit[ID == input.ID];
										if(unit.Availability == "Vacant" || unit.Availability == "New Unit")
										{
											enable Occupancy_Type;
										}
										hide Owner_Mail_ID;
										user_conf = User_Configuration[ID != 0];
										login_profile = thisapp.permissions.loginUserProfile();
										if(user_conf.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager" && login_profile in {"Admin","Administrator"})
										{
											show Owner_Mail_ID;
										}
						)
					}
				}

			}
			Subform_Disable as "Subform Disable"
			{
				type =  form
				form = Tenant_Agreement
				record event = on edit

				field rules
				{
					actions  (Status == "Requested" || Status == "Owner Approved")
					{
					show add row of Other_Occupants_Details;
					show delete row of Other_Occupants_Details;
					}
					actions  (Status == "Tenant Approved" || Status == "Owner Rejected" || Status == "Tenant Rejected" || Status == "Auto Rejected" || Status == "Vacate Requested" || Status == "Vacated" || Status == "Agreement Renewed")
					{
					hide add row of Other_Occupants_Details;
					hide delete row of Other_Occupants_Details;
					}
				}

			}
