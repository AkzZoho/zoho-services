pos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;renew&quot; &amp;&amp; Add_renew.count() &gt; 0)\n\t\t{\n\t\t\trenew = Renew_Agreement_Request[ID == input.rec_id];\n\t\t\tpage_link = &quot;&quot;;\n\t\t\tif(renew.Base_Agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t{\n\t\t\t\ttext = language.get(&quot;zcpm.Rental.Agreement&quot;);\n\t\t\t\tpage_link = &quot;Rental&quot;;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\ttext = language.get(&quot;zcpm.Lease.Agreement&quot;);\n\t\t\t\tpage_link = &quot;Lease&quot;;\n\t\t\t}\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(text,page_link_name + &quot;?tab=&quot; + input.tab,&quot;Tenant_Agreement&quot;,&quot;zc_Header=false&amp;Renew_Base_Agreement=&quot; + renew.Base_Agreement + &quot;&amp;Renew_Agreement_Request=&quot; + renew.ID + &quot;&amp;Agreement_Type=Rent&amp;zc_NextUrl=#Page:&quot; + page_link + &quot;?tab=allagreement&quot;)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;createUnitConfig&quot;)\n\t\t{\n\t\t\tunit = Add_Unit[ID == input.rec_id];\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Unit.Configure&quot;),page_link_name + &quot;?action=unitdetail&amp;rec_id=&quot; + input.rec_id + &quot;&amp;tab=&quot; + input.tab,&quot;Configure&quot;,&quot;zc_Header=false&amp;Configure1=Modified&amp;Property=&quot; + unit.Property.ID + &quot;&amp;Unit=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;paymentconfigedit&quot;)\n\t\t{\n\t\t\tunitConfig = Configure[ID == input.rec_id];\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Modified.Configuration&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + unitConfig.Unit + &quot;&amp;tab_detail=payment-configure&quot;,&quot;Configure&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Configure_Report&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + unitConfig.Unit.ID + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t}\n\t\telse if(unit.count() &gt; 0 || agreement.count() &gt; 0 || vacate_req.count() &gt; 0 || renew.count() &gt; 0 || complaint.count() &gt; 0 || tenant.count() &gt; 0)\n\t\t{\n\t\t\tif(input.action == &quot;unitedit&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Unit.Edit&quot;),page_link_name + &quot;?action=unitdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + input.rec_id,&quot;Add_Unit&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Units_Report&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=unitdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;tenantedit&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.tenant.edit.tenant&quot;),page_link_name + &quot;?action=tenantdetail&amp;tab=&quot; + input.tab + &quot;&amp;rec_id=&quot; + input.rec_id,&quot;New_User&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Tenant_Approval_Report_Direct&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=tenantdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;editnewagreements&quot; &amp;&amp; edit_agreement.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(&quot;Edit Tenant Agreement&quot;,page_link_name + &quot;?tab=&quot; + input.tab,&quot;Tenant_Agreement&quot;,&quot;zc_Header=false&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=agreementdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;editvacaterequests&quot; &amp;&amp; edit_vacate.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(&quot;Edit Vacate Request&quot;,page_link_name + &quot;?tab=&quot; + input.tab,&quot;Vacate_Request&quot;,&quot;zc_Header=false&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=vacatedetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;editcomplaints&quot; &amp;&amp; edit_complaint.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(&quot;Edit Complaint&quot;,page_link_name + &quot;?tab=&quot; + input.tab,&quot;Raise_a_Complaint&quot;,&quot;zc_Header=false&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?action=complaintdetail%26tab=&quot; + input.tab + &quot;%26rec_id=&quot; + input.rec_id + &quot;%26tab_detail=&quot; + input.tab_detail)%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;unitdetail&quot; &amp;&amp; unit.count() &gt; 0)\n\t\t\t{\n\t\t\t\tcolor = &quot;red&quot;;\n\t\t\t\tif(unit.Availability == &quot;New Unit&quot;)\n\t\t\t\t{\n\t\t\t\t\tcolor = &quot;green&quot;;\n\t\t\t\t}\n\t\t\t\telse if(unit.Availability == &quot;Vacant&quot;)\n\t\t\t\t{\n\t\t\t\t\tcolor = &quot;l_blue&quot;;\n\t\t\t\t}\n\t\t\t\telse if(unit.Availability == &quot;Occupied&quot;)\n\t\t\t\t{\n\t\t\t\t\tcolor = &quot;orange&quot;;\n\t\t\t\t}\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(unit.ID,unit.Unit_Image,&quot;Units_Report&quot;,&quot;Unit_Image&quot;,unit.Unit_Name,true);\n\t\t\t\tgetTabsLinkName = &quot;Units_Detail_View&quot;;\n\t\t\t\tList_Tabs = thisapp.Page.Get_Tab1(getTabsLinkName);\n\t\t\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\t\t\treport_filter = &quot;&quot;;\n\t\t\t\tunitConfig = Configure[Unit.ID == input.rec_id];\n\t\t\t\tdefaulfConfig = Configure[ID != 0 &amp;&amp; Configure1 == &quot;Default&quot;];\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-rental-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=units&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=unit.Property.Property_Name%&gt; - &lt;%=unit.Unit_Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n\t\t\t&lt;!-- span class=&apos;zc-prop-flt-left zc-prop-badge zc-prop-badge-&lt;%=color%&gt;&apos;&gt; &lt;%=unit.Availability%&gt; &lt;\/span --&gt;\n            &lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=unitedit&amp;rec_id=&lt;%=input.rec_id%&gt;&amp;tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=input.tab_detail%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\tif(unitConfig.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\tlink = &quot;#Page:&quot; + page_link_name + &quot;?action=paymentconfigedit&amp;rec_id=&quot; + unitConfig.ID + &quot;&amp;tab_detail=&quot; + input.tab_detail + &quot;&amp;tab=&quot; + input.tab;\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tlink = &quot;#Page:&quot; + page_link_name + &quot;?action=createUnitConfig&amp;rec_id=&quot; + input.rec_id + &quot;&amp;tab_detail=&quot; + input.tab_detail + &quot;&amp;tab=&quot; + input.tab;\n\t\t\t\t}\n\t\t\t\tif(input.tab_detail == &quot;payment-configure&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;&lt;%=link%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.property.Modified.Configure&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Approve_Confirmation?Add_Unit=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?Add_Unit=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n        &lt;\/div&gt;\n&lt;%\n\t\t\t\tprop_amenities = if(unit.Property.Amenities.size() &gt; 0,unit.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,unit.Property.Property_Type,unit.Owner_Mail_ID.Email,unit.Property.Location.Location,prop_amenities,unit.Address,unit.Size_in_Sq_ft)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\t\ttab_map_detail = thisapp.Page.Get_Tab1(&quot;Approval_Unit_Detail_View&quot;);\n\t\t\t\ttab_keys_detail = tab_map_detail.keys();\n\t\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null || !tab_keys_detail.contains(input.tab_detail),tab_keys_detail.get(0),input.tab_detail);\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\tfor each  main_tab in tab_keys_detail\n\t\t\t\t{\n\t\t\t\t\tclass_name = if(input.tab_detail == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=main_tab%&gt;&amp;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map_detail.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\t\treport_filter = &quot;&quot;;\n\t\t\t\tif(input.tab_detail == &quot;appliances&quot; || input.tab_detail.isEmpty())\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Add_Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t\telse if((unitConfig.count() &gt; 0 &amp;&amp; input.tab_detail == &quot;payment-configure&quot;) || input.tab_detail == &quot;previousOccupant&quot;)\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;documents&quot;)\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id + &quot;&amp;Property.ID=&quot; + unit.Property;\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;complaints&quot; || input.tab_detail == &quot;payments&quot;)\n\t\t\t\t{\n\t\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id;\n\t\t\t\t}\n\t\t\t\tif(input.tab_detail == &quot;payment-configure&quot;)\n\t\t\t\t{\n\t\t\t\t\tdefaultConfig = Configure[Configure1 == &quot;Default&quot;];\n\t\t\t\t\tunitConfig = Configure[Unit == input.rec_id];\n\t\t\t\t\tif(unitConfig.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\tconfig = unitConfig.Configure1;\n\t\t\t\t\t\tconfig_penalty = unitConfig.Do_you_want_configure_penalty;\n\t\t\t\t\t\tpenaltypaymentmethod = unitConfig.Penalty_Payment_Method;\n\t\t\t\t\t\tfixedamount = unitConfig.Fixed_Penalty_Amount;\n\t\t\t\t\t\tpercentage = unitConfig.Penalty;\n\t\t\t\t\t\tgracedays = unitConfig.Grace_Days_For_Monthly_Payment;\n\t\t\t\t\t\tbillgenaration = unitConfig.Bill_Generation;\n\t\t\t\t\t\tafterduedate = unitConfig.After_Due_Date;\n\t\t\t\t\t\tmanagercommissions = unitConfig.Do_You_Want_Configure_Manager_Commission;\n\t\t\t\t\t\tcategory = unitConfig.Category;\n\t\t\t\t\t\trentalmonthly = unitConfig.Rental_Monthly;\n\t\t\t\t\t\tcomplaint_config = unitConfig.Complaint;\n\t\t\t\t\t\tagreement_config = unitConfig.Agreement;\n\t\t\t\t\t\tallAdditionalPayment = unitConfig.Additional_Payment_Monthly;\n\t\t\t\t\t\tsecurityDeposit = unitConfig.Security_Deposit;\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\tconfig = defaultConfig.Configure1;\n\t\t\t\t\t\tconfig_penalty = defaultConfig.Do_you_want_configure_penalty;\n\t\t\t\t\t\tpenaltypaymentmethod = defaultConfig.Penalty_Payment_Method;\n\t\t\t\t\t\tfixedamount = defaultConfig.Fixed_Penalty_Amount;\n\t\t\t\t\t\tpercentage = defaultConfig.Penalty;\n\t\t\t\t\t\tgracedays = defaultConfig.Grace_Days_For_Monthly_Payment;\n\t\t\t\t\t\tbillgenaration = defaultConfig.Bill_Generation;\n\t\t\t\t\t\tafterduedate = defaultConfig.After_Due_Date;\n\t\t\t\t\t\tmanagercommissions = defaultConfig.Do_You_Want_Configure_Manager_Commission;\n\t\t\t\t\t\tcategory = defaultConfig.Category;\n\t\t\t\t\t\trentalmonthly = defaultConfig.Rental_Monthly;\n\t\t\t\t\t\tcomplaint_config = defaultConfig.Complaint;\n\t\t\t\t\t\tagreement_config = defaultConfig.Agreement;\n\t\t\t\t\t\tallAdditionalPayment = defaultConfig.Additional_Payment_Monthly;\n\t\t\t\t\t\tsecurityDeposit = defaultConfig.Security_Deposit;\n\t\t\t\t\t}\n\t\t\t\t\tif(unit.Occupancy_Type == &quot;Rent&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tbaseamount = if(unitConfig.count() &gt; 0,unitConfig.Base_Rental_Monthly_Amount,defaultConfig.Base_Rental_Monthly_Amount);\n\t\t\t\t\t\toccupancy_Type = language.get(&quot;zcpm.property.base.rent&quot;);\n\t\t\t\t\t}\n\t\t\t\t\telse if(unit.Occupancy_Type == &quot;Lease&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tbaseamount = if(unitConfig.count() &gt; 0,unitConfig.Base_Lease_Amount,defaultConfig.Base_Lease_Amount);\n\t\t\t\t\t\toccupancy_Type = language.get(&quot;zcpm.property.base.lease&quot;);\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=config%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=occupancy_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(baseamount)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.Security.Deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(securityDeposit)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(allAdditionalPayment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Additional.Payment.Monthly&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tcount = 1;\n\t\t\t\t\tfor each  additionalpayment in allAdditionalPayment\n\t\t\t\t\t{\n\t\t\t\t\t\tif(count.isOdd())\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=additionalpayment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=additionalpayment.Amount_Display%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\tcount = count + 1;\n\t\t\t\t\t\tif(count.isOdd())\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Monthly.Payment.Penalty&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.configure.penalty&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=config_penalty%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.penalty.payment.method&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=penaltypaymentmethod%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\t\tif(penaltypaymentmethod == &quot;Fixed Amount&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.fixed.penalty.amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=fixedamount%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.penalty.percentage&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=percentage%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.grace.days&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=gracedays%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Payment.Reminder.Notification&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.bill.generation&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=billgenaration%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\tif(config_penalty == &quot;Yes&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.after.due.date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=afterduedate%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.property.Commission&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.manager.commissions&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=managercommissions%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\tif(managercommissions == &quot;Yes&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.Category&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=category%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(category.size() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n&lt;%\n\t\t\t\t\t\tif(category.contains(&quot;Rental Monthly&quot;))\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.rental.monthly&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=rentalmonthly%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(category.contains(&quot;Complaint&quot;))\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Complaint&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=complaint_config%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(category.size() &lt;= 2 &amp;&amp; category.contains(&quot;Agreement&quot;))\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Agreement&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(agreement_config)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(category.size() == 3 &amp;&amp; category.contains(&quot;Agreement&quot;))\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt;  &lt;%=language.get(&quot;zcpm.property.Agreement&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=thisapp.Currency.currencyDisplayFormat(agreement_config)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map_detail.get(input.tab_detail).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&lt;%=report_filter%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;tenantdetail&quot; &amp;&amp; tenant.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Styles.Property_Info()%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\t\ttenant_proof = Screening_File[Tenant_Screening == tenant_screening.ID];\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(tenant.ID,tenant.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,tenant.Name,true);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-tenant-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=tenant.Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n            &lt;!-- span class=&apos;zc-prop-flt-left zc-prop-badge zc-prop-badge-green&apos;&gt; &lt;%=tenant.Tenant_Status%&gt; &lt;\/span --&gt;\n            &lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=tenantedit&amp;rec_id=&lt;%=input.rec_id%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\tif(tenant.Tenant_Status == &quot;Waiting for Approval&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Form:Tenant_Screening?Page_Name=Approval&amp;Tenant=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.move.to.screening&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Approve_Confirmation?Page_Name=Approval&amp;New_User=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?Page_Name=Approval&amp;New_User=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n        &lt;\/div&gt;\n\t\t &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-property-info zc-prop-card zc-prop-clearfix zc-prop-fw&apos;&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-flt-left zc-prop-label-value-wrapper&apos;&gt;\n                    &lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=tenant.Email%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Phone_Number.isEmpty(),tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=tenant.Location.Location%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Address.isEmpty(),tenant.Address,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Gender&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=if(!tenant.Gender.isEmpty(),tenant.Gender,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                        &lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n                            &lt;label&gt; &lt;%=language.get(&quot;zcpm.Date.of.Birth&quot;)%&gt; &lt;\/label&gt;\n                            &lt;span&gt; &lt;%=if(tenant.Date_of_Birth != null,tenant.Date_of_Birth,&quot;-&quot;)%&gt; &lt;\/span&gt;\n                        &lt;\/li&gt;\n                    &lt;\/ul&gt;\n                &lt;\/div&gt;\n            &lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-mono-wrapper&apos;&gt;\n                &lt;div class=&apos;zc-prop-card-header&apos;&gt;\n                    &lt;h6&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screeing.Details&quot;)%&gt; &lt;\/h6&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Name.isEmpty(),tenant_screening.Current_Owner_Name,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Contact.Number&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Contact_Number.isEmpty(),tenant_screening.Current_Owner_Contact_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Address.isEmpty(),tenant_screening.Current_Address,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Occupant.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Occupant_Type.isEmpty(),tenant_screening.Occupant_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(tenant_screening.Occupant_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Monthly.Rental&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Monthly_Rental &gt; 0,tenant_screening.Monthly_Rental_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Lease_Type.isEmpty(),tenant_screening.Lease_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Lease_Amount &gt; 0,tenant_screening.Lease_Amount_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\tif(proof.File_upload == null)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; - &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=proof.File_upload%&gt;&lt;\/a&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;agreementdetail&quot; &amp;&amp; agreement.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(agreement.Unit.ID,agreement.Unit.Unit_Image,&quot;Units_Report&quot;,&quot;Unit_Image&quot;,agreement.Unit.Unit_Name,true);\n\t\t\t\tpage_detail_name = &quot;Agreement_Detail_View&quot;;\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\t\ttab_keys = tab_map.keys();\n\t\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-tenant-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a class=&apos;zc-prop-flt-left zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=agreement.Property.Property_Name%&gt; - &lt;%=agreement.Unit.Unit_Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\t\t\tif(agreement.Status == &quot;Requested&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=editnewagreements&amp;rec_id=&lt;%=input.rec_id%&gt;&amp;tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=input.tab_detail%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Agreement_Approval?Page_Link_Name=Approval&amp;Action_field=Approve&amp;Property=&lt;%=agreement.Property.ID%&gt;&amp;Unit=&lt;%=agreement.Unit.ID%&gt;&amp;Tenant_Agreement=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?Tenant_Agreement=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\tprop_amenities = if(agreement.Property.Amenities.size() &gt; 0,agreement.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t\taddition_payment = Agreement_Additional_Payment[Tenant_Agreement == agreement.ID];\n\t\t\t\ttenant_proof = Screening_File[Tenant_Screening.Tenant == agreement.Tenant];\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,agreement.Property.Property_Type,agreement.Unit.Owner_Mail_ID.Email,agreement.Property.Location.Location,prop_amenities,agreement.Unit.Address.toString(),agreement.Unit.Size_in_Sq_ft)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n                &lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n                    &lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\t\tfor each  sub_tab in tab_keys\n\t\t\t\t{\n\t\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n                    &lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;agreement&quot;)\n\t\t\t\t{\n\t\t\t\t\tunit_agreement = Tenant_Agreement[Unit == agreement.Unit.ID &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + agreement.Unit.ID + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + input.rec_id + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n                                        &lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt; &lt;\/td&gt;\n                                            &lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\t\tif(unit_agreement.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Agreement_History?view_link_name=Unit_Agreement_History&amp;param=&lt;%=history_report_filter%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-copy-04&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.history&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=4&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;tenant-details&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Email%&gt; &lt;\/td&gt;\t\t\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Tenant.Location.Location%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.mobile_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!agreement.Tenant.Phone_Number.isEmpty(),agreement.Tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=proof.File_upload%&gt; &lt;\/a&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n                        \t\t&lt;\/table&gt;\n                    \t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n                &lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;vacatedetail&quot; &amp;&amp; vacate_req.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.Timeline()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(vacate_req.Unit.ID,vacate_req.Unit.Unit_Image,&quot;Units_Report&quot;,&quot;Unit_Image&quot;,vacate_req.Unit.Unit_Name,true);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-rental-vacate-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vacate_req.Property.Property_Name%&gt; - &lt;%=vacate_req.Unit.Unit_Name%&gt; &lt;\/h5&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(vacate_req.Vacate_Status == &quot;Requested&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-btn-wrapper zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Form:Inspection_Form?Page_Link_Name=&lt;%=page_link_name%&gt;&amp;Unit=&lt;%=vacate_req.Unit%&gt;&amp;Vacate_Request=&lt;%=vacate_req.ID%&gt;&amp;Tenant_Agreement=&lt;%=vacate_req.Tenant_Agreement.ID%&gt;&amp;Property=&lt;%=vacate_req.Property%&gt;&amp;zc_LoadIn=dialog\t&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-1-zoom-88&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.time.inspection&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\tprop_amenities = if(vacate_req.Property.Amenities.size() &gt; 0,vacate_req.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t\tpage_detail_name = &quot;Renew_Vacate_Detail_View&quot;;\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\t\ttab_keys = tab_map.keys();\n\t\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t\ttenant_proof = Screening_File[Tenant_Screening.Tenant == vacate_req.Tenant_Agreement.Tenant];\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,vacate_req.Property.Property_Type,vacate_req.Unit.Owner_Mail_ID.Email,vacate_req.Property.Location.Location,prop_amenities,vacate_req.Unit.Address,vacate_req.Unit.Size_in_Sq_ft)%&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\t\tfor each  sub_tab in tab_keys\n\t\t\t\t{\n\t\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;timeline&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-timeline-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\tfor each  timeline in Timeline_Form[Vacate_Request.ID == input.rec_id] sort by Date_Time\n\t\t\t\t\t{\n\t\t\t\t\t\tdate_val = timeline.Date_Time.toString();\n\t\t\t\t\t\tseconds = timeline.Date_Time.getSeconds();\n\t\t\t\t\t\tif(seconds &lt; 10)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tseconds = &quot;0&quot; + seconds;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tdate_time_value = date_val.removeLastOccurence(&quot;:&quot; + seconds);\n\t\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(timeline.New_User.ID,timeline.New_User.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,timeline.New_User.Name.first_name + &quot; &quot; + timeline.New_User.Name.last_name,false);\n\t\t\t\t\t\tvacate_req = Vacate_Request[ID == timeline.Vacate_Request.ID];\n\t\t\t\t\t\tinspection = Inspection_Form[Vacate_Request.ID == timeline.Vacate_Request.ID];\n\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-timeline-date&apos;&gt; &lt;%=date_time_value%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-timeline-detail&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left zc-prop-bold-txt&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;%=timeline.Action_field%&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-username-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left zc-prop-username&apos;&gt; &lt;%=timeline.New_User.Name%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\tif(timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vacate_req.Vacate_Date%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(timeline.Action_field == &quot;Inspection Done&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif(inspection.count(Complaints) &gt; 0)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.complaints&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\t\t\tfor each  inspec_complaint in inspection.Complaints\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tif(inspec_complaint.Cost &gt; 0)\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspec_complaint.Compliant_About%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspec_complaint.Cost%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(timeline.Action_field == &quot;Inspection Done&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif(inspection.count(Complaints) &gt; 0)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.time.total.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Complaints_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Advance_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t\tif(inspection.Pending_Amount &gt; 0)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.pending.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Pending_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.balance.security&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Balance_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(!vacate_req.Comments.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Approved&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=vacate_req.Comments%&gt;&lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(!vacate_req.Reason.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Rejected&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=vacate_req.Reason%&gt;&lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(!vacate_req.Vacate_Reason.isEmpty() &amp;&amp; timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=vacate_req.Vacate_Reason%&gt;&lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;agreement&quot;)\n\t\t\t\t{\n\t\t\t\t\tagreement = Tenant_Agreement[ID == vacate_req.Tenant_Agreement];\n\t\t\t\t\tunit_agreement = Tenant_Agreement[Unit == agreement.Unit.ID &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + agreement.Unit.ID + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + input.rec_id + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n                                        &lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt; &lt;\/td&gt;\n                                            &lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\t\tif(unit_agreement.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Agreement_History?view_link_name=Unit_Agreement_History&amp;param=&lt;%=history_report_filter%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-copy-04&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.history&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=4&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;tenant-details&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=vacate_req.Tenant_Agreement.Tenant.Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=vacate_req.Tenant_Agreement.Tenant.Email%&gt; &lt;\/td&gt;\t\t\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=vacate_req.Tenant_Agreement.Tenant.Location.Location%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.mobile_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!vacate_req.Tenant_Agreement.Tenant.Phone_Number.isEmpty(),vacate_req.Tenant_Agreement.Tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=proof.File_upload%&gt; &lt;\/a&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;renewdetail&quot; &amp;&amp; renew.count() &gt; 0)\n\t\t\t{\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(renew.Unit.ID,renew.Unit.Unit_Image,&quot;Units_Report&quot;,&quot;Unit_Image&quot;,renew.Unit.Unit_Name,true);\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.Timeline()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-rental-renew-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=renew-requests&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=renew.Property.Property_Name%&gt; - &lt;%=renew.Unit.Unit_Name%&gt;&lt;\/h5&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\t\t\tif(renew.Status == &quot;Owner Approved&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-btn-wrapper zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Form:Tenant_Agreement?Renew_Base_Agreement=&lt;%=renew.Base_Agreement%&gt;&amp;Renew_Agreement_Request=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&amp;zc_Header=false&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline business-cheque&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.time.extend.agreement&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n&lt;%\n\t\t\t\tprop_amenities = if(renew.Property.Amenities.size() &gt; 0,renew.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t\tpage_detail_name = &quot;Renew_Vacate_Detail_View&quot;;\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\t\ttab_keys = tab_map.keys();\n\t\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t\ttenant_proof = Screening_File[Tenant_Screening.Tenant == renew.Base_Agreement.Tenant];\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Property_Info(img_src,renew.Property.Property_Type,renew.Unit.Owner_Mail_ID.Email,renew.Property.Location.Location,prop_amenities,renew.Unit.Address,renew.Unit.Size_in_Sq_ft)%&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\t\tfor each  sub_tab in tab_keys\n\t\t\t\t{\n\t\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;timeline&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-timeline-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\tfor each  timeline in Timeline_Form[Renew_Agreement_Request.ID == input.rec_id] sort by Date_Time\n\t\t\t\t\t{\n\t\t\t\t\t\tdate_val = timeline.Date_Time.toString();\n\t\t\t\t\t\tseconds = timeline.Date_Time.getSeconds();\n\t\t\t\t\t\tif(seconds &lt; 10)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tseconds = &quot;0&quot; + seconds;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tdate_time_value = date_val.removeLastOccurence(&quot;:&quot; + seconds);\n\t\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(timeline.New_User.ID,timeline.New_User.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,timeline.New_User.Name.first_name + &quot; &quot; + timeline.New_User.Name.last_name,false);\n\t\t\t\t\t\trenew = Renew_Agreement_Request[ID == timeline.Renew_Agreement_Request];\n\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-timeline-date&apos;&gt; &lt;%=date_time_value%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-timeline-detail&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left zc-prop-bold-txt&apos;&gt; &lt;%=timeline.Action_field%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-username-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left zc-prop-username&apos;&gt; &lt;%=timeline.New_User.Name%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\tif(!renew.Description.isEmpty() &amp;&amp; timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=renew.Description%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(!renew.Comments.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Approved&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt; &lt;%=renew.Comments%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(!renew.Reason.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Rejected&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=renew.Reason%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;agreement&quot;)\n\t\t\t\t{\n\t\t\t\t\tagreement = Tenant_Agreement[ID == renew.Base_Agreement];\n\t\t\t\t\tunit_agreement = Tenant_Agreement[Unit == agreement.Unit.ID &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + agreement.Unit.ID + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + input.rec_id + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n                                        &lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt; &lt;\/td&gt;\n                                            &lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\t\tif(unit_agreement.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Agreement_History?view_link_name=Unit_Agreement_History&amp;param=&lt;%=history_report_filter%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-copy-04&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.history&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=4&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(input.tab_detail == &quot;tenant-details&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=renew.Base_Agreement.Tenant.Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.email&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=renew.Base_Agreement.Tenant.Email%&gt; &lt;\/td&gt;\t\t\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=renew.Base_Agreement.Tenant.Location.Location%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.mobile_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!renew.Base_Agreement.Tenant.Phone_Number.isEmpty(),renew.Base_Agreement.Tenant.Phone_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=proof.File_upload%&gt; &lt;\/a&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.action == &quot;complaintdetail&quot; &amp;&amp; complaint.count() &gt; 0)\n\t\t\t{\n\t\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(complaint.ID,complaint.Photo,report_name,&quot;Photo&quot;,complaint.Complaint_About,true);\n\t\t\t\tclass_name = &quot;&quot;;\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Complaints_Detail_View()%&gt;\n.zcform_Review_Complaint,\n.zcform_Work_Order_Payment {\n    width: 600px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\t\t\tlow_color = if(complaint.Priority == &quot;Low&quot;,&quot;zc-prop-badge-green&quot;,&quot;&quot;);\n\t\t\t\tmedium_color = if(complaint.Priority == &quot;Medium&quot;,&quot;zc-prop-badge-yellow&quot;,&quot;&quot;);\n\t\t\t\thigh_color = if(complaint.Priority == &quot;High&quot;,&quot;zc-prop-badge-orange&quot;,&quot;&quot;);\n\t\t\t\tveryhigh_color = if(complaint.Priority == &quot;Very High&quot;,&quot;zc-prop-badge-red&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-complaints-detail-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-header-title&apos;&gt;\n\t\t\t&lt;a class=&apos;zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_summary&quot;)%&gt; - &lt;%=complaint.Work_Order_Number%&gt;&lt;\/h5&gt;\n\t\t\t\t&lt;span class=&apos;zc-prop-badge &lt;%=low_color + medium_color + high_color + veryhigh_color%&gt; &apos;&quot;&gt;\n\t\t\t\t\t&lt;%=complaint.Priority%&gt;\n\t\t\t\t&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(complaint.Complaint_Status == &quot;Requested&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=edit&amp;tab=&lt;%=input.tab%&gt;&amp;rec_id=&lt;%=input.rec_id%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(login_profile != &quot;Tenant&quot; &amp;&amp; complaint.Complaint_Status == &quot;Approved&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Review_Complaint?Complaint=&lt;%=input.rec_id%&gt;&amp;Complaint_Details&lt;%=complaint.Complaint_Details%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(complaint.Complaint_Status == &quot;Work Order Completed&quot; &amp;&amp; login_profile != &quot;Tenant&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Work_Order_Payment?Work_Order=&lt;%=input.rec_id%&gt;&amp;Property=&lt;%=complaint.Property%&gt;&amp;Unit=&lt;%=complaint.Unit%&gt;&amp;Vendor_Update=&lt;%=complaint.Vendor_Update%&gt;&amp;Complaint_Amount=&lt;%=complaint.Complaint_Amount%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign.pay&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t\ttop_bar_map = thisapp.Timeline.Get_Topbar(input.rec_id);\n\t\t\t\tkey_lis = top_bar_map.keys();\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-stepper-wrapper zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\t\t\tfor each  top_bar in key_lis\n\t\t\t\t{\n\t\t\t\t\tstyle = if(top_bar != 5,top_bar_map.get(top_bar).get(&apos;Style&apos;),&quot;&quot;);\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=style%&gt;&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=top_bar%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n&lt;%\n\t\t\t\t\tif(top_bar == 5)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;%=top_bar_map.get(top_bar).get(&apos;Style&apos;)%&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=top_bar_map.get(top_bar).get(&apos;Display&apos;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\tif(top_bar != 5)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-complaints-info&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card-header&apos;&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.compliant_detail&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;\/div&gt;\t\n\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-img-txt-outer zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper-outer&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Complaint_About%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;p&gt; &lt;%=complaint.Complaint_Details%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4&apos;&gt;\n\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.property&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Property_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.unit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Unit.Unit_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt;  &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Location.Location%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Date_of_Reporting%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.duration&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\t\tif(complaint.End_Time != null &amp;&amp; complaint.Start_Time != null)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=thisapp.Get_Duration_Time(complaint.ID)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.not.yet&quot;)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.Expected_Date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Expected_Date == null,&quot;-&quot;,complaint.Expected_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.resolved_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Resolved_Date == null,&quot;-&quot;,complaint.Resolved_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\t\t\tif(complaint.Complaint_Status != &quot;Rejected&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.comments&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Comments.isEmpty(),&quot;-&quot;,complaint.Comments)%&gt;&lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Reason.isEmpty(),&quot;-&quot;,complaint.Reason)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.vendor_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.name&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Name)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.email&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Email)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;&lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt;&lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Phone_Number)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Complaint_Amount == null,&quot;-&quot;,complaint.Complaint_Amount_Display)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_by&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\t\tif(complaint.Payment_By == &quot;Owner&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Owner_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse if(complaint.Payment_By == &quot;Tenant&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Tenant_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;h6&gt; - &lt;\/h6&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t\telse if(!input.action.isEmpty() &amp;&amp; agreement.count() == 0 || vacate_req.count() == 0 || renew.count() == 0 || complaint.count() == 0 || unit.count() == 0 || edit_agreement.count() == 0 || edit_vacate.count() == 0 || edit_complaint.count() == 0)\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Tenant_Profile(string action, string detailViewAction, int detail_rec_id, int rec_id, string tab)
		{
			displayname = "Tenant Profile"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet12' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet12()\ncontent\n&lt;%{\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tlanguage = thisapp.Localization.Pages();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n.zc-prop-notes-field .zc-prop-label-value-wrapper {\n    width: calc(100% - 171px);\n}\n.zcform_Renew_Agreement_Request,\n.zcform_Vacate_Request,\n.zcform_Reject_Confirmation {\n\twidth: 550px;\n}\n&lt;\/style&gt;\n&lt;%\n\tif(login_profile != &quot;Tenant&quot;)\n\t{\n\t\tno_data_component_params = {&quot;is_img&quot;:false,&quot;Primary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.page.alert.tenant&quot;)};\n\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\tCommon_language = thisapp.Localization.common();\n\t\tpage_link_name = &quot;Tenant_Profile&quot;;\n\t\tgetTenant = New_User[Email == zoho.loginuserid];\n\t\tfield_name = &quot;Profile_Photo&quot;;\n\t\treport_name = &quot;Tenant_Profile_Report&quot;;\n\t\t\/\/ \tcurrent_params_values = if(!input.tab.isEmpty() || input.tab != null,&quot;tab=&quot; +input.tab + &quot;&amp;&quot;,&quot;&quot;);\n\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\tunit = Add_Unit[ID == input.rec_id &amp;&amp; Current_Tenant.Email == zoho.loginuserid];\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\tnew_agreement = Tenant_Agreement[ID == input.rec_id &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\ttenant_screening = Tenant_Screening[Tenant.Email == zoho.loginuserid];\n\t\ttenant_proof = Screening_File[Tenant_Screening == tenant_screening.ID];\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(getTenant.ID,getTenant.Profile_Photo,report_name,field_name,getTenant.Name,false);\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Tenant_Profile()%&gt;\n&lt;%\n\t\t\tif(input.tab == &quot;new-agreement&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Styles.Custom_Action_Btn()%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-tenant-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-profile-info zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=getTenant.Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t&lt;!-- div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-clearfix zc-prop-edit-txt&apos; href=&apos;#Page:Tenant_Profile?action=editProfile&amp;rec_id=&lt;%=getTenant.ID%&gt;&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline ui-1-edit-72&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; Edit &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t&lt;\/div --&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-email-85 zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-flt-left&apos; href=&apos;mailto:&lt;%=getTenant.Email%&gt;&apos;&gt; &lt;%=getTenant.Email%&gt; &lt;\/a&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-3-phone zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(getTenant.Phone_Number.isEmpty(),&quot;-&quot;,getTenant.Phone_Number)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-single-02 zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(getTenant.Gender.isEmpty(),&quot;-&quot;,getTenant.Gender)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline business-briefcase-24 zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(getTenant.Occupation.isEmpty(),&quot;&quot;,getTenant.Occupation.Occupation)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-calendar-60 zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(getTenant.Date_of_Birth == null,&quot;-&quot;,getTenant.Date_of_Birth)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline location-pin zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=if(getTenant.Address.isEmpty(),&quot;&quot;,getTenant.Address)%&gt; &lt;\/span&gt;\n\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t&lt;\/ul&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-tab-wrapper&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\tif(input.tab != &quot;previous-occupant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(tenant_screening.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Details&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\tif(tenant_screening.count() &gt; 0 &amp;&amp; tenant_screening.Status == &quot;Not Update&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=previous-occupant&amp;action=update&amp;rec_id=&lt;%=tenant_screening.ID%&gt;&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-1-refresh-69&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.Update&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Name&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Name.isEmpty(),tenant_screening.Current_Owner_Name,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Owner.Contact.Number&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Owner_Contact_Number.isEmpty(),tenant_screening.Current_Owner_Contact_Number,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.orgz.address&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Current_Address.isEmpty(),tenant_screening.Current_Address,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Occupant.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Occupant_Type.isEmpty(),tenant_screening.Occupant_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(tenant_screening.Occupant_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Monthly.Rental&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Monthly_Rental &gt; 0,tenant_screening.Monthly_Rental_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(!tenant_screening.Lease_Type.isEmpty(),tenant_screening.Lease_Type,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.Lease.Amount&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(tenant_screening.Lease_Amount &gt; 0,tenant_screening.Lease_Amount_Display,&quot;-&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Tenant.Screening.Proof&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(tenant_proof.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Proof&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Document&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  proof in tenant_proof\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=proof.Proof.Proof1%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;a href=&apos;&lt;%=zoho.appuri%&gt;report\/All_Screening_Files\/&lt;%=proof.ID%&gt;\/File_upload\/download-file?filepath=\/&lt;%=proof.File_upload%&gt;&amp;mediaType=3&apos;&gt; &lt;%=if(proof.File_upload == null,&quot;-&quot;,proof.File_upload)%&gt; &lt;\/a&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(proof.Description.isEmpty(),&quot;-&quot;,proof.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;update&quot; &amp;&amp; input.tab == &quot;previous-occupant&quot; &amp;&amp; tenant_screening.Status == &quot;Not Update&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Tenant.Screening&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Tenant_Screening&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Tenant_Screening_for_Tenant&amp;zc_NextUrl=#Page:Tenant_Profile?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;unitDetailView&quot; &amp;&amp; unit.count() &gt; 0)\n\t\t{\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(unit.ID,unit.Unit_Image,&quot;My_Unit_Tenant&quot;,&quot;Unit_Image&quot;,unit.Unit_Name,true);\n\t\t\tdetail_view_tabs = thisapp.Page.Get_Tab1(page_link_name + &quot;_Detail_View&quot;);\n\t\t\ttab_keys = detail_view_tabs.keys();\n\t\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\t\tagreement = Tenant_Agreement[Unit.Current_Tenant == thisapp.get_user_id() &amp;&amp; Agreement_Status == &quot;Active&quot;];\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-tenant-unit-detail-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a href=&apos;#Page:Tenant_Profile&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=unit.Property.Property_Name + &quot; - &quot; + unit.Unit_Name%&gt; &lt;\/h5&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a href=&apos;#Form:Renew_Agreement_Request?Action_field=my_unit&amp;Property=&lt;%=unit.Property%&gt;&amp;Unit=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos; class=&apos;zc-outline-primary-btn&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-refresh&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.Renew&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a href=&apos;#Form:Vacate_Request?Action_field=my_unit&amp;Unit=&lt;%=input.rec_id%&gt;&amp;zc_LoadIn=dialog&apos; class=&apos;zc-outline-primary-btn&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.vacate.request&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t\t\tprop_amenities = if(agreement.Property.Amenities.size() &gt; 0,agreement.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,agreement.Property.Property_Type,agreement.Unit.Owner_Mail_ID.Email,agreement.Property.Location.Location,prop_amenities,agreement.Unit.Address,agreement.Unit.Size_in_Sq_ft)%&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=detail_view_tabs.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\tif(!detail_view_tabs.get(input.tab).get(&quot;viewLinkName&quot;).isEmpty() &amp;&amp; input.detailViewAction.isEmpty())\n\t\t\t{\n\t\t\t\treport_filter = &quot;&amp;Unit.ID=&quot; + input.rec_id + &quot;&amp;Tenant_Agreement.ID=&quot; + agreement.ID + &quot;&amp;Property.ID=&quot; + unit.Property;\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=detail_view_tabs.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&lt;%=report_filter%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;agreements&quot;)\n\t\t\t{\n\t\t\t\taddition_payment = Agreement_Additional_Payment[Tenant_Agreement == agreement.ID];\n\t\t\t\tunit_agreement = Tenant_Agreement[Unit == input.rec_id &amp;&amp; Agreement_Status == &quot;Inactive&quot; &amp;&amp; Tenant.Email == zoho.loginuserid];\n\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + input.rec_id + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + agreement.ID + &quot;&amp;ID_op=19&amp;Tenant.ID=&quot; + thisapp.get_user_id() + &quot;&amp;Tenant.ID_op=18&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Each_Agreement_Template?rec_id=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-eye-17&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.view&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\tif(unit_agreement.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Agreement_History?view_link_name=Unit_Agreement_History&amp;param=&lt;%=history_report_filter%&gt;&amp;zc_LoadIn=dialog&apos;&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-copy-04&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.history&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt;&lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Description%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\t\t\t\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;detailagreement&quot;)\n\t\t{\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(new_agreement.Unit.ID,new_agreement.Unit.Unit_Image,&quot;Unit_Image&quot;,&quot;Unit_Image&quot;,new_agreement.Unit.Unit_Name,true);\n\t\t\tmanager = if(new_agreement.Unit.Manager != null,new_agreement.Unit.Manager.Name,&quot;-&quot;);\n\t\t\taddress = if(new_agreement.Unit.Address.isEmpty(),&quot;-&quot;,new_agreement.Unit.Address);\n\t\t\tbase_amo = if(new_agreement.Agreement_Type == &quot;Rent&quot;,new_agreement.Base_Rent_Display,new_agreement.Base_Lease_Display);\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-tenant-agreement-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt;\n                    &lt;%=new_agreement.Property.Property_Name + &quot; - &quot; + new_agreement.Unit.Unit_Name%&gt;\n                &lt;\/h5&gt;\n            &lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-header-btn-wrapper zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-approve-btn&apos; href=&apos;#Form:Agreement_Approval?Property=&lt;%=new_agreement.Property%&gt;&amp;Unit=&lt;%=new_agreement.Unit.ID%&gt;&amp;Tenant_Agreement=&lt;%=new_agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.approve&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn zc-prop-reject-btn&apos; href=&apos;#Form:Reject_Confirmation?Action_field=TenantReject&amp;Tenant_Agreement=&lt;%=new_agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.reject&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n        &lt;\/div&gt;\n&lt;%\n\t\t\tprop_amenities = if(new_agreement.Property.Amenities.size() &gt; 0,new_agreement.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\taddition_payment = Agreement_Additional_Payment[Tenant_Agreement == new_agreement.ID];\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,new_agreement.Property.Property_Type,new_agreement.Unit.Owner_Mail_ID.Email,new_agreement.Property.Location.Location,prop_amenities,new_agreement.Unit.Address,new_agreement.Unit.Size_in_Sq_ft)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-mono-wrapper&apos;&gt;\n                &lt;div class=&apos;zc-prop-card-header&apos;&gt;\n                    &lt;h6&gt; &lt;%=language.get(&quot;zcpm.property.Agreement.Details&quot;)%&gt; &lt;\/h6&gt;\n                &lt;\/div&gt;\n                &lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\tif(new_agreement.Agreement_Type == &quot;Rent&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_lease&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=new_agreement.End_Date%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(new_agreement.Comments.isEmpty(),&quot;-&quot;,new_agreement.Comments)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n        \t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(unit.count() == 0)\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Requests(string action, int rec_id, string tab, string tab_detail)
		{
			displayname = "Requests"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tlanguage = thisapp.Localization.Pages();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n.zcform_Agree_Popup_Form {\n    width: 450px;\n}\n.zcform_Review_Complaint, \n.zcform_Work_Order_Payment {\n    width: 550px;\n}\n&lt;\/style&gt;\n&lt;%\n\tif(login_profile != &quot;Tenant&quot;)\n\t{\n\t\tno_data_component_params = {&quot;is_img&quot;:false,&quot;Primary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.page.alert.tenant&quot;)};\n\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\t\tinput.action = &quot;detail&quot;;\n\t\t}\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\tpage_link_name = &quot;Requests&quot;;\n\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\ttab_keys = tab_map.keys();\n\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\t\tbtn_value = language.get(&apos;zcpm.request.add.request&apos;);\n\t\taction_value = if(input.tab == &quot;renew-requests&quot;,&quot;addrenew&quot;,&quot;addvacate&quot;);\n\t\trenew = Renew_Agreement_Request[ID == input.rec_id];\n\t\tvacate_req = Vacate_Request[ID == input.rec_id];\n\t\tagreement = Tenant_Agreement[ID == renew.Base_Agreement || ID == vacate_req.Tenant_Agreement];\n\t\taddition_payment = Agreement_Additional_Payment[Tenant_Agreement == agreement.ID];\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_View()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n    content: &apos;Agreement No&apos;; \n}\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-view zc-prop-withoutpanel zc-prop-requests-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.requests&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,btn_value,&quot;#Page:&quot; + page_link_name + &quot;?action=&quot; + action_value + &quot;&amp;tab=&quot; + input.tab)%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody zc-prop-card-content&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Focus=false&amp;Page=&lt;%=page_link_name%&gt;&amp;Report=&lt;%=report_name%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos; name=&apos;&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;addvacate&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Vacate.Request&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Vacate_Request&quot;,&quot;zc_Header=false&amp;Action_field=Request_Page&amp;#Page:&quot; + page_link_name + &quot;?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;addrenew&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Renew.Request&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Renew_Agreement_Request&quot;,&quot;zc_Header=false&amp;Action_field=Request_Page&amp;#Page:&quot; + page_link_name + &quot;?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;editvacaterequests&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Edit.Vacate.Request&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Vacate_Request&quot;,&quot;zc_Header=false&amp;Action_field=Request_Page&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;renewdetailview&quot; &amp;&amp; renew.count() &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.Timeline()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(renew.Unit.ID,renew.Unit.Unit_Image,&quot;My_Unit_Tenant&quot;,&quot;Unit_Image&quot;,renew.Unit.Unit_Name,false);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-renew-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a href=&apos;#Page:Requests?tab=renew-requests&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=renew.Unit.Unit_Name%&gt;&lt;\/h5&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n&lt;%\n\t\t\tprop_amenities = if(renew.Property.Amenities.size() &gt; 0,renew.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\tpage_detail_name = &quot;Request_Renew_Vacate_Detail_View&quot;;\n\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Property_Info(img_src,renew.Property.Property_Type,renew.Unit.Owner_Mail_ID.Email,renew.Property.Location.Location,prop_amenities,renew.Unit.Address.toString(),renew.Unit.Size_in_Sq_ft)%&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  sub_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;timeline&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-timeline-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\tfor each  timeline in Timeline_Form[Renew_Agreement_Request.ID == input.rec_id] sort by Date_Time\n\t\t\t\t{\n\t\t\t\t\tdate_val = timeline.Date_Time.toString();\n\t\t\t\t\tseconds = timeline.Date_Time.getSeconds();\n\t\t\t\t\tif(seconds &lt; 10)\n\t\t\t\t\t{\n\t\t\t\t\t\tseconds = &quot;0&quot; + seconds;\n\t\t\t\t\t}\n\t\t\t\t\tdate_time_value = date_val.removeLastOccurence(&quot;:&quot; + seconds);\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(timeline.New_User.ID,timeline.New_User.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,timeline.New_User.Name.first_name + &quot; &quot; + timeline.New_User.Name.last_name,false);\n\t\t\t\t\trenew = Renew_Agreement_Request[ID == timeline.Renew_Agreement_Request];\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-timeline-date&apos;&gt; &lt;%=date_time_value%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-timeline-detail&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left zc-prop-bold-txt&apos;&gt; &lt;%=timeline.Action_field%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-username-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left zc-prop-username&apos;&gt; &lt;%=timeline.New_User.Name%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(!renew.Description.isEmpty() &amp;&amp; timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt;&lt;%=renew.Description%&gt;&lt;\/p&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab_detail == &quot;agreement&quot;)\n\t\t\t{\n\t\t\t\tunit_agreement = Tenant_Agreement[Unit == agreement.Unit.ID &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + agreement.Unit.ID + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + input.rec_id + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Status == &quot;Active&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Each_Agreement_Template?rec_id=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-eye-17&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.view&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(agreement.Status == &quot;Owner Rejected&quot; || agreement.Status == &quot;Auto Rejected&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Reason.isEmpty(),&quot;-&quot;,agreement.Reason)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(agreement.Status == &quot;Tenant Rejected&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.tenant.reason&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Tenant_Reason.isEmpty(),&quot;-&quot;,agreement.Tenant_Reason)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;vacatedetailview&quot; &amp;&amp; vacate_req.count() &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles.Timeline()%&gt;\n&lt;%=thisapp.Styles.New_Table()%&gt;\n&lt;%=thisapp.Styles_Page.Common_Detailview()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(vacate_req.Unit.ID,vacate_req.Unit.Unit_Image,&quot;My_Unit_Tenant&quot;,&quot;Unit_Image&quot;,vacate_req.Unit.Unit_Name,true);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-detailview zc-prop-vacate-detail-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n            &lt;div class=&apos;zc-prop-header-title zc-prop-clearfix&apos;&gt;\n                &lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos; class=&apos;zc-prop-flt-left zc-prop-back-icon&apos;&gt;\n                    &lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n                &lt;\/a&gt;\n                &lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vacate_req.Unit.Unit_Name%&gt; &lt;\/h5&gt;\n            &lt;\/div&gt;\n&lt;%\n\t\t\tinspection = Inspection_Form[Vacate_Request.ID == input.rec_id];\n\t\t\tif(vacate_req.Vacate_Status == &quot;Waiting for Tenant Approval&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-btn-wrapper zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-flt-left zc-outline-primary-btn&apos; href=&apos;#Form:Agree_Popup_Form?zc_Header=false&amp;zc_LoadIn=dialog&amp;Inspection_Form=&lt;%=inspection.ID%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-2-like&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.request.agree&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n        &lt;div class=&apos;zc-prop-page-content&apos;&gt;\n&lt;%\n\t\t\tprop_amenities = if(vacate_req.Property.Amenities.size() &gt; 0,vacate_req.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\tpage_detail_name = &quot;Request_Renew_Vacate_Detail_View&quot;;\n\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_detail_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.tab_detail = if(input.tab_detail == &quot;&quot; || input.tab_detail == null,tab_keys.get(0),input.tab_detail);\n\t\t\tinput.tab_detail = if(!tab_keys.contains(input.tab_detail),tab_keys.get(0),input.tab_detail);\n\t\t\treport_name = tab_map.get(input.tab_detail).get(&quot;viewLinkName&quot;);\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Property_Info(img_src,vacate_req.Property.Property_Type,vacate_req.Unit.Owner_Mail_ID.Email,vacate_req.Property.Location.Location,prop_amenities,vacate_req.Unit.Address.toString(),vacate_req.Unit.Size_in_Sq_ft)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  sub_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab_detail == sub_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&amp;tab_detail=&lt;%=sub_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(sub_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n&lt;%\n\t\t\tif(input.tab_detail.isEmpty() || input.tab_detail == &quot;timeline&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-timeline-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\tfor each  timeline in Timeline_Form[Vacate_Request.ID == input.rec_id] sort by Date_Time\n\t\t\t\t{\n\t\t\t\t\tdate_val = timeline.Date_Time.toString();\n\t\t\t\t\tseconds = timeline.Date_Time.getSeconds();\n\t\t\t\t\tif(seconds &lt; 10)\n\t\t\t\t\t{\n\t\t\t\t\t\tseconds = &quot;0&quot; + seconds;\n\t\t\t\t\t}\n\t\t\t\t\tdate_time_value = date_val.removeLastOccurence(&quot;:&quot; + seconds);\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(timeline.New_User.ID,timeline.New_User.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,timeline.New_User.Name.first_name + &quot; &quot; + timeline.New_User.Name.last_name,false);\n\t\t\t\t\tvacate_req = Vacate_Request[ID == timeline.Vacate_Request.ID];\n\t\t\t\t\tinspection = Inspection_Form[Vacate_Request.ID == timeline.Vacate_Request.ID];\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-timeline-date&apos;&gt; &lt;%=date_time_value%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-timeline-detail&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left zc-prop-bold-txt&apos;&gt; &lt;%=timeline.Action_field%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-username-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left zc-prop-username&apos;&gt; &lt;%=timeline.New_User.Name%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.vacate.date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vacate_req.Vacate_Date%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(timeline.Action_field == &quot;Inspection Done&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tSumofCost = inspection.Complaints;\n\t\t\t\t\t\tif(inspection.count(Complaints) &gt; 0 &amp;&amp; SumofCost.sum(Cost) &gt; 0)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.complaints&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\t\tfor each  inspec_complaint in inspection.Complaints\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif(inspec_complaint.Cost &gt; 0)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspec_complaint.Compliant_About%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspec_complaint.Cost%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(timeline.Action_field == &quot;Inspection Done&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\tif(inspection.count(Complaints) &gt; 0)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.time.total.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Complaints_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Advance_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\tif(inspection.Pending_Amount &gt; 0)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.pending.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Pending_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-keyvalue-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-clearfix&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.request.balance.security&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=inspection.Balance_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(!vacate_req.Comments.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Approved&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt; &lt;%=vacate_req.Comments%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(!vacate_req.Reason.isEmpty() &amp;&amp; timeline.Action_field == &quot;Owner Rejected&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt; &lt;%=vacate_req.Reason%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\tif(!vacate_req.Vacate_Reason.isEmpty() &amp;&amp; timeline.Action_field == &quot;Requested&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;p class=&apos;zc-prop-timeline-comments&apos;&gt; &lt;%=vacate_req.Vacate_Reason%&gt; &lt;\/p&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab_detail == &quot;agreement&quot;)\n\t\t\t{\n\t\t\t\tunit_agreement = Tenant_Agreement[Unit == agreement.Unit.ID &amp;&amp; Agreement_Status == &quot;Inactive&quot;];\n\t\t\t\thistory_report_filter = encodeUrl(&quot;&amp;Unit.ID=&quot; + agreement.Unit.ID + &quot;&amp;Unit.ID_op=18&amp;ID=&quot; + input.rec_id + &quot;&amp;ID_op=19&quot;);\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-tabcontent-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-table-kv-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;3&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreeement.Details&quot;)%&gt;&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-align-right zc-prop-table-btn-td&apos;&gt;\n&lt;%\n\t\t\t\tif(agreement.Agreement_Status == &quot;Active&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:Each_Agreement_Template?rec_id=&lt;%=agreement.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-eye-17&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.view&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_no&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_No%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.agreement_type&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Agreement_Type%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.base_rent&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Base_Rent_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Security_Deposit_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.start_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.Start_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.end_date&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=agreement.End_Date%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.comments&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Comments.isEmpty(),&quot;-&quot;,agreement.Comments)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\tif(agreement.Status == &quot;Owner Rejected&quot; || agreement.Status == &quot;Auto Rejected&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Reason.isEmpty(),&quot;-&quot;,agreement.Reason)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\tif(agreement.Status == &quot;Tenant Rejected&quot;)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;td&gt; &lt;%=language.get(&quot;zcpm.rental.tenant.reason&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(agreement.Tenant_Reason.isEmpty(),&quot;-&quot;,agreement.Tenant_Reason)%&gt; &lt;\/td&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;tr class=&apos;zc-prop-table-sub-header-tr&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;td class=&apos;zc-prop-table-sub-header&apos; colspan=&apos;4&apos;&gt; &lt;%=language.get(&quot;zcpm.Agreement.Additional.Payment&quot;)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\tif(addition_payment.count() &gt; 0)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-table-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;table&gt;\n\t\t\t\t\t\t\t\t\t&lt;thead&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.pay.for&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.pdf.amount&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th&gt; &lt;%=language.get(&quot;zcpm.Description&quot;)%&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;tr class=&apos;zc-prop-tspace&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;th colspan=&apos;3&apos;&gt; &lt;\/th&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/thead&gt;\n\t\t\t\t\t\t\t\t\t&lt;tbody&gt;\n&lt;%\n\t\t\t\t\tfor each  payment in addition_payment\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Pay_For.Pay_For%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=payment.Amount_Display%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;td&gt; &lt;%=if(payment.Description.isEmpty(),&quot;-&quot;,payment.Description)%&gt; &lt;\/td&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/tr&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Complaints(string action, int rec_id, string tab)
		{
			displayname = "Complaints"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet9' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet9()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tlanguage_tab = thisapp.Localization.Tab();\n\t\tCommon_language = thisapp.Localization.common();\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\t\tinput.action = &quot;detail&quot;;\n\t\t}\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\tpage_link_name = &quot;Complaints&quot;;\n\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\ttab_keys = tab_map.keys();\n\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\t\tuser_config = User_Configuration[ID != 0];\n\t\tpanel_count = 5;\n\t\tif(thisapp.Get_Logged_In_Profile() == &quot;Administrator&quot; || login_profile == &quot;Admin&quot; || login_profile == &quot;Developer&quot;)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\t\topen_WO = Raise_a_Complaint[Complaint_Status == &quot;Requested&quot; || Complaint_Status == &quot;Approved&quot;];\n\t\t\tOnGoing_WO = Raise_a_Complaint[Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Vendor Assigned&quot;];\n\t\t\tassign_WO = Raise_a_Complaint[Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot; || Complaint_Status == &quot;Work Order Completed&quot;];\n\t\t\trejected_WO = Raise_a_Complaint[Complaint_Status == &quot;Rejected&quot;];\n\t\t\tall_WO = Raise_a_Complaint[ID != 0];\n\t\t}\n\t\telse if(login_profile == &quot;Owner&quot;)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Owner_Email.Email == zoho.loginuserid];\n\t\t\topen_WO = Raise_a_Complaint[Owner_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Requested&quot; || Complaint_Status == &quot;Approved&quot;];\n\t\t\tOnGoing_WO = Raise_a_Complaint[Owner_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Vendor Assigned&quot;];\n\t\t\tassign_WO = Raise_a_Complaint[Owner_Email.Email == zoho.loginuserid &amp;&amp; Payment_By == &quot;Owner&quot; &amp;&amp; Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;];\n\t\t\trejected_WO = Raise_a_Complaint[Owner_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Rejected&quot;];\n\t\t\tall_WO = Raise_a_Complaint[Owner_Email.Email == zoho.loginuserid];\n\t\t}\n\t\telse if(login_profile == &quot;Manager&quot;)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Manager.Email == zoho.loginuserid];\n\t\t\topen_WO = Raise_a_Complaint[Manager.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Requested&quot; || Complaint_Status == &quot;Approved&quot;];\n\t\t\tOnGoing_WO = Raise_a_Complaint[Manager.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Vendor Assigned&quot;];\n\t\t\tassign_WO = Raise_a_Complaint[Manager.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot; || Complaint_Status == &quot;Work Order Completed&quot;];\n\t\t\trejected_WO = Raise_a_Complaint[Manager.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Rejected&quot;];\n\t\t\tall_WO = Raise_a_Complaint[Manager.Email == zoho.loginuserid];\n\t\t}\n\t\telse if(login_profile == &quot;Tenant&quot;)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Tenant_Email.Email == zoho.loginuserid];\n\t\t\topen_WO = Raise_a_Complaint[Tenant_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Requested&quot; || Complaint_Status == &quot;Approved&quot;];\n\t\t\tOnGoing_WO = Raise_a_Complaint[Tenant_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;In Progress&quot; || Complaint_Status == &quot;Vendor Assigned&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot; || Complaint_Status == &quot;Work Order Completed&quot;];\n\t\t\trejected_WO = Raise_a_Complaint[Tenant_Email.Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Rejected&quot;];\n\t\t\tall_WO = Raise_a_Complaint[Tenant_Email.Email == zoho.loginuserid];\n\t\t\tpanel_count = 4;\n\t\t}\n\t\tsearch = language.get(&quot;zcpm.complaint.search&quot;);\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_View()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n\tcontent: &apos;&lt;%=search%&gt;&apos;; \n}\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-complaints-page zc-prop-common-view&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-page-header-with-options zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt;  &lt;%=language.get(&quot;zcpm.complaint.complaints&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.complaint.raise_a_complaint&quot;),&quot;#Page:Complaints?action=add&amp;tab=&quot; + input.tab)%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;ul class=&apos;zc-prop-panel-wrapper zc-prop-panel-count-&lt;%=panel_count%&gt; zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-yellow&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Complaints?tab=complaints&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;  &lt;%=open_WO.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language_tab.get(&quot;zcpm.New.complaints&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-d_blue&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Complaints?tab=workorders&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;  &lt;%=OnGoing_WO.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language_tab.get(&quot;zcpm.Work.Orders&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\tif(login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Complaints?tab=payments&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=assign_WO.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language_tab.get(&quot;zcpm.assignpay&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-red&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Complaints?tab=rejectedcomplaints&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=rejected_WO.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language_tab.get(&quot;zcpm.rejected.complaints&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-grey&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Complaints?tab=finishedcomplaints&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=all_WO.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language_tab.get(&quot;zcpm.Finished.Complaints&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t&lt;\/ul&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody zc-prop-card-content&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Focus=false&amp;Page=&lt;%=page_link_name%&gt;&amp;Report=&lt;%=report_name%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos; name=&apos;&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;add&quot;)\n\t\t{\n\t\t\tnext_url = &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name;\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.complaint.raise_a_complaint&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Raise_a_Complaint&quot;,&quot;zc_Header=false&quot; + next_url)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;edit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Edit.Complaint&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Raise_a_Complaint&quot;,&quot;zc_Header=false&amp;viewLinkName=&quot; + report_name + &quot;&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;import&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Import(page_link_name)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;detailview&quot; &amp;&amp; complaint.count() != 0)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(complaint.ID,complaint.Photo,report_name,&quot;Photo&quot;,complaint.Complaint_About,true);\n\t\t\tclass_name = &quot;&quot;;\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Complaints_Detail_View()%&gt;\n.zcform_Review_Complaint,\n.zcform_Work_Order_Payment {\n    width: 600px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\t\tlow_color = if(complaint.Priority == &quot;Low&quot;,&quot;zc-prop-badge-green&quot;,&quot;&quot;);\n\t\t\tmedium_color = if(complaint.Priority == &quot;Medium&quot;,&quot;zc-prop-badge-yellow&quot;,&quot;&quot;);\n\t\t\thigh_color = if(complaint.Priority == &quot;High&quot;,&quot;zc-prop-badge-orange&quot;,&quot;&quot;);\n\t\t\tveryhigh_color = if(complaint.Priority == &quot;Very High&quot;,&quot;zc-prop-badge-red&quot;,&quot;&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-complaints-detail-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-header-title&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-back-icon&apos; href=&apos;#Page:Complaints?tab=&lt;%=input.tab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_summary&quot;)%&gt; - &lt;%=complaint.Work_Order_Number%&gt;&lt;\/h5&gt;\n\t\t\t\t&lt;span class=&apos;zc-prop-badge &lt;%=low_color + medium_color + high_color + veryhigh_color%&gt; &apos;&quot;&gt;\n\t\t\t\t\t&lt;%=complaint.Priority%&gt;\n\t\t\t\t&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\tif(complaint.Complaint_Status == &quot;Requested&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=edit&amp;tab=&lt;%=input.tab%&gt;&amp;rec_id=&lt;%=input.rec_id%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(login_profile != &quot;Tenant&quot; &amp;&amp; complaint.Complaint_Status == &quot;Approved&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Review_Complaint?Complaint=&lt;%=input.rec_id%&gt;&amp;Assign_Vendor=true&amp;Complaint_Details&lt;%=complaint.Complaint_Details%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(complaint.Complaint_Status == &quot;Work Order Completed&quot; &amp;&amp; login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Work_Order_Payment?Work_Order=&lt;%=input.rec_id%&gt;&amp;Property=&lt;%=complaint.Property%&gt;&amp;Unit=&lt;%=complaint.Unit%&gt;&amp;Vendor_Update=&lt;%=complaint.Vendor_Update%&gt;&amp;Complaint_Amount=&lt;%=complaint.Complaint_Amount%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign.pay&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\ttop_bar_map = thisapp.Timeline.Get_Topbar(input.rec_id);\n\t\t\tkey_lis = top_bar_map.keys();\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-stepper-wrapper zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\t\tfor each  top_bar in key_lis\n\t\t\t{\n\t\t\t\tstyle = if(top_bar != 5,top_bar_map.get(top_bar).get(&apos;Style&apos;),&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=style%&gt;&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=top_bar%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n&lt;%\n\t\t\t\tif(top_bar == 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;%=top_bar_map.get(top_bar).get(&apos;Style&apos;)%&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=top_bar_map.get(top_bar).get(&apos;Display&apos;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\tif(top_bar != 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-complaints-info&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card-header&apos;&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.compliant_detail&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;\/div&gt;\t\n\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-img-txt-outer zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper-outer&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Complaint_About%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;p&gt; &lt;%=complaint.Complaint_Details%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4&apos;&gt;\n\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.property&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Property_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.unit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Unit.Unit_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt;  &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Location.Location%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Date_of_Reporting%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.duration&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.End_Time != null &amp;&amp; complaint.Start_Time != null)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=thisapp.Get_Duration_Time(complaint.ID)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.not.yet&quot;)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.Expected_Date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Expected_Date == null,&quot;-&quot;,complaint.Expected_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.resolved_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Resolved_Date == null,&quot;-&quot;,complaint.Resolved_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\t\tif(complaint.Complaint_Status != &quot;Rejected&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.comments&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Comments.isEmpty(),&quot;-&quot;,complaint.Comments)%&gt;&lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Reason.isEmpty(),&quot;-&quot;,complaint.Reason)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.vendor_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.name&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Name)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.email&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Email)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;&lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt;&lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Phone_Number)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Complaint_Amount == null,&quot;-&quot;,complaint.Complaint_Amount_Display)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_by&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.Payment_By == &quot;Owner&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Owner_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(complaint.Payment_By == &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Tenant_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; - &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(complaint.count() == 0)\n\t\t{\n\t\t\tno_data_component_params = {&quot;is_btn&quot;:true,&quot;primary_btn&quot;:false,&quot;both_btn&quot;:false,&quot;secondary_btn&quot;:true,&quot;Secondary_header_txt&quot;:true,&quot;header_txt&quot;:language.get(&quot;zcpm.something.worng&quot;),&quot;btn_name&quot;:language.get(&quot;zcpm.back.to.homepage&quot;),&quot;primary_btn_link&quot;:&quot;#Page:&quot; + page_link_name};\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Accounting(string action, string payment_type, int rec_id, string tab)
		{
			displayname = "Accounting"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet8' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet8()\ncontent\n&lt;%{\n\tlanguage = thisapp.Localization.Pages();\n\tCommon_language = thisapp.Localization.common();\n\tif(input.action.contains(&quot;&amp;&quot;))\n\t{\n\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\tinput.action = &quot;detail&quot;;\n\t}\n\tpage_link_name = &quot;Accounting&quot;;\n\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\ttab_keys = tab_map.keys();\n\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\tuser_config = User_Configuration[ID != 0];\n\tpenaltypayfor = Pay_For_Monthly[Pay_For == &quot;Penalty&quot;];\n\tcommissionpayfor = Pay_For_Monthly[Pay_For == &quot;Commission&quot;];\n\tsecuritypayfor = Pay_For_Monthly[Pay_For == &quot;Security Deposit&quot;];\n\tpanel_count = 5;\n\texpense_link = &quot;#Page:Accounting?tab=all&amp;payment_type=Expense&quot;;\n\tif(login_profile == &quot;Owner&quot;)\n\t{\n\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Owner_Email.Email == zoho.loginuserid];\n\t\ttotal_income = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_expense = Add_Payment_Notes[ID != 0 &amp;&amp; Raise_a_Complaint.Payment_By == &quot;Owner&quot; &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_expense_security = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Pay_For == &quot;Vacate&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_security_deposit = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Security Deposit&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_vacate_complaint = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Vacate Complaints&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\towner_commission = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_commission_security = Payment_Details[Add_Payment_Notes == owner_commission.ID.getall() &amp;&amp; Add_Payment_Notes.Pay_For == &quot;Security Deposit&quot; &amp;&amp; Pay_For == commissionpayfor];\n\t\ttotal_over_due = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Unpaid&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Due_Date != null &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt;= zoho.currentdate &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_penalty_owner = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Owner_Mail_ID == thisapp.get_user_id()];\n\t\ttotal_penalty = Payment_Details[ID != 0 &amp;&amp; Pay_For == penaltypayfor.ID &amp;&amp; Add_Payment_Notes == total_penalty_owner.ID.getall()];\n\t}\n\telse if(login_profile == &quot;Manager&quot;)\n\t{\n\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Manager.Email == zoho.loginuserid];\n\t\ttotal_income = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_expense = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Raise_a_Complaint.Payment_By == &quot;Owner&quot; &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_expense_security = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Pay_For == &quot;Vacate&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_security_deposit = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Security Deposit&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_vacate_complaint = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Vacate Complaints&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\tmanager_commission = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_commission_security = Payment_Details[Add_Payment_Notes == manager_commission.ID.getall() &amp;&amp; Add_Payment_Notes.Pay_For == &quot;Security Deposit&quot; &amp;&amp; Pay_For == commissionpayfor];\n\t\ttotal_over_due = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Unpaid&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Due_Date != null &amp;&amp; Due_Date &lt;= zoho.currentdate &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_penalty_manager = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Unit.Manager == thisapp.get_user_id() || Property.Manager == thisapp.get_user_id()];\n\t\ttotal_penalty = Payment_Details[ID != 0 &amp;&amp; Pay_For == penaltypayfor.ID &amp;&amp; Add_Payment_Notes == total_penalty_manager.ID.getall()];\n\t\tmanager_unit_Payment = Add_Payment_Notes[ID != null &amp;&amp; Unit.Manager == thisapp.get_user_id() &amp;&amp; Status == &quot;Received&quot;];\n\t\ttotal_manager_commission = Payment_Details[ID != 0 &amp;&amp; Pay_For == commissionpayfor.ID || Pay_For.Pay_For == &quot;Complaint Commissions&quot; &amp;&amp; Add_Payment_Notes in manager_unit_Payment];\n\t}\n\telse if(login_profile == &quot;Tenant&quot;)\n\t{\n\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id &amp;&amp; Tenant_Email.Email == zoho.loginuserid];\n\t\ttotal_expense = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payer.Email == zoho.loginuserid &amp;&amp; Pay_For == &quot;Monthly Payment&quot;];\n\t\ttotal_security_tenant = Payment_Details[ID != 0 &amp;&amp; Add_Payment_Notes.Status == &quot;Received&quot; &amp;&amp; Add_Payment_Notes.Payer == thisapp.get_user_id() &amp;&amp; Add_Payment_Notes.Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == securitypayfor];\n\t\ttotal_payment = Add_Payment_Notes[Payer.Email == zoho.loginuserid];\n\t\ttotal_complaints_tenant = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payer == thisapp.get_user_id() &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Pay_For == &quot;Complaint&quot;];\n\t\tpanel_count = 4;\n\t\texpense_link = &quot;href=&apos;#Page:Accounting?tab=monthly-payments&apos;&quot;;\n\t}\n\telse\n\t{\n\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\ttotal_income = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Payment_Type == &quot;Income&quot;];\n\t\ttotal_expense = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Expense&quot;];\n\t\ttotal_expense_security = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Expense&quot; &amp;&amp; Pay_For == &quot;Vacate&quot;];\n\t\ttotal_security_deposit = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Security Deposit&quot;];\n\t\ttotal_vacate_complaint = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Received&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Pay_For == &quot;Vacate Complaints&quot;];\n\t\ttotal_commission_security = Payment_Details[Add_Payment_Notes.Pay_For == &quot;Security Deposit&quot; &amp;&amp; Add_Payment_Notes.Status == &quot;Received&quot; &amp;&amp; Pay_For == commissionpayfor];\n\t\ttotal_over_due = Add_Payment_Notes[ID != 0 &amp;&amp; Status == &quot;Unpaid&quot; &amp;&amp; Payment_Type == &quot;Income&quot; &amp;&amp; Due_Date != null &amp;&amp; Pay_For != &quot;Security Deposit&quot; &amp;&amp; Due_Date &lt;= zoho.currentdate];\n\t\t\/\/ \t\ttotal_penalty = Add_Payment_Notes[ID != 0 &amp;&amp; Payment_Details.Pay_For == penaltypayfor.ID];\n\t\ttotal_penalty = Payment_Details[ID != 0 &amp;&amp; Add_Payment_Notes.Status == &quot;Received&quot; &amp;&amp; Pay_For == penaltypayfor.ID];\n\t\ttotal_manager_commission = Payment_Details[ID != 0 &amp;&amp; Pay_For == commissionpayfor.ID || Pay_For.Pay_For == &quot;Complaint Commissions&quot; &amp;&amp; Add_Payment_Notes.Status == &quot;Received&quot;];\n\t}\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_View()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n    content: &apos;&lt;%=language.get(&quot;zcpm.bill.no.filter&quot;)%&gt;&apos;; \n}\n.zcpopup.compact .popupbox-wrapper .popupbox{\n\twidth: 750px;\n}\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-view zc-prop-accounting-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-page-header-with-options zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.account.accounting&quot;)%&gt; &lt;\/h5&gt;\n&lt;%\n\t\t\tif(login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.account.add_payment&quot;),&quot;#Page:Accounting?action=add&amp;tab=&quot; + input.tab)%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t&lt;ul class=&apos;zc-prop-panel-wrapper zc-prop-panel-count-&lt;%=panel_count%&gt; zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\t\tif(login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=all&amp;payment_type=Income&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline business-chart-bar-32&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; \n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_income.sum(Total_Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.total_income&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-yellow&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;&lt;%=expense_link%&gt;&apos;&apos; &gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline business-handout&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; \n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_expense.sum(Total_Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=if(login_profile == &quot;Tenant&quot;,language.get(&quot;zcpm.account.total_Monthly_expense&quot;),language.get(&quot;zcpm.account.total_expense&quot;))%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=security-deposit&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-lock&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\t\tif(login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_security_deposit.sum(Total_Amount) - total_expense_security.sum(Total_Amount) - total_vacate_complaint.sum(Total_Amount) - total_commission_security.sum(Amount))%&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_security_tenant.sum(Amount))%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.security_deposit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\tif(login_profile == &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-l_blue&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=maintenancepayment&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-2-time&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_complaints_tenant.sum(Total_Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.dashboard.complaints&quot;) + &quot; &quot; + language.get(&quot;zcpm.dashboard.payment.chart&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-l_blue&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=all&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-2-time&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_payment.sum(Total_Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.all.payment&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-l_blue&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Accounting?tab=overduespayment&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline arrows-2-time&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_over_due.sum(Total_Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.ovedue_payments&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(login_profile == &quot;Developer&quot; || login_profile == &quot;Owner&quot; || (user_config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Owner&quot; &amp;&amp; login_profile == &quot;Admin&quot;) || (user_config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Owner&quot; &amp;&amp; login_profile == &quot;Administrator&quot;))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-red&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; \n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_penalty.sum(Amount))%&gt;\n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.penalty&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(login_profile == &quot;Developer&quot; || login_profile == &quot;Manager&quot; || (user_config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Manager&quot; &amp;&amp; login_profile == &quot;Admin&quot;) || (user_config.What_type_of_Property_Management_app_are_you_looking_for == &quot;Admin as a Manager&quot; &amp;&amp; login_profile == &quot;Administrator&quot;))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-red&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Manager_Commission?zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline files-single-paragraph&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; \n\t\t\t\t\t\t\t&lt;%=thisapp.Currency.Get_Currency() + thisapp.CommonFeatures.numberFormat(total_manager_commission.sum(Amount))%&gt; \n\t\t\t\t\t\t&lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=language.get(&quot;zcpm.account.commission&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody zc-prop-card-content&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Focus=false&amp;Page=&lt;%=page_link_name%&gt;&amp;Report=&lt;%=report_name%&gt;&amp;tab=&lt;%=input.tab%&gt;&amp;Payment_Type=&lt;%=input.payment_type%&gt;&apos; name=&apos;&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;add&quot;)\n\t\t{\n\t\t\tnext_url = &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name;\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Add.Payment.Note&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Add_Payment_Notes&quot;,&quot;zc_Header=false&quot; + next_url)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;import&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Import(page_link_name)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;complaintdetail&quot; &amp;&amp; complaint.count() &gt; 0)\n\t\t{\n\t\t\tcomplaint = Raise_a_Complaint[ID == input.rec_id];\n\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(complaint.ID,complaint.Photo,report_name,&quot;Photo&quot;,complaint.Complaint_About,true);\n\t\t\tclass_name = &quot;&quot;;\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Complaints_Detail_View()%&gt;\n.zcform_Review_Complaint,\n.zcform_Work_Order_Payment {\n    width: 600px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\t\tlow_color = if(complaint.Priority == &quot;Low&quot;,&quot;zc-prop-badge-green&quot;,&quot;&quot;);\n\t\t\tmedium_color = if(complaint.Priority == &quot;Medium&quot;,&quot;zc-prop-badge-yellow&quot;,&quot;&quot;);\n\t\t\thigh_color = if(complaint.Priority == &quot;High&quot;,&quot;zc-prop-badge-orange&quot;,&quot;&quot;);\n\t\t\tveryhigh_color = if(complaint.Priority == &quot;Very High&quot;,&quot;zc-prop-badge-red&quot;,&quot;&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-complaints-detail-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-page-header-title&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-back-icon&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=input.tab%&gt;&apos;&gt;\n\t\t\t\t\t&lt;span class=&apos;fa fa-angle-left&apos;&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_summary&quot;)%&gt; - &lt;%=complaint.Work_Order_Number%&gt;&lt;\/h5&gt;\n\t\t\t\t&lt;span class=&apos;zc-prop-badge &lt;%=low_color + medium_color + high_color + veryhigh_color%&gt; &apos;&quot;&gt;\n\t\t\t\t\t&lt;%=complaint.Priority%&gt;\n\t\t\t\t&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\tif(complaint.Complaint_Status == &quot;Requested&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=edit&amp;tab=&lt;%=input.tab%&gt;&amp;rec_id=&lt;%=input.rec_id%&gt;&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(login_profile != &quot;Tenant&quot; &amp;&amp; complaint.Complaint_Status == &quot;Approved&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Review_Complaint?Complaint=&lt;%=input.rec_id%&gt;&amp;Complaint_Details&lt;%=complaint.Complaint_Details%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(complaint.Complaint_Status == &quot;Work Order Completed&quot; &amp;&amp; login_profile != &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-outline-primary-btn&apos; href=&apos;#Form:Work_Order_Payment?Work_Order=&lt;%=input.rec_id%&gt;&amp;Property=&lt;%=complaint.Property%&gt;&amp;Unit=&lt;%=complaint.Unit%&gt;&amp;Vendor_Update=&lt;%=complaint.Vendor_Update%&gt;&amp;Complaint_Amount=&lt;%=complaint.Complaint_Amount%&gt;&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.reload&apos;&gt;\n\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-add&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.assign.pay&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\ttop_bar_map = thisapp.Timeline.Get_Topbar(input.rec_id);\n\t\t\tkey_lis = top_bar_map.keys();\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-stepper-wrapper zc-prop-fw&apos;&gt;\n\t\t\t\t\t&lt;ul class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n&lt;%\n\t\t\tfor each  top_bar in key_lis\n\t\t\t{\n\t\t\t\tstyle = if(top_bar != 5,top_bar_map.get(top_bar).get(&apos;Style&apos;),&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-stepper &lt;%=style%&gt;&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-stepper-status&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=top_bar%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-small&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-circle-remove&apos;&gt;&lt;\/i&gt;\n&lt;%\n\t\t\t\tif(top_bar == 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;%=top_bar_map.get(top_bar).get(&apos;Style&apos;)%&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;span&gt; &lt;%=top_bar_map.get(top_bar).get(&apos;Display&apos;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\tif(top_bar != 5)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-stepper-line&apos;&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-complaints-info&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card-header&apos;&gt;\n\t\t\t\t\t&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.compliant_detail&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t&lt;\/div&gt;\t\n\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-img-txt-outer zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper-outer&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Complaint_About%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;p&gt; &lt;%=complaint.Complaint_Details%&gt; &lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-label-value-wrapper zc-prop-label-value-wrapper-new zc-prop-count-4&apos;&gt;\n\t\t\t\t\t\t&lt;ul&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.property&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Property_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;  &lt;%=language.get(&quot;zcpm.complaint.unit&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Unit.Unit_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.property.location&quot;)%&gt;  &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Property.Location.Location%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.complaint_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=complaint.Date_of_Reporting%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.duration&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.End_Time != null &amp;&amp; complaint.Start_Time != null)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=thisapp.Get_Duration_Time(complaint.ID)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=language.get(&quot;zcpm.complaint.not.yet&quot;)%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.Expected_Date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Expected_Date == null,&quot;-&quot;,complaint.Expected_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.resolved_date&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Resolved_Date == null,&quot;-&quot;,complaint.Resolved_Date)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\t\tif(complaint.Complaint_Status != &quot;Rejected&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.comments&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Comments.isEmpty(),&quot;-&quot;,complaint.Comments)%&gt;&lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.reason&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt;&lt;%=if(complaint.Reason.isEmpty(),&quot;-&quot;,complaint.Reason)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.vendor_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.name&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Name)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.email&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Vendor_Email)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt;&lt;%=language.get(&quot;zcpm.Phone.Number&quot;)%&gt;&lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Assigned_to == null,&quot;-&quot;,complaint.Assigned_to.Phone_Number)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-subheader&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_details&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.request.complaint.amount&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=if(complaint.Complaint_Amount == null,&quot;-&quot;,complaint.Complaint_Amount_Display)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n\t\t\t\t\t\t\t&lt;li class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;label&gt; &lt;%=language.get(&quot;zcpm.complaint.payment_by&quot;)%&gt; &lt;\/label&gt;\n&lt;%\n\t\t\tif(complaint.Payment_By == &quot;Owner&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Owner_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(complaint.Payment_By == &quot;Tenant&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=complaint.Tenant_Email.Name%&gt; &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;h6&gt; - &lt;\/h6&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/li&gt;\n\t\t\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Communication(string action, int rec_id, string tab)
		{
			displayname = "Communication"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet10' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet10()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tlanguage = thisapp.Localization.Pages();\n\t\tCommon_language = thisapp.Localization.common();\n\t\tif(input.action.contains(&quot;&amp;&quot;))\n\t\t{\n\t\t\tinput.rec_id = input.action.getSuffix(&quot;rec_id=&quot;);\n\t\t\tinput.action = &quot;detail&quot;;\n\t\t}\n\t\tpage_link_name = &quot;Communication&quot;;\n\t\tno_data_component_params = {&quot;is_img&quot;:true,&quot;header_txt&quot;:&quot;No Data&quot;,&quot;Secondary_header_txt&quot;:true};\n\t\tif(!input.rec_id.isEmpty())\n\t\t{\n\t\t\tgetTenant = Tenant_Agreement[ID == input.rec_id];\n\t\t\tgetUnit = Add_Unit[ID == getTenant.Unit];\n\t\t\tgetProperty = Add_Property[ID == getUnit.Property];\n\t\t}\n\t\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n.zcform_Delete_Confirmation {\n    width: 450px;\n}\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Feeds()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-feeds-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header&apos;&gt;\n\t\t\t&lt;h5&gt; &lt;%=language.get(&quot;zcpm.communication.communication&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-action-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-toggle-wrapper&apos;&gt;\n\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(main_tab == input.tab,&quot;class=&apos;zc-prop-toggle-active&apos;&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li &lt;%=class_name%&gt;&gt;\n\t\t\t\t\t\t\t&lt;a href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&apos;&gt;  &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,language.get(&quot;zcpm.communication.add_post&quot;),&quot;#Page:Communication?action=addpost&amp;tab=&quot; + input.tab)%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n&lt;%\n\t\t\tif(input.tab == &quot;allpost&quot; || input.tab.isEmpty() &amp;&amp; login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t\t{\n\t\t\t\tall_posts = Post[ID != 0];\n\t\t\t}\n\t\t\telse if(input.tab == &quot;allpost&quot; || input.tab.isEmpty())\n\t\t\t{\n\t\t\t\tall_posts = Post[ID != 0 &amp;&amp; (Post_To == &quot;Properties&quot; &amp;&amp; Post_Viewers.contains(thisapp.get_user_id())) || (Post_To == &quot;Individual&quot; &amp;&amp; Users.contains(thisapp.get_user_id()))] sort by Added_Time desc;\n\t\t\t}\n\t\t\telse if(input.tab == &quot;mypost&quot;)\n\t\t\t{\n\t\t\t\tall_posts = Post[ID != 0 &amp;&amp; Post_By.Email == zoho.loginuserid];\n\t\t\t}\n\t\t\tif(all_posts.count() &gt; 0)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;ul class=&apos;zc-pra-feeds-wrapper zc-prop-fwh&apos;&gt;\n&lt;%\n\t\t\t\tfor each  post1 in all_posts\n\t\t\t\t{\n\t\t\t\t\timg_src = &quot;&quot;;\n\t\t\t\t\tif(!post1.Image.isEmpty())\n\t\t\t\t\t{\n\t\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(post1.ID,post1.Image,&quot;Posts_Report&quot;,&quot;Image&quot;,post1.Title,true);\n\t\t\t\t\t}\n\t\t\t\t\tgetPostBy = New_User[ID == post1.Post_By.ID];\n\t\t\t\t\tprofile_image = thisapp.CommonFeatures.processImageUrl(getPostBy.ID,getPostBy.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,getPostBy.Name,false);\n\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t&lt;a class=&apos;zc-prop-overlay&apos; href=&apos;#Page:Communication_Detail_View?rec_id=&lt;%=post1.ID%&gt;&amp;zc_LoadIn=dialog&apos;&gt; &lt;\/a&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-basic-info&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-img-wrapper&apos;&gt; &lt;%=profile_image%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=post1.Post_By.Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=post1.Date_field%&gt; &lt;%=post1.Added_Time.getTime(12)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\tif(post1.Post_By.Email == zoho.loginuserid || login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-more-options zc-prop-rounded&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-hover-extend&apos;&gt;&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;fa fa-ellipsis-h&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\t\t\t\t\tif(post1.Post_By.Email == zoho.loginuserid)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Page:Communication?tab=&lt;%=input.tab%&gt;&amp;action=editpost&amp;rec_id=&lt;%=post1.ID%&gt;&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(post1.Post_By.Email == zoho.loginuserid || login_profile == &quot;Admin&quot; || login_profile == &quot;Administrator&quot; || login_profile == &quot;Developer&quot;)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-color-red&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;a href=&apos;#Form:Delete_Confirmation?Post=&lt;%=post1.ID%&gt;&amp;zc_Header=false&amp;zc_LoadIn=dialog&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-trash-simple&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.post.delete&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t\t\t}\n\t\t\t\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n&lt;%\n\t\t\t\t\tif(!img_src.isEmpty())\n\t\t\t\t\t{\n\t\t\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-img-wrapper zc-prop-feed-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n&lt;%\n\t\t\t\t\t}\n\t\t\t\t\t%&gt;\n&lt;h6&gt; &lt;%=post1.Title%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t&lt;p class=&apos;zc-prop-feed-desc&apos;&gt; &lt;%=post1.Description%&gt;  &lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/ul&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;addpost&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.communication.add_post&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Post&quot;,&quot;zc_Header=false&amp;zc_NextUrl=#Page:Communication?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;editpost&quot;)\n\t\t{\n\t\t\treport_name = &quot;My_Posts&quot;;\n\t\t\topenUrl(&quot;#Script:dialog.closeAll&quot;,&quot;same window&quot;);\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.Post.Edit&quot;),page_link_name + &quot;?tab=&quot; + input.tab,&quot;Post&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=&quot; + report_name + &quot;&amp;zc_NextUrl=#Page:Communication?tab=&quot; + input.tab)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Vendor_Profile(string action, int rec_id, string tab)
		{
			displayname = "Vendor Profile"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet16' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet16()\ncontent\n&lt;%{\n\tlanguage = thisapp.Localization.Pages();\n\tlogin_profile = thisapp.permissions.loginUserProfile();\n\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\tif(login_profile != &quot;Vendor&quot;)\n\t{\n\t\tno_data_component_params = {&quot;is_img&quot;:false,&quot;header_txt&quot;:language.get(&quot;zcpm.page.alert.vendor&quot;),&quot;Primary_header_txt&quot;:true};\n\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\tCommon_language = thisapp.Localization.common();\n\t\tvendor = Add_Vendor[Vendor_Email == zoho.loginuserid];\n\t\tfield_name = &quot;Profile_Photo&quot;;\n\t\treport_name = &quot;Vendor_Profile_Report&quot;;\n\t\timg_src = thisapp.CommonFeatures.processImageUrl(vendor.ID,vendor.Profile_Photo,report_name,field_name,vendor.Vendor_Name,false);\n\t\tpage_link_name = &quot;Vendor_Profile&quot;;\n\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\ttab_keys = tab_map.keys();\n\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\t\tno_data_src = thisapp.Data_Map.Image_Sources();\n\t\tno_data_component_params = {&quot;is_img&quot;:true,&quot;header_txt&quot;:&quot;No Data&quot;,&quot;Secondary_header_txt&quot;:true};\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Vendor_Profile()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-vendor-profile-page&apos;&gt;\n\t&lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;h5&gt; Welcome &lt;%=zoho.loginuser%&gt;, &lt;\/h5&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t\t&lt;div class=&apos;zc-prop-info-wrapper zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-flt-left zc-prop-vendor-info&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-vendor-personal-info zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;%=img_src%&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-txt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vendor.Vendor_Name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t&lt;!-- div class=&apos;zc-prop-flt-right&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;a class=&apos;zc-prop-clearfix zc-prop-edit-txt&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?action=editvendor&amp;rec_id=&lt;%=vendor.ID%&gt;&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-prop-flt-left zc-li-outline ui-1-edit-72&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; Edit &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/a&gt;\n\t\t\t\t\t\t\t\t&lt;\/div --&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-email-85 zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t&lt;a class=&apos;zc-prop-flt-left&apos; href=&apos;mailto:&lt;%=vendor.Vendor_Email%&gt;&apos;&gt; &lt;%=vendor.Vendor_Email%&gt; &lt;\/a&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-3-phone zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vendor.Phone_Number%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw zc-prop-itxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline location-pin zc-prop-flt-left&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=vendor.Address%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-vendor-other-info zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-label-text&apos;&gt; &lt;%=language.get(&quot;zcpm.vendor.org&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-span-text&apos;&gt; &lt;%=if(vendor.Organization.isEmpty(),&quot;-&quot;,vendor.Organization)%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t\t\t&lt;label class=&apos;zc-prop-label-text&apos;&gt; &lt;%=language.get(&quot;zcpm.vendor.service&quot;)%&gt; &lt;\/label&gt;\n\t\t\t\t\t\t\t&lt;ul&gt;\n&lt;%\n\t\tcolor = List();\n\t\tcolor.add(&quot;green&quot;);\n\t\tcolor.add(&quot;orange&quot;);\n\t\tcolor.add(&quot;yellow&quot;);\n\t\tcolor.add(&quot;red&quot;);\n\t\tcount = 0;\n\t\tfor each  service in vendor.Maintenance_Services\n\t\t{\n\t\t\t%&gt;\n&lt;li&gt; &lt;span class=&apos;zc-prop-badge zc-prop-badge-&lt;%=color.get(count)%&gt;&apos;&gt; &lt;%=service.Maintenance_Service_Name%&gt; &lt;\/span&gt; &lt;\/li&gt;\n&lt;%\n\t\t\tcount = if(count == 2,0,count + 1);\n\t\t}\n\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-flt-left&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=language.get(&quot;zcpm.vendor.work_order_status&quot;)%&gt; &lt;\/h6&gt;\n\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\tassign_work = Raise_a_Complaint[Complaint_Status == &quot;Vendor Assigned&quot; &amp;&amp; Assigned_to.Vendor_Email == zoho.loginuserid];\n\t\tongoing_work = Raise_a_Complaint[Complaint_Status == &quot;In Progress&quot; &amp;&amp; Assigned_to.Vendor_Email == zoho.loginuserid];\n\t\tpayment_work = Raise_a_Complaint[Assigned_to.Vendor_Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Work Order Completed&quot; || Complaint_Status == &quot;Waiting for Payment&quot; || Complaint_Status == &quot;Paid&quot;];\n\t\tcompleted_work = Raise_a_Complaint[Complaint_Status == &quot;Completed&quot; &amp;&amp; Assigned_to.Vendor_Email == zoho.loginuserid];\n\t\tchart_name = &quot;Order&quot;;\n\t\tChart_Inputs = {language.get(&quot;zcpm.vendor.assigned&quot;):assign_work.count(),language.get(&quot;zcpm.vendor.ongoing&quot;):ongoing_work.count(),language.get(&quot;zcpm.vendor.payment&quot;):payment_work.count(),language.get(&quot;zcpm.vendor.completed&quot;):completed_work.count()};\n\t\tcolors = {&quot;#FCA76C&quot;,&quot;#84E2C9&quot;,&quot;#A68DED&quot;,&quot;#77C4F4&quot;};\n\t\tshow_legend = true;\n\t\t%&gt;\n&lt;%=thisapp.Components.Custom_Donut(chart_name,Chart_Inputs,colors,show_legend)%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-flt-left zc-prop-list-wrapper&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-header zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;h6 class=&apos;zc-prop-flt-left&apos;&gt;&lt;%=language.get(&quot;zcpm.vendor.pending_payment&quot;)%&gt;&lt;\/h6&gt;\n\t\t\t\t\t\t&lt;a class=&apos;zc-prop-flt-right&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=vendor-payments&apos;&gt; &lt;%=language.get(&quot;zcpm.vendor.view_all&quot;)%&gt; &lt;\/a&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-card-content&apos;&gt;\n&lt;%\n\t\tcomplaint = Raise_a_Complaint[Assigned_to.Vendor_Email == zoho.loginuserid &amp;&amp; Complaint_Status == &quot;Paid&quot; || Complaint_Status == &quot;Waiting for Payment&quot; &amp;&amp; Payment_By != null] sort by Resolved_Date desc range from 0 to 2;\n\t\tif(complaint.count() &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;ul&gt;\n&lt;%\n\t\t\tfor each  pay in complaint\n\t\t\t{\n\t\t\t\tstatus = if(pay.Complaint_Status == &quot;Waiting for Payment&quot;,&quot;Pending&quot;,&quot;Paid&quot;);\n\t\t\t\tcolor = if(pay.Complaint_Status == &quot;Waiting for Payment&quot;,&quot;#b8770d&quot;,&quot; #187822&quot;);\n\t\t\t\tif(pay.Payment_By == &quot;Owner&quot;)\n\t\t\t\t{\n\t\t\t\t\tname = pay.Owner_Email.Name;\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(pay.Owner_Email.ID,pay.Owner_Email.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,pay.Owner_Email.Name.first_name + &quot; &quot; + pay.Owner_Email.Name.last_name,false);\n\t\t\t\t}\n\t\t\t\telse if(pay.Payment_By == &quot;Tenant&quot;)\n\t\t\t\t{\n\t\t\t\t\tname = pay.Tenant_Email.Name;\n\t\t\t\t\timg_src = thisapp.CommonFeatures.processImageUrl(pay.Tenant_Email.ID,pay.Tenant_Email.Profile_Photo,&quot;All_User_Profile_Photo&quot;,&quot;Profile_Photo&quot;,pay.Tenant_Email.Name.first_name + &quot; &quot; + pay.Tenant_Email.Name.last_name,false);\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;li class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-clearfix zc-prop-btxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-img-wrapper&apos;&gt; &lt;%=img_src%&gt; &lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-atxt-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;h6&gt; &lt;%=name%&gt; &lt;\/h6&gt;\n\t\t\t\t\t\t\t\t\t\t&lt;span&gt; &lt;%=pay.Complaint_Amount_Display%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t&lt;span class=&apos;zc-prop-flt-right&apos; style=&apos;color:&lt;%=color%&gt;;&apos;&gt; &lt;%=status%&gt; &lt;\/span&gt;\n\t\t\t\t\t\t\t\t&lt;!-- &lt;a class=&apos;zc-prop-flt-right zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-check-circle-08&apos;&gt; &lt;\/i&gt;\n\t\t\t\t\t\t\t\t&lt;\/a&gt;--&gt;\n\t\t\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.No_Data(no_data_component_params)%&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\tfor each  main_tab in tab_keys\n\t\t{\n\t\t\tclass_name = if(input.tab == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?tab=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;viewLinkName&quot;)%&gt;&apos; params=&apos;Assigned_to.Vendor_Email=&lt;%=zoho.loginuserid%&gt;&amp;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Preferences(string action, string agreement_type, int rec_id, string tab)
		{
			displayname = "Preferences"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"card\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet111' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet111()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tcommon = thisapp.Localization.Tab();\n\t\tpage_link_name = &quot;Preferences&quot;;\n\t\tlanguage = thisapp.Localization.Pages();\n\t\ttablinks = List();\n\t\tList_Tabs = thisapp.Page.Get_Tab1(page_link_name);\n\t\tinput.tab = if(input.action.contains(&quot;&amp;&quot;),input.action.getSuffix(&quot;&amp;tab=&quot;).getprefix(&quot;&amp;agreement_type=&quot;),input.tab);\n\t\tinput.agreement_type = if(input.action.contains(&quot;&amp;&quot;),input.action.getSuffix(&quot;agreement_type=&quot;),input.agreement_type);\n\t\tinput.agreement_type = if(input.agreement_type.isEmpty(),&quot;Rent&quot;,input.agreement_type);\n\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\ttab_keys = tab_map.keys();\n\t\tinput.tab = if(input.tab == &quot;&quot; || input.tab == null,tab_keys.get(0),input.tab);\n\t\tinput.tab = if(!tab_keys.contains(input.tab),tab_keys.get(0),input.tab);\n\t\treport_name = tab_map.get(input.tab).get(&quot;viewLinkName&quot;);\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;%=thisapp.Styles_Page.Preferences()%&gt;\n.zcform_Set_as_Default { width: 450px; }\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-preference-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n        &lt;div class=&apos;zc-prop-card zc-prop-fwh&apos;&gt;\n            &lt;div class=&apos;zc-prop-page-header&apos;&gt;\n                &lt;h5&gt; &lt;%=common.get(&quot;zcpm.setup.setup&quot;)%&gt; &lt;\/h5&gt;\n                &lt;p&gt; &lt;%=common.get(&quot;zcpm.setup.your.organisation&quot;)%&gt; &lt;\/p&gt;\n            &lt;\/div&gt;\n            &lt;div class=&apos;zc-prop-page-content zc-prop-vertical-tabpanel zc-prop-clearfix zc-prop-fwh&apos;&gt;\n                &lt;ul class=&apos;zc-prop-vertical-tabhead zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\tfor each  main_tab in tab_keys\n\t\t{\n\t\t\tclass_name = if(main_tab == input.tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t%&gt;\n&lt;li&gt;\n\t\t\t\t\t\t&lt;input id=&apos;tabCount&apos; type=&apos;checkbox&apos; name=&apos;zc-prop-tab&apos;&gt;\n\t\t\t\t\t\t&lt;label for=&apos;tabCount&apos;&gt;\n\t\t\t\t\t\t\t&lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:Preferences?tab=&lt;%=main_tab%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt;\n\t\t\t\t\t\t&lt;\/label&gt;\n\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/ul&gt;\n                &lt;div class=&apos;zc-prop-vertical-tabbody zc-prop-flt-left&apos;&gt;\n&lt;%\n\t\tgeneral1 = General[ID != 0];\n\t\tconfig = Configure[Configure1 = &quot;Default&quot;];\n\t\tif(input.tab == &quot;general&quot;)\n\t\t{\n\t\t\tparam = &quot;&amp;recLinkID=&quot; + general1.ID + &quot;&amp;viewLinkName=&quot; + report_name + &quot;&amp;&quot;;\n\t\t}\n\t\telse if(input.tab == &quot;configure&quot;)\n\t\t{\n\t\t\tparam = &quot;&amp;recLinkID=&quot; + config.ID + &quot;&amp;viewLinkName=&quot; + report_name + &quot;&amp;&quot;;\n\t\t}\n\t\tif(input.tab == &quot;organizations&quot; || input.tab == &quot;idsetup&quot; || input.tab == &quot;agreement-templates&quot;)\n\t\t{\n\t\t\tif(input.tab == &quot;agreement-templates&quot; &amp;&amp; input.action == &quot;addAgreementTemplate&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.property.Add.Agreement.Templates&quot;),page_link_name + &quot;?tab=agreement-templates&quot;,&quot;Agreement_Template&quot;,&quot;zc_Header=false&amp;Agreement_Type=&quot; + input.agreement_type + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?tab=agreement-templates&quot;)%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Agreement_Add_Record()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;agreement-templates&quot; &amp;&amp; input.action == &quot;editAgreementTemplate&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(language.get(&quot;zcpm.property.Edit.Agreement.Templates&quot;),page_link_name + &quot;?tab=&quot; + input.tab + &quot;&amp;agreement_type=&quot; + input.agreement_type,&quot;Agreement_Template&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=All_Agreement_Templates&amp;zc_NextUrl=#Page:Preferences?action=edit%26tab=agreement-templates%26agreement_type=&quot; + input.agreement_type)%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles_Page.Agreement_Add_Record()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\t\t}\n\t\t\telse if(input.tab == &quot;agreement-templates&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab_Using_Form()%&gt;\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n\t&lt;div class=&apos;zc-prop-horizontal-tabhead&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Agreement_Template_Tab&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;Agreement_Template_Type=&lt;%=input.agreement_type%&gt;&apos;&gt;&lt;\/div&gt;\n\t&lt;div class=&apos;zc-prop-horizontal-tabbody&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-report&apos; name=&apos;embedDiv&apos; elName=&apos;zc-component&apos; pageLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;pageLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; pageLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;pageLinkName&quot;)%&gt;&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t\telse if(input.tab == &quot;general&quot; || input.tab == &quot;configure&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&apos;zc-pra-form&apos; elName=&apos;zc-component&apos; formLinkName=&apos;&lt;%=tab_map.get(input.tab).get(&quot;formLinkName&quot;)%&gt;&apos; params=&apos;&lt;%=param%&gt;zc_NextUrl=#Script:page.refresh&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\tbtn = if(input.tab == &quot;email-template&quot;,false,true);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=report_name%&gt;&apos; params=&apos;zc_Import&amp;false&amp;zc_ShowAs=false&amp;zc_Search=false&amp;zc_MoreAction=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=&lt;%=btn%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Users(string action, int rec_id, string role)
		{
			displayname = "Users"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet17' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet17()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tpage_language = thisapp.Localization.Pages();\n\t\tpage_link_name = &quot;Users&quot;;\n\t\tuser_config = User_Configuration[ID != 0];\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\ttab_map = thisapp.Page.Get_Tab1(page_link_name);\n\t\t\ttab_keys = tab_map.keys();\n\t\t\tinput.role = if(input.role == &quot;&quot; || input.role == null,tab_keys.get(0),input.role);\n\t\t\tinput.role = if(!tab_keys.contains(input.role),tab_keys.get(0),input.role);\n\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\treport_name = tab_map.get(input.role).get(&quot;viewLinkName&quot;);\n\t\t\tadmin_count = New_User[Role == &quot;Admin&quot; &amp;&amp; Status == &quot;Active&quot;];\n\t\t\towner_count = New_User[Role == &quot;Owner&quot; &amp;&amp; Status == &quot;Active&quot;];\n\t\t\tmanager_count = New_User[Role == &quot;Manager&quot; &amp;&amp; Status == &quot;Active&quot;];\n\t\t\ttenant_count = New_User[Role == &quot;Tenant&quot; &amp;&amp; Status == &quot;Active&quot;];\n\t\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Horizontal_Tab()%&gt;\n&lt;%=thisapp.Styles_Page.Common_View()%&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n    content: &apos;&lt;%=page_language.get(&quot;zcpm.users.search&quot;)%&gt;&apos;; \n}\n&lt;\/style&gt;\n&lt;div class=&apos;zc-prop-page-container zc-prop-common-view zc-prop-users-page&apos;&gt;\n    &lt;div class=&apos;zc-prop-page-container-inner zc-prop-fwh&apos;&gt;\n\t\t&lt;div class=&apos;zc-prop-page-header zc-prop-page-header-with-options zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;h5 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=page_language.get(&quot;zcpm.Users&quot;)%&gt; &lt;\/h5&gt;\n\t\t\t&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-flt-left&apos;&gt;\n\t\t\t\t&lt;%=thisapp.Components.Button(&quot;Add&quot;,page_language.get(&quot;zcpm.Add.New.User&quot;) + input.role,&quot;#Page:&quot; + page_link_name + &quot;?action=add&amp;role=&quot; + input.role)%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;ul class=&apos;zc-prop-panel-wrapper zc-prop-panel-count-4 zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Users?role=Admin&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-security&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=admin_count.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=page_language.get(&quot;zcpm.admin&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Users?role=Owner&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-a-star&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=owner_count.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=page_language.get(&quot;zcpm.owner&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Users?role=Manager&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline location-explore-user&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=manager_count.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=page_language.get(&quot;zcpm.manager&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t\t&lt;li class=&apos;zc-prop-flt-left zc-prop-panel zc-prop-color-green&apos;&gt;\n\t\t\t\t&lt;a class=&apos;zc-prop-card&apos; href=&apos;#Page:Users?role=Tenant&apos;&gt;\n\t\t\t\t\t&lt;div class=&apos;zc-prop-clearfix zc-prop-fw&apos;&gt;\n\t\t\t\t\t\t&lt;div class=&apos;zc-prop-flt-left zc-prop-icon-wrapper&apos;&gt;\n\t\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline users-2-home&apos;&gt;&lt;\/i&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;h4 class=&apos;zc-prop-flt-left&apos;&gt; &lt;%=tenant_count.count()%&gt; &lt;\/h4&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span&gt; &lt;%=page_language.get(&quot;zcpm.tenant&quot;)%&gt; &lt;\/span&gt;\n\t\t\t\t&lt;\/a&gt;\n\t\t\t&lt;\/li&gt;\n\t\t&lt;\/ul&gt;\n\t\t&lt;div class=&apos;zc-prop-card zc-prop-horizontal-tabpanel&apos;&gt;\n\t\t\t&lt;ul class=&apos;zc-prop-horizontal-tabhead&apos;&gt;\n&lt;%\n\t\t\tfor each  main_tab in tab_keys\n\t\t\t{\n\t\t\t\tclass_name = if(input.role == main_tab,&quot;zc-prop-active-tab&quot;,&quot;&quot;);\n\t\t\t\t%&gt;\n&lt;li&gt; &lt;a class=&apos;&lt;%=class_name%&gt;&apos; href=&apos;#Page:&lt;%=page_link_name%&gt;?role=&lt;%=main_tab%&gt;&lt;%=current_params_values%&gt;&apos;&gt; &lt;%=tab_map.get(main_tab).get(&quot;Display&quot;)%&gt; &lt;\/a&gt; &lt;\/li&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabbody zc-prop-card-content&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-filter&apos; elName=&apos;zc-component&apos; formLinkName=&apos;Property_Filter_Form&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Focus=false&amp;Page=&lt;%=page_link_name%&gt;&amp;Report=New_Users_Report&amp;Role=&lt;%=input.role%&gt;&apos; name=&apos;&apos;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-report&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;New_Users_Report&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_AddRec=false&amp;Role=&lt;%=input.role%&gt;&apos; name=&apos;&lt;%=page_link_name%&gt;&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t}\n\t\tif(input.action == &quot;add&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(page_language.get(&quot;zcpm.Add.New.User&quot;) + input.role,page_link_name + &quot;?role=&quot; + input.role,&quot;New_User&quot;,&quot;zc_Header=false&amp;Role=&quot; + input.role + &quot;&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?role=&quot; + input.role)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;edit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(page_language.get(&quot;zcpm.Edit.User&quot;),page_link_name + &quot;?role=&quot; + input.role,&quot;New_User&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=New_Users_Report&amp;zc_NextUrl=#Page:&quot; + page_link_name + &quot;?role=&quot; + input.role)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;import&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Import(page_link_name)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Vendors(string action, int rec_id)
		{
			displayname = "Vendors"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet7' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet7()\ncontent\n&lt;%{\n\tif(thisapp.Page.Is_Onboard_Completed())\n\t{\n\t\tpage_language = thisapp.Localization.Pages();\n\t\tpage_link_name = &quot;Vendors&quot;;\n\t\treport_view_component_params = {&quot;report_param&quot;:&quot;&quot;,&quot;is_Option&quot;:true,&quot;display_name&quot;:page_language.get(&quot;zcpm.Vendors&quot;),&quot;add_button_text&quot;:page_language.get(&quot;zcpm.Add.Vendor&quot;),&quot;add_link&quot;:&quot;#Page:&quot; + page_link_name + &quot;?action=add&quot;,&quot;form_link_name&quot;:&quot;Property_Filter_Form&quot;,&quot;report_linkname&quot;:&quot;Vendors_Report&quot;,&quot;page_linkname&quot;:&quot;Vendors&quot;,&quot;can_show_report&quot;:true};\n\t\t%&gt;\n&lt;style&gt;\n&lt;%=thisapp.Styles.Common_Styles()%&gt;\n&lt;\/style&gt;\n&lt;%\n\t\tif(input.action.isEmpty())\n\t\t{\n\t\t\t%&gt;\n&lt;style&gt;\n.zc-prop-filter .form-group label.zc-Search-label .zc-label-text:after  { \n    content: &apos;&lt;%=page_language.get(&quot;zcpm.users.search&quot;)%&gt;&apos;; \n}\n&lt;\/style&gt;\n&lt;%=thisapp.Components.Report_View_Advance(report_view_component_params)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;add&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(page_language.get(&quot;zcpm.Add.Vendor&quot;),page_link_name,&quot;Add_Vendor&quot;,&quot;zc_Header=false&amp;zc_NextUrl=#Page:&quot; + page_link_name)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;edit&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Add_Record(page_language.get(&quot;zcpm.Edit.Vendor&quot;),page_link_name,&quot;Add_Vendor&quot;,&quot;zc_Header=false&amp;recLinkID=&quot; + input.rec_id + &quot;&amp;viewLinkName=Vendors_Report&amp;zc_NextUrl=#Page:&quot; + page_link_name)%&gt;\n&lt;%\n\t\t}\n\t\telse if(input.action == &quot;import&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;%=thisapp.Components.Import(page_link_name)%&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\topenUrl(&quot;#Page:Setup_Wizard&quot;,&quot;same window&quot;);\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Parking_Allotments(string activetab)
		{
			displayname = "Parking Allotments"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet25' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet25()\ncontent\n&lt;%{\n\tif(input.activetab.isempty())\n\t{\n\t\tinput.activetab = &quot;S&quot;;\n\t}\n\t%&gt;\n&lt;style&gt;\n    :root {\n        --zcs-card-bg: #ffffff;\n        --zcs-primary-text: #34495e;\n        --zcs-border-color: #e0e0e0;\n    }\n\n    * {\n        margin: 0;\n        padding: 0;\n        box-sizing: border-box;\n    }\n\n    .zcpm-tabbed \n\t{\n        overflow-x: hidden;\n        height: 100%;\n        width: 100%;\n        display: flex;\n        flex-direction: column;\n    }\n\n    .zcpm-tab-container \n\t{\n        display: flex;\n        flex: 1;\n        align-items: center;\n\t\tjustify-content: center;\n    }\n\n    .zcpm-tabRadio \n\t{\n        display: none;\n    }\n\n    .zcpm-tabs \n\t{\n        display: flex;\n        justify-content: flex-start;\n        align-items: center;\n        gap: 1.5rem;\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        width: 100%;\n        border-bottom: 1px solid #ececec;\n    }\n\n    .zcpm-tabLabel \n\t{\n        display: block;\n        padding: 12px 10px;\n        border: 3px solid transparent;\n        color: black;\n        font-size: 16px;\n        font-weight: 600;\n        cursor: pointer;\n        transition: all 0.3s;\n        background: white;\n        text-overflow: ellipsis;\n        white-space: nowrap;\n        overflow: hidden;\n    }\n\n    .zcpm-tabs .zcpm-tab:first-child .zcpm-tabLabel \n\t{\n        border-top-left-radius: 8px;\n    }\n\n    .zcpm-tabs .zcpm-tab:last-child .zcpm-tabLabel \n\t{\n        border-top-right-radius: 8px;\n    }\n\n    .zcpm-tab:hover label \n\t{\n        border-bottom-color: #ffffff;\n        color: #blue;\n    }\n\n    .zcpm-tab-content\n\t{\n        opacity: 0;\n        height: 0;\n        overflow: hidden;\n        width: 100%;\n    }\n\n    .zcpm-tabRadio:nth-of-type(1):checked ~ .zcpm-tabs .zcpm-tab:nth-of-type(1) label,\n    .zcpm-tabRadio:nth-of-type(2):checked ~ .zcpm-tabs .zcpm-tab:nth-of-type(2) label\n\t{\n        border-bottom-color: #5051f9;\n        background: #fff;\n        color: #5051f9;\n    }\n\n    .zcpm-tabRadio:nth-of-type(1):checked ~ .zcpm-tab-content:nth-of-type(1),\n    .zcpm-tabRadio:nth-of-type(2):checked ~ .zcpm-tab-content:nth-of-type(2)\n\t{\n        opacity: 1;\n        border-radius: 10px;\n        padding: 5px;\n        height: calc(100% - 55px);\n    }\n\t.zc-pb-page-content-wrapper {\n    height: 100%;\n    background: #f2f4f5;\n    overflow: auto;\n    overflow: hidden;\n}\n.inner .zc-page-content-wrapper .fullscreen.zc-form-edit-popup-container .popupbox-wrapper {\n    overflow: auto;\n    overflow-x: hidden;\n}\n&lt;\/style&gt;\n\n&lt;div id=&quot;zcpm-dashboard-container&quot;&gt;\n        &lt;main class=&quot;zcpm-main-grid&quot;&gt;\n            &lt;!-- Left Column --&gt;\n            &lt;section class=&quot;zcpm-content-left&quot;&gt;\n                &lt;!-- Reports Section --&gt;\n                &lt;!-- Tabbed Navigation --&gt;\n                &lt;div class=&quot;zcpm-card tabbed&quot;&gt;\n                    &lt;input type=&quot;radio&quot; id=&quot;tab1&quot; class=&quot;zcpm-tabRadio&quot; name=&quot;css-tabs&quot; &lt;%=if(input.activetab == &quot;S&quot;,&quot;checked&quot;,&quot;&quot;)%&gt; &gt;\n                    &lt;input type=&quot;radio&quot; id=&quot;tab2&quot; class=&quot;zcpm-tabRadio&quot; name=&quot;css-tabs&quot; &lt;%=if(input.activetab == &quot;F&quot;,&quot;checked&quot;,&quot;&quot;)%&gt; &gt;\n\t\t\t\t\t\n                    &lt;ul class=&quot;zcpm-tabs&quot;&gt;\n                        &lt;div class=&quot;zcpm-tab-container&quot;&gt;\n                            &lt;li class=&quot;zcpm-tab&quot;&gt;&lt;label class=&quot;zcpm-tabLabel&quot; for=&quot;tab1&quot;&gt;Occupied&lt;\/label&gt;&lt;\/li&gt;\n                            &lt;li class=&quot;zcpm-tab&quot;&gt;&lt;label class=&quot;zcpm-tabLabel&quot; for=&quot;tab2&quot;&gt;Un Occupied&lt;\/label&gt;&lt;\/li&gt;\n                        &lt;\/div&gt;\n                    &lt;\/ul&gt;\n\t\t\t\t\t\n                    &lt;div class=&quot;zcpm-tab-content&quot; id=&quot;Occupied&quot;&gt;\n                        &lt;div class=&quot;zcpm-embdDIv&quot; elName=&apos;zc-component&apos; params=&apos;zc_Header=false&apos;&gt;\n                            &lt;!-- Not Contacted --&gt;\n                            &lt;div elName=&apos;zc-component&apos; viewLinkName=&quot;All_Car_Parking_Management&quot; params=&apos;zc_Header=true&amp;zc_AddRec=false&amp;zc_ShowAs=false&amp;zc_Import=false&amp;Status=Occupied&apos; style=&apos;height:calc(100vh - 117px)&apos;;&gt;&lt;\/div&gt;\n                        &lt;\/div&gt;\n                    &lt;\/div&gt;\n\n                    &lt;div class=&quot;zcpm-tab-content&quot; id=&quot;UnOccupied&quot;&gt;\n                        &lt;div class=&quot;zcpm-embdDIv&quot; elName=&apos;zc-component&apos; params=&apos;zc_Header=false&apos;&gt;\n                            &lt;!-- Contacted --&gt;\n                            &lt;div elName=&apos;zc-component&apos; viewLinkName=&quot;All_Car_Parking_Management&quot; params=&apos;zc_Header=true&amp;zc_AddRec=false&amp;zc_ShowAs=false&amp;zc_Import=false&amp;Status=UnOccupied&apos; style=&apos;height:calc(100vh - 117px)&apos;;&gt;&lt;\/div&gt;\n                        &lt;\/div&gt;\n                    &lt;\/div&gt;\n                &lt;\/div&gt;\n\t\t\t\t&lt;!-- Report Section End --&gt;\n            &lt;\/section&gt;\n        &lt;\/main&gt;\n    &lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
	}


		 functions
		 {
			 Deluge
			 {
				 void AddEmailTemplates()
                 {
                 	email_templates = thisapp.Data_Map.Email_Templates();
                 	// 	create a list related to approval flow/ Template Name
                 	lis = List();
                 	lis.add("Complaint completed to Vendor");
                 	lis.add("Complaint send to Vendor");
                 	lis.add("Vacate Inspection Report to owner without complaints");
                 	lis.add("Vacate Inspection Report to owner with complaints");
                 	lis.add("Agreement rejected by Tenant");
                 	lis.add("Agreement Approval waiting for owner");
                 	lis.add("Tenant Vacate Request to owner");
                 	lis.add("Tenant Agreement waiting for Tenant Approval");
                 	for each  email_template in email_templates
                 	{
                 		if(!lis.contains(email_template.get("TemplateName")))
                 		{
                 			info email_template.get("TemplateName");
                 			if(Email_Template[Template_Name == email_template.get("TemplateName") && Send_To == email_template.get("SendTo")].count() == 0)
                 			{
                 				mail_message = email_template.get("Message").replaceAll("\\/","/");
                 				insert into Email_Template
                 				[
                 					Send_To=email_template.get("SendTo")
                 					Template_Name=email_template.get("TemplateName")
                 					Subject_field=email_template.get("Subject")
                 					Message=mail_message
                 					Enable_This_Mail_Notification=true
                 					Added_User=zoho.loginuser
                 				]
                 			}
                 		}
                 		else if(!lis.contains(email_template.get("TemplateName")))
                 		{
                 			mail_message = email_template.get("Message").replaceAll("\\/","/");
                 			current_email_template = Email_Template[Template_Name == email_template.get("TemplateName") && Send_To == email_template.get("SendTo")];
                 			if(current_email_template.count() != 0)
                 			{
                 				current_email_template.Message=mail_message;
                 				current_email_template.Enable_This_Mail_Notification=true;
                 			}
                 		}
                 	}
                 }
				 void Change_User_Post_Viewer()
                 {
                 	users = New_User[Role == "Admin"].ID.getAll();
                 	for each  post in Post[ID != 0]
                 	{
                 		for each  user in New_User[Role != "Admin"]
                 		{
                 			property = Add_Property[ID == post.Properties && Unit_Owners.Email.contains(user.Email) || Units.Manager == user.ID || Units.Current_Tenant == user.ID];
                 			if(property.count() > 0)
                 			{
                 				users.add(user);
                 			}
                 		}
                 		post.Post_Viewers=users;
                 	}
                 }
