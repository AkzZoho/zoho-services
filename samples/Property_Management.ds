                 	style_txt = ".zc-prop-card .zc-prop-horizontal-tabpanel { border-radius: 0px 0px 12px 12px; overflow: hidden; } .zc-prop-card .zc-prop-horizontal-tabpanel .zc-prop-horizontal-tabbody { border-radius: 0px 0px 12px 12px; } .zc-prop-card .zc-prop-card-header { padding: 16px 30px; border-bottom: 1px solid #EBECF0; } .zc-prop-card .zc-prop-card-content { height: calc(100% - 53px); overflow: auto; } /* Table Styles start */ .zc-prop-tabcontent-wrapper { padding: 15px 30px; } .zc-prop-tabcontent-wrapper>div:not(:last-child) { margin-bottom: 20px; } .zc-prop-table-kv-wrapper table { width: 100%; line-height: normal; border-collapse: collapse; } .zc-prop-table-kv-wrapper table tbody tr td { font-size: 14px; line-height: 21px; vertical-align: top; } .zc-prop-table-kv-wrapper table tbody tr td:nth-child(odd) { width: 20%; font-weight: 400; color: " + color_codes.get("zc-prop-secondary-text-color") + "; padding: 15px 0px; } .zc-prop-table-kv-wrapper table tbody tr td:nth-child(even) { width: 30%; font-weight: 500; color: " + color_codes.get("zc-prop-primary-text-color") + "; padding: 15px; } .zc-prop-table-kv-wrapper table tbody tr.zc-prop-table-sub-header-tr td { border-bottom: 1px solid " + color_codes.get("zc-prop-border-color") + "; vertical-align: middle; } .zc-prop-table-kv-wrapper table tbody tr td.zc-prop-table-sub-header { width: 100%; font-size: 16px; font-weight: 500; line-height: 19px; color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-table-kv-wrapper table tbody tr td.zc-prop-table-btn-td { padding: 0px 0px 10px 0px; } .zc-prop-table-kv-wrapper table tbody tr td.zc-prop-align-right { text-align: right; } /* Table Styles end */ /* Report Styles start */ .zc-prop-report { height: 100% !important; padding-top: 16px; overflow: auto; } .zc-prop-horizontal-tabbody .view-outer-wrapper, .zc-prop-horizontal-tabbody .zc-reporttype-list, .zc-prop-horizontal-tabbody .list-view-inner { border-radius: 0px 0px 12px 12px; } .zc-prop-page-container .view-outer-wrapper .reportfullwidth { border-width: 1px 0px 0px 0px; border-radius: 0px 0px 12px 12px; } /* Report Styles end */";
                 	rtl_txt = ".zc-rtl-wrapper .zc-prop-table-kv-wrapper table tbody tr td.zc-prop-align-right { text-align: left; }";
                 	style_txt = style_txt + rtl_txt;
                 	return style_txt;
                 }
				 string Styles.Report()
                 {
                 	style_txt = ".zc-prop-page-container .zc-reporttype-list, .zc-prop-page-container .zc-reporttype-list .list-view-inner .handsontable.ht_master .wtHolder { height: 100% !important; } .zc-prop-page-container .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead tr th { cursor: default; } .zc-prop-page-container .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead tr th i.zc-report-sortOrder { display: none; } .zc-prop-page-container .zc-reporttype-list .zc-reportheader-tooltip.zc-reportheader-activetooltip { visibility: hidden; opacity: 0; } /* No data */ .zc-prop-page-container .zc-reporttype-list .nodata .zc-importdata-report, .zc-prop-page-container .zc-reporttype-list .nodata span { display: none; } .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th .relative .colHeader span { max-width: 100%; } .zc-prop-page-container .view-outer-wrapper .reportfullwidth { border-width: 1px 0px 0px 0px; border-radius: 0px 0px 12px 12px; } .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zc-conditionalformat-cont .zc-conditionalformat { background-color: transparent !important; }";
                 	// 	Hide Hover State CSS in List Report
                 	style_txt = style_txt + ".zc-prop-reporttype-list-hover-hide .zc-prop-report .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td { cursor: default; } .zc-prop-reporttype-list-hover-hide .zc-prop-report .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr:hover td { background-color: transparent; }";
                 	return style_txt;
                 }
				 string Styles.Report_Header_Customization()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	add_text = "Add";
                 	style_txt = ".zc-prop-page-container .view-outer-wrapper .view-header { height: 69px; padding: 16px 15px; border-bottom: 1px solid " + color_codes.get("zc-prop-border-color") + "; border-radius: 12px 12px 0px 0px; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-new-report-header { height: 36px; } .zc-prop-page-container .view-header .view-options { padding: 0px; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-new-report-header.row>.row { top: 0px; right: 0px; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-reportnameheader { padding: 0px 15px; } .zc-prop-page-container .view-outer-wrapper .view-header>.row h3 { padding: 5px 15px 5px 0; } .zc-prop-page-container .view-outer-wrapper .view-header>.row h3 .zc-view-name { line-height: 26px; font-weight: 500; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-reportoptionheader { margin-top: 0px; padding: 0px 15px; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-reportoptionheader ul li a.zc-add-record { width: auto; height: 36px; padding: 0px 20px; font-size: 14px; line-height: 36px; font-weight: 400; } .zc-prop-page-container .view-header .zc-add-record .fa { display: inline-block; vertical-align: top; } .zc-prop-page-container .view-outer-wrapper .view-header .zc-add-record .fa:before { content: '\ed29'; display: inline-block; vertical-align: top; font: normal normal normal 14px/36px 'ZC Live Outline'; font-size: 12px; font-weight: 600; margin-right: 8px; } .zc-prop-page-container .view-header .zc-add-record:after { content: '" + add_text + "'; display: inline-block; vertical-align: top; } .zc-prop-page-container .view-header.zc-show-new-menu .zc-new-report-header .zc-report-newheader { top: 3px; } .zc-prop-page-container .view-header .zc-more-options { width: 36px; height: 36px; border: 1px solid " + color_codes.get("zc-prop-border-color") + "; border-radius: 6px; } .zc-prop-page-container .view-header .zc-more-options i, .zc-prop-page-container .view-header .zc-reportnameheader .view-name-save { line-height: 36px; } .zc-prop-page-container .view-header .zc-add-record .zc-tooltip { display: none !important; }";
                 	rtl_txt = ".zc-rtl-wrapper .zc-prop-page-container .view-header .zc-add-record .fa:before { margin-right: 0px; margin-left: 8px; }";
                 	style_txt = style_txt + rtl_txt;
                 	return style_txt;
                 }
				 string Styles.Stepper(int no_Of_Step)
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	stepper_width = 100 / no_Of_Step;
                 	steps = no_Of_Step.leftPad(no_Of_Step - 1).toList(" ");
                 	count = 1;
                 	style_txt = ".zc-prop-stepper-wrapper { padding: 25px; text-align: center; } .zc-prop-stepper-wrapper ul { position: relative; } .zc-prop-stepper-wrapper ul li { list-style-type: none; width: " + stepper_width + "%; position: relative; z-index: 2; } .zc-prop-stepper-wrapper ul li a { display: inline-block; vertical-align: top; margin: 0px auto; } /* Visited styles start */ .zc-prop-stepper-status { width: 26px; height: 26px; background-color: var(--theme_brand_color); border: 3px solid " + color_codes.get("zc-prop-white") + "; border-radius: 50%; margin: 0px auto 8px; position: relative; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-level .zc-prop-stepper-status { background-color: " + color_codes.get("zc-prop-white") + "; } .zc-prop-stepper-status h6 { font-size: 12px; font-weight: 600; line-height: 18px; color: " + color_codes.get("zc-prop-secondary-text-color") + "; border: 1px solid " + color_codes.get("zc-prop-border-color") + "; border-radius: 50%; display: none; } .zc-prop-stepper-status .ui-1-check-small { /* font-size: 13px; */ font-size: 18px; font-weight: bolder; line-height: 20px; color: " + color_codes.get("zc-prop-white") + "; display: inline-block; vertical-align: top; } .zc-prop-stepper-status .ui-1-circle-remove { font-size: 18px; font-weight: 400; line-height: 30px; color: " + color_codes.get("zc-prop-white") + "; display: none; vertical-align: top; } .zc-prop-stepper-wrapper ul li span.zc-prop-stepper-level-span { display: none; border-radius: 50%; background-color: var(--theme_brand_color); } .zc-prop-stepper-wrapper ul li span { font-size: 14px; font-weight: 400; line-height: 1.5; color: " + color_codes.get("primary-text-color") + "; display: inline-block; vertical-align: top; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-line { height: 1px; background-color: var(--theme_brand_color); position: absolute; top: calc(26px / 2); z-index: 1; } /* Visited styles end */ /* Active styles start */ .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active .zc-prop-stepper-status { width: 36px; height: 36px; margin-top: -5px; margin-bottom: 4px; background-color: " + color_codes.get("zc-prop-white") + "; transition: transform 0.3s ease; /* transform: scale(1.5); */ } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active .zc-prop-stepper-status h6 { display: block; border-color: var(--theme_brand_color); line-height: 28px; color: var(--theme_brand_color); } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active .zc-prop-stepper-status i { display: none; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active span { font-weight: 500; color: var(--theme_brand_color); } /* Stepper stop styles */ .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active.zc-prop-stepper-stop .zc-prop-stepper-status { background-color: " + color_codes.get("zc-prop-red") + "; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active.zc-prop-stepper-stop .zc-prop-stepper-status h6 { 	display: none; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active.zc-prop-stepper-stop .zc-prop-stepper-status i.ui-1-circle-remove { display: inline-block; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active.zc-prop-stepper-stop span { color: " + color_codes.get("zc-prop-primary-text-color") + "; } /* Stepper complete level */ .zc-prop-stepper-wrapper ul li.zc-prop-stepper-level .zc-prop-stepper-status:before { content: ''; position: absolute; width: 100%; height: 100%; border: 1px solid var(--theme_brand_color); border-radius: 50%; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-level .zc-prop-stepper-status h6, .zc-prop-stepper-wrapper ul li.zc-prop-stepper-level .zc-prop-stepper-status i { display: none; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-level span.zc-prop-stepper-level-span { display: inline-block; } /* Active styles end */ /* Unvisited styles start */ .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active~li .zc-prop-stepper-status { background-color: " + color_codes.get("zc-prop-white") + "; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active~li .zc-prop-stepper-status h6 { display: block; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active~li .zc-prop-stepper-status i { display: none; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active~li span { color: " + color_codes.get("zc-prop-secondary-text-color") + "; } .zc-prop-stepper-wrapper ul li.zc-prop-stepper-active~li.zc-prop-stepper-line { background-color: " + color_codes.get("zc-prop-border-color") + "; } /* Unvisited styles end */";
                 	for each  step in steps
                 	{
                 		stepper_line_position = (count - 1) * 100 / no_Of_Step + (100 / no_Of_Step) / 2;
                 		style_txt = style_txt + ".zc-prop-stepper-wrapper ul li:nth-child(" + count * 2 + ") {left: " + stepper_line_position + "%;} .zc-rtl-wrapper .zc-prop-stepper-wrapper ul li:nth-child(" + count * 2 + ") {left: auto; right: " + stepper_line_position + "%;}";
                 		count = count + 1;
                 	}
                 	return style_txt;
                 }
				 string Styles.Timeline()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	style_txt = "/* Timeline style */ .zc-prop-timeline-wrapper { padding: 10px 40px; } .zc-prop-timeline-wrapper ul li { list-style-type: none; font-size: 0px; position: relative; } .zc-prop-timeline-wrapper>ul>li { padding: 25px 0px; border-radius: 10px; } .zc-prop-timeline-wrapper .zc-prop-timeline-date { min-width: 165px; max-width: 165px; font-size: 13px; line-height: 20px; font-weight: 400; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-secondary-text-color") + "; text-align: right; display: inline-block; vertical-align: top; } .zc-prop-timeline-wrapper .zc-prop-timeline-detail { width: calc(100% - 165px); padding-left: 51px; } .zc-prop-timeline-wrapper ul li .zc-prop-img-wrapper { width: 20px; height: 20px; margin: 0px 8px; } .zc-prop-timeline-wrapper ul li .zc-prop-img-wrapper span { line-height: 18px !important; font-size: 11px !important; } .zc-prop-timeline-wrapper .zc-prop-username, .zc-prop-timeline-wrapper .zc-prop-timeline-comments { font-size: 14px; line-height: 20px; font-weight: 400; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-text-color") + " 6; } .zc-prop-timeline-wrapper .zc-prop-timeline-comments { margin-top: 8px; } .zc-prop-timeline-wrapper>ul>li:before, .zc-prop-timeline-wrapper>ul>li:after { content: ''; display: inline-block; vertical-align: top; position: absolute; } .zc-prop-timeline-wrapper>ul>li:before { width: 11px; height: 11px; border-radius: 11px; background-color: var(--theme_brand_color); border: 1px solid white; box-shadow: 0px 2px 6px 0px #C4DEE4; top: 28px; left: 181px; z-index: 2; } .zc-prop-timeline-wrapper>ul>li:after { width: 1px; height: 100%; background-color: #E1E1E1; top: 28px; left: calc(181px + (11px / 2)); z-index: 1; } .zc-prop-timeline-wrapper>ul>li:last-child:after { display: none; } .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li, .zc-prop-document-wrapper ul li { margin: 8px 8px 0px 0px; } .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li label, .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li span { font-size: 14px; line-height: 21px; letter-spacing: 0.1px; margin-right: 4px; } .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li label { font-weight: 400; color: " + color_codes.get("zc-prop-secondary-text-color") + "; cursor: default; } .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li span { font-weight: 600; color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li span, .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li a { font-size: 14px; line-height: 21px; letter-spacing: 0.1px; font-weight: 400; } .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li span { color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li a i { vertical-align: top; line-height: 21px; margin-right: 6px; } .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li a span { color: var(--theme_brand_color); } .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li>span:after { content: ''; margin: 0px 8px; width: 1px; height: 21px; float: right; background-color: #E1E1E1; }";
                 	rtl_txt = ".zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-timeline-date { text-align: left; } .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-timeline-detail { padding-left: 0px; padding-right: 51px; } .zc-rtl-wrapper .zc-prop-timeline-wrapper>ul>li:before { left: auto; right: 181px; } .zc-rtl-wrapper .zc-prop-timeline-wrapper>ul>li:after { left: auto; right: calc(181px + (11px / 2)); } .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li, .zc-prop-document-wrapper ul li { margin: 8px 0px 0px 8px; } .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li label, .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-keyvalue-wrapper ul li span { margin-right: 0px; margin-left: 4px; } .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li a i { margin-right: 0px; margin-left: 6px; } .zc-rtl-wrapper .zc-prop-timeline-wrapper .zc-prop-document-wrapper ul li>span:after { float: left; }";
                 	style_txt = style_txt + rtl_txt;
                 	return style_txt;
                 }
				 string Styles.Toggle()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	style_txt = ".zc-prop-toggle-wrapper ul { display: flex; flex-direction: row; align-items: center; justify-content: space-around; gap: 4px; background-color: var(--component_hover_color); /* box-shadow: " + color_codes.get("zc-prop-box-shadow") + "; border: 1px solid " + color_codes.get("zc-prop-border-color") + "; */ padding: 6px; border-radius: 6px; } .zc-prop-toggle-wrapper li { list-style-type: none; text-align: center; border-radius: 3.5px; } .zc-prop-toggle-wrapper li a { display: block; cursor: pointer; font-size: 14px; font-weight: 600; line-height: 24px; color: " + color_codes.get("zc-prop-secondary-text-color") + "; padding: 0px 10px; } .zc-prop-toggle-wrapper li.zc-prop-toggle-active { background-color: " + color_codes.get("zc-prop-white") + "; } .zc-prop-toggle-wrapper li:hover a { color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-toggle-wrapper li.zc-prop-toggle-active a, .zc-prop-toggle-wrapper li.zc-prop-toggle-active:hover a { color: var(--theme_brand_color); }";
                 	return style_txt;
