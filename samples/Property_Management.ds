			Run_Scripts_While_submit_3 as "Run Scripts - While submit the record"
			{
				type =  form
				form = Add_Unit
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Occupancy_Type == "Owned")
										{
											input.Current_Tenant = input.Owner_Mail_ID;
										}
										for each  prop in Add_Property[ID == input.Property]
										{
											oldunit = prop.Units;
											oldunit.add(input.ID);
											prop.Units=oldunit;
											oldowner = prop.Unit_Owners;
											oldowner.add(input.Owner_Mail_ID);
											prop.Unit_Owners=oldowner;
										}
										if(input.Occupancy_Type == "Owned" || input.Occupancy_Type == "Sold Out")
										{
											input.Availability = "Occupied";
										}
										if(input.Occupancy_Type == "Sale")
										{
											input.Availability = "Available";
										}
										for each  unit_item in Unit_Items[Add_Unit == input.ID]
										{
											if(unit_item.Cost > 0)
											{
												unit_item.Cost_Display=thisapp.Currency.currencyDisplayFormat(unit_item.Cost);
											}
										}
										thisapp.Change_User_Post_Viewer();
										// if((input.Occupancy_Type == "Owned" && input.Unit_Type == "Both") || (input.Occupancy_Type == "Owned" && input.Unit_Type == "Parking"))
										// {
										// 	input.Parking_Availability = "Occupied";
										// }
										// else if((input.Occupancy_Type == "Rent" && input.Unit_Type == "Both") || (input.Occupancy_Type == "Lease" && input.Unit_Type == "Both"))
										// {
										// 	input.Parking_Availability = "Occupied";
										// }
										// else if((input.Occupancy_Type == "Rent" && input.Unit_Type == "Parking") || (input.Occupancy_Type == "Lease" && input.Unit_Type == "Parking"))
										// {
										// 	input.Parking_Availability = "Available";
										// }
										// else if(input.Occupancy_Type == "Sale" && input.Unit_Type == "Parking")
										// {
										// 	input.Parking_Availability = "Available";
										// }
										// else if(input.Occupancy_Type == "Sale" && input.Unit_Type == "Both")
										// {
										// 	input.Parking_Availability = "Occupied";
										// }
						)
					}
				}

			}
			Run_Scripts_On_click_of_b as "Run Scripts - On click of button"
			{
				type =  form
				form = Active_Form
				button = Active
				on click
				{
					actions 
					{
					on click
					(
						if(input.New_User != null)
										{
											user = New_User[ID == input.New_User.ID];
											user.Status="Active";
											thisapp.permissions.assignUserInProfile(user.Email,user.Role,true);
										}
										else if(input.Add_Vendor != null)
										{
											vendor = Add_Vendor[ID == input.Add_Vendor];
											vendor.Status="Active";
											thisapp.permissions.assignUserInProfile(vendor.Vendor_Email,"Vendor",true);
										}
										openUrl("#Script:page.reload","same window");
					)
					}
				}
			}
			Run_Scripts_On_click_of_b1 as "Run Scripts - On click of button"
			{
				type =  form
				form = Inactive_Form
				button = Inactive
				on click
				{
					actions 
					{
					on click
					(
						if(input.New_User != null)
										{
											user = New_User[ID == input.New_User];
											user.Status="Inactive";
											deletedUser = thisapp.permissions.deleteUser(user.Email);
											thisapp.mail.SendToUserRemoved(user.ID);
										}
										else
										{
											vendor = Add_Vendor[ID == input.Add_Vendor];
											vendor.Status="Inactive";
											deletedUser = thisapp.permissions.deleteUser(vendor.Vendor_Email);
											thisapp.mail.SendToUserRemoved(vendor.ID);
										}
										openUrl("#Script:page.reload","same window");
					)
					}
				}
			}
