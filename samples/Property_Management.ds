			)
			conditional formatting
			(
				"Requested & Vacate Requested"
				{
				condition = (Status == "Requested" || Status == "Vacate Requested")
				fields = [Status]
				format = "color:#b8770d;"
				}
				"Approved"
				{
				condition = (Status == "Owner Approved" || Status == "Tenant Approved")
				fields = [Status]
				format = "color:#04a267;"
				}
				"Rejected"
				{
				condition = (Status == "Owner Rejected" || Status == "Tenant Rejected" || Status == "Auto Rejected")
				fields = [Status]
				format = "color:#fe455d;"
				}
				"Vacated"
				{
				condition = (Status == "Vacated")
				fields = [Status]
				format = "color:#5051f9;"
				}
				"Agreement Renewed"
				{
