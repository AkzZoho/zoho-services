				 map Insert_General_Setup()
                 {
                 	countries = thisapp.Data_Map.Countries();
                 	allTimeZones = thisapp.Data_Map.Time_Zones();
                 	try 
                 	{
                 		response = getUrl("https://us4-internaliplocation.zoho.com/getipinfo?ip=" + zoho.ipaddress + "&type=json");
                 	}
                 	catch (e)
                 	{
                 		response = {"COUNTRY_CODE":"US","OLSON_TIME_ZONE":"AMERICA/NEW_YORK"};
                 	}
                 	info response;
                 	userInfo = Map();
                 	countryCode = response.get("COUNTRY_CODE");
                 	ipTimeZone = response.get("OLSON_TIME_ZONE");
                 	currencyCode = countries.get(countryCode).get("currency_code");
                 	currencySymbal = countries.get(countryCode).get("currency_symbol");
                 	currencyWithSymbal = currencyCode + " (" + currencySymbal + ")";
                 	timeZone = allTimeZones.get(ipTimeZone.toLowerCase());
                 	userInfo.put("currency_symbol",currencyWithSymbal);
                 	userInfo.put("timezone",timeZone);
                 	if(General.count() == 0)
                 	{
                 		gen_Det_ID = insert into General
                 		[
                 			Currency=currencyWithSymbal
                 			Currency_Format="1,234,567.89"
                 			Date_Format="dd-MMM-yy (15-Aug-47)"
                 			Time_Zone=timeZone
                 			Time_Format="24 Hours"
                 			Added_User=zoho.loginuser
                 		];
                 		gen_Det = General[ID != 0];
                 		timeFormat = if(gen_Det.Time_Format == "24 Hours",true,false);
                 		dateFormat = gen_Det.Date_Format.getprefix(" (");
                 		gen_timeZone = gen_Det.Time_Zone.getsuffix("(");
                 		gen_timeZone = if(gen_timeZone.contains("("),gen_timeZone.getsuffix("(").getPrefix(")"),gen_timeZone.getPrefix(")"));
                 		zoho.service.changeDateTimeFormat(gen_timeZone,dateFormat,timeFormat,{});
                 	}
                 	return userInfo;
                 }
				 void Insert_System_Data()
                 {
                 	thisapp.Insert_General_Setup();
                 	thisapp.AddEmailTemplates();
                 	admin_rec = New_User[Email == zoho.adminuserid];
                 	user_config = User_Configuration[ID != 0];
                 	// 	try 
                 	// 	{
                 	// 		response = getUrl("https://us4-internaliplocation.zoho.com/getipinfo?ip=" + zoho.ipaddress + "&type=json");
                 	// 	}
                 	// 	catch (e)
                 	// 	{
                 	// 	add this below details
                 	response = {"COUNTRY_CODE":"CY","OLSON_TIME_ZONE":"","CITY":"Nicosia"};
                 	// 	}
                 	location = insert into Location
                 	[
                 		Location="India"
                 		Added_User=zoho.loginuser
                 	];
                 	info location;
                 	admin_role = "Admin as a Owner";
                 	if(admin_rec.count() == 0)
                 	{
                 		add_admin = insert into New_User
                 		[
                 			Email=zoho.adminuserid
                 			Name.first_name="Admin"
                 			Name.last_name=zoho.adminuser
                 			Role="Admin"
                 			Role_Admin=admin_role
                 			Status="Active"
                 			Location=location
                 			Added_User=zoho.adminuser
                 		];
                 		admin = New_User[ID == add_admin];
                 		img_src = thisapp.CommonFeatures.processImageUrl(admin.ID,admin.Profile_Photo,"All_User_Profile_Photo","Profile_Photo",admin.Name,false);
                 		admin.User="<div class='zc-prop-rt-wrapper zc-prop-rt-clearfix zc-prop-rt-fw'> <div class='zc-prop-rt-flt-left zc-prop-rt-img-wrapper'> " + img_src + " </div> <div class='zc-prop-rt-flt-left zc-prop-rt-txt-wrapper'> <span class='zc-prop-rt-primary-text'>" + admin.Name + "</span> <span class='zc-prop-rt-secondary-text'>" + admin.Email + "</span> </div> </div>";
                 	}
                 	id_setup = insert into ID_Setup
                 	[
                 		Added_User=zoho.loginuser
                 		Agreement_ID="Agreement No"
                 		Work_Order_No="WO No"
                 		Bill_No="Bill No"
                 	];
                 	agreement_template = insert into Agreement_Template
                 	[
                 		Agreement_Type="Rent"
                 		Template="<p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: center\" class=\"zw-paragraph heading1\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: center\" class=\"zw-paragraph heading1\"><b><u><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">RENT AGREEMENT</span></span></u></b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">This Rent Agreement is made on this ${zoho.Added_Time}&nbsp;by ${Unit.Owner_Mail_ID.Name},&nbsp; Add </span></span><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${Unit.Address}</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">. Herein after called the Lessor / Owner, Party Of the first part</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: center\" class=\"zw-paragraph heading2\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">AND</span></span></b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${Tenant.Name}, through its proposed , Party of the Second Part</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;the&nbsp;&nbsp;expression&nbsp;&nbsp;of&nbsp;&nbsp;the&nbsp;&nbsp;&nbsp;term ,&nbsp;&nbsp;&nbsp;Lessor/Owner and&nbsp;&nbsp;the Lessee/Tenant&nbsp;&nbsp;&nbsp;&nbsp;Shall mean&nbsp;&nbsp;&nbsp;and&nbsp;&nbsp;&nbsp;&nbsp;include&nbsp;&nbsp;&nbsp;their&nbsp;&nbsp;&nbsp;legal&nbsp;&nbsp;&nbsp;&nbsp;heirs&nbsp;&nbsp;&nbsp;successors ,&nbsp;&nbsp;assigns , representative&nbsp;&nbsp;etc. Whereas the Lessor /Owner is the owner and&nbsp;&nbsp;&nbsp;in possession of the </span></span><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${Unit.Address}</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;and&nbsp;&nbsp;has&nbsp;&nbsp;agreed&nbsp;&nbsp;to&nbsp;&nbsp;let&nbsp;&nbsp;out&nbsp;&nbsp;&nbsp;the one office&nbsp;&nbsp;Room, one Toilet &amp; Bathroom Set on said property, to the Lessee/Tenant and&nbsp;&nbsp;the Lessee/Tenant&nbsp;&nbsp;&nbsp;has&nbsp;&nbsp;agreed&nbsp;&nbsp;to&nbsp;&nbsp;take&nbsp;&nbsp;the&nbsp;&nbsp;same&nbsp;&nbsp;on&nbsp;&nbsp;${Agreement_Type}&nbsp;of ${Monthly_Payable} per month.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><u style=\"font-weight: 400\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">NOW THIS RENT AGREEMENT WITNESSETH AS UNDER:</span></span></u><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant/Lessee shall pay as the monthly rent of ${Monthly_Payable}-&nbsp;&nbsp;per&nbsp;&nbsp;month.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"2\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant /Lessee shall not sub–let any part of the above said demised premised premises to anyone else under any circumstances without the&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;consent of Owner.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"3\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;the&nbsp;&nbsp;Tenant&nbsp;&nbsp;/ Lessee&nbsp;&nbsp;shall&nbsp;&nbsp;&nbsp;abide&nbsp;&nbsp;by&nbsp;&nbsp;&nbsp;all&nbsp;&nbsp;the&nbsp;&nbsp;bye&nbsp;&nbsp;-&nbsp;&nbsp;laws ,&nbsp;&nbsp;rules&nbsp;&nbsp;and regulation, of the local authorities in respect&nbsp;&nbsp;of the demised premises and shall not do any illegal activities in the said demised premises.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"4\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;&nbsp;this&nbsp;&nbsp;&nbsp;Lease&nbsp;&nbsp;&nbsp;is&nbsp;&nbsp;&nbsp;granted&nbsp;&nbsp;for&nbsp;&nbsp;a&nbsp;&nbsp;period&nbsp;&nbsp;&nbsp;of&nbsp;&nbsp;&nbsp;${Start_Date} to ${End_Date} and&nbsp;&nbsp;this&nbsp;&nbsp;Agreement&nbsp;&nbsp;&nbsp;can&nbsp;&nbsp;be&nbsp;&nbsp;extended further by&nbsp;&nbsp;&nbsp;both&nbsp;&nbsp;&nbsp;the&nbsp;&nbsp;&nbsp;parties&nbsp;&nbsp;with&nbsp;&nbsp;&nbsp;their&nbsp;&nbsp;mutual&nbsp;&nbsp;consent on the basis of&nbsp;&nbsp;prevailing rental value&nbsp;&nbsp;in the market .</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.25in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"5\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Lessee shall pay Electricity &amp; Water charge as per&nbsp;&nbsp;&nbsp;the proportionate consumption of the meter to the Lessor /Owner.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"6\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant/Lessee shall not be entitled to make structure in the rented premises except the installation of temporary decoration, wooden partition/ cabin, air – conditioners etc. without the prior consent of&nbsp;&nbsp;&nbsp;the owner.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"7\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;the&nbsp;&nbsp;Tenant/lessee&nbsp;&nbsp;can neither&nbsp;&nbsp;make&nbsp;&nbsp;addition/alteration in&nbsp;&nbsp;the said premises without&nbsp;&nbsp;the&nbsp;&nbsp;written&nbsp;&nbsp;consent of the owner, nor the lessee can sublet part or entire&nbsp;&nbsp;premises to any person(s)/firm(s)/company(s).</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: right\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"8\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant/Lessee shall permit the Lessor/Owner or his Authorized&nbsp;&nbsp;&nbsp;&nbsp;agent&nbsp;&nbsp;to&nbsp;&nbsp;enter&nbsp;&nbsp;&nbsp;in&nbsp;&nbsp;to&nbsp;&nbsp;the&nbsp;&nbsp;&nbsp;said&nbsp;&nbsp;tenanted&nbsp;&nbsp;premises&nbsp;&nbsp;for&nbsp;&nbsp;inspection/general checking or to carry out the repair work, at any reasonable time.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.25in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"9\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant/Lessee shall keep the said premises in clean &amp; hygienic condition and shall not do or causes to be done any act which may be a nuisance to other.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.25in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"10\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Tenant/Lessees shall carry on all day to day minor repairs at his/her own cost.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.5in; line-height: 1.5\" class=\"zw-paragraph heading105\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"11\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;this Agreement&nbsp;&nbsp;may&nbsp;&nbsp;be&nbsp;&nbsp;terminated&nbsp;&nbsp;&nbsp;before&nbsp;&nbsp;the expiry of this tenancy period by serving One month prior notice by either&nbsp;&nbsp;party&nbsp;&nbsp;for&nbsp;&nbsp;this intention .</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.5in; line-height: 1.5\" class=\"zw-paragraph heading105\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"12\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Lessee shall use the above said premises for Official Purpose Only.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.5in; line-height: 1.5\" class=\"zw-paragraph heading105\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"13\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That&nbsp;&nbsp;the&nbsp;&nbsp;Lessee/Tenant&nbsp;&nbsp;Shall&nbsp;&nbsp;not&nbsp;&nbsp;store/Keep any offensive, dangerous, explosive or highly&nbsp;&nbsp;Inflammable&nbsp;&nbsp;articles&nbsp;&nbsp;in&nbsp;&nbsp;the&nbsp;&nbsp;said&nbsp;&nbsp;premises and shall not use the same for any unlawful activities .</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"14\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That the Lessee shall pay the one month’s advance rent to the Lessor the same shall be adjusted in monthly rent.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt 0.583in; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><ol style=\"list-style: decimal\" start=\"15\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify; padding-left: 0.294in\" class=\"zw-list zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">That both the parties have read over and understood all the contents of this agreement and have signed the same without any force or pressure from any side.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p></li></ol><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">In WITNESS WHEREOF&nbsp;&nbsp;the&nbsp;&nbsp;lessor/Owner&nbsp;&nbsp;and&nbsp;&nbsp;the Tenant / Lessee have hereunto subscribed&nbsp;&nbsp;their&nbsp;&nbsp;hand&nbsp;&nbsp;at ${Unit.Address.City}&nbsp;on this&nbsp;&nbsp;the ${zoho.Added_Time}&nbsp;.</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px 0px 0pt; line-height: 1.5; text-align: justify\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"text-align: justify; margin: 0px -1in 0pt 0px; line-height: 1.5\" class=\"zw-paragraph align-center\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp; &nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;${Unit.Owner_Mail_ID.Name}&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;${Tenant.Name}</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"margin: 0px -1in 0pt 0px; line-height: 1.5\" class=\"zw-paragraph\"><span class=\"EOP\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><p style=\"text-align: justify; margin: 0px -1in 0pt 0px; line-height: 1.5\" class=\"zw-paragraph align-left\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;Owner&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Tenant</span><span class=\"size\" style=\"font-size: 16px\"><br /></span></span></p><div><br /></div>"
                 		Name="Rental Agreement"
                 		Mark_as_Default_Template=true
                 		Added_User=zoho.loginuser
                 	];
                 	lease_template = insert into Agreement_Template
                 	[
                 		Agreement_Type="Lease"
                 		Template="<div><div><div><p class=\"zw-paragraph heading0 align-center\" style=\"text-align: center; margin: 12pt 0px; line-height: 1.2; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">LEASE AGREEMENT</span></span></b></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">This Lease Agreement is made and entered into on this&nbsp;&nbsp;day of&nbsp;</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${zoho.Added_Time}&nbsp;</span></span><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">by and between:</span></span></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Landlord</span></span></b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">:&nbsp;${Unit.Owner_Mail_ID.Name}</span></span></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Tenant</span></span></b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">:&nbsp;${Tenant.Name}</span></span></span><br /></p><div><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Property Address</span></span></b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">:&nbsp;${Unit.Address}</span></span></span></span><br /></div><div><br /></div><div><br /></div><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">1. Term</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The lease term shall begin on ${Start_Date}&nbsp; and shall end on </span></span><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${End_Date}</span></span></span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;unless terminated earlier in accordance with this Agreement.</span></span></span><br /></p><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">2. Monthly Payment</span></span></b></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The monthly payment for the property shall be ${Monthly_Payable}&nbsp;payable on the ${Next_Payment} day of each month. Payments shall be made by [Method of Payment, e.g., check, bank transfer, etc.].</span></span></span><br /></p><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">3. Security Deposit</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><div><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The Tenant shall pay a security deposit of (${Security_Deposit} on or before the start date. This deposit will be refunded within&nbsp;&nbsp;10 days after the termination of the lease, subject to any deductions for damages beyond normal wear and tear.</span></span></span></span></span><br /></div></div><p style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\" class=\"zw-paragraph heading3\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">4. Utilities</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><p style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The responsibility for payment of utilities shall be as follows:</span></span></span><br /></p><ul style=\"list-style: disc\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Electricity:&nbsp;${Tenant.Name}</span></span></span><br /></p></li><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Water:&nbsp;${Tenant.Name}</span></span></span><br /></p></li><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Gas:&nbsp;${Tenant.Name}</span></span></span><br /></p></li><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Internet/Cable:&nbsp;${Tenant.Name}</span></span></span><br /></p></li></ul><p style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\" class=\"zw-paragraph heading3\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">5. Maintenance and Repairs</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><ul style=\"list-style: disc\"><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Tenant is responsible for maintaining the property in good condition and for reporting any issues promptly.</span></span></span><br /></p></li><li><p style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-list zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Landlord will be responsible for repairs, except for damages caused by tenant negligence.</span></span></span><br /></p></li></ul><p style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\" class=\"zw-paragraph heading3\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">6. Occupants</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><p style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\" class=\"zw-paragraph heading0\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Only the persons listed below are permitted to occupy the property:</span></span></span><br /></p><div><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">${Other_Occupant}</span></span><br /></div></div><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">7. Restrictions</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The Tenant shall not:</span></span></span><br /></p><ul style=\"list-style: disc\"><li><p class=\"zw-list zw-paragraph heading0\" style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Sublet the property or allow others to live on the property without the Landlord’s consent.</span></span></span><br /></p></li><li><p class=\"zw-list zw-paragraph heading0\" style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Use the property for illegal activities.</span></span></span><br /></p></li><li><p class=\"zw-list zw-paragraph heading0\" style=\"margin: 0px 0px 0pt; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Make alterations without prior written approval.</span></span></span><br /></p></li></ul><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">8. Entry</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><div><div><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">The Landlord may enter the property for inspection, repairs, or showing the property to prospective tenants by giving the Tenant at least&nbsp;&nbsp;10 hours' notice, except in case of an emergency.</span></span></span><br /></div><div><br /></div></div><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">9. Termination</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Either party may terminate this agreement by providing at least 30 days' written notice before the end of the rental term or according to the terms set forth herein.</span></span></span><br /></p><p class=\"zw-paragraph heading3\" style=\"margin: 14.04pt 0px; line-height: 1.2; text-align: left\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">10. Governing Law</span></span></b></span><span><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">&nbsp;&nbsp;</span></span></span><br /></p><div><div><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">This Agreement shall be governed by the laws of the State of ${Unit.Address.City}.</span></span></span></span><br /></div><div><br /></div><div><br /></div></div><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><b><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Signatures</span></span></b></span><br /></p><p class=\"zw-paragraph heading0\" style=\"margin: 12pt 0px; line-height: 1.2; text-align: left; direction: ltr\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Landlord’s Signature: ________________________ Date:&nbsp;${zoho.Added_Time}</span></span></span><br /></p><div><div><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"colour\" style=\"color: rgb(0, 0, 0)\"><span class=\"font\" style=\"font-family: Arimo, sans-serif\"><span class=\"size\" style=\"font-size: 16px\">Tenant’s Signature: _________________________ Date:&nbsp;${zoho.Added_Time}</span></span></span></span></span><br /></div></div><div><br /></div></div><div><br /></div>"
                 		Name="Lease Agreement"
                 		Mark_as_Default_Template=true
                 		Added_User=zoho.loginuser
                 	];
                 	pay_for_list = {"Rent","Security Deposit","Commission","Complaints","Complaint Commissions","Penalty","Vacate","Vacate Complaints"};
                 	for each  pay_for in pay_for_list
                 	{
                 		pay_for_monthly = insert into Pay_For_Monthly
                 		[
                 			Added_User=zoho.loginuser
                 			Pay_For=pay_for
                 		];
                 	}
                 }
				 void migrate()
                 {
                 	customer_id_response = zoho.books.getRecords("items","892920402");
                 	info customer_id_response;
                 	payfor = Pay_For_Monthly[Pay_For == "Rent"];
                 	itemMap = Map();
                 	itemMap.put("name",payfor.Pay_For);
                 	itemMap.put("rate",0);
                 	response_add_item = zoho.books.createRecord("items","892920402",itemMap);
                 	info response_add_item;
                 	payfor.Books_ID=response_add_item.get("item").get("item_id");
                 }
				 string Template_Making(int agreement_rec_id, int temo_rec_id)
                 {
                 	agreement = Tenant_Agreement[ID == input.agreement_rec_id];
                 	temp = Agreement_Template[ID == input.temo_rec_id];
                 	template = temp.Template;
                 	property = Add_Property[ID == agreement.Property];
                 	unit = Add_Unit[ID == agreement.Unit];
                 	parking = Add_Unit[ID == agreement.Parking_No];
                 	owner = New_User[ID == agreement.Unit.Owner_Mail_ID];
                 	manager = New_User[ID == agreement.Unit.Manager];
                 	tenant = New_User[ID == agreement.Tenant];
                 	agreement_date = agreement.Added_Time.getDate();
                 	template = template.replaceAll("${Property.Property_Name}",property.Property_Name,true);
                 	template = template.replaceAll("${Unit.Unit_Name}",unit.Unit_Name,true);
                 	//template = template.replaceAll("${Parking_No.Unit_Name}",parking.Parking_No.Unit_Name,true);
                 	template = template.replaceAll("${Unit.Owner_Mail_ID.Name}",owner.Name.first_name + " " + owner.Name.last_name,true);
                 	template = template.replaceAll("${Unit.Manager.Name}",manager.Name.first_name + " " + manager.Name.last_name,true);
                 	template = template.replaceAll("${Tenant.Name}",tenant.Name.first_name + " " + tenant.Name.last_name,true);
                 	template = template.replaceAll("${zoho.Added_Time}",agreement_date.toString(),true);
                 	template = template.replaceAll("${Next_Payment}",agreement.Next_Pay_Date.day().toString(),true);
                 	template = template.replaceAll("${Agreement_No}",agreement.Agreement_No,true);
                 	template = template.replaceAll("${Other_Occupant}",(agreement.Other_Occupants_Details.Name.getall()).toString(),true);
                 	template = template.replaceAll("${Base_Lease}",agreement.Base_Lease.toString(),true);
                 	template = template.replaceAll("${Monthly_Payable}",agreement.Monthly_Payable.toString(),true);
                 	template = template.replaceAll("${Start_Date}",agreement.Start_Date.toString(),true);
                 	template = template.replaceAll("${End_Date}",agreement.End_Date.toString(),true);
                 	template = template.replaceAll("${Security_Deposit}",agreement.Security_Deposit.toString(),true);
                 	template = template.replaceAll("${Unit.Address}",unit.Address.address_line_1 + "," + unit.Address.address_line_2 + "," + unit.Address.district_city + "," + unit.Address.state_province + "," + unit.Address.postal_Code + "," + unit.Address.country,true);
                 	template = template.replaceAll("${Unit.Address.City}",unit.Address.district_city,true);
                 	template = template.replaceAll("${Agreement_Type}",agreement.Agreement_Type,true);
                 	return template;
                 }
				 void Books_Integration.getOrgID()
                 {
                 	org = zoho.books.getOrganizations();
                 	info org;
                 }
				 map Books_Integration.Sync_Invoice(int rec_id)
                 {
                 	invoice_create_rec = Map();
                 	payment_note = Add_Payment_Notes[ID == input.rec_id];
                 	if(payment_note.Books_ID.isEmpty())
                 	{
                 		new_user = New_User[ID == payment_note.Payer];
                 		if(new_user.Books_ID.isEmpty())
                 		{
                 			contactMap = Map();
                 			contactMap.put("contact_name",new_user.Name);
                 			contactMap.put("first_name",new_user.Name.first_name);
                 			contactMap.put("last_name",new_user.Name.last_name);
                 			contactMap.put("contact_type","customer");
                 			contactMap.put("email",new_user.Email);
                 			contactMap.put("phone",new_user.Phone_Number);
                 			response = zoho.books.createRecord("Contacts","892920402",contactMap);
                 			for each  var in response
                 			{
                 				new_user.Books_ID=var.get("contact_id");
                 			}
                 		}
                 		listVar = List();
                 		for each  sub_payment in Payment_Details[Add_Payment_Notes == payment_note.ID]
                 		{
                 			payfor = Pay_For_Monthly[ID == sub_payment.Pay_For];
                 			if(payfor.Books_ID.isEmpty())
                 			{
                 				itemMap = Map();
                 				itemMap.put("name",payfor.Pay_For);
                 				itemMap.put("rate",0);
                 				response_add_item = zoho.books.createRecord("items","892920402",itemMap);
                 				for each  var in response_add_item
                 				{
                 					payfor.Books_ID=var.get("item_id");
                 				}
                 			}
                 			mapVar = Map();
                 			mapVar.put("item_id",payfor.Books_ID);
                 			mapVar.put("name",payfor.Pay_For);
                 			mapVar.put("rate",sub_payment.Amount);
                 			mapVar.put("quantity",1);
                 			listVar.add(mapVar);
                 		}
                 		values = Map();
                 		values.put("customer_id",new_user.Books_ID);
                 		values.put("line_items",listVar);
                 		invoice_create_rec = zoho.books.createRecord("Invoices","892920402",values);
                 		//info invoice_create_rec;
                 		for each  var in invoice_create_rec
                 		{
                 			payment_note.Books_ID=var.get("invoice_id");
                 		}
                 		info invoice_create_rec;
                 	}
                 	return invoice_create_rec;
                 }
				 string CommonFeatures.generateletterAvatar(string name, string backgroung_Color)
                 {
                 	avatar = "";
                 	if(name != null)
                 	{
                 		letter_to_be_displayed = "";
                 		name_to_list = name.trim().toList(" ");
                 		for each index list_index in name_to_list
                 		{
                 			letter_to_be_displayed = letter_to_be_displayed + name_to_list.get(list_index).subString(0,1).toUpperCase();
                 			if(list_index == 1)
                 			{
                 				break;
                 			}
                 		}
                 		avatar_style = "<style>.custom-letter-avatar{height: 100%; width: 100%;border-radius:10px;display: flex;align-items: center;justify-content: center;font-size:14px;}</style>";
                 		avatar = avatar_style + "<span style=' width: 100%; height: 100%; border-radius: 50%; display: block; background-color: " + backgroung_Color + "; font-size: 13px; font-weight: 400; line-height: 30px; color: #FFF; letter-spacing: 0.1px; text-align: center; '>" + letter_to_be_displayed + "</span>";
                 	}
                 	return avatar;
                 }
				 string CommonFeatures.numberFormat(float number)
                 {
                 	all_currency_display_format = {"1,234,567.89":{"seperator_digits":"3","seperator":",","class":"format-1"},"12,34,567.89":{"seperator_digits":"2","seperator":",","class":"format-2"},"1 234 567.89":{"seperator_digits":"3","seperator":" ","class":"format-3"},"1.234.567,89":{"seperator_digits":"3","seperator":".","class":"format-4"}};
                 	settingsFormat = "1,234,567.89";
                 	currency_Format = all_currency_display_format.get(settingsFormat);
                 	number_cpy = number.round(0).toString();
                 	formatedNumber = "";
                 	if(number >= 1000)
                 	{
                 		decimalSuffix = "." + number_cpy.getSuffix(".");
                 		number_cpy = number_cpy.remove(decimalSuffix);
                 		suffixNumber = currency_Format.get("seperator") + number_cpy.subString(number_cpy.Length() - 3,number_cpy.Length());
                 		number_cpy = number_cpy.subString(0,number_cpy.Length() - 3);
                 		formatedNumber = number_cpy.replaceAll("(?<!\.\d)(?<=\d)(?=(?:\d{" + currency_Format.get("seperator_digits") + "})+\b)",currency_Format.get("seperator")) + suffixNumber;
                 	}
                 	else
                 	{
                 		number_cpy = number_cpy.toString();
                 		formatedNumber = number_cpy;
                 	}
                 	roundedRoundNumber = if(formatedNumber.contains("."),formatedNumber.getprefix("."),formatedNumber);
                 	return roundedRoundNumber;
                 }
				 string CommonFeatures.processImageUrl(int rec_ID, string img_field_value, string report_name, string field_name, string name, bool no_data)
                 {
                 	// img_field_value should be fatched image field value.
                 	// rec_ID should be image field's actual record id.
                 	// report_name should be source report of image, The report must be shared with the user/ portal user.
                 	// field_name should be actual name of image field.
                 	img = "";
                 	if(img_field_value != "" && img_field_value != null)
                 	{
                 		img_name = img_field_value.getSuffix("viewLinkName/fieldName/image/").getPrefix("\"");
                 		if(img_name != "")
                 		{
                 			img_src = zoho.appuri + "report/" + report_name + "/" + rec_ID + "/" + field_name + "/download-file?filepath=/" + img_name + "&mediaType=1";
                 		}
                 		else
                 		{
                 			img_src = img_field_value.getSuffix("\"").getPrefix("\"");
                 		}
                 		img = "<img width=100% src='" + img_src + "' alt='" + name + "'/>";
                 	}
                 	else if(no_data)
                 	{
                 		img = "<i class=\"zc-li-outline media-1-image-02\"></i>";
                 	}
                 	else
                 	{
                 		backGroundColor = "#2A6FFC";
                 		// 				if(Add_Product[ID == rec_ID].count() != 0)
                 		// 				{
                 		// 					backGroundColor = "#009432";
                 		// 				}
                 		// 				else if(New_Vendor[ID == rec_ID].count() != 0)
                 		// 				{
                 		// 					backGroundColor = "#22a6b3";
                 		// 				}
                 		img = thisapp.CommonFeatures.generateletterAvatar(name,backGroundColor);
                 		// 		img = "<i class='zc-li-outline media-1-image-02'></i>";
                 	}
                 	return img;
                 }
				 int CommonFeatures.tenToThePowerOf(int number)
                 {
                 	degit = number.toString().length();
                 	round_Of = number + 10.power(degit - 1) - number % 10.power(degit - 1);
                 	return round_Of;
                 }
				 string Components.Add_Record(string display_name, string page_link_name, string form_linkname, string form_params)
                 {
                 	style_txt = "<style>" + thisapp.Styles_Page.Add_Record(page_link_name) + "</style>";
                 	dom_txt = "<div class='zc-prop-page-container zc-prop-add-record'><div class='zc-prop-page-container-inner zc-prop-fwh'><div class='zc-prop-card zc-prop-fwh'><div class='zc-prop-page-header zc-prop-clearfix zc-prop-fw'><h5 class='zc-prop-flt-left'>" + display_name + "</h5><a class='zc-prop-flt-right zc-prop-close-icon' href='#Page:" + page_link_name + "'></a></div><div class='zc-prop-page-content'><div elName='zc-component' formLinkName='" + form_linkname + "' params='" + form_params + "'></div></div></div></div></div>";
                 	component_code = style_txt + dom_txt;
                 	return component_code;
                 }
				 string Components.Bar_Chart(int data_count, int rec_id)
                 {
                 	login_profile = thisapp.permissions.loginUserProfile();
                 	if(data_count != 0)
                 	{
                 		currency = General[ID != 0].Currency.getSuffix("(").getprefix(")");
                 		style = "<style>.zc-prop-barchart-wrapper { padding: 24px; } /* y-axis Styles */ .zc-prop-barchart-inner { position: relative; } .zc-prop-barchart-wrapper ul li { list-style-type: none; } .zc-prop-barchart-wrapper ul.zc-prop-y-axis-value-and-line li { padding: 16px 0px; } .zc-prop-barchart-wrapper ul.zc-prop-y-axis-value-and-line li:first-child { padding-top: 0px; } .zc-prop-barchart-wrapper ul.zc-prop-y-axis-value-and-line li:last-child { padding-bottom: 0px; } .zc-prop-barchart-wrapper ul li span { display: inline-block; vertical-align: top; } .zc-prop-barchart-wrapper ul.zc-prop-y-axis-value-and-line li .zc-prop-axis-value { width: 80px; white-space: nowrap; } .zc-prop-barchart-wrapper ul li .zc-prop-axis-value { font-size: 14px; font-weight: 400; line-height: 21px; letter-spacing: 0.1px; color: #3E4650; } .zc-prop-barchart-wrapper ul li .zc-prop-axis-line { width: calc(100% - 80px); border-top: 1px dashed #EBECF0; margin: 10px 0px; } /* x-axis value styles */ .zc-prop-x-axis-value { padding-left: 80px; } .zc-prop-barchart-wrapper ul.zc-prop-x-axis-value li { text-align: center; width: calc(100% / 6); } .zc-prop-barchart-wrapper ul.zc-prop-axis-bar { width: calc(100% - 80px); height: calc(100% - 20px); position: absolute; bottom: 0px; left: 80px; } .zc-prop-barchart-wrapper ul.zc-prop-axis-bar li { width: calc(100% / 6); height: 100%; text-align: center; position: relative; } .zc-prop-barchart-wrapper ul.zc-prop-axis-bar li div { width: 10px; display: inline-block; vertical-align: top; border-radius: 4px 4px 0px 0px; background-color: #06d627; margin: 0px -2px 10px; position: absolute; bottom: 0px; } /* Tooltip */ .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper { width: 150px; padding: 12px; border-radius: 4px; position: absolute; left: 50%; transform: translate(-50%, -50%); display: none; background-color: #FFF; box-shadow: 0px 3px 8px 0px #EAECF0; border: 1px solid #eee; z-index: 1; } .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper:after { content: ''; position: absolute; top: 100%; left: 50%; margin-left: -7px; border-width: 7px; border-style: solid; border-color: #FFF transparent transparent transparent; } .zc-prop-barchart-wrapper ul.zc-prop-axis-bar li div:hover~.zc-prop-bc-tooltip-wrapper, .zc-prop-barchart-wrapper ul.zc-prop-axis-bar li div~.zc-prop-bc-tooltip-wrapper:hover { display: block; } .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li { width: 100%; text-align: left; padding: 3px 0px; } .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li span { font-size: 14px; font-weight: 400; line-height: 21px; letter-spacing: 0.1px; color: #131635; position: static; } .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li span:before { content: ''; display: inline-block; vertical-align: top; width: 11px; height: 11px; margin: 5px 12px 5px 0px; border-radius: 50%;} .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li:nth-child(1) span:before{background-color:#11D2DD} .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li:nth-child(2) span:before{background-color:#F05A7A} .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li:nth-child(3) span:before{background-color:#F05A7A}.zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li:nth-child(4) span:before{background-color:#EBECF0} /* To be removed */ .zc-prop-pie-chart-header { padding: 10px 16px; border-bottom: 1px solid #EBECF0; } .zc-prop-pie-chart-header h6 { padding: 8px 0px; } ul.zc-prop-pie-chart-legent { text-align: center; } ul.zc-prop-pie-chart-legent li { display: inline-block; vertical-align: top; padding: 7px 20px; } ul.zc-prop-pie-chart-legent li span { font-size: 14px; font-weight: 400; line-height: 21px; color: #666D79; } ul.zc-prop-pie-chart-legent li span:before { content: ''; display: inline-block; vertical-align: top; width: 11px; height: 11px; margin: 5px 12px 5px 0px; border-radius: 50%; } ul.zc-prop-pie-chart-legent li:nth-child(1) span:before { background-color: #06d627; } /* RTL */ .zc-rtl-wrapper .zc-prop-x-axis-value { padding-left: 0px; padding-right: 80px; } .zc-rtl-wrapper .zc-prop-barchart-wrapper ul.zc-prop-axis-bar { left: auto; right: 80px; } .zc-rtl-wrapper .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li { text-align: right; } .zc-rtl-wrapper .zc-prop-barchart-wrapper ul.zc-prop-bc-tooltip-wrapper li span:before, .zc-rtl-wrapper ul.zc-prop-pie-chart-legent li span:before { margin: 5px 0px 5px 12px; }</style>";
                 		barcontent = "<div class='zc-prop-barchart-wrapper zc-prop-fw'><div class='zc-prop-barchart-inner zc-prop-fw'><ul class='zc-prop-y-axis-value-and-line'>";
                 		thisyear = zoho.currentdate.getYear();
                 		largest_Amount = 0;
                 		month_localization = thisapp.Localization.Months();
                 		monthList = {1:"Jan",2:"Feb",3:"Mar",4:"Apr",5:"May",6:"Jun",7:"Jul",8:"Aug",9:"Sep",10:"Oct",11:"Nov",12:"Dec"};
                 		loop_count = 0;
                 		ns = 5;
                 		iterationString = "".leftPad(ns);
                 		stringLength = iterationString.length();
                 		iterationString = iterationString.replaceAll(" ",",");
                 		iterationString = iterationString.subString(0,iterationString.length() - 1);
                 		listPads = iterationString.toList();
                 		date_val = zoho.currentdate;
                 		lastMonth = date_val.subMonth(5);
                 		CurrentSixMonth = List();
                 		for each  dat in listPads
                 		{
                 			CurrentSixMonth.add(monthList.get(lastMonth.getMonth()));
                 			lastMonth = lastMonth.addMonth(1);
                 		}
                 		CurrentSixMonth.add(monthList.get(date_val.getMonth()));
                 		for each  month in CurrentSixMonth
                 		{
                 			date_format = ("1-" + month + "-" + zoho.currentdate.getYear()).toString().toDate();
                 			thisyear = if(zoho.currentdate.getMonth() < date_format.getMonth(),zoho.currentdate.subYear(1).getYear(),zoho.currentdate.getYear());
                 			from_date = ("1-" + month + "-" + thisyear).toString().toDate();
                 			end_date = from_date.eomonth(0);
                 			if(login_profile == "Manager" && input.rec_id == null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(login_profile == "Owner" && input.rec_id == null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(input.rec_id == null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date].sum(Total_Amount);
                 			}
                 			if(login_profile == "Manager" && input.rec_id != null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(login_profile == "Owner" && input.rec_id != null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Property == input.rec_id && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(input.rec_id != null)
                 			{
                 				sum_of_orders = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Property == input.rec_id].sum(Total_Amount);
                 			}
                 			if(largest_Amount < sum_of_orders)
                 			{
                 				largest_Amount = sum_of_orders;
                 			}
                 			if(zoho.currentdate.contains(month))
                 			{
                 				break;
                 			}
                 		}
                 		//round_Of = largest_Amount + 1000 - largest_Amount % 1000;
                 		round_Of = thisapp.CommonFeatures.tenToThePowerOf(largest_Amount.round(0));
                 		step = largest_Amount;
                 		step_margin = largest_Amount / 4;
                 		for each  value in {0,1,2,3,4}
                 		{
                 			step_value = round_Of - value * round_Of / 4;
                 			barcontent = barcontent + "<li class='zc-prop-clearfix zc-prop-fw'><span class='zc-prop-flt-left zc-prop-axis-value'>" + currency + thisapp.CommonFeatures.numberFormat(step_value) + "</span><span class='zc-prop-flt-left zc-prop-axis-line'></span></li>";
                 		}
                 		months = "";
                 		barheight = "";
                 		for each  month in CurrentSixMonth
                 		{
                 			date_format = ("1-" + month + "-" + zoho.currentdate.getYear()).toString().toDate();
                 			thisyear = if(zoho.currentdate.getMonth() < date_format.getMonth(),zoho.currentdate.subYear(1).getYear(),zoho.currentdate.getYear());
                 			from_date = ("1-" + month + "-" + thisyear).toString().toDate();
                 			end_date = from_date.eomonth(0);
                 			if(login_profile == "Manager" && input.rec_id == null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income" && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense" && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(login_profile == "Owner" && input.rec_id == null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income" && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense" && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(input.rec_id == null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income"].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense"].sum(Total_Amount);
                 			}
                 			if(login_profile == "Manager" && input.rec_id != null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income" && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense" && Unit.Manager == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(login_profile == "Owner" && input.rec_id != null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income" && Property == input.rec_id && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense" && Property == input.rec_id && Unit.Owner_Mail_ID == thisapp.get_user_id()].sum(Total_Amount);
                 			}
                 			else if(input.rec_id != null)
                 			{
                 				sum_of_income = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Income" && Property == input.rec_id].sum(Total_Amount);
                 				sum_of_expense = Add_Payment_Notes[Status == "Received" && Pay_For != "Security Deposit" && Pay_For != "Vacate" && Payment_Date >= from_date && Payment_Date <= end_date && Payment_Type == "Expense" && Property == input.rec_id].sum(Total_Amount);
                 			}
                 			heightpercent_income = sum_of_income / round_Of * 100;
                 			heightpercent_expense = sum_of_expense / round_Of * 100;
                 			months = months + "<li class='zc-prop-flt-left'><span class='zc-prop-axis-value'>" + month_localization.get(month) + "</span></li>";
                 			barheight = barheight + "<li class='zc-prop-flt-left'>";
                 			// 			if(heightpercent_income != 0)
                 			// 			{
                 			barheight = barheight + "<div style='height:" + heightpercent_income + "%; left: calc(50% - 5px); background-color: #11D2DD;'></div>";
                 			// 			}
                 			// 			if(heightpercent_expense != 0)
                 			// 			{
                 			barheight = barheight + "<div style='height:" + heightpercent_expense + "%; left: calc(50% + 5px); background-color: #F05A7A;'></div>";
                 			// 			}
                 			barheight = barheight + "<ul class='zc-prop-bc-tooltip-wrapper' style='bottom:" + heightpercent_income + "%'><li><span>" + currency + thisapp.CommonFeatures.numberFormat(sum_of_income) + "</span></li><li><span>" + currency + thisapp.CommonFeatures.numberFormat(sum_of_expense) + "</span></li></ul></li>";
                 		}
                 		barcontent = barcontent + "</ul><ul class='zc-prop-axis-bar'> " + barheight + "</ul></div><ul class='zc-prop-x-axis-value zc-prop-clearfix zc-prop-fw'>" + months + "</ul></div>";
                 		barChart = style + barcontent;
                 	}
                 	else
                 	{
                 		no_data_text = "No Data";
                 		icon = "<div class='zc-prop-nodata-img'><img src='data:image/svg+xml;base64,'></div>";
                 		nodata = "<div class='zc-prop-nodata zc-prop-fwh'><div class='zc-prop-nodata-content'>" + icon + "<span>" + no_data_text + "</span></div></div>";
                 		barChart = nodata;
                 	}
                 	return barChart;
                 }
				 string Components.Button(string type, string title, string redirectTo)
                 {
                 	if(type == "Add")
                 	{
                 		style_txt = ".zc-live-primary-btn i { font-size: 12px; line-height: 18px; font-weight: 600; margin-right: 8px; } .zc-live-primary-btn span { display: inline-block; font-weight: 400; line-height: 18px; letter-spacing: 0.1px; } .zc-rtl-wrapper .zc-live-primary-btn i { margin-right: 0px; margin-left: 8px; }";
                 		a_tag_class = "zc-live-primary-btn";
                 		i_tag_class = "zc-li-outline ui-1-simple-add";
                 	}
                 	else if(type == "Edit")
                 	{
                 		style_txt = ".zc-prop-page-container .zc-live-primary-outline-btn:hover { background-color: var(--theme_brand_color); } .zc-live-primary-outline-btn i { vertical-align: top; margin-right: 6px; line-height: 17px; } .zc-rtl-wrapper .zc-live-primary-outline-btn i { margin-right: 0px; margin-left: 6px; }";
                 		a_tag_class = "zc-live-primary-outline-btn";
                 		i_tag_class = "zc-li-outline ui-1-edit-72";
                 	}
                 	else if(type == "Print")
                 	{
                 		style_txt = ".zc-live-primary-outline-btn i { vertical-align: top; margin-right: 6px; line-height: 17px; } .zc-rtl-wrapper .zc-live-primary-outline-btn i { margin-right: 0px; margin-left: 6px; }";
                 		a_tag_class = "zc-live-primary-outline-btn";
                 		i_tag_class = "zc-li-outline tech-print";
                 	}
                 	else if(type == "PDF")
                 	{
                 		style_txt = ".zc-live-primary-outline-btn i { vertical-align: top; margin-right: 6px; line-height: 17px; } .zc-rtl-wrapper .zc-live-primary-outline-btn i { margin-right: 0px; margin-left: 6px; }";
                 		a_tag_class = "zc-live-primary-outline-btn";
                 		i_tag_class = "zc-li-outline files-3-pdf";
                 	}
                 	else if(type == "Active")
                 	{
                 		style_txt = ".zc-live-primary-outline-btn.zc-prop-active-btn { border-color: #179E6C; color: #179E6C; } .zc-live-primary-outline-btn.zc-prop-active-btn:hover { background-color: #179E6C; border-color: #179E6C; color: #FFFFFF; } .zc-live-primary-outline-btn i { vertical-align: top; margin-right: 6px; line-height: 17px; } .zc-rtl-wrapper .zc-live-primary-outline-btn i { margin-right: 0px; margin-left: 6px; }";
                 		a_tag_class = "zc-live-primary-outline-btn zc-prop-active-btn";
                 		i_tag_class = "zc-li-outline ui-1-check-circle-08";
                 	}
                 	else if(type == "Inactive")
                 	{
                 		style_txt = ".zc-live-primary-outline-btn.zc-prop-inactive-btn { border-color: #FE455D; color: #FE455D; } .zc-live-primary-outline-btn.zc-prop-inactive-btn:hover { background-color: #FE455D; border-color: #FE455D; color: #FFFFFF; } .zc-live-primary-outline-btn i { vertical-align: top; margin-right: 6px; line-height: 17px; } .zc-rtl-wrapper .zc-live-primary-outline-btn i { margin-right: 0px; margin-left: 6px; }";
                 		a_tag_class = "zc-live-primary-outline-btn zc-prop-inactive-btn";
                 		i_tag_class = "zc-li-outline ui-1-circle-remove";
                 	}
                 	html = "<style>" + style_txt + "</style><a class='" + a_tag_class + "' href='" + redirectTo + "'><i class='" + i_tag_class + "'></i><span>" + title + "</span></a>";
                 	return html;
                 }
				 string Components.Custom_Donut(string chart_name, map chart_Inputs, list colors, bool show_legend)
                 {
                 	// 	language = thisapp.Content.Common();
                 	// 	no_data_text = language.get("zcp.dashboards.chart.nodata");
                 	chartValues = chart_Inputs.get(chart_name);
                 	total_chart_value = 0;
                 	no_of_valid_legends = 0;
                 	for each  value in chart_Inputs
                 	{
                 		info value;
                 		total_chart_value = total_chart_value + value;
                 		no_of_valid_legends = no_of_valid_legends + if(value != 0,1,0);
                 	}
                 	donut_chart = "";
                 	if(total_chart_value != 0)
                 	{
                 		stroke_width = 20;
                 		cx = 100;
                 		cy = 100;
                 		size_of_svg = cx + cy;
                 		radius = 80;
                 		pi = 3.14;
                 		inputKeys = chart_Inputs.keys();
                 		style_txt = "<style>.zc-prop-donut-chart-" + chart_name + " { display: flex; flex-direction: row; justify-content: center; align-items: center; } .zc-prop-chart-diagram-" + chart_name + " { position: relative; } .zc-prop-donut-chart-" + chart_name + " .zc-prop-chart-name { font-size: 16px; font-weight: 400; line-height: " + size_of_svg + "px; color: #131635; text-align: center; position: absolute; top: 0px; left: 0px; right: 0px; } .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li { list-style-type: none; padding: 10px 20px; } .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li span { display: inline-block; vertical-align: top; font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0.1px; color: #131635; } .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li span:first-child { width: 120px; } .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li span:first-child:before { content: ''; display: inline-block; vertical-align: top; width: 11px; height: 11px; border-radius: 50%; margin: 5px 12px 5px 0px; } /* RTL */ .zc-rtl-wrapper .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li span:first-child:before { margin: 5px 0px 5px 12px; }";
                 		html_txt = "<div class='zc-prop-donut-chart-" + chart_name + " zc-prop-fwh'><div class='zc-prop-chart-diagram-" + chart_name + "'><svg>";
                 		style_txt = style_txt + " .zc-prop-chart-diagram-" + chart_name + " svg { width: " + size_of_svg + "px; height: " + size_of_svg + "px; }";
                 		child = 1;
                 		previouscircleValue = 0;
                 		dashoffset = 0;
                 		legentCont = "";
                 		legentContColor = "";
                 		for each  inputKey in inputKeys
                 		{
                 			legendValue = chart_Inputs.get(inputKey);
                 			if(legendValue != 0)
                 			{
                 				baseCircleStart = if(no_of_valid_legends == 1,0,1);
                 				arc = legendValue / total_chart_value * 100;
                 				dashoffset = (2 * pi * radius) / 4 - previouscircleValue;
                 				white_space = 2 * 0;
                 				whitespace_arclength = 2 * pi * radius * white_space / 100;
                 				style_txt = style_txt + ".zc-prop-chart-diagram-" + chart_name + " svg .zc-prop-legend-" + child + " { stroke-dasharray: calc(2px * " + pi + " * " + radius + " * " + arc + " / 100) calc(2px * " + pi + " * " + radius + " * calc(" + baseCircleStart + " - " + arc + " / 100)); stroke-dashoffset: " + dashoffset + "; }";
                 				html_txt = html_txt + "<circle class = 'zc-prop-legend-" + child + "' cx=" + cx + " cy=" + cy + " r=" + radius + " fill='transparent' stroke='" + colors.get(child - 1) + "' stroke-width=" + stroke_width + "></circle>";
                 				//previouscircleValue = previouscircleValue + 2 * pi * radius * arc / 100 + 10;
                 				previouscircleValue = previouscircleValue + 2 * pi * radius * arc / 100 + whitespace_arclength;
                 			}
                 			if(show_legend == true)
                 			{
                 				legentCont = legentCont + "<li><span>" + inputKey + " </span><span> " + chart_Inputs.get(inputKey) + " </span></li>";
                 				legentContColor = legentContColor + " .zc-prop-donut-chart-" + chart_name + " ul.zc-prop-legend-info li:nth-child(" + child + ") span:first-child:before { background-color: " + colors.get(child - 1) + "; }";
                 			}
                 			child = child + 1;
                 		}
                 		style_txt = style_txt + legentContColor + "</style>";
                 		html_txt = html_txt + "</svg><span class='zc-prop-chart-name'>" + chart_name + " </span></div>" + if(show_legend == true,"<ul class='zc-prop-legend-info'>" + legentCont + "</ul>","") + "</div>";
                 		donut_chart = style_txt + html_txt;
                 	}
                 	else
                 	{
                 		icon = "<div class='zc-prop-nodata-img'><img src='data:image/svg+xml;base64,'></div>";
                 		nodata = "<div class='zc-prop-nodata zc-prop-fwh'><div class='zc-prop-nodata-content'>" + icon + "<span>No Data</span></div></div>";
                 		donut_chart = donut_chart + nodata;
                 	}
                 	return donut_chart;
                 }
				 string Components.Import(string page_link_name)
                 {
                 	common = thisapp.Localization.common();
                 	detail_map = thisapp.Page.Get_Import_Details(page_link_name);
                 	title = detail_map.get("Title");
                 	export_text = detail_map.get("Export");
                 	import_url = detail_map.get("Import");
                 	note_lis = detail_map.get("Notes");
                 	style_txt = "<style>" + thisapp.Styles_Page.Import_Common() + "</style>";
                 	if(title == "Units")
                 	{
                 		page_link_name = "Properties?tab=units";
                 	}
                 	dom_txt = "<div class='zc-prop-page-container zc-prop-import'><div class='zc-prop-page-container-inner zc-prop-fwh'><div class='zc-prop-page-header zc-prop-clearfix zc-prop-fw'><a class='zc-prop-flt-left zc-prop-back-icon' href='#Page:" + page_link_name + "'><span class='fa fa-angle-left'></span></a><h5 class='zc-prop-flt-left'>" + title + " - " + common.get("zcpm.import") + "</h5></div><div class='zc-prop-page-content'><div class='zc-prop-card zc-prop-clearfix zc-prop-fwh'><div class='zc-prop-flt-left zc-prop-upload-container'><p>" + export_text + "</p><div class='zc-prop-upload-content'><a class='zc-prop-upload-link-wrapper' href='" + import_url + "'><i class='arrows-1-cloud-upload-96 zc-li-outline'></i><h6>" + common.get("zcpm.import.upload.button") + "</h6><p>" + common.get("zcpm.import.fileformat") + "</p></a></div></div><div class='zc-prop-flt-left zc-prop-notes-container'><div class='zc-prop-notes-content zc-prop-fwh'><div class='zc-prop-notes-header zc-prop-clearfix zc-prop-fw'><i class='zc-prop-flt-left business-bulb-63 zc-li-solid'></i><h6 class='zc-prop-flt-left'>" + common.get("zcpm.import.thingstonote.title") + "</h6></div><ul>";
                 	for each  note in note_lis
                 	{
                 		dom_txt = dom_txt + "<li><p>" + note + "</p></li>";
                 	}
                 	dom_txt = dom_txt + "</ul></div></div></div></div></div></div>";
                 	return style_txt + dom_txt;
                 }
				 string Components.No_Data(map component_options)
                 {
                 	no_data_src = thisapp.Data_Map.Image_Sources();
                 	html_txt = "<div class='zc-prop-nodata zc-prop-fwh'><div class='zc-prop-nodata-content'>";
                 	if(component_options.get('is_img') == true)
                 	{
                 		html_txt = html_txt + "<img src='" + no_data_src.get('no_data') + "' alt='No Data'>";
                 	}
                 	if(component_options.get('Primary_header_txt') == true)
                 	{
                 		html_txt = html_txt + "<h4>" + component_options.get('header_txt') + "</h4>";
                 	}
                 	if(component_options.get('Secondary_header_txt') == true)
                 	{
                 		html_txt = html_txt + "<h6>" + component_options.get('header_txt') + "</h6>";
                 	}
                 	if(component_options.get('is_btn') == true)
                 	{
                 		html_txt = html_txt + "<div class='zc-prop-nodata-btns'>";
                 		if(component_options.get('primary_btn'))
                 		{
                 			html_txt = html_txt + "<a class='zc-live-primary-btn' href='" + component_options.get('primary_btn_link') + "'>" + component_options.get('primary_btn') + "</a>";
                 		}
                 		if(component_options.get('both_btn'))
                 		{
                 			html_txt = html_txt + "<span> or </span>";
                 		}
                 		if(component_options.get('secondary_btn'))
                 		{
                 			html_txt = html_txt + "<a class='zc-live-secondary-btn' href='" + component_options.get('primary_btn_link') + "'>" + component_options.get('btn_name') + "</a>";
                 		}
                 		html_txt = html_txt + "</div>";
                 	}
                 	html_txt = html_txt + "</div></div>";
                 	return html_txt;
                 }
				 string Components.Property_Info(string img, string prop_type, string email, string prop_location, string amenities, string prop_address, int prop_size)
                 {
                 	language = thisapp.Localization.Pages();
                 	style_txt = thisapp.Styles.Property_Info();
                 	email_text = "";
                 	new_user = New_User[Email == input.email];
                 	if(new_user.Role == "Owner" || (new_user.Role == "Admin" && new_user.Role_Admin == "Owner"))
                 	{
                 		email_text = language.get("zcpm.property.property_owner");
                 	}
                 	else if(new_user.Role == "Manager" || new_user.Role_Admin == "Manager")
                 	{
                 		email_text = language.get("zcpm.property.property_manager");
                 	}
                 	dom_txt = "<div class='zc-prop-property-info zc-prop-card zc-prop-clearfix zc-prop-fw'><div class='zc-prop-flt-left zc-prop-img-wrapper'>" + input.img + "</div><div class='zc-prop-flt-left zc-prop-label-value-wrapper'> <ul class='zc-prop-clearfix zc-prop-fw'> <li class='zc-prop-flt-left'> <label> " + language.get("zcpm.property.property_type") + " </label> <span> " + input.prop_type + " </span> </li> <li class='zc-prop-flt-left'> <label> " + email_text + " </label> <span> " + new_user.Name + " </span> </li> </li> <li class='zc-prop-flt-left'> <label> " + language.get("zcpm.property.location") + " </label> <span> " + input.prop_location + " </span> </li> <li class='zc-prop-flt-left'> <label> " + language.get("zcpm.property.amenities") + " </label> <span> " + input.amenities + " </span> </li> <li class='zc-prop-flt-left'> <label> " + language.get("zcpm.property.address") + " </label> <span> " + input.prop_address + " </span> </li> <li class='zc-prop-flt-left'> <label> " + language.get("zcpm.property.size") + " </label> <span> " + input.prop_size + " </span> </li> </ul> </div> </div>";
                 	component_code = style_txt + dom_txt;
                 	return component_code;
                 }
				 string Components.Range_Bar_Style()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	range_bar = "/* Rangebar styles */ .zc-prop-rangebar-wrapper { max-height: 302px; border-radius: 12px; overflow: hidden; } .zc-prop-rangebar-wrapper>ul { padding: 20px; overflow: auto; } .zc-prop-rangebar-wrapper ul li { list-style-type: none; padding: 16px 20px; } .zc-prop-rangebar-wrapper ul li span { width: 170px; font-size: 14px; font-weight: 400; line-height: 20px; letter-spacing: 0.1px; color: \" + color_codes.get(\"zc-prop-secondary-text-color\") + \"; } .zc-prop-rangebar-value { width: calc(100% - 170px); margin: 7px 0px; position: relative; } .zc-prop-rangebar { width: 100%; height: 6px; background-color: #EBECF0; border-radius: 3px; overflow: hidden; cursor: pointer; } .zc-prop-rangebar-level { height: inherit; background-color: var(--theme_brand_color); border-radius: 3px; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper { width: 150px; padding: 12px; border-radius: 4px; position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); display: none; background-color: #FFF; box-shadow: 0px 3px 8px 0px #EAECF0; border: 1px solid \" + color_codes.get(\"zc-prop-border-color\") + \"; z-index: 1; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper:after { content: ''; position: absolute; top: 100%; left: 50%; margin-left: -7px; border-width: 7px; border-style: solid; border-color: #FFF transparent transparent transparent; } .zc-prop-rangebar-wrapper ul li .zc-prop-rangebar-value:hover .zc-prop-tooltip-wrapper { display: block; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li { padding: 3px 0px; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li:not(:last-child) { margin-bottom: 5px; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li span { color: \" + color_codes.get(\"zc-prop-primary-text-color\") + \"; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li span:before { content: ''; display: inline-block; vertical-align: top; width: 11px; height: 11px; margin: 5px 12px 5px 0px; border-radius: 50%; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li:nth-child(1) span:before, .zc-prop-range-bar ul.zc-prop-legent-info li:nth-child(1) span:before { background-color: #4E66F0; } .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li:nth-child(2) span:before, .zc-prop-range-bar ul.zc-prop-legent-info li:nth-child(2) span:before { background-color: #EBECF0; } /* 1st two tooltip styles */ .zc-prop-rangebar-wrapper ul li:nth-child(1) ul.zc-prop-tooltip-wrapper, .zc-prop-rangebar-wrapper ul li:nth-child(2) ul.zc-prop-tooltip-wrapper { bottom: auto; top: 15px; box-shadow: 0px -3px 8px 0px #EAECF0; } .zc-prop-rangebar-wrapper ul li:nth-child(1) ul.zc-prop-tooltip-wrapper:after, .zc-prop-rangebar-wrapper ul li:nth-child(2) ul.zc-prop-tooltip-wrapper:after { top: auto; bottom: 100%; border-color: transparent transparent #FFF transparent; } /* Report styles */ .zc-prop-report-wrapper { height: 350px; } .zc-prop-card .zc-prop-card-content.zc-prop-report { height: calc(100% - 57px) !important; } .zc-prop-report .view-outer-wrapper, .zc-prop-report .zc-reporttype-list, .zc-prop-report .list-view-inner { border-radius: 0px 0px 12px 12px; } .zc-prop-report .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th { border-top-width: 0px !important; } /* RTL */ .zc-rtl-wrapper .zc-prop-split-col>div:not(:last-child) { margin-right: 0px; margin-left: 20px; } .zc-rtl-wrapper ul.zc-prop-legent-info li span:before, .zc-rtl-wrapper .zc-prop-rangebar-wrapper ul.zc-prop-tooltip-wrapper li span:before { margin: 5px 0px 5px 12px; }";
                 	return range_bar;
                 }
				 string Components.Report_View_Advance(map component_options)
                 {
                 	dom_txt = "";
                 	with_option = "";
                 	if(component_options.get('is_Option') == true)
                 	{
                 		with_option = " zc-prop-page-header-with-option";
                 		if(component_options.get('can_show_report') == false)
                 		{
                 			info component_options.get('can_show_report');
                 			with_option = " zc-prop-page-header-with-option-nodata";
                 		}
                 	}
                 	dom_txt = "<div class='zc-prop-page-container zc-prop-report-view'><div class='zc-prop-page-container-inner zc-prop-fwh'><div class='zc-prop-card zc-prop-fwh'><div class='zc-prop-page-header zc-prop-clearfix zc-prop-fw" + with_option + "'><div class='zc-prop-page-header-title zc-prop-clearfix zc-prop-flt-left'>";
                 	if(component_options.get('back_url') != null)
                 	{
                 		dom_txt = dom_txt + "<a class='zc-prop-flt-left zc-prop-back-icon' href='" + component_options.get('back_url') + "'><span class='fa fa-angle-left'></span></a>";
                 	}
                 	dom_txt = dom_txt + "<h5 class='zc-prop-flt-left'>" + component_options.get('display_name') + "</h5></div><div class='zc-prop-flt-right'>";
                 	if(component_options.get('add_link') != null)
                 	{
                 		dom_txt = dom_txt + "<div class='zc-prop-flt-left'>" + thisapp.Components.Button("Add",component_options.get("add_button_text"),component_options.get('add_link')) + "</div>";
                 	}
                 	if(component_options.get('is_Option') == true && component_options.get('can_show_report') == false)
                 	{
                 		dom_txt = dom_txt + "<div class='zc-prop-flt-left zc-prop-more-options zc-prop-square'><div class='zc-prop-hover-extend'></div><i class='fa fa-bars'></i><ul><li><a href='#Page:" + component_options.get('page_linkname') + "?action=import'><i class='zc-li-outline arrows-2-file-download-87'></i><span>Import</span></a></li><li><a href='" + zoho.appuri + "csv/" + component_options.get('export_report_name') + component_options.get('export_value') + "'><i class='zc-li-outline arrows-2-file-upload-86'></i><span>Export</span></a></li></ul></div>";
                 	}
                 	dom_txt = dom_txt + "</div></div><div class='zc-prop-page-content'>";
                 	if(component_options.get('can_show_report') == true)
                 	{
                 		dom_txt = dom_txt + "<div class='zc-prop-content-wrapper zc-prop-fwh'><div class='zc-prop-filter' elName='zc-component' formLinkName='" + component_options.get('form_link_name') + "' params='zc_Header=false&zc_Footer=false&zc_Focus=false" + component_options.get('report_param') + "&Page=" + component_options.get('page_linkname') + "&Report=" + component_options.get('report_linkname') + "'></div><div class='zc-prop-report' elName='zc-component' viewLinkName='" + component_options.get('report_linkname') + "'params='zc_Header=false&zc_AddRec=false&zc_ColMenu=false&zc_Footer=false" + component_options.get('report_param') + "'name='" + component_options.get('page_linkname') + "' name='" + component_options.get('page_linkname') + "'></div></div>";
                 	}
                 	else
                 	{
                 		no_data_component_params = {"is_img":true,"header_txt":"No Data"};
                 		dom_txt = dom_txt + thisapp.Components.No_Data(no_data_component_params);
                 	}
                 	dom_txt = dom_txt + "</div></div></div></div>";
                 	style_txt = "<style>" + thisapp.Styles_Page.Report_View_Advance(component_options.get("page_linkname")) + " </style>";
                 	component_txt = style_txt + dom_txt;
                 	return component_txt;
                 }
				 string Currency.currencyDisplayFormat(float number)
                 {
                 	all_currency_display_format = {{"format":"1,234,567.89","seperator_digits":"3","seperator":",","class":"zc-pra-currency-format1"},{"format":"12,34,567.89","seperator_digits":"2","seperator":",","class":"zc-pra-currency-format2"},{"format":"1 234 567.89","seperator_digits":"3","seperator":" ","class":"zc-pra-currency-format3"},{"format":"1.234.567,89","seperator_digits":"3","seperator":".","class":"zc-pra-currency-format4"}};
                 	final_html = "<div class='zc-pra-currency'>";
                 	final_html = final_html + "<span class='zc-pra-currency-default zc-pra-currency-value'>" + number + "</span>";
                 	for each  cdf in all_currency_display_format
                 	{
                 		number_cpy = number;
                 		formatedNumber = "";
                 		if(number >= 1000)
                 		{
                 			number_cpy = number_cpy.round(2).toString();
                 			decimalSuffix = "." + number_cpy.getSuffix(".");
                 			number_cpy = number_cpy.remove(decimalSuffix);
                 			decimalSuffix = if(cdf.get('format') == "1.234.567,89",decimalSuffix.replaceAll(".",",",true),decimalSuffix);
                 			suffixNumber = number_cpy.subString(number_cpy.Length() - 3,number_cpy.Length());
                 			number_cpy = number_cpy.subString(0,number_cpy.Length() - 3);
                 			formatedNumber = number_cpy.replaceAll("(?<!\.\d)(?<=\d)(?=(?:\d{" + cdf.get('seperator_digits') + "})+\b)",cdf.get('seperator')) + cdf.get('seperator') + suffixNumber + decimalSuffix;
                 		}
                 		else
                 		{
                 			number_cpy = number_cpy.round(2).toString();
                 			formatedNumber = if(cdf.get('format') == "1.234.567,89",number_cpy.replaceAll(".",",",true),number_cpy);
                 		}
                 		final_html = final_html + "<span class='" + cdf.get('class') + " zc-pra-currency-value'>" + formatedNumber + "</span>";
                 	}
                 	final_html = final_html + "</div>";
                 	return final_html;
                 }
