			Data_Validation1 as "Data Validation"
			{
				type =  form
				form = Tenant_Screening
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										login_profile = thisapp.permissions.loginUserProfile();
										unit = Add_Unit[ID == input.Tenant.Unit];
										if((login_profile == "Admin" && input.Status == "Not Update") || (login_profile == "Administrator" && input.Status == "Not Update") || (login_profile == "Developer" && input.Status == "Not Update") || (login_profile == "Owner" && input.Status == "Not Update" && unit.Owner_Mail_ID == thisapp.get_user_id()) || input.Tenant == thisapp.get_user_id())
										{
											if(input.Screening_Process == "My Self")
											{
												if(input.Occupant_Type.isEmpty())
												{
													alert language_alert.get("zcpm.enter.occupant.type");
													cancel submit;
												}
												if(input.Occupant_Type == "Rent" && input.Monthly_Rental == null)
												{
													alert language_alert.get("zcpm.valid.rental.amount");
													cancel submit;
												}
												else if(input.Occupant_Type == "Lease" && input.Lease_Type.isEmpty() || input.Lease_Amount == null)
												{
													alert language_alert.get("zcpm.valid.lease.detail");
													cancel submit;
												}
												if(input.Occupant_Type == "Rent")
												{
													input.Lease_Type = null;
													input.Lease_Amount = null;
												}
												else if(input.Occupant_Type == "Lease")
												{
													input.Monthly_Rental = null;
												}
											}
											if(input.Current_Owner_Name == null && login_profile == "Tenant")
											{
												alert language_alert.get("zcpm.enter.owner.name");
												cancel submit;
											}
										}
						)
					}
				}

			}
			Unit_User_input as "Unit User input"
			{
				type =  form
				form = Renew_Agreement_Request
				record event = on add or edit

				on user input of Unit
				{
					actions 
					{
						custom deluge script
						(
											getAgreement = Tenant_Agreement[Unit == input.Unit && Unit.Current_Tenant == thisapp.get_user_id() && Status == "Tenant Approved"];
										input.Base_Agreement = getAgreement.ID;
										if(input.Property == null)
										{
											input.Property = input.Unit.Property;
										}
										language = thisapp.Localization.Pages();
										language_alert = thisapp.Localization.Alert();
										payment = Add_Payment_Notes[Unit == input.Unit && Pay_For == "Security Deposit" && Status == "Unpaid"];
										if(payment.count() == 1 && input.Unit != null && input.Action_field != "my_unit")
										{
											alert language_alert.get("zcpm.vacate.security.deposit");
											input.Unit = null;
										}
										unit = if(input.Unit == null,"-",input.Unit.Unit_Name);
										agreement_no = if(input.Base_Agreement == null,"-",input.Base_Agreement.Agreement_No);
										tenant = if(input.Base_Agreement == null,"-",input.Base_Agreement.Tenant.Name);
										start = if(input.Base_Agreement == null,"-",input.Base_Agreement.Start_Date);
										end = if(input.Base_Agreement == null,"-",input.Base_Agreement.End_Date);
										property = if(input.Property == null,"-",input.Property.Property_Name);
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile != "Tenant" && input.Action_field != "my_unit")
										{
											show plain;
											input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr><tr><td>" + language.get("zcpm.user.tenant") + "</td><td>" + tenant + "</td></tr><tr><td>" + language.get("zcpm.agreement.no") + "</td><td>" + agreement_no + "</td></tr><tr><td>" + language.get("zcpm.renew.Agreement_Duration") + "</td><td class='zc-prop-yellow'>" + start + " " + language.get("zcpm.renew.to") + " " + end + "</td></tr></tbody></table></div></div>";
										}
										else if(input.Action_field != "my_unit")
										{
											show plain1;
											input.plain1 = thisapp.Styles_Popup.Notes_Field() + "<style>.zc-plain1-group .zc-prop-notes-field {width: 475px;}</style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + property + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + unit + "</td></tr><tr><td>" + language.get("zcpm.user.tenant") + "</td><td>" + tenant + "</td></tr><tr><td>" + language.get("zcpm.agreement.no") + "</td><td>" + agreement_no + "</td></tr><tr><td>" + language.get("zcpm.renew.Agreement_Duration") + "</td><td class='zc-prop-yellow'>" + start + " " + language.get("zcpm.renew.to") + " " + end + "</td></tr></tbody></table></div></div>";
										}
						)
					}
				}

			}
			Next_Rent_Pay as "Next Rent Pay"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add

				on user input of Start_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.Start_Date != null)
										{
											input.Next_Pay_Date = input.Start_Date.addMonth(1);
											if(input.End_Date <= input.Next_Pay_Date)
											{
												input.Next_Pay_Date = null;
											}
										}
						)
					}
				}

			}
			Avoid_Negative_value_Base as "Avoid Negative value - Base Lease"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Base_Lease
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Base_Lease != null && input.Base_Lease < 0)
										{
											input.Base_Lease = null;
											alert language_alert.get("zcpm.valid.base.lease");
										}
										if(input.Base_Lease != null && input.Base_Lease > 0)
										{
											input.Security_Deposit = input.Base_Lease;
											input.Security_Deposit_Display = thisapp.Currency.currencyDisplayFormat(input.Base_Lease);
										}
						)
					}
				}

			}
			Avoid_Negative_value_Base1 as "Avoid Negative value - Base Rent"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Base_Rent
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Base_Rent != null && input.Base_Rent < 0)
										{
											input.Base_Rent = null;
											alert language_alert.get("zcpm.valid.base.rent");
										}
										language_alert = thisapp.Localization.Alert();
										if(input.Base_Rent != null && input.Base_Rent < 0)
										{
											input.Base_Rent = null;
											alert language_alert.get("zcpm.valid.base.rent");
										}
										if(input.Agreement_Type == "Rent")
										{
											input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount);
										}
										else
										{
											input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount);
