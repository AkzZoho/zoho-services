                 	label_style = ".zc-prop-field-group .zc-prop-label .zc-prop-label-txt { font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-text-color") + "; text-align: left; display: block; } .zc-prop-field-group .zc-prop-label.zc-prop-label-with-count .zc-prop-label-txt { padding: 2px 0px; } .zc-prop-field-group .zc-prop-count { padding: 0px 8px; margin: 0px 8px; background-color: " + color_codes.get("zc-prop-table-header-bg") + "; border-radius: 4px; font-size: 14px; font-weight: 400; line-height: 25px; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-text-color") + "; text-align: center; } .zc-prop-field-group .zc-prop-label .zc-prop-value-txt { font-size: 14px; font-weight: 600; line-height: 1.5; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-secondary-text-color") + "; text-align: left; display: block; margin: 0px 6px; }";
                 	banner_style = ".zc-prop-notes-field .zc-prop-banner.zc-prop-banner-with-border { padding: 8px 16px; }";
                 	list_style = ".zc-prop-list-wrapper ul { font-size: 0px; padding: 0px; margin: 0px; } .zc-prop-field-group .zc-prop-list-wrapper { margin-top: 6px; }";
                 	rtl_txt = ".zc-rtl-wrapper .zc-prop-field-group .zc-prop-label .zc-prop-label-txt, .zc-rtl-wrapper .zc-prop-field-group .zc-prop-label .zc-prop-value-txt { text-align: right; }";
                 	style_txt = "<style>" + override_style + common_style + label_style + thisapp.Styles.Note_Text() + banner_style + list_style + thisapp.Styles_Popup.Key_Value_View() + rtl_txt + "</style>";
                 	return style_txt;
                 }
				 string Styles_Popup.Permission()
                 {
                 	style_txt = "div#zc-component { height: 100%; overflow: hidden; } .page_content_wrapper * { margin: 0px; padding: 0px; box-sizing: border-box; } .zc-form-fullheight, .zc-form-fullheight .form-outer-wrapper, .zc-form-fullheight .form-outer-wrapper .row, .zc-form-fullheight .form-outer-wrapper .row form, .zc-form-fullheight .form-outer-wrapper .formContainer { height: 100%; } .zc-form-fullheight .form-outer-wrapper .form-header, .zc-form-fullheight .form-outer-wrapper .zc-footer-wrapper { display: none; } .zc-form-fullheight .form-outer-wrapper form .formColumn { width: 100%; } .zc-form-fullheight .form-outer-wrapper form .form-group.zc-addnote-fld { margin: 100px auto 20px; }";
                 	return style_txt;
                 }
				 string Styles_Popup.Popup()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	override_style = ".zcpopup.compact .popupbox-wrapper .popupbox.formWithinPopup .popupboxOuter .form-outer-wrapper form .formContainer { padding: 20px 30px 0px; } .zcpopup.compact .popupbox-wrapper .popupbox.formWithinPopup .popupboxOuter .form-outer-wrapper form .zc-footer-wrapper .formbutton { padding: 16px; text-align: center; } .zcpopup .statelessFormWidth .form-action .zc-live-primary-btn { padding: 8px 20px; margin: 0px; } .zcpopup.compact .form-outer-wrapper form.form-table,  .zcpopup.compact .form-outer-wrapper form.form-table .zc-addnote-fld { width: 100%; } .zcpopup .form-group { margin-bottom: 0px; }";
                 	common_style = ".zc-prop-popup-content { padding: 20px; text-align: center; } .zc-prop-popup-content .zc-prop-icon-wrapper { width: 48px; height: 48px; border-radius: 50%; text-align: center; display: inline-block; vertical-align: top; } .zc-prop-popup-content .zc-prop-icon-wrapper i { font-size: 24px; line-height: 48px; font-style: normal; vertical-align: top; } .zc-prop-popup-content h4 { font-size: 18px; font-weight: 500; line-height: 1.3; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-text-color") + "; margin: 16px 0px 12px; } .zc-prop-popup-content p { display: inline-block; vertical-align: top; font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0.1px; color: " + color_codes.get("zc-prop-primary-text-color") + "; } .zc-prop-popup-content .zc-pra-currency { padding: 0px 4px; }";
                 	style_txt = override_style + common_style;
                 	return style_txt;
                 }
				 string Styles_Popup.Table_View()
                 {
                 	color_codes = thisapp.Styles.Color_Codes();
                 	table_style = thisapp.Styles.New_Table();
                 	style_txt = table_style + ".zc-prop-table-wrapper table thead tr th { font-weight: 600; } .zc-prop-table-wrapper table tbody tr.zc-prop-total-tr td { font-size: 15px; font-weight: 600; } .zc-prop-table-wrapper table tbody tr:hover td { background-color: transparent; } .zc-prop-table-wrapper table tbody tr:first-child td { border-width: 0px; }";
                 	return style_txt;
                 }
				 map Timeline.Get_Topbar(int rec_id)
                 {
                 	language = thisapp.Localization.Pages();
                 	complaint = Raise_a_Complaint[ID == input.rec_id];
                 	mp = Map();
                 	// Badge class name
                 	status_color_rej = if(complaint.Complaint_Status == "Rejected","zc-prop-badge-red","");
                 	status_color_others = if(complaint.Complaint_Status == "Requested" || complaint.Complaint_Status == "Approved" || complaint.Complaint_Status == "Vendor Assigned" || complaint.Complaint_Status == "In Progress","zc-prop-badge-orange","");
                 	status_color_par_comple = if(complaint.Complaint_Status == "Work Order Completed" || complaint.Complaint_Status == "Waiting for Payment" || complaint.Complaint_Status == "Paid","zc-prop-badge-yellow","");
                 	status_color_comp = if(complaint.Complaint_Status == "Completed","zc-prop-badge-green","");
                 	// Stepper class name
                 	class_name_req = if(complaint.Complaint_Status == "Requested"," zc-prop-stepper-active","");
                 	class_name_com_rev = if(complaint.Complaint_Status == "Approved"," zc-prop-stepper-active","");
                 	class_name_rej = if(complaint.Complaint_Status == "Rejected"," zc-prop-stepper-active zc-prop-stepper-stop","");
                 	class_name_ass_ven = if(complaint.Complaint_Status == "Vendor Assigned" || complaint.Complaint_Status == "In Progress"," zc-prop-stepper-active","");
                 	class_name_work_com = if(complaint.Complaint_Status == "Work Order Completed"," zc-prop-stepper-active","");
                 	class_name_wait_pay = if(complaint.Complaint_Status == "Waiting for Payment" || complaint.Complaint_Status == "Paid"," zc-prop-stepper-active","");
                 	status_list = {"Requested","In Progress","Work Order Completed","Waiting for Payment","Completed"};
                 	count = 1;
                 	for each  status in status_list
                 	{
                 		status_map = Map();
                 		if(count == 1)
                 		{
                 			status_map.put("Display",language.get("zcpm.complaint.requested"));
                 			status_map.put("Style",class_name_req);
                 		}
                 		else if(count == 2)
                 		{
                 			if(complaint.Complaint_Status == "Approved")
                 			{
                 				display = language.get("zcpm.dashboard.complaint.reviewed");
                 			}
                 			else if(complaint.Complaint_Status == "Rejected")
                 			{
                 				display = language.get("zcpm.dashboard.complaint.rejected");
                 			}
                 			else
                 			{
                 				display = language.get("zcpm.complaint.vendor_assigned");
                 			}
                 			style = class_name_ass_ven + class_name_com_rev + class_name_rej;
                 			status_map.put("Display",display);
                 			status_map.put("Style",style);
                 		}
                 		else if(count == 3)
                 		{
                 			status_map.put("Display",language.get("zcpm.complaint.work_order_completed"));
                 			status_map.put("Style",class_name_work_com);
                 		}
                 		else if(count == 4)
                 		{
                 			status_map.put("Display",language.get("zcpm.complaint.waiting_for_payment"));
                 			status_map.put("Style",class_name_wait_pay);
                 		}
                 		else if(count == 5)
                 		{
                 			status_map.put("Display",language.get("zcpm.complaint.completed"));
                 			status_map.put("Style","<span style='width: 0%; height: 0%; margin: 50%;' class='zc-prop-stepper-level-span'> </span>");
                 		}
                 		mp.put(count.toString(),status_map);
                 		count = count + 1;
                 	}
                 	return mp;
                 }
			 }
		 }
		workflow
		{
		form
		{
			Field_rules as "Field rules"
			{
				type =  form
				form = Add_Property
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide No_of_Blocks,Property_Status,Hide;
					}
					actions  (Mark_it_as_single_unit_property1 == true)
					{
						hide Blocks;
					}
				}

			}
			On_Success_Submit as "On Success Submit"
			{
				type =  form
				form = Add_Property
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.No_of_Blocks = input.Blocks.count();
										delete from Documents[Property == null];
										new_user = New_User[Role == "Admin"];
										input.Admins = new_user.ID.getall();
						)
					}
				}

			}
			Field_rules1 as "Field rules"
			{
				type =  form
				form = Add_Unit
				record event = on add or edit

				field rules
				{
					actions 
					{
						disable Availability;
					}
					actions 
					{
						hide Hidden;
					}
				}

			}
			Edit_On_load_Hide_show_se as "Edit On load - Hide/show section"
			{
				type =  form
				form = Tenant_Agreement
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Agreement_Type == "Rent")
										{
											hide Base_Lease;
											show Base_Rent;
										}
										else if(input.Agreement_Type == "Lease")
										{
											show Base_Lease;
											hide Base_Rent;
										}
										disable Tenant;
										disable Agreement_Type;
										disable Base_Rent;
										disable Base_Lease;
										disable Start_Date;
										disable End_Date;
										disable Security_Deposit;
										disable Document;
										disable Next_Pay_Date;
										if(input.Status == "Requested" || input.Status == "Owner Approved")
										{
											enable Tenant;
											enable Agreement_Type;
											enable Base_Rent;
											enable Base_Lease;
											enable Start_Date;
											enable End_Date;
											enable Security_Deposit;
											enable Document;
											disable Next_Pay_Date;
										}
						)
					}
				}

			}
			Type_hide_show_Section as "Type - hide/show Section"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Agreement_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.Agreement_Type == "Rent")
										{
											// 	null the Lease based values
											input.Base_Lease = null;
											input.Start_Date = null;
											input.End_Date = null;
											hide Base_Lease;
											show Base_Rent;
										}
										else if(input.Agreement_Type == "Lease")
										{
											// 	null the rent based values
											input.Base_Rent = null;
											show Base_Lease;
											hide Base_Rent;
											hide Security_Deposit;
										}
										else if(input.Agreement_Type == "Owned")
										{
											// 	null the rent based values
											input.Base_Rent = null;
											// 	null the Lease based values
											input.Base_Lease = null;
											input.Start_Date = null;
											input.End_Date = null;
											hide Base_Lease;
											hide Base_Rent;
										}
										if(input.Agreement_Type != "" && input.Agreement_Type == "Owned" && input.Unit.Owner_Mail_ID.Email != input.Tenant.Email)
										{
											input.Agreement_Type = "";
											alert "Kindly enter the valid occupancy type";
										}
										if(input.Property != null && input.Agreement_Type == "Rent" && input.Renew_Base_Agreement == null)
										{
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
										else if(input.Property != null && input.Agreement_Type == "Lease" && input.Renew_Base_Agreement == null)
										{
											getUnit = Add_Unit[Property == input.Property && Occupancy_Type == input.Agreement_Type && Availability == "Vacant"].ID.getAll();
											input.Unit:ui.add(getUnit);
										}
						)
					}
				}

			}
			Addition_on_row_select_ma1 as "Addition on row - select main occupant"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on add row of Other_Occupants_Details
				{
					actions 
					{
						custom deluge script
						(
											if(input.Tenant != null)
										{
											row.Main_Tenant=input.Tenant;
										}
										if(input.Property != null)
										{
											row.Property=input.Property;
										}
										disable row.Property;
						)
					}
				}

			}
			Avoid_Future_Date_age_cal as "Avoid Future Date & age calculate"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on user input of Other_Occupants_Details.Date_of_Birth
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(row.Date_of_Birth >= zoho.currentdate)
										{
											row.Date_of_Birth=null;
											alert language_alert.get("zcpm.valid.DOB");
										}
										if(row.Date_of_Birth != null)
										{
											row.Age=zoho.currenttime.getYear() - row.Date_of_Birth.getYear();
										}
						)
					}
				}

			}
			Onload_subform_field_rule as "Onload - subform field rules"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Monthly_Payable;
										hide Status;
										hide Section;
										hide plain1;
										if(input.Agreement_Type == "Lease")
										{
											hide Security_Deposit;
										}
										hide Other_Occupants_Details.Property;
										if(input.Unit != null)
										{
											input.Property = input.Unit.Property;
											input.Unit_Type = input.Unit.Unit_Type;
										}
										language = thisapp.Localization.Pages();
										if((input.Property != null && input.Unit != null) || input.Renew_Base_Agreement != null)
										{
											hide Property;
											hide Unit;
											show Section;
											show plain1;
											if(input.Renew_Base_Agreement != null)
											{
												input.Unit_Type = input.Renew_Base_Agreement.Unit_Type;
												input.Property = input.Renew_Base_Agreement.Property;
												input.Unit = input.Renew_Base_Agreement.Unit;
												input.Tenant = input.Renew_Base_Agreement.Tenant;
											}
											input.plain1 = "<Style>" + thisapp.Styles_Popup.Key_Value_View() + ".zc-plain1-group.zc-addnote-fld { width: 665px; } </style><div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + input.Property.Property_Name + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + input.Unit.Unit_Name + "</td></tr>";
											if(input.Renew_Base_Agreement != null || input.Tenant != null)
											{
												hide Tenant;
												input.plain1 = input.plain1 + "<tr><td>" + language.get("zcpm.tenant.tenants") + "</td><td class='zc-prop-yellow'>" + input.Tenant.Name + "</td></tr>";
											}
											input.plain1 = input.plain1 + "</tbody></table></div></div>";
										}
										hide Other_Occupants_Details.Main_Tenant;
										disable Other_Occupants_Details.Age;
										//<tr><td>" + language.get("zcpm.agreement.Unit.Type") + "</td><td class='zc-prop-orange'>" + input.Unit_Type + "</td></tr>
						)
					}
				}

			}
			Field_rules5 as "Field rules"
			{
				type =  form
				form = Add_Block
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide No_of_Units;
					}
				}

			}
			On_Successful_Submit_incr as "On Successful Submit - increase block count"
			{
				type =  form
				form = Add_Block
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											property = Add_Property[ID == input.Property];
										property.No_of_Blocks=property.No_of_Blocks + 1;
										openUrl("#Script:page.reload","same window");
						)
					}
				}

			}
			On_Load_disable_field as "On Load - disable field"
			{
				type =  form
				form = Add_Unit
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Manager;
										if(Add_Unit.count() > 0)
										{
											show Manager;
										}
										config = User_Configuration[ID != 0];
										if(config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Manager")
										{
											input.Manager = thisapp.get_user_id();
											show Manager;
										}
										if(input.Property != null && input.Block != null)
										{
											disable Property;
											disable Block;
										}
										else if(input.Property != null)
										{
											disable Property;
											if(input.Property.Mark_it_as_single_unit_property1)
											{
												hide Block;
												input.Size_in_Sq_ft = input.Property.Size;
											}
											getBlocks = Add_Block[Property == input.Property];
											input.Block:ui.add(getBlocks.ID.getall());
										}
										else if(input.Block != null)
										{
											input.Property = input.Block.Property;
											disable Block;
										}
										current_property = input.Property;
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Manager")
										{
											fetchProperty = Add_Property[Manager.Email == zoho.loginuserid];
											input.Property:ui.add(fetchProperty.ID.getall());
											input.Property = current_property;
										}
										config = User_Configuration[ID != 0];
										if(config.What_type_of_Property_Management_app_are_you_looking_for == "Admin as a Owner")
										{
											admin = New_User[Role == "Admin"];
											input.Owner_Mail_ID = admin.ID;
											hide Owner_Mail_ID;
										}
										input.Address = input.Property.Property_Address;
						)
					}
				}

			}
			On_Load_Hide_field as "On Load - Hide field"
			{
				type =  form
				form = Add_Property
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Blocks;
										document = Documents[Property.ID == input.ID && Property != null];
										document_list = input.Documents_Document_Name;
										input.Documents_Document_Name:ui.add(document.ID.getall());
										Documents_Document_Name.select(document_list);
										if(Add_Vendor.count() == 0)
										{
											hide Property_Vendors;
										}
						)
					}
				}

			}
			Onload_field_rule as "Onload - field rule"
			{
				type =  form
				form = Add_Block
				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Property != null)
										{
											disable Property;
										}
						)
					}
				}

			}
			Input_of_property as "Input of property"
			{
				type =  form
				form = Add_Unit
				record event = on add or edit

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											if(input.Property != null)
										{
											input.Address = input.Property.Property_Address;
											getblocks = Add_Block[Property == input.Property];
											input.Block:ui.add(getblocks.ID.getall());
											language = thisapp.Localization.Alert();
											unit = Add_Unit[Property == input.Property].count();
											if(input.Property.Mark_it_as_single_unit_property1 == true && unit == 1 && input.Unit_Type == "Unit")
											{
												alert language.get("zcpm.single.unit");
												input.Property = null;
											}
										}
										else if(input.Property == null)
										{
											list = List();
											input.Block:ui.add(list);
										}
						)
					}
				}

			}
			Validation_Property as "Validation - Property"
			{
				type =  form
				form = Add_Unit
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Block != null && input.Block.Property != input.Property)
										{
											input.Block = null;
											alert language_alert.get("zcpm.valid.block");
											cancel submit;
										}
										unit = Add_Unit[Property == input.Property].count();
										if(input.Property.Mark_it_as_single_unit_property1 == true && unit == 1 && input.Unit_Type == "Unit")
										{
											alert language_alert.get("zcpm.single.unit");
											cancel submit;
										}
										property = Add_Property[ID == input.Property];
										if(property.No_of_Parking_Slots != null)
										{
											parking = Add_Unit[Property == input.Property && Unit_Type == "Parking"].count();
											if(parking == property.No_of_Parking_Slots && input.Unit_Type == "Parking")
											{
												alert "If you wish to add the parking to this property, Please Configure the Parking Count in the Property.";
												cancel submit;
											}
										}
						)
					}
