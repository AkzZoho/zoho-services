			User_input_of_Property3 as "User input of Property"
			{
				type =  form
				form = Approve_Confirmation
				record event = on add

				on user input of Property
				{
					actions 
					{
						custom deluge script
						(
											if(input.New_User.Property != input.Property || input.Property == null)
										{
											input.Decision_box = false;
											lst = List();
											input.Unit:ui.add(lst);
										}
										if(input.Property != null)
										{
											unit = Add_Unit[Property == input.Property && Owner_Approval_Status == "Approved" && Occupancy_Type != "Owned" && Availability == "Vacant" && Unit_Type == "Unit"].ID.getAll();
