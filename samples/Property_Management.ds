			Disable_fields1 as "Disable fields"
			{
				type =  form
				form = Work_Order_Payment
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Property;
										hide Unit;
										hide Work_Order;
										hide Vendor_Update;
										hide Page_Link_Name;
										if(input.Unit.Current_Tenant == null)
										{
											input.Payment_By = "Owner";
											disable Payment_By;
										}
										unit_config = Configure[Unit == input.Unit];
										default_config = Configure[Configure1 == "Default"];
										if(unit_config.count() > 0 && unit_config.Do_You_Want_Configure_Manager_Commission == "Yes" && unit_config.Category.contains("Complaint"))
										{
											input.Commission = (input.Complaint_Amount * unit_config.Complaint) / 100;
										}
										else if(default_config.count() > 0 && default_config.Do_You_Want_Configure_Manager_Commission == "Yes" && default_config.Category.contains("Complaint"))
										{
											input.Commission = (input.Complaint_Amount * default_config.Complaint) / 100;
										}
										language = thisapp.Localization.Pages();
										input.plain = thisapp.Styles_Popup.Notes_Field() + "<div class='zc-prop-notes-field'><div class='zc-prop-keyvalue-view zc-prop-with-bg'><table class='zc-prop-table'><tbody><tr><td>" + language.get("zcpm.complaint.property") + "</td><td class='zc-prop-blue'>" + input.Property.Property_Name + "</td></tr><tr><td>" + language.get("zcpm.complaint.unit") + "</td><td class='zc-prop-green'>" + input.Unit.Unit_Name + "</td></tr><tr><td>" + language.get("zcpm.vendor.update") + "</td><td>" + input.Vendor_Update + "</td></tr></tbody></table></div></div>";
						)
					}
				}

			}
			Payment_Update as "Payment Update"
			{
				type =  form
				form = Work_Order_Payment
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						complaint = Raise_a_Complaint[ID == input.Work_Order];
										complaint.Complaint_Amount=input.Complaint_Amount;
										complaint.Complaint_Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaint_Amount);
										complaint.Payment_By=input.Payment_By;
										complaint.Complaint_Status="Waiting for Payment";
										id = ID_Setup[ID != 0];
										if(complaint.Complaint_Amount > 0 && input.Payment_By == "Owner")
										{
											pay = insert into Add_Payment_Notes
											[
												Payer=complaint.Owner_Email
												Total_Amount=complaint.Complaint_Amount
												Unit=complaint.Unit
												Property=complaint.Property
												Added_User=zoho.loginuser
												Status="Unpaid"
												Payment_Type="Expense"
												Pay_For="Complaint"
												Due_Date=zoho.currentdate
												Raise_a_Complaint=complaint.ID
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaint_Amount)
											];
											bill = Add_Payment_Notes[ID == pay];
											// 	thisapp.Books_Integration.Sync_Invoice(bill.ID);
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											payfor = Pay_For_Monthly[Pay_For == "Complaints"];
											payment_details = insert into Payment_Details
											[
												Added_User=zoho.loginuser
												Pay_For=payfor.ID
												Add_Property=complaint.Property
												Add_Unit=complaint.Unit
												Amount=complaint.Complaint_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(complaint.Complaint_Amount)
												Description=complaint.Complaint_About + " Complaint"
												Add_Payment_Notes=pay
											];
											if(input.Commission > 0)
											{
												payfor_commission = Pay_For_Monthly[Pay_For == "Complaint Commissions"];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payfor_commission.ID
													Add_Property=complaint.Property
													Add_Unit=complaint.Unit
													Amount=input.Commission
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Commission)
													Description="Complaint Commissions"
													Add_Payment_Notes=pay
												];
												bill.Total_Amount=input.Complaint_Amount + input.Commission;
												bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaint_Amount + input.Commission);
											}
											// 	thisapp.Books_Integration.Sync_Invoice(bill.ID);
											thisapp.mail.SendToOwnerComplaintPaymentRequired(complaint.ID);
										}
										else if(complaint.Complaint_Amount > 0 && input.Payment_By == "Tenant")
										{
											pay = insert into Add_Payment_Notes
											[
												Payer=complaint.Tenant_Email
												Total_Amount=complaint.Complaint_Amount
												Unit=complaint.Unit
												Property=complaint.Property
												Added_User=zoho.loginuser
												Status="Unpaid"
												Payment_Type="Expense"
												Pay_For="Complaint"
												Due_Date=zoho.currentdate
												Raise_a_Complaint=complaint.ID
												Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaint_Amount)
											];
											bill = Add_Payment_Notes[ID == pay];
											bill.Billing__ID=id.Bill_No + bill.Bill_No;
											payfor = Pay_For_Monthly[Pay_For == "Complaints"];
											payment_details = insert into Payment_Details
											[
												Added_User=zoho.loginuser
												Pay_For=payfor.ID
												Add_Property=complaint.Property
												Add_Unit=complaint.Unit
												Amount=complaint.Complaint_Amount
												Amount_Display=thisapp.Currency.currencyDisplayFormat(complaint.Complaint_Amount)
												Description=complaint.Complaint_About + " Complaint"
												Add_Payment_Notes=pay
											];
											if(input.Commission > 0)
											{
												payfor_commission = Pay_For_Monthly[Pay_For == "Complaint Commissions"];
												payment_details = insert into Payment_Details
												[
													Added_User=zoho.loginuser
													Pay_For=payfor_commission.ID
													Amount=input.Commission
													Add_Property=complaint.Property
													Add_Unit=complaint.Unit
													Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Commission)
													Description="Complaint Commissions"
													Add_Payment_Notes=pay
												];
												bill.Total_Amount=input.Complaint_Amount + input.Commission;
												bill.Amount_Display=thisapp.Currency.currencyDisplayFormat(input.Complaint_Amount + input.Commission);
											}
											// 	thisapp.Books_Integration.Sync_Invoice(bill.ID);
											thisapp.mail.SendToTenantComplaintPaymentRequired(complaint.ID);
										}
										if(thisapp.Get_Logged_In_Profile() == "Administrator" && input.Page_Link_Name == "Approval")
										{
											openUrl("#Page:Approval?tab=complaints","same window");
										}
										else
										{
											openUrl("#Page:Complaints?tab=payments","same window");
										}
					)
					}
				}
			}
			Configure_Rent as "Configure Rent"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add

				on user input of Unit
				{
					actions 
					{
						custom deluge script
						(
											items = Add_Unit[ID == input.Unit];
										unit_configure = Configure[Unit == input.Unit];
										main_configure = Configure[Configure1 == "Default"];
										if(input.Agreement_Type == "Rent" && unit_configure.count() == 1)
										{
											input.Base_Rent = unit_configure.Base_Rental_Monthly_Amount;
											input.Security_Deposit = unit_configure.Security_Deposit;
										}
										else if(input.Agreement_Type == "Rent" && main_configure.count() == 1)
										{
											input.Base_Rent = main_configure.Base_Rental_Monthly_Amount;
											input.Security_Deposit = main_configure.Security_Deposit;
										}
										if(input.Agreement_Type == "Lease" && unit_configure.count() == 1)
										{
											input.Base_Lease = unit_configure.Base_Lease_Amount;
										}
										else if(input.Agreement_Type == "Lease" && main_configure.count() == 1)
										{
											input.Base_Lease = main_configure.Base_Lease_Amount;
										}
										addition_collection = Collection();
										input.Additional_Payment_Monthly.clear();
										if(main_configure.count() > 0 && unit_configure.count() == 0)
										{
											for each  main_configure_subform in main_configure.Additional_Payment_Monthly
											{
												addition_row = Tenant_Agreement.Additional_Payment_Monthly();
												addition_row.Pay_For=main_configure_subform.Pay_For;
												addition_row.Amount=main_configure_subform.Amount;
												addition_row.Amount_Display=main_configure_subform.Amount_Display;
												addition_row.Description=main_configure_subform.Description;
												addition_collection.insert(addition_row);
											}
											if(input.Agreement_Type == "Rent" && main_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && main_configure.Category.contains("Rental Monthly"))
											{
												addition_row = Tenant_Agreement.Additional_Payment_Monthly();
												payfor = Pay_For_Monthly[Pay_For == "Commission"];
												addition_row.Pay_For=payfor.ID;
												addition_row.Amount=input.Base_Rent * main_configure.Rental_Monthly / 100;
												addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
												addition_row.Description="Commission";
												addition_collection.insert(addition_row);
											}
											input.Additional_Payment_Monthly.insert(addition_collection);
											input.Agreement_Commission = main_configure.Agreement;
											input.Agreement_Commission_Display = main_configure.Agreement_Display;
										}
										else if(unit_configure.count() > 0)
										{
											for each  unit_configure_subform in unit_configure.Additional_Payment_Monthly
											{
												addition_row = Tenant_Agreement.Additional_Payment_Monthly();
												addition_row.Pay_For=unit_configure_subform.Pay_For;
												addition_row.Amount=unit_configure_subform.Amount;
												addition_row.Amount_Display=unit_configure_subform.Amount_Display;
												addition_row.Description=unit_configure_subform.Description;
												addition_collection.insert(addition_row);
											}
											if(input.Agreement_Type == "Rent" && unit_configure.Do_You_Want_Configure_Manager_Commission == "Yes" && unit_configure.Category.contains("Rental Monthly"))
											{
												addition_row = Tenant_Agreement.Additional_Payment_Monthly();
												payfor = Pay_For_Monthly[Pay_For == "Commission"];
												addition_row.Pay_For=payfor.ID;
												addition_row.Amount=input.Base_Rent * unit_configure.Rental_Monthly / 100;
												addition_row.Amount_Display=thisapp.Currency.currencyDisplayFormat(addition_row.Amount);
												addition_row.Description="Commission";
												addition_collection.insert(addition_row);
											}
											input.Additional_Payment_Monthly.insert(addition_collection);
											input.Agreement_Commission = unit_configure.Agreement;
											input.Agreement_Commission_Display = unit_configure.Agreement_Display;
										}
										unit_items = Collection();
										input.Unit_Appliancias.clear();
										for each  unit_items_subform in items.Unit_Items
										{
											addition_row1 = Tenant_Agreement.Unit_Appliancias();
											addition_row1.Items=unit_items_subform.Item;
											addition_row1.Condition_field=unit_items_subform.Condition_field;
											addition_row1.Description=unit_items_subform.Description;
											unit_items.insert(addition_row1);
										}
										input.Unit_Appliancias.insert(unit_items);
										if(input.Agreement_Type == "Rent")
										{
											input.Monthly_Payable = input.Base_Rent + input.Additional_Payment_Monthly.sum(Amount);
										}
										else if(input.Agreement_Type == "Lease")
										{
											input.Monthly_Payable = input.Additional_Payment_Monthly.sum(Amount);
										}
										agreement = Tenant_Agreement[Unit == input.Unit && Status == "Owner Approved"];
										language = thisapp.Localization.Alert();
										if(agreement.count() > 0)
										{
											alert language.get("zcpm.agreement.unit.alert");
										}
						)
					}
				}

			}
			On_Success_Submit6 as "On Success Submit"
			{
				type =  form
				form = Inspection_Form
				record event = on add or edit
					status = inactive

				on success
				{
					actions 
