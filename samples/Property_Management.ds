			OnLoad12 as "OnLoad"
			{
				type =  form
				form = Raise_a_Complaint
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											clear Unit;
										hide plain;
										login_profile = thisapp.permissions.loginUserProfile();
										if(login_profile == "Tenant")
										{
											unit = Add_Unit[Current_Tenant.Email == zoho.loginuserid];
											input.Property:ui.add(unit.Property.getall());
											input.Unit:ui.add(unit.ID.getall());
											input.Tenant_Email = thisapp.get_user_id();
											// incase tenant have one unit auto select
											if(unit.count() == 1)
											{
												input.Property = unit.Property;
												input.Unit = unit.ID;
												input.Location = unit.Property.Location;
											}
										}
										else if(login_profile == "Manager")
										{
											unit_manager = Add_Property[Units.Manager == thisapp.get_user_id()];
											input.Property:ui.add(unit_manager.ID.getall());
										}
										else if(login_profile == "Owner")
										{
											unit_owner = Add_Unit[Owner_Mail_ID.Email == zoho.loginuserid];
											input.Property:ui.add(unit_owner.Property.getall());
										}
						)
					}
				}

			}
