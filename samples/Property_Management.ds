\t\t\t}\n\t\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(unit.Availability == &quot;Sold Out&quot;)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-flt-right zc-prop-clearfix&apos;&gt;\n\t\t\t\t&lt;a href=&apos;#Page:Properties?action=saleedit&amp;rec_id=&lt;%=unit.ID%&gt;&amp;tab=&lt;%=input.tab%&gt;&apos; class=&apos;zc-outline-primary-btn&apos;&gt; \n\t\t\t\t\t\t&lt;i class=&apos;zc-li-outline ui-1-edit-72&apos;&gt;&lt;\/i&gt; \n\t\t\t\t\t\t&lt;span&gt; &lt;%=Common_language.get(&quot;zcpm.common.edit&quot;)%&gt; &lt;\/span&gt; \n\t\t\t\t&lt;\/a&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\t\tprop_amenities = if(unit.Property.Amenities.size() &gt; 0,unit.Property.Amenities.Amenities,&quot;-&quot;);\n\t\t\t%&gt;\n&lt;div class=&apos;zc-prop-page-content&apos;&gt;\n\t\t&lt;%=thisapp.Components.Property_Info(img_src,unit.Property.Property_Type,unit.Owner_Mail_ID.Email,unit.Property.Location.Location,prop_amenities,unit.Address,unit.Size_in_Sq_ft)%&gt;\n            &lt;div class=&apos;zc-prop-card zc-prop-main-info zc-prop-tab-wrapper&apos;&gt;\n\t\t\t\t&lt;div class=&apos;zc-prop-horizontal-tabpanel&apos;&gt;\n&lt;%\n\t\t\tif(unit.Occupancy_Type == &quot;Sale&quot;)\n\t\t\t{\n\t\t\t\ttab_map = thisapp.Page.Get_Tab1(&quot;Units_Detail_View1&quot;);\n\t\t\t\ttab_keys = tab_map.keys();\n\t\t\t\tinput.subtab = if(input.subtab == &quot;&quot; || input.subtab == null,tab_keys.get(0),input.subtab);\n\t\t\t\tinput.subtab = if(!tab_keys.contains(input.subtab),tab_keys.get(0),input.subtab);\n\t\t\t\tcurrent_params_values = if(!input.action.isEmpty() || input.action != null,&quot;&amp;action=&quot; + input.action,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(!input.rec_id.isEmpty() || input.rec_id != null,&quot;&amp;rec_id=&quot; + input.rec_id,&quot;&quot;);\n\t\t\t\tcurrent_params_values = current_params_values + if(input.tab.isEmpty(),&quot;&amp;tab=&quot; + tab_keys.get(0),&quot;&amp;tab=&quot; + inp