				"Cancel & Unpaid"
				{
				condition = (Add_Payment_Notes.Status == "Cancel" || Add_Payment_Notes.Status == "Unpaid")
				fields = [Add_Payment_Notes.Status]
				format = "color:#fe455d;"
				}
				"Paid & Received"
				{
				condition = (Add_Payment_Notes.Status == "Paid" || Add_Payment_Notes.Status == "Received")
				fields = [Add_Payment_Notes.Status]
				format = "color:#187822;"
				}
			)
		}
