			Approve_Tenant_Request_Ma1 as "Approve - Tenant Request Manager"
			{
				type =  functions
				form = Tenant_Agreement
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						input.Status = "Approved";
										getUnit = Add_Unit[ID == input.Unit];
										getUnit.Current_Tenant=input.Tenant;
										getUnit.Availability="Occupied";
										for each  getTenantAgreements in Tenant_Agreement[Unit == getUnit.ID && ID != input.ID]
										{
											getTenantAgreements.Status="Rejected";
										}
					)
					}
				}
			}
