		list Unit_List_View
		{
			displayName = "Unit List View"
			show all rows from Add_Unit    
			(
				Unit_Name as "Unit Name"
				Size_in_Sq_ft as "Size (in Sq. ft)"
				Bed_Rooms as "Bed Rooms"
				Rest_Rooms as "Rest Rooms"
				Amenities
				Availability
				Owner_Approval_Status as "Approval Status"
				Owner_Mail_ID as "Owner"
				Occupancy_Type as "Occupancy Type"
				Unit_Image as "Unit Image"
				Block
				Property
				Address 
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				Property.ID
				Owner_Mail_ID.Email
				Manager.Email
				Manager
				Owner_Mail_ID.ID
				Manager.ID
			)
			custom actions
			(
				"Detail View - Unit_List_View"
				(
	  			workflow = Detail_View_Unit_List_Vie
				)
			)
			conditional formatting
			(
				"Approve"
				{
				condition = (Owner_Approval_Status == "Approved")
				fields = [Owner_Approval_Status]
				format = "color:#04a267;"
				}
				"Reject"
				{
				condition = (Owner_Approval_Status == "Rejected")
				fields = [Owner_Approval_Status]
				format = "color:#fe455d;"
				}
				"Requested"
				{
				condition = (Owner_Approval_Status == "Requested")
				fields = [Owner_Approval_Status]
				format = "color:#b8770d;"
				}
				"New Unit"
				{
				condition = (Availability == "New Unit")
				fields = [Availability]
				format = "color:#b8770d;"
				}
				"Vacant"
				{
				condition = (Availability == "Vacant")
				fields = [Availability]
				format = "color:#5051f9;"
				}
				"Occupied"
				{
				condition = (Availability == "Occupied")
				fields = [Availability]
				format = "color:#f48c06;"
				}
				"Rejected Unit"
				{
				condition = (Availability == "Rejected Unit")
				fields = [Availability]
				format = "color:#fe455d;"
				}
			)
		}
