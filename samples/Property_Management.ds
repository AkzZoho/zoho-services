			On_Success_Submit10 as "On Success Submit"
			{
				type =  form
				form = Pay_Popup_Form
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											bill = Add_Payment_Notes[ID == input.Billing_ID];
										bill.Status="Paid";
										bill.Payment_Date=zoho.currentdate;
										bill.Bill=input.Bill;
