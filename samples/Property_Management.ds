				 map mail.getMessageVariables(int et_ID, string currentMsg, string currentSubject)
                 {
                 	oldVarList = List();
                 	currentVarList = List();
                 	template = Email_Template[ID == et_ID];
                 	temp_msg = template.Message;
                 	no_variables = temp_msg.getOccurenceCount("${");
                 	no_variables_cur_msg = currentMsg.getOccurenceCount("${");
                 	lef_pad = "".leftpad(no_variables - 1);
                 	li_temp = lef_pad.toList(" ");
                 	for each  rec in li_temp
                 	{
                 		oldVal = temp_msg.subString(temp_msg.indexOf("${"),temp_msg.indexOf("}") + 1);
                 		oldVarList.add(oldVal);
                 		temp_msg = temp_msg.removeFirstOccurence(oldVal);
                 		if(currentMsg.contains(oldVal))
                 		{
                 			currentVarList.add(oldVal);
                 		}
                 	}
                 	variableAccurence = if(oldVarList == currentVarList && no_variables == no_variables_cur_msg,true,false);
                 	temp_subject = template.Subject_field;
                 	if(temp_subject.contains("${") && variableAccurence == true)
                 	{
                 		oldSubVarList = List();
                 		curSubVarList = List();
                 		no_variables_Insub = temp_subject.getOccurenceCount("${");
                 		no_variables_cur_sub = currentSubject.getOccurenceCount("${");
                 		sub_lef_pad = "".leftpad(no_variables_Insub - 1);
                 		li_subtemp = sub_lef_pad.toList(" ");
                 		for each  rec in li_subtemp
                 		{
                 			oldsubVar = temp_subject.subString(temp_subject.indexOf("${"),temp_subject.indexOf("}") + 1);
                 			oldSubVarList.add(oldsubVar);
                 			temp_msg = temp_subject.removeFirstOccurence(oldsubVar);
                 			if(currentSubject.contains(oldsubVar))
                 			{
                 				curSubVarList.add(oldsubVar);
                 			}
                 		}
                 		variableAccurence = if(oldSubVarList == curSubVarList && no_variables_Insub == no_variables_cur_sub,true,false);
                 		oldSubVarList.addAll(oldVarList);
                 		oldVarList = oldSubVarList;
                 	}
                 	return {"variables":oldVarList,"variableEdited":variableAccurence};
                 }
				 list mail.getToEmaillDs(string role)
                 {
                 	to_Mail_IDs = New_User[Role = role && Status == "Active"].Email.getAll();
                 	if(to_Mail_IDs.size() == 0)
                 	{
                 		to_Mail_IDs = New_User[Role == "Admin" && Status == "Active"].Email.getAll();
                 	}
                 	return to_Mail_IDs;
                 }
				 void mail.sendMailTask(list to_Email_IDs, string mail_subject, string mail_message)
                 {
                 	sendmail
                 	[
                 		from :zoho.adminuserid
                 		to :to_Email_IDs
                 		subject :mail_subject
                 		message :mail_message
                 	]
                 }
				 void mail.SendTenantApproved(int rec_id)
                 {
                 	new_user = New_User[ID == input.rec_id];
                 	mail_template = Email_Template[Template_Name == "Tenant Profile Approved" && Send_To == "Tenant" && Enable_This_Mail_Notification == true];
                 	if(mail_template.count() != 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("${Tenant_Name}",new_user.Name.first_name + " " + new_user.Name.last_name,true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		thisapp.mail.sendMailTask(new_user.Email.toList(),mail_template.Subject_field,msg);
                 	}
                 }
				 void mail.SendTenantPaymentDueDateReminder(int payment_rec_id)
                 {
                 	payment = Add_Payment_Notes[ID == input.payment_rec_id];
                 	general = General[ID != 0];
                 	mail_template = Email_Template[Template_Name == "Payments Due Date Reminder to all" && Send_To == "Property Management" && Enable_This_Mail_Notification == true];
                 	getConfig = Configure[Unit == payment.Unit];
                 	getDefaultConfig = Configure[Configure1 == "Default"];
                 	due_days = if(getConfig.count() == 1,getConfig.Grace_Days_For_Monthly_Payment,getDefaultConfig.Grace_Days_For_Monthly_Payment);
                 	if(mail_template.count() != 0)
                 	{
                 		msg = mail_template.Message;
                 		msg = msg.replaceAll("${Tenant_Name}",payment.Payer.Name.first_name + " " + payment.Payer.Name.last_name,true);
                 		msg = msg.replaceAll("${Amount}",thisapp.Currency.numberFormatAccurate(payment.Total_Amount,general.Currency),true);
                 		msg = msg.replaceAll("${Due_Date}",if(payment.Due_Date == null,"-",payment.Due_Date.toString()),true);
                 		msg = msg.replaceAll("${Penalty_Date}",payment.Due_Date.addDay(due_days).toString(),true);
                 		msg = msg.replaceAll("${Description}",payment.Pay_For,true);
                 		msg = msg.replaceAll("${Admin_User}",zoho.adminuser,true);
                 		thisapp.mail.sendMailTask(payment.Payer.toList(),mail_template.Subject_field,msg);
                 	}
                 }
