			Onvalidate_Data_s as "Onvalidate  - Data's"
			{
				type =  form
				form = Tenant_Agreement
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											language_alert = thisapp.Localization.Alert();
										if(input.Agreement_Type == "Rent" && input.Base_Rent == null || input.Base_Rent < 0)
										{
											alert language_alert.get("zcpm.valid.base.rent");
											cancel submit;
										}
										else if(input.Agreement_Type == "Lease" && input.Base_Lease == null || input.Start_Date == null || input.End_Date == null)
										{
											alert language_alert.get("zcpm.valid.lease.detail");
											cancel submit;
										}
										if(input.Agreement_Type == "Rent" && input.Security_Deposit <= 0)
										{
											alert language_alert.get("zcpm.valid.security.deposit");
											cancel submit;
										}
										if(input.End_Date < input.Next_Pay_Date)
										{
											alert language_alert.get("zcpm.valid.next.payment.date");
											cancel submit;
										}
						)
					}
				}

			}
			On_load_Auto_fill_data as "On load - Auto fill data"
			{
				type =  form
				form = Vacate_Request
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											login_profile = thisapp.permissions.loginUserProfile();
										if(input.Unit == null && login_profile == "Tenant" && input.Action_field == "Request_Page")
										{
											show Unit;
											getTenant = New_User[Email == zoho.loginuserid && Role == "Tenant"];
											agreement = Tenant_Agreement[Unit.Current_Tenant == thisapp.get_user_id() && Agreement_Status == "Active"];
											input.Unit:ui.add(agreement.Unit.ID.getall());
											if(getTenant.count() > 0 && agreement.count() == 1)
											{
												clear Unit;
												input.Tenant = getTenant.ID;
												input.Unit = agreement.Unit.ID;
												input.Property = agreement.Property;
											}
											show Property;
											show Unit;
											property = Add_Unit[Current_Tenant == thisapp.get_user_id()].Property.ID.getAll();
											input.Property:ui.add(property);
										}
						)
					}
				}

			}
