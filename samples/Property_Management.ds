	  			workflow = Unit_Details_View_Units
				show action in edit record menu = true
				)
				"Edit Unit"
				(
	  			workflow = Edit_Unit
				show action in edit record menu = true
				)
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		bgColor = '#FFFFFF'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	width = '400px'\n	height = '250px'\n	type = 'field'\n	value = 'Unit_Image'\n	cornerRadius = '0px'\n/>\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '20px'\n	paddingLeft = '17px'\n	paddingRight = '17px'\n	paddingBottom = '17px'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n		width = '100%'\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	color = '#000000'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n    lineHeight = '23'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Unit_Name'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '10px'\n	paddingLeft = '17px'\n	paddingRight = '17px'\n	paddingBottom = '17px'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n		width = '100%'\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	color = '#000000'\n	size = '16px'\n	type = 'field'\n\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n    lineHeight = '23'\n    numOfLines = '3'\n\n\n\n\n\n	  value = 'Property.Property_Address'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
