		{
			displayname = "Audit Review"
			icon = "design-window-paragraph"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n\n.searchContainer {\n    height: 90px;\n    overflow: hidden;\n}\n      .zc-opjs-fwh {\n        width: 100%;\n        height: 89vh;\n    }\n\n    .zc-opjs-clearfix {\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-flt-left {\n        float: left;\n    }\n\n    .zc-opjs-vertical-tabpanel {}\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead,\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabbody {\n        height: 85vh;\n        overflow: auto;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead {\n        width: 250px;\n        padding: 20px;\n        border-right: 1px solid #EBECF0;\n        margin: 0px;\n        box-sizing: border-box;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabbody {\n        width: 100%;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li {\n        list-style-type: none;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a {\n        width: 100%;\n        display: block;\n        border-radius: 4px;\n        padding: 10px 12px;\n        margin: 2px 0px;\n        box-sizing: border-box;\n        font-size: 14px;\n        font-weight: 400;\n        line-height: 21px;\n        color: #131635;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a:hover {\n        color: var(--theme_brand_color);\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a.zc-opjs-vertical-tabactive {\n        background-color: var(--left_pane_section_selected);\n        font-weight: 600;\n        color: var(--theme_brand_color);\n    }\n\t\n\n\t\/* \thorizontal style  *\/\n\t\n\t  .zc-opjs-horizontal-tabpanel {\n        width: 100%;\n        height: 100%;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead {\n        height: 51px;\n        border-bottom: 1px solid #EBECF0;\n        padding: 0px;\n        margin: 0px;\n        box-sizing: border-box;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabbody {\n        height: 100%;\n        overflow: auto;\n    }\n\t\n\t.zc-opjs-horizontal-tabbody {\n        height: 100vh !important;\n       \n    }\n\t\n\t\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li {\n        list-style-type: none;\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a {\n        font-size: 15px;\n        font-weight: 500;\n        line-height: 18px;\n        color: #666D79;\n        margin: 0px 16px -1px 16px;\n        padding: 16px 0px;\n        border-bottom: 1px solid transparent;\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a:hover {\n        color: var(--theme_brand_color);\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a.zc-opjs-horizontal-tabactive {\n        border-bottom: 1px solid var(--theme_brand_color);\n        color: var(--theme_brand_color);\n    }\n\t\n\t\/*---------------style override-------------------*\/\n\t\n\n.reportfullwidth.zc-report-no-header {\n    border-radius: 0px !important;\n}\n\ndiv#viewheadername {\n    visibility: hidden;\n}\n\n.container-fluid{\n\tborder : none !important; \n}\n\n.dashboard {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n      gap: 20px;\n      max-width: 1200px;\n      margin: auto;\n\t  padding:20px;\n    }\n\n    .card {\n      background-color: white;\n      border-radius: 10px;\n    box-shadow: rgba(0, 0, 0, 0.05) 0px 6px 24px 0px, rgba(0, 0, 0, 0.08) 0px 0px 0px 1px;\n      padding: 20px;\n    }\n\n    .card-label {\n      font-size: 14px;\n      color: #6b7280;\n      margin-bottom: 5px;\n    }\n\n    .card-value {\n      font-size: 20px;\n      font-weight: bold;\n      color: #111827;\n\t   color: var(--theme_brand_color);\n    }\n\n\tlabel.form-label.decision-box-label{ \n\tposition: absolute;\n\tleft: -20px; \n\tfont: bold 11px Arial;\n\ttext-decoration: none;\n\tbackground-color: var(--left_pane_section_selected);\n\tcolor: var(--theme_brand_color);\n\tpadding: 10px !important;  \n\tborder: 1.5px solid var(--theme_brand_color);\n\tborder-radius: .5rem !important; \n\t}\n\t\n\n&lt;\/style&gt;\n\n&lt;div class=&quot;zc-opjs-vertical-tabpanel zc-opjs-clearfix zc-opjs-fwh&quot;&gt;\n\n\n&lt;%=thisapp.htmlComponents.SplitView(input.tab,input.search)%&gt;\n\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
			script
			{
				/* Write your script logic here. You can assign values to the page variables you've created in the previous tab. Enter 'input.' to list the created page variables. */
				if(input.tab == null)
				{
					input.tab = 1;
				}
			}
		}
	}
