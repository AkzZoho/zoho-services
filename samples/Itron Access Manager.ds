	section Domain
	{
		icon = "tech-desktop"
		form Domain
		{
			success message = "Data Added Successfully!"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Type_field
			(
				type = picklist
				displayname = "Type"
				maxchar = 100
				values = {"Microsoft AD","openLDAP"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			DC_Name
			(
    			type = text
				displayname = "DC Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Domain_Name
			(
    			type = text
				displayname = "Domain Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Associated_Groups
			(
				type = grid
				displayname = "Associated Groups"
				values  = Group.ID
    			bidirectional = Domain
	 			row = 2
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "ui-1-bold-add"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	section Group
	{
		icon = "tech-desktop"
		form Group
		{
			success message = "Data Added Successfully!"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Domain
