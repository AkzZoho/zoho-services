		page Settings(int settings_tab, int user_tab)
		{
			displayname = "Settings"
			icon = "design-window-paragraph"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet1' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1()\ncontent\n&lt;%{\n\ttab0 = &quot;null&quot;;\n\ttab1 = &quot;null&quot;;\n\ttab2 = &quot;null&quot;;\n\ttab3 = &quot;null&quot;;\n\ttab4 = &quot;null&quot;;\n\ttab5 = &quot;null&quot;;\n\ttab6 = &quot;null&quot;;\n\ttab7 = &quot;null&quot;;\n\ttab8 = &quot;null&quot;;\n\ttab9 = &quot;null&quot;;\n\ttab10 = &quot;null&quot;;\n\tif(input.settings_tab == 0)\n\t{\n\t\ttab0 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 1)\n\t{\n\t\ttab1 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 2)\n\t{\n\t\ttab2 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 3)\n\t{\n\t\ttab3 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 4)\n\t{\n\t\ttab4 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 5)\n\t{\n\t\ttab5 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 6)\n\t{\n\t\ttab6 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 7)\n\t{\n\t\ttab7 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 8)\n\t{\n\t\ttab8 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 9)\n\t{\n\t\ttab9 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\telse if(input.settings_tab == 10)\n\t{\n\t\ttab10 = &quot;zc-opjs-vertical-tabactive&quot;;\n\t}\n\t%&gt;\n&lt;style&gt;\n      .zc-opjs-fwh {\n        width: 100%;\n        height: 89vh;\n    }\n\n    .zc-opjs-clearfix {\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-flt-left {\n        float: left;\n    }\n\n    .zc-opjs-vertical-tabpanel {}\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead,\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabbody {\n        height: 85vh;\n        overflow: auto;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead {\n        width: 250px;\n        padding: 20px;\n        border-right: 1px solid #EBECF0;\n        margin: 0px;\n        box-sizing: border-box;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabbody {\n        width: calc(100% - 250px);\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li {\n        list-style-type: none;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a {\n        width: 100%;\n        display: block;\n        border-radius: 4px;\n        padding: 10px 12px;\n        margin: 2px 0px;\n        box-sizing: border-box;\n        font-size: 14px;\n        font-weight: 400;\n        line-height: 21px;\n        color: #131635;\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a:hover {\n        color: var(--theme_brand_color);\n    }\n\n    .zc-opjs-vertical-tabpanel .zc-opjs-vertical-tabhead li a.zc-opjs-vertical-tabactive {\n        background-color: var(--left_pane_section_selected);\n        font-weight: 600;\n        color: var(--theme_brand_color);\n    }\n\t\n\n\t\/* \thorizontal style  *\/\n\t\n\t  .zc-opjs-horizontal-tabpanel {\n        width: 100%;\n        height: 100%;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead {\n        height: 51px;\n        border-bottom: 1px solid #EBECF0;\n        padding: 0px;\n        margin: 0px;\n        box-sizing: border-box;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabbody {\n        height: 100%;\n        overflow: auto;\n    }\n\t\n\t.zc-opjs-horizontal-tabbody {\n        height: 100vh !important;\n       \n    }\n\t\n\t\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li {\n        list-style-type: none;\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a {\n        font-size: 15px;\n        font-weight: 500;\n        line-height: 18px;\n        color: #666D79;\n        margin: 0px 16px -1px 16px;\n        padding: 16px 0px;\n        border-bottom: 1px solid transparent;\n        display: inline-block;\n        vertical-align: top;\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a:hover {\n        color: var(--theme_brand_color);\n    }\n\n    .zc-opjs-horizontal-tabpanel .zc-opjs-horizontal-tabhead li a.zc-opjs-horizontal-tabactive {\n        border-bottom: 1px solid var(--theme_brand_color);\n        color: var(--theme_brand_color);\n    }\n\t\n\t\/*---------------style override-------------------*\/\n\t\n\n.reportfullwidth.zc-report-no-header {\n    border-radius: 0px !important;\n}\n\ndiv#viewheadername {\n    visibility: hidden;\n}\n\n.divEmbedContainer{\n\t    height: 89vh !important;\n \t\toverflow:hidden !important;\n}\n\n.divEmbedContainer&gt;div{\n\/\/ \toverflow:scroll !important;\n}\n\n\n\n\t\n&lt;\/style&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabpanel zc-opjs-clearfix zc-opjs-fwh&quot;&gt;\n    &lt;ul class=&quot;zc-opjs-vertical-tabhead zc-opjs-flt-left&quot;&gt;\n\t    &lt;li&gt; &lt;a class=&lt;%=tab0%&gt; href=&quot;#Page:Settings?settings_tab=0&quot;&gt;Departments&lt;\/a&gt; &lt;\/li&gt;\n        &lt;li&gt; &lt;a class=&lt;%=tab1%&gt; href=&quot;#Page:Settings?settings_tab=1&quot;&gt;Domains &lt;\/a&gt; &lt;\/li&gt;\n        &lt;li&gt; &lt;a class=&lt;%=tab2%&gt; href=&quot;#Page:Settings?settings_tab=2&quot;&gt;Groups&lt;\/a&gt; &lt;\/li&gt;\n        &lt;li&gt; &lt;a class=&lt;%=tab3%&gt; href=&quot;#Page:Settings?settings_tab=3&quot;&gt;Users&lt;\/a&gt; &lt;\/li&gt;\n\t\t&lt;li&gt; &lt;a class=&lt;%=tab4%&gt; href=&quot;#Page:Settings?settings_tab=4&quot;&gt;Mail Template&lt;\/a&gt; &lt;\/li&gt;\n\t\t\n\t\n    &lt;\/ul&gt;\n&lt;%\n\tif(input.settings_tab == 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Department_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 1)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Domain_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 2)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Group_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 3)\n\t{\n\t\t%&gt;\n&lt;%=thisapp.htmlComponents.SplitView_Users(input.user_tab)%&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 4)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Email_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 5)\n\t{\n\t\t%&gt;\n\/\/&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Email_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 6)\n\t{\n\t\t%&gt;\n\/\/&lt;%=thisapp.configComponents.PAnPSA(input.panpsa_tab)%&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 7)\n\t{\n\t\t%&gt;\n\/\/&lt;%=thisapp.configComponents.course(input.course_tab)%&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 8)\n\t{\n\t\t%&gt;\n\/\/&lt;%=thisapp.configComponents.hr(input.hr_tab)%&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 9)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zc-opjs-vertical-tabbody zc-opjs-flt-left&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Benifit_Document_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.settings_tab == 10)\n\t{\n\t\t%&gt;\n\/\/&lt;%=thisapp.configComponents.keys(input.key_tab)%&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
			script
			{
				/* Write your script logic here. You can assign values to the page variables you've created in the previous tab. Enter 'input.' to list the created page variables. */
				if(input.settings_tab == null)
				{
					input.settings_tab = 0;
				}
				if(input.user_tab == null)
				{
					input.user_tab = 1;
				}
			}
		}
