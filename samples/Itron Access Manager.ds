												fetRec.Rejection_Comment=input.Reason;
												fetRec.Audit_Date=zoho.currentdate;
											}
										}
										else
										{
											fetUser = Users_Access[ID == input.Users];
											fetUser.Rejected=true;
											fetUser.Rejection_Comment=input.Reason;
											fetUser.Audit_Date=zoho.currentdate;
										}
										openUrl("#Script:page.parent.refresh ","parent window");
					)
					}
				}
