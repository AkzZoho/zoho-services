				 void Utils.fetchAllGroups(int recid)
                 {
                 	fetDomain = Domain[ID == recid];
                 	response = invokeurl
                 	[
                 		url :thisapp.Utils.admpAppUrl(false) + "RestAPI/SearchGroup?domainName=" + fetDomain.Domain_Name + "&AuthToken=" + thisapp.Utils.admpAppUrl(true) + "&searchText=&PRODUCT_NAME=MODULE&isPrimaryGroup=false&RANGE=100&FROM_INDEX=1"
                 		type :GET
                 	];
                 	groupList = response.toList();
                 	for each  rec in groupList
                 	{
                 		fetchGrp = Group[Group_Name = rec.get("GROUP_NAME") && Domain == fetDomain.ID];
                 		if(fetchGrp.count() == 0)
                 		{
                 			insert into Group
                 			[
                 				Added_User=zoho.loginuser
                 				Domain=fetDomain.ID
                 				Group_Name=rec.get("GROUP_NAME")
                 				Active=true
                 			]
                 		}
                 	}
                 }
				 void Utils.fetchAllUsers(int recid)
                 {
                 	fetGroup = Group[ID == recid];
                 	response = invokeurl
                 	[
                 		url :thisapp.Utils.admpAppUrl(false) + "RestAPI/ListGroupMembers?domainName=mickeyadfs.com&AuthToken=" + thisapp.Utils.admpAppUrl(true) + "&inputFormat=[{\"sAMAccountName\":\"" + fetGroup.Group_Name + "\"}]&PRODUCT_NAME=MODULE&refresh=true"
                 		type :GET
                 	];
                 	if(response.toList().get(0).get("Members").get("Users") != null)
                 	{
                 		respList = response.toList().get(0).get("Members").get("Users").toList();
                 		userName = List();
                 		for each  rec in respList
                 		{
                 			userName.add(rec.get("sAMAccountName"));
                 		}
                 		for each  rec in userName
                 		{
                 			fetUser = Users_Access[Name == rec && Archive == false];
                 			response2 = invokeurl
                 			[
                 				url :thisapp.Utils.admpAppUrl(false) + "RestAPI/SearchUser?domainName=mickeyadfs.com&AuthToken=" + thisapp.Utils.admpAppUrl(true) + "&range=1&startIndex=1&filter=(sAMAccountName:equal:" + rec + ")"
                 				type :GET
                 			];
                 			userDetails = response2.get("UsersList").toList().get(0);
                 			samAccName = userDetails.get("SAM_ACCOUNT_NAME");
                 			expDate = userDetails.get("ACCOUNT_EXPIRY_DATE");
                 			emailAdd = userDetails.get("EMAIL_ADDRESS");
                 			lastLogin = userDetails.get("LAST_LOGON_TIME");
                 			fetchUserProfile = User_Profile[Email == emailAdd && Group == fetGroup.ID];
                 			if(fetchUserProfile.count() > 0)
                 			{
                 				insert into Users_Access
                 				[
                 					Added_User=zoho.loginuser
                 					Account_Expiration_Date=expDate
                 					Domain=fetGroup.Domain
                 					Type_field=fetGroup.Domain.Type_field
                 					Department=fetGroup.Department
                 					Email1=emailAdd
                 					Group=fetGroup.ID
                 					Department=fetGroup.Department
                 					Last_Logon=lastLogin
                 					Name=samAccName
                 					Sync_Date=zoho.currentdate
                 					User_Profile=fetchUserProfile.ID
                 				]
                 			}
                 			else
                 			{
                 				userProfileID = insert into User_Profile
                 				[
                 					Added_User=zoho.loginuser
                 					Email=emailAdd
                 					Group=fetGroup.ID
                 				];
                 				insert into Users_Access
                 				[
                 					Added_User=zoho.loginuser
                 					Account_Expiration_Date=expDate
                 					Domain=fetGroup.Domain
                 					Type_field=fetGroup.Domain.Type_field
                 					Department=fetGroup.Department
                 					Email1=emailAdd
                 					Group=fetGroup.ID
                 					Department=fetGroup.Department
                 					Last_Logon=lastLogin
                 					Name=samAccName
                 					Sync_Date=zoho.currentdate
                 					User_Profile=userProfileID
                 				]
                 			}
                 		}
                 	}
                 }
				 bool Utils.removeUserFromGroup(string userName, string groupName)
                 {
                 	response = invokeurl
                 	[
                 		url :thisapp.Utils.admpAppUrl(false) + "RestAPI/RemoveUsersFromGroup?domainName=mickeyadfs.com&AuthToken=" + thisapp.Utils.admpAppUrl(true) + "&inputFormat=[{\"sAMAccountName\":\"" + userName + "\"}]&isRemoveFromAllGroup=false&removeGroup=[" + groupName + "]&PRODUCT_NAME=MODULE)"
                 		type :GET
                 	];
                 	if(response.toList().get(0).toMap().get("status") == 1)
                 	{
                 		return true;
                 	}
                 	return false;
                 }
				 string Utils.returnUserDept()
                 {
                 	fetUser = Audit_Users[Email == zoho.loginuserid];
                 	return fetUser.ID;
                 }
				 void bulkreject(Users_Access usr)
                 {
                 	userlist = List();
                 	for each  rec in usr
                 	{
                 		userlist.add(rec.ID);
                 	}
                 	openUrl("#Form:Rejection_Reason?all_users=true&all_users1=" + userlist,"popup window","height=<height>,width=<width>");
                 }
			 }
