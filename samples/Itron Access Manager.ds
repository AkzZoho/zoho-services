	section Users
	{
		icon = "users-2-a-add"
		list openLDAP_Users
		{
			displayName = "openLDAP Users"
   			hide = true
			show all rows from Users_Access  [Type_field == "openLDAP" && Archive == false && Rejected == true]  
			(
				Name
				Type_field as "Type"
				custom action "Reject "
				(
	  			workflow = Disassociate_User_AD
				show action in edit record menu = true
				column header = "Reject "
				)
				custom action "Disable User"
				(
	  			workflow = disable_user_openLDAP
				show action in edit record menu = true
				column header = "Disable User"
				confirmation before execution
				(
					message for individual record = "Would you like to disable ${Name} profile ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Group.Group_Name as "Group Name"
				custom action "Disassociate"
				(
	  			workflow = Disassociate_User_openLDA
				show action in edit record menu = true
				column header = "Disassociate"
				confirmation before execution
				(
					message for individual record = "Would you like to disassociate ${Name} from the group : ${Group.Group_Name}?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Rejection_Comment as "Rejection Comment"
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
						layout type = -1
						fields
						(
							Name
							Type_field as "Type"
							"Disassociate"
							"Disable User"
							Rejection_Comment as "Rejection Comment"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
					record
					(
						Edit   	   
						Duplicate   	   
						Delete   	   
    				)
    			)
    			action
    			(
					on click
					(
						View Record   	   
    				)
					on right click
					(
						Edit   	   
						Delete   	   
						Duplicate   	   
						View Record   	   
    				)
     			)
			)
			detailview
			(
				layout
				(
		 			type = 1
					datablock1
					(
						layout type = -2
						fields
						(
							Name
							Type_field as "Type"
						)
					)
				)
				menu
    			(
    	 			header
    	 			(
    		 			Edit 
    		 			Duplicate 
    		 			Delete 
    	 			)
    			)
			)
		}
		default list AD_Users
		{
			displayName = "AD Users"
   			hide = true
			show all rows from Users_Access  [Type_field == "Microsoft AD" && Archive == false && Rejected == true]  
			(
				Name
				Type_field as "Type"
				custom action "Disassociate"
				(
	  			workflow = Disassociate_User_AD
				show action in edit record menu = true
				column header = "Disassociate"
				confirmation before execution
				(
					message for individual record = "Would you like to disassociate ${1} from the group : ${2}  ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Rejected
				Archive
				Domain
				Account_Expiration_Date as "Account Expiration Date"
