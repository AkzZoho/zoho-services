			run_script_initate_sync as "run script - initate sync"
			{
				type =  form
				form = Search
				record event = on add

				on user input of Initiate_Sync
				{
					actions 
					{
						custom deluge script
						(
											if(Initiate_Sync == true)
										{
											input.Initiate_Sync = false;
											fetSE = Scheduled_Execution_1[Initiated_By == zoho.loginuserid && completed == false];
											if(fetSE.count() > 0)
											{
												openUrl("#Form:Popup_Alert?plain=Please wait till the existing sync is completed.","popup window","height=<height>,width=<width>");
											}
											else
											{
												openUrl("#Form:sync_modal?tab=" + input.tab + "&Department=" + input.Department,"popup window","height=<height>,width=<width>");
											}
										}
						)
					}
				}

			}
