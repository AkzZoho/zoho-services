		list Auditor_AD
		{
			displayName = "Auditor AD"
   			hide = true
			show all rows from Users_Access  [Type_field == "Microsoft AD" && Archive == false && Rejected == false && Formula.contains(thisapp.Utils.returnUserDept())]  
			(
				Name
				Email1 as "Email"
				Type_field as "Type"
				Last_Logon as "Last Logon"
				Account_Expiration_Date as "Account Expiration Date"
				Domain
				Rejected
				Archive
				custom action "Accept"
				(
	  			workflow = Common_accept
				show action in edit record menu = true
				column header = "Accept"
				confirmation before execution
				(
					message for individual record = "Would you like to approve the continued access for the user (${Name}) ?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Reject"
				(
	  			workflow = Common_reject
				show action in edit record menu = true
				column header = "Reject"
				)
				Group
				Department
			)
			options
			(
				icon = "design-bullet-list-67"
	 		)
			custom actions
			(
				"Accept All"
				(
	  			workflow = bulk_accept_AD1
				show action in view header = true
				show action in edit record menu = true
				confirmation before execution
				(
					message for multiple records = "Would you like to accept the current access of the selected users?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Reject All"
				(
	  			workflow = Bulk_reject_AD1
				show action in view header = true
				show action in edit record menu = true
				execute action for collection of records
				)
			)
			quickview
			(
				layout
				(
		 			type = -1
					datablock1
					(
