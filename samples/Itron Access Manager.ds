			run_script_onload10 as "run script - onload"
			{
				type =  form
				form = sync_modal
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.tab == 1)
										{
											insert into Scheduled_Execution_1
											[
												Added_User=zoho.loginuser
												Sync_Time=zoho.currenttime.addSeconds(10)
												AD=true
												Department=input.Department
												Initiated_By=zoho.loginuserid
											]
										}
										else if(input.tab == 2)
										{
											insert into Scheduled_Execution_1
											[
												Added_User=zoho.loginuser
												Sync_Time=zoho.currenttime.addSeconds(10)
												openLDAP=true
												Department=input.Department
												Initiated_By=zoho.loginuserid
											]
										}
						)
					}
				}

			}
