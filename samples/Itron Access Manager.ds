		form Users_Access
		{
			displayname = "Users Access"
			success message = "Data Added Successfully!"
			field alignment = left
					hide = true
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			User_Profile
			(
				type = picklist	
				displayname = "User Profile"
				values  = User_Profile.ID
    			bidirectional = Current_Access_Record
    			displayformat = [Email]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Name
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Email1
			(
    			type = text
				displayname = "Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Type_field
			(
				type = picklist
				displayname = "Type"
				maxchar = 100
				values = {"Microsoft AD","openLDAP"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Last_Logon
			(
    			type = text
				displayname = "Last Logon"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Sync_Date
			(
    			type = date
				displayname = "Sync Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Audit_Date
			(
    			type = date
				displayname = "Audit Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Account_Expiration_Date
			(
    			type = text
				displayname = "Account Expiration Date"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Domain
			(
				type = picklist	
				values  = Domain.ID
    			displayformat = [Domain_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Group
			(
				type = picklist	
				values  = Group.ID
    			displayformat = [Group_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Department
			(
				type = picklist	
				values  = Department.ID
    			displayformat = [Department_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Formula
			(
    			type = formula
				value =  Department.Auditors.getall()
				visibility = false
				format = plaintext
	 			row = 1
	 			column = 1   
				width = medium
			)
			Accepted
			(
    			type = checkbox
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Rejected
			(
    			type = checkbox
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Rejection_Comment
			(
    			type = textarea
				displayname = "Rejection Comment"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Archive
			(
    			type = checkbox
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			NOC_Action_Performed
			(
				type = picklist
				displayname = "Action Performed"
				maxchar = 100
				values = {"Removed From Group","Disabled User Profile"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			NOC_Action_Performed_By
			(
				type = picklist	
				displayname = "Action Performed By"
				values  = NOC_Users.ID
    			displayformat = [Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			customize
			(
				icon = "ui-1-bold-add"
			)
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
