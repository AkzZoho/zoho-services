		schedule
		{
			sync_user_data as "sync user data"
			{
				type =  schedule
				form = Department[Disable_Sync == false]
				start = Next_Sync_Date at "10:30:00"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						if(input.Disable_Sync == false)
										{
											fetUsersAD = Users_Access[Department == input.ID && Archive == false && Type_field == "Microsoft AD" && Accepted == false && Rejected == false];
											fetUsersLDPA = Users_Access[Department == input.ID && Archive == false && Type_field == "openLDAP" && Accepted == false && Rejected == false];
											for each  rec01 in fetUsersAD
											{
												rec01.Archive=true;
											}
											for each  rec02 in fetUsersLDPA
											{
												rec02.Archive=true;
											}
											// script to sync users -- AD
											fetgrpAD = Group[Department == input.ID && Domain.Type_field == "Microsoft AD" && Active == true];
											for each  reco in fetgrpAD
											{
												thisapp.Utils.fetchAllUsers(reco.ID);
											}
											// code for setting up next interval
											interval = input.Sync_Interval;
											Last_Sync_date = zoho.currentdate;
											last_date = Last_Sync_date;
											if(interval == "Weekly")
											{
												input.Next_Sync_Date = last_date.addDay(7);
											}
											else if(interval == "Monthly")
											{
												input.Next_Sync_Date = last_date.addMonth(1);
											}
											else if(interval == "Quarterly")
											{
												input.Next_Sync_Date = last_date.addMonth(3);
											}
											else if(interval == "Bi-Annually")
											{
												input.Next_Sync_Date = last_date.addMonth(6);
											}
											else if(interval == "Annually")
											{
												input.Next_Sync_Date = last_date.addYear(1);
											}
										}
					)
					}
				}
			}
			run_script_instant_sync_ as "run script - instant sync "
			{
				type =  schedule
				form = Scheduled_Execution_1
				start = Sync_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						try 
										{
											if(input.AD == true)
											{
												fetUsers = Users_Access[Department == input.Department && Archive == false && Type_field == "Microsoft AD" && Accepted == false && Rejected == false];
											}
											else if(input.openLDAP == true)
											{
												fetUsers = Users_Access[Department == input.Department && Archive == false && Type_field == "openLDAP" && Accepted == false && Rejected == false];
											}
											for each  rec in fetUsers
											{
												rec.Archive=true;
											}
											// script to sync users -- AD
											if(input.AD == true)
											{
												fetgrpAD = Group[Department == input.Department && Active == true && Domain.Type_field == "Microsoft AD"];
												for each  reco in fetgrpAD
												{
													thisapp.Utils.fetchAllUsers(reco.ID);
												}
											}
											//---------------------
											input.completed = true;
										}
										catch (e)
										{
											input.completed = true;
											input.Error = e;
										}
					)
					}
				}
			}
		}




