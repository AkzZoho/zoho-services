				 void mail.accessRenewalNotification(string type, string name, string email, string portalName)
                 {
                 	if(type == "accepted")
                 	{
                 		fetchMail = Email[Email_Name == "AcceptMail"];
                 	}
                 	else if(type == "rejected")
                 	{
                 		fetchMail = Email[Email_Name == "RejectMail"];
                 	}
                 	mailContent = fetchMail.Email_Content.replaceAll("${userName}",name,true).replaceAll("${portalName}",portalName,true);
                 	sendmail
                 	[
                 		from :zoho.adminuserid
                 		to :email
                 		subject :fetchMail.Email_Subject
                 		message :fetchMail.Email_Content
                 	]
                 }
