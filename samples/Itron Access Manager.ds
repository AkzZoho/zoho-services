				 string htmlComponents.SplitView(int user_tab, string searchText)
                 {
                 	htmlContent = "";
                 	// 	if(user_tab == null)
                 	// 	{
                 	// 		user_tab = 1;
                 	// 	}
                 	tab1 = "null";
                 	tab2 = "null";
                 	if(user_tab == 1)
                 	{
                 		tab1 = "zc-opjs-horizontal-tabactive";
                 	}
                 	else if(user_tab == 2)
                 	{
                 		tab2 = "zc-opjs-horizontal-tabactive";
                 	}
                 	htmlContent = htmlContent + "<div class='zc-opjs-vertical-tabbody zc-opjs-flt-left'>";
                 	htmlContent = htmlContent + "<div class='zc-opjs-horizontal-tabpanel'>";
                 	htmlContent = htmlContent + "<ul class='zc-opjs-horizontal-tabhead'>";
                 	htmlContent = htmlContent + "<li> ";
                 	htmlContent = htmlContent + "<a class=" + tab1 + " href='#Page:Audit_Review?tab=1'>Microsoft AD</a>";
                 	htmlContent = htmlContent + "</li>";
                 	htmlContent = htmlContent + "<li> ";
                 	htmlContent = htmlContent + "<a class=" + tab2 + " href='#Page:Audit_Review?tab=2'>OpenLDAP</a> ";
                 	htmlContent = htmlContent + "</li>";
                 	htmlContent = htmlContent + "</ul>";
                 	if(user_tab == 1)
                 	{
                 		if(searchText not in {"",null,NULL})
                 		{
                 			fetDept = Department[Department_Name == searchText];
                 			params11 = "zc_Header=false&tab=" + user_tab + "&Department=" + fetDept.ID;
                 			params12 = "zc_Header=true&amp;Department=" + fetDept.Department_Name;
                 		}
                 		else
                 		{
                 			params11 = "zc_Header=false&tab=" + user_tab;
                 			params12 = "zc_Header=true";
                 		}
                 		htmlContent = htmlContent + "<div class=\"searchContainer\">";
                 		htmlContent = htmlContent + "<div elName='zc-component' formLinkName='Search' params='" + params11 + "'></div>";
                 		htmlContent = htmlContent + "</div>";
                 		htmlContent = htmlContent + "<div class='zc-opjs-horizontal-tabbody' elName='zc-component' viewLinkName='Auditor_AD' params='" + params12 + "'></div>";
                 	}
                 	else if(user_tab == 2)
                 	{
                 		if(searchText not in {"",null,NULL})
                 		{
                 			fetDept = Department[Department_Name == searchText];
                 			params21 = "zc_Header=false&tab=" + user_tab + "&Department=" + fetDept.ID;
                 			params22 = "zc_Header=true&amp;Department=" + fetDept.Department_Name;
                 		}
                 		else
                 		{
                 			params21 = "zc_Header=false&tab=" + user_tab;
                 			params22 = "zc_Header=true";
                 		}
                 		htmlContent = htmlContent + "<div class=\"searchContainer\">";
                 		htmlContent = htmlContent + "<div elName='zc-component' formLinkName='Search' params='" + params21 + "'></div>";
                 		htmlContent = htmlContent + "</div>";
                 		htmlContent = htmlContent + "<div class='zc-opjs-horizontal-tabbody' elName='zc-component' viewLinkName='Auditor_OpenLDAP' params='" + params22 + "'></div>";
                 	}
                 	htmlContent = htmlContent + "</div>";
                 	htmlContent = htmlContent + "</div>";
                 	return htmlContent;
                 }
