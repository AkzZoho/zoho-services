	section Auditor_Report
	{
		displayname= "Auditor Report"
		page Auditor_Report
		{
			displayname = "Auditor Report"
			icon = "design-window-paragraph"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet3' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet3()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n\t\tlabel.form-label.decision-box-label{ \n\tposition: absolute;\n\tleft: -20px; \n\tfont: bold 11px Arial;\n\ttext-decoration: none;\n\tbackground-color: var(--left_pane_section_selected);\n\tcolor: var(--theme_brand_color);\n\tpadding: 10px !important;  \n\tborder: 1.5px solid var(--theme_brand_color);\n\tborder-radius: .5rem !important; \n\t}\n\t\n\t.zc-Search1-group div{display:none !important;} \n\t\n\t.ZCPageContainer{\nheight :95vh; \n}\n\n.searchForm{\n\theight:25%; \n}\n\n.searchReport{\n\nheight:75%; \n}\n\t&lt;\/style&gt;\n\t&lt;div class=&apos;ZCPageContainer&apos;&gt;\n\t&lt;div class=&apos;searchForm&apos; &gt;\n&lt;div elName=&apos;zc-component&apos; formLinkName=&apos;Report_Filter&apos; params=&apos;zc_Header=false&amp;amp;zc_SuccMsg=Data Added Successfully!&amp;amp;zc_SubmitVal=Submit&amp;amp;zc_ResetVal=Reset&apos;&gt;Loading Form...&lt;\/div&gt;\n&lt;div&gt;\n&lt;div class=&apos;searchReport&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;Users_Report&apos; params=&apos;zc_Header=true&apos;&gt;Loading View...&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		form Report_Filter
		{
			displayname = "Report Filter"
			store data in zc = false
			success message = ""
			field alignment = left
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have From
			(
    			type = date
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Auditor
			(
				type = picklist	
				values  = Audit_Users.ID
    			displayformat = [Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Group
			(
				type = picklist	
				values  = Group[Department.ID == input.Department].ID
    			displayformat = [Group_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have To
			(
    			type = date
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Department
			(
				type = picklist	
				values  = Department.ID
    			displayformat = [Department_Name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Search1
			(
    			type = checkbox
				displayname = "Search"
				initial value = false
	 			row = 1
	 			column = 2   
				width = medium
			)
	
		}
	}
