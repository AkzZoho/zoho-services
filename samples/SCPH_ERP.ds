					}
					actions  (Visitor_Type != "General")
					{
						hide Entry_Time,Exit_Time,Reason_For_Visit,Staff,Status,Student,To_Visit,Visitor_Name;
					}
					actions  (Visitor_Type == "Staff")
					{
						show Staff;
					}
					actions  (Visitor_Type == "Student")
					{
						show Student;
					}
				}

			}
