				 string apiJson.getSubstituationValues(string substituationSessionID)
                 {
                 	session = Session_Subform[ID == input.substituationSessionID.toNumber()];
                 	mainSession = Sessions[ID == session.Sessions];
                 	sess = Session_Subform[Sessions.Date_field == mainSession.Date_field && Session_Name == session.Session_Name].Staff.getAll();
                 	allStaff = Staff[Status == "Active" && Staff_Type == "Teaching Staff"].ID.getAll();
                 	allStaff.removeAll(sess);
                 	associatedStaffs = Lesson_Plan_Mapping[Class == mainSession.Class].Staff.getAll();
                 	associatedStaffs.removeAll(sess);
                 	getAssociatedStaff = Staff[ID == associatedStaffs];
                 	getAllStaff = Staff[ID == allStaff];
                 	info getAssociatedStaff;
                 	info associatedStaffs;
                 	info allStaff;
                 	info mainSession;
                 	info sess;
                 	info session;
                 	info substituationSessionID;
                 	getLoginUser = Staff[Email_ID == zoho.loginuserid];
                 	returnJson = Map();
                 	substituationValuesList = List();
                 	substituationValuesMap = Map();
                 	substituationValuesMap.put("loginUser",getLoginUser.Name);
                 	substituationValuesMap.put("sessionID",session.ID.toString());
                 	substituationValuesMap.put("mainSessionID",mainSession.ID.toString());
                 	associatedstaffsList = List();
                 	for each  associatedStaffsOption in getAssociatedStaff
                 	{
                 		associatedstaffsMap = Map();
                 		associatedstaffsMap.put("staffName",associatedStaffsOption.Name);
                 		associatedstaffsMap.put("staffID",associatedStaffsOption.ID.toString());
                 		associatedstaffsList.add(associatedstaffsMap);
                 	}
                 	allstaffsList = List();
                 	for each  allStaffsOption in getAllStaff
                 	{
                 		allstaffsMap = Map();
                 		allstaffsMap.put("staffName",allStaffsOption.Name);
                 		allstaffsMap.put("staffID",allStaffsOption.ID.toString());
                 		allstaffsList.add(allstaffsMap);
                 	}
                 	substituationValuesMap.put("assocoiatedStaff",associatedstaffsList);
                 	substituationValuesMap.put("allStaff",allstaffsList);
                 	substituationValuesList.add(substituationValuesMap);
                 	returnJson.put("SubstitueValue",substituationValuesList);
                 	return returnJson;
                 }
				 map apiJson.getTimeTable()
                 {
                 	getsubjects = Lesson_Plan_Mapping[Staff.Email_ID == zoho.loginuserid];
                 	info getsubjects;
                 	subjectListJson = List();
                 	for each  sessionSubject in getsubjects
                 	{
                 		subjectListMap = Map();
                 		subjectListMap.put("subjectName",sessionSubject.Subject_field.Subject_Name);
                 		subjectListMap.put("subjectID",sessionSubject.Subject_field.ID.toString());
                 		subjectListJson.add(subjectListMap);
                 	}
                 	getModule = Subject_Modules[ID != 0];
                 	info getModule;
                 	modulesListJson = List();
                 	for each  moduleDet in getModule
                 	{
                 		modulesListMap = Map();
                 		modulesListMap.put("modeleName",moduleDet.Module_Name);
                 		modulesListMap.put("moduleID",moduleDet.ID.toString());
                 		modulesListJson.add(modulesListMap);
                 	}
                 	login = zoho.loginuserid;
                 	staffOtherJSON = Map();
                 	staffInfo = Staff[Email_ID == login];
                 	totalDays = Staff_Attendance[Staff == staffInfo.ID].count();
                 	totalDaysPresent = Staff_Attendance[Staff == staffInfo.ID && Status != "Absent"].count();
                 	totalDaysAbsent = Staff_Attendance[Staff == staffInfo.ID && Status == "Absent"].count();
                 	time_table = Time_Table[Class == Lesson_Plan_Mapping[Staff.Email_ID == login].Class.get(0)];
                 	break1Time = zoho.currentdate + " " + time_table.Break_1.toString();
                 	break1TimeString = break1Time.toTime().toString("HH:mm") + " - " + break1Time.toTime().addMinutes(time_table.Break_Duration_in_Mins).toString("HH:mm");
                 	break2Time = zoho.currentdate + " " + time_table.Break_2_Time.toString();
                 	break2TimeString = break2Time.toTime().toString("HH:mm") + " - " + break2Time.toTime().addMinutes(time_table.Break_Duration_in_Mins).toString("HH:mm");
                 	lunchTime = zoho.currentdate + " " + time_table.Lunch_Time.toString();
                 	// 	lunchTimeString = lunchTime.toTime().toString("HH:mm") + " - " + lunchTime.toTime().addMinutes(time_table.Lunch_Duration_in_Mins).toString("HH:mm");
                 	lessonPlan = Lesson_Plan_Mapping[Staff.Email_ID == login].Class;
                 	timeTable = Time_Table[Class == lessonPlan.get(0)];
                 	timeTableJSON = Map();
                 	timeTableHeader = List();
                 	for each  data in timeTable.Time_Table_Subform
                 	{
                 		timeTableHeader.add(data.Time);
                 		if(data.Time.contains(break1Time.toTime().toString("HH:mm")))
                 		{
                 			timeTableHeader.add("break - " + break1TimeString);
                 		}
                 		if(data.Time.contains(break2Time.toTime().toString("HH:mm")))
                 		{
                 			timeTableHeader.add("break - " + break2TimeString);
                 		}
                 		if(data.Time.contains(lunchTime.toTime().toString("HH:mm")))
                 		{
                 			// 			timeTableHeader.add("lunch - " + lunchTimeString);
                 		}
                 	}
                 	timeTableJSON.put("TimeTableHeader",timeTableHeader);
                 	timeTableJSON.put("TimeTableValues",thisapp.test.test());
                 	staffOtherJSON.put("TimeTableData",timeTableJSON);
                 	staffAttendanceInfo = Map();
                 	staffAttendanceInfo.put("Total_Days",totalDays);
                 	staffAttendanceInfo.put("Total_Days_Present",totalDaysPresent);
                 	staffAttendanceInfo.put("Total_Days_Absent",totalDaysAbsent);
                 	staffOtherJSON.put("Attendance_Info",staffAttendanceInfo);
                 	staffComList = List();
                 	for each  com in Communication_Form[Mode_of_Communication == "Internal" && Added_Time is Today]
                 	{
                 		innerMap = Map();
                 		innerMap.put("Time",com.Added_Time.toString("dd MMM, yyyy"));
                 		innerMap.put("Title",com.Subject_field);
                 		innerMap.put("Content",com.Message.xmlDecode());
                 		staffComList.add(innerMap);
                 	}
                 	staffOtherJSON.put("Commication_Info",staffComList);
                 	staffOtherJSON.put("subjectInfo",subjectListJson);
                 	staffOtherJSON.put("moduleInfo",modulesListJson);
                 	staffCheck = Staff_Attendance[Date_field == zoho.currentdate && Staff.Email_ID == zoho.loginuserid];
                 	currentStatus = "";
                 	if(staffCheck.count() == 1)
                 	{
                 		if(staffCheck.Status == "Logged In")
                 		{
                 			currentStatus = "Check In";
                 		}
                 		else
                 		{
                 			currentStatus = "Check Out";
                 		}
                 	}
                 	else
                 	{
                 		currentStatus = "Check Out";
                 	}
                 	staffOtherJSON.put("Current_Status",currentStatus);
                 	return staffOtherJSON;
                 }
