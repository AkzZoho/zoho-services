		page Library_Dashboard
		{
			displayname = "Library Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet43' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet43()\ncontent\n&lt;%{\n\tborrowed_books = Borrowed_Books_Subform[Status == &quot;Borrowed&quot; || Status == &quot;Extended&quot;].count();\n\toverdue_books = Borrowed_Books_Subform[Status != &quot;Returned&quot; &amp;&amp; Expected_Return_Date &lt; zoho.currentdate].count();\n\tall_books = Resources[ID != 0].count();\n\tvisitors = Library_Visitor_Record[In_Time == zoho.currentdate].count();\n\tday_1 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(6)].count();\n\tborrower_day_1 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(6) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_2 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(5)].count();\n\tborrower_day_2 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(5) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_3 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(4)].count();\n\tborrower_day_3 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(4) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_4 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(3)].count();\n\tborrower_day_4 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(3) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_5 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(2)].count();\n\tborrower_day_5 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(2) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_6 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(1)].count();\n\tborrower_day_6 = Library_Visitor_Record[In_Time == zoho.currentdate.subDay(1) &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tday_7 = Library_Visitor_Record[In_Time == zoho.currentdate].count();\n\tborrower_day_7 = Library_Visitor_Record[In_Time == zoho.currentdate &amp;&amp; is_Borrowing == &quot;Borrowers&quot;].count();\n\tall_list = List();\n\tall_list.addAll({day_2,day_3,day_4,day_5,day_6,day_7});\n\tmax = day_1;\n\tfor each  rec in all_list\n\t{\n\t\tif(max &lt; rec)\n\t\t{\n\t\t\tmax = rec;\n\t\t}\n\t}\n\tmod = max % 4;\n\tmax_value = max + 4 - mod;\n\tvalue = max_value \/ 4;\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n        }\n\t\t\n\t\tdiv#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n\t\t\n        .library-container{\n          height: 100%;\n          width: 100%;\n          padding: 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display: flex;\n\t\t  flex-direction: column;\n\t\t  gap: 13px;\n\t\t  box-sizing: border-box;\n      }\n\t  .row1-container\n\t  {\n\t\t  display:flex;\n\t\t  height:380px !important;\n\t\t  gap:13px;\n\t  }\n\t  .report-container-div {\n\t\t\theight: calc(100% - 380px) !important;\n\t\t\twidth: 100%;\n\t\t\tdisplay: flex;\n\t\t\tgap: 13px;\n\t\t}\n\t  .row2-container\n\t  {\n\t\t  height:100%;\n\t\t  width:50%;\n\t\t  position:relative;\n\t\t  border-radius: 8px;\n\t\t  overflow: hidden;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t  }\n\t  .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        padding: 5px 20px;\n        position:relative;\n        overflow:hidden;\n\t\tpadding-left:70px;\n\t\tbox-sizing: border-box;\n      }\n\t  \n\t  .panels .panel span:nth-child(1){\n          font-size: 20px;\n\t\t  font-weight:700;\n      }\n      .panels .panel span:nth-child(2) {\n          font-size: 14px;\n\t\t  font-weight:500;\n\t\t  color:#7D7D7D;\n      }\n      .panels{\n        display: flex;\n\t\tflex-direction: column;\n\t\tgap: 10px;\n\t\twidth:20%;\n      }\n\t  .panel-icon img {\n    \t\theight: 100%;\n\t\t\tpadding: 7px;\n\t\t\tbox-sizing: border-box;\n\t\t\tfilter: brightness(0) invert(1);\n\t\t}\n\t\t\n\t\t.panel-icon {\n\t\t\theight: 50px;\n\t\t\twidth: 50px;\n\t\t\tposition: absolute;\n\t\t\tleft: 20px;\n\t\t\tborder-radius: 8px;\n\/* \t\t\tbox-shadow: 0px 0px 5px #cdcdcd; *\/\n\t\t}\n\t  .form-links\n\t  {\n\t\t  width:20%;\n\t  }\n\t  .chart\n\t  {\n\t\t  width:60%;\n\t\t  background:var(--panel-background-color);\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t  border-radius: 10px;\n\t\t  overflow: hidden;\n\t  }\n\t  \n\t  .panel\n\t  {\n\t\t  gap:5px;\n\t  }\n\t  .borrowed-books-value\n\t  {\n\t\t  color:var(--borrowed-book-color);\n\t  }\n\t  .overdue-value\n\t  {\n\t\t  color:var(--overdue-color);\n\t  }\n\t  .visitors-value\n\t  {\n\t\t  color:var(--visitor-color);\n\t  }\n\t  .books-value\n\t  {\n\t\t  color:var(--books-color);\n\t  }\n\t  .form-links\n\t  {\n\t\t    background:var(--panel-background-color);\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t\tborder-radius: 10px;\n\t  }\n\t  \n\t   .quickLinksUL \n\t   {\n\t\t     padding: 0px 15px;\n\t\t\tmargin-top: 15px;\n\t\t\twidth: 100%;\n\t\t\tlist-style: none;\n\t\t\tbox-sizing: border-box;\n\t   }\n\t .quickLinksLI\n\t {\n\t    text-align: center;\n\t\tmargin-bottom: 10px;\n\t\tmargin-left: 12px;\n\t\twidth: 100%;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tjustify-content: left;\n\t}\n\t.quickLinksLI &gt; a\n\t{\n\t\tcolor: #494747;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tgap: 5px;\n\t}\n\t\n\t\t\n\t\t.barchart-Wrapper {\n      display: table;\n      position: relative;\n      margin: 20px;\n      height: 200px;\n    }\n\t\n    .barChart-Container {\n      display: table-cell;\n      width: 100%;\n      height: 100%;\n      padding-left: 15px;\n\t  box-sizing: border-box;\n    }\n    .barchart {\n     display: table;\n     table-layout: fixed;\n     height: 100%;\n     width: 100%;\n    }\n    .barchart-Col {\n      position: relative;\n      vertical-align: bottom;\n      display: table-cell;\n      height: 100%;\n    }\n    .barchart-Col + .barchart-Col {\n      border-left: 4px solid transparent;\n    }\n    .barchart-Bar {\n      position: relative;\n      height: 100%;\n      transition: height 0.5s ease-in;\n      width: 30px;\n      margin: auto;\n\t  display:flex;\n    }\n\t.visitor-bar,.borrower-bar\n     {\n\t\t width:50%;\n\t\t position: absolute;\n         bottom: 0;\n\t }\n\t .visitor-bar\n\t {\n\t\t background:var(--visitor-background-color);\n\t\t left:0;\n\t }\n\t .borrower-bar\n\t {\n\t\t background:var(--borrower-background-color);\n         right: 0;\n\t }\n    .barchart-Bar:after {\n      content: attr(attr-height);\n      color: white;\n      position: absolute;\n      text-align: center;\n      width: 100%;\n    }\n    .barchart-BarFooter {\n      position: absolute;\n      text-align: center;\n      height: 10%;\n      width: 100%;\n\t  padding:5px;\n\t  box-sizing: border-box;\n    }\n    .barchart-BarFooter p {\n      color: #000000;\n    }\n    .barchart-TimeCol {\n      position: absolute;\n      top: 0;\n      height: 100%;\n      width: 100%;\n    }\n    .barchart-Time {\n      height: 25%;\n      vertical-align: middle;\n      position: relative;\n    }\n    .barchart-Time:after {\n      border-bottom: 1px solid #AAAAAA;\n      content: &quot;&quot;;\n      position: absolute;\n      width: 100%;\n      left: 0;\n      top: 0em;\n    }\n    .barchart-TimeText {\n      position: absolute;\n      top: -8px;\n      z-index: 1;\n      background: white;\n      padding-right: 5px;\n      color: #000000;\n      font-size: 12px;\n\t  box-sizing: border-box;\n      font-family: &apos;Avenir Medium&apos;;\n    }\n\t.chart-topics\n\t{\n\t\t display:flex;\n\t\t gap:30px;\n\t\t padding: 0 10px;\n\t\t box-sizing: border-box;\n\t}\n\t.topic1,.topic2\n\t{\n\t\tdisplay:flex;\n\t}\n\t.total-visitor,.total-borrower {\n\t\tposition: relative;\n\t\tpadding-left: 15px;\n\t\tbox-sizing: border-box;\n    }\n\t.total-visitor:before,.total-borrower:before\n\t{\n\t\twidth: 10px;\n\t\tposition: absolute;\n\t\theight: 10px;\n\t\tcontent: &quot;&quot;;\n\t\tleft: 0px;\n\t\ttop: 50%;\n\t\ttransform: translateY(-50%);\n\t\tborder-radius: 50%;\n     }\n\t.total-visitor:before {\n        border: 2px solid #4A8BFF;\n\t\tbackground: #4A8BFF;\n      }\n\t .total-borrower:before {\n        border: 2px solid #83FFE3;\n\t\tbackground: #83FFE3;\n      }\n\t  .zc-live-primary-btn,.zc-live-primary-btn:hover\n\t  {\n\t\t  color:#fff !important;\n\t  }\n\t\t  \n\t  \/* Search Remove Icon *\/\n\t\t.report_search .formColumn.first-column, \n\t\t.report_search .formColumn.second-column {\n\t\t\twidth: auto !important;\n\t\t\tmin-width: auto !important;\n\t\t}\n\t\t\n\t\t.report_search .formColumn.second-column {\n\t\t\twidth: auto !important;\n\t\t\tmin-width: auto !important;\n\t\t\tposition: absolute;\n\t\t\tleft: calc(100% - 18px);\n\t\t}\n\t\t\n\t\t.report_search .decision-box-label:hover:before{\n\t\t\tcolor:red;\n\t\t}\n\t\t\n\t\t.report_search .decision-box-label:before {\n\t\t\tcontent: &quot;\\ed84&quot;;\n\t\t\tfont-family: &quot;ZC Live Outline&quot;;\n\t\t\tfont-size: 17px;\n\t\t\tposition: absolute;\n\t\t\ttop: 50%;\n\t\t\ttransform: translateY(-50%);\n\t\t\tcursor: pointer;\n\t\t}\n\t\t.report_search .form-label.decision-box-label {\n\t\t\ttop: 50% !important;\n\t\t\theight: 30p