			Re_Calculate_Form_Fields as "Re-Calculate Form Fields"
			{
				type =  form
				form = Monthly_Fees
				record event = on edit

				on user input of Fee_Details.Fee_Amount
				{
					actions 
					{
						custom deluge script
						(
											ExistingVals = Monthly_Fee_Subform[ID == row.ID];
										if(row.Fee_Amount > 0)
										{
											if(row.Fee_Head.Monthly_Recurring == false)
											{
												alert "Fee Amount can only be edited for Tution and Transportation Fee";
												row.Fee_Amount=ExistingVals.Fee_Amount;
											}
											// 	else if ( row.Fee_Amount > row.Balance_Amount ) 
											//     {
											// 		alert "Fee Amount cannot be greater than Balance Amount" ;
											// 		row.Fee_Amount = ExistingVals.Fee_Amount;
											//     }
											else
											{
												row.Balance_Amount=row.Fee_Amount - row.Received_Amount;
											}
										}
										else
										{
											alert "Fee Amount should be Greater than 0";
											row.Fee_Amount=ExistingVals.Fee_Amount;
										}
										input.Total_Fee_Amount = input.Fee_Details.sum(Fee_Amount);
										input.Total_Received_Amount = input.Fee_Details.sum(Received_Amount);
										input.Total_Balance_Amount = input.Fee_Details.sum(Balance_Amount);
						)
					}
				}

			}
			Update_Parent_Fields as "Update Parent Fields"
			{
				type =  form
				form = Monthly_Fees
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  StudentSubform in Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details]
										{
											StudentSubform.Fee_Amount=Monthly_Fee_Subform[Fee_Head == StudentSubform.Fee_Head && Monthly_Fees.Student_Fee_Details == StudentSubform.Student_Fee_Details].sum(Fee_Amount);
											TotalConcessionAmount = Concession_Details_Students[ID in StudentSubform.Concession_Details].sum(Concession_Amount);
											StudentSubform.Total_Concession_Amount=TotalConcessionAmount;
											StudentSubform.Net_Amount=ifnull(StudentSubform.Fee_Amount,0) - ifnull(StudentSubform.Total_Concession_Amount,0);
											StudentSubform.Balance_Amount=StudentSubform.Net_Amount - StudentSubform.Paid_Amount;
										}
										StudentFeeDetail = Student_Fee_Details[ID == input.Student_Fee_Details];
										AllStudentFeeSubform = Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details];
										StudentFeeDetail.Total_Fee_Amount=AllStudentFeeSubform.sum(Fee_Amount);
										StudentFeeDetail.Total_Concession_Amount=AllStudentFeeSubform.sum(Total_Concession_Amount);
										StudentFeeDetail.Total_Net_Amount=AllStudentFeeSubform.sum(Net_Amount);
										StudentFeeDetail.Total_Amount_Due=AllStudentFeeSubform.sum(Balance_Amount);
										StudentFeeDetail.Total_Amount_Paid=AllStudentFeeSubform.sum(Paid_Amount);
										if(input.Total_Balance_Amount == 0)
										{
											input.Update1 = "<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>";
										}
										openUrl("#Script:page.parent.reload","parent window");
						)
					}
				}

			}
