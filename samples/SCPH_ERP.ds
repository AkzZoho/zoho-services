						custom deluge script
						(
											if(input.Exam_Schedule != null)
										{
											for each  rec in input.Questions2
											{
												availableQuestions = Question_Paper_DB[Module == rec.Module && Marks == rec.Marks && Subject_form == input.Subject_form];
