			onSubmission21 as "onSubmission"
			{
				type =  form
				form = Service_Request_Stateless
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						serviceRequest = Service_Request[ID == input.Service_Request];
										serviceRequest.Parts_Changed=input.Parts_Changed;
										serviceRequest.Service_Done=input.Service_Done;
										for each  ele in input.Parts_Changed
										{
											part = Add_Item[ID == ele];
											part.Quantity=part.Quantity - 1;
											if(part.Quantity < part.Threshold_Value)
											{
												if(part.Quantity == 0)
												{
													part.Status="Not Available";
												}
												else
												{
													part.Status="Restocking Required";
												}
											}
										}
										serviceRequest.Status="Finished";
										openUrl("#Script:page.parent.reload","parent window");
					)
					}
				}
			}
			onSubmission22 as "onSubmission"
			{
				type =  form
				form = Asset_Request
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											resp = insert into Asset_Mapping
										[
											Added_User=zoho.loginuser
											Map_to=input.Request_Type
											Room=input.Room
											Staff=input.Staff
											Block=input.Block1
											Requested_Item=input.Request_Item
											Asset_Request=input.ID
										];
						)
					}
				}

			}
			loadOfTheForm as "loadOfTheForm"
			{
				type =  form
				form = Asset_Mapping
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											asset = Asset_Mapping[ID != 0 && Asset_Request.Status != "Request Raised"];
										assetCount = asset.count() + 1;
										assetId = "Asset-" + zoho.currentdate.toString("ddMMyyyy") + "-" + assetCount;
										input.Asset_ID = assetId;
						)
					}
				}

			}
			onSubmission23 as "onSubmission"
			{
				type =  form
				form = Asset_Mapping
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											assetRequest = Asset_Request[ID == input.Asset_Request];
										assetRequest.Status="Request Closed";
										item = Add_Item[ID == input.Requested_Item];
										item.Quantity=item.Quantity - 1;
										if(item.Quantity < item.Threshold_Value)
										{
											if(item.Quantity == 0)
											{
												item.Status="Not Available";
											}
											else
											{
												item.Status="Restocking Required";
											}
										}
										openUrl("#Page:Inventory_Dashboard","parent window");
						)
					}
				}

			}
			showHideDisable12 as "showHideDisable"
			{
				type =  form
