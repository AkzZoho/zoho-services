			createDailyBusAttendanceM as "createDailyBusAttendanceMorning"
			{
				type =  schedule
				form = Educational_Year
				start = Educational_Year_Start_Date at "08:10:00"
				end   = Educational_Year_End_Date
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						if(zoho.currentdate.weekday() != 1)
										{
											for each  vehicle in Vehicle[Status != "Under Maintenance"]
											{
												lis = Collection();
												vehicle_rec = Vehicle[ID == vehicle.ID];
												getStudents = {};
												if(vehicle_rec.Students.size() != 0)
												{
													getStudents = vehicle_rec.Students.toList();
												}
												for each  stud in getStudents
												{
													att = Vehicle_Attendance.Students();
													att.Vehicle=vehicle.ID;
													att.Student=stud;
													att.Is_Present=true;
													lis.insert(att);
												}
												resp = insert into Vehicle_Attendance
												[
													Added_User=zoho.loginuser
													Morning_Evening="Morning"
													Date_field=zoho.currentdate
													Vehicle=vehicle.ID
													Students=lis
												];
											}
										}
										//4254807000205986063
					)
					}
				}
			}
