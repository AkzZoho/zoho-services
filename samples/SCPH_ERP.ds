			{
				type =  form
				form = Student
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											educationalYear = Educational_Year[Status == "Current"].ID;
										studentsCount = Student[ID != 0].count();
										studentsCount = studentsCount + 1;
										input.Admission_Number = "Adm-" + studentsCount;
										input.Status = "Active";
										if(input.Registration != null)
										{
											regi = Registration[ID == input.Registration];
											regi.Status="Class Assigned";
											openUrl("#Report:Selected_List?zc_LoadIn=embed-leadpage&zc_Header=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false","same window");
											openUrl("#Page:Print_Admission_Form?SID=" + input.ID,"popup window");
											// openUrl("https://creatorapp.zoho.in/export" + zoho.appuri + "print/Print_Registration_Form/?RID=" + input.ID + "&isc5page=true","popup window");
										}
										input.Class_DB1 = input.Class_UID.Class.ID;
										if(Class_UID.Mentors.size() != 0 && input.Mentor == null)
										{
											prevStudRec = Student[Class_UID == input.ID].Mentor sort by Added_Time desc;
											mentorList = input.Class_UID.Mentors;
											sizeLen = mentorList.size();
											getIndex = mentorList.indexOf(prevStudRec);
											if(getIndex + 1 == sizeLen)
											{
												input.Mentor = mentorList.get(0);
											}
											else
											{
												input.Mentor = mentorList.get(getIndex + 1);
											}
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											thisapp.LIVE.CreateFee_V2(input.ID);
										thisapp.LIVE.CreateMonthlyFee(input.ID);
						)
					}
				}

			}
