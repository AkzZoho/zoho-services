				 void testData.getStudentTimeTableData()
                 {
                 	stud = Student[Email == zoho.loginuserid];
                 	timTable = Time_Table[Class == stud.Class_UID];
                 	curDay = zoho.currentdate.weekday();
                 	lunchy = Subject_form[Subject_Name == "LUNCH"];
                 	allValues = Time_Table_Subform[Time_Table == timTable];
                 	mondayList = List();
                 	tuesdayList = List();
                 	wedList = List();
                 	thursList = List();
                 	friList = List();
                 	satList = List();
                 	allMap = Map();
                 	for each  rec in allValues
                 	{
                 		monMap = Map();
                 		tuesMap = Map();
                 		roomNo = "";
                 		monMap.put("time",rec.Time);
                 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Monday1];
                 		subjectName = if(lmp.count() == 0,if(rec.Monday1 == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		monMap.put("className",subjectName);
                 		if(zoho.currentdate.weekday() == 2)
                 		{
                 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 			roomNo = session.Room.Room_Number;
                 			monMap.put("roomNo",roomNo);
                 		}
                 		mondayList.add(monMap);
                 		// 		tuesMap.put("time",rec.Time);
                 		// 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Tuesday1];
                 		// 		subjectName = if(lmp.count() == 0,if(rec.Tuesday1 == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		// 		tuesMap.put("className",subjectName);
                 		// 		if(zoho.currentdate.weekday() == 3)
                 		// 		{
                 		// 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 		// 			roomNo = session.Room.Room_Number;
                 		// 			tuesMap.put("roomNo",roomNo);
                 		// 		}
                 		// 		tuesdayList.add(tuesMap);
                 		// 	
                 		wedMap = Map();
                 		thursMap = Map();
                 		friMap = Map();
                 		satMap = Map();
                 		wedMap.put("time",rec.Time);
                 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Wednesday];
                 		subjectName = if(lmp.count() == 0,if(rec.Wednesday == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		wedMap.put("className",subjectName);
                 		if(zoho.currentdate.weekday() == 4)
                 		{
                 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 			roomNo = session.Room.Room_Number;
                 			wedMap.put("roomNo",roomNo);
                 		}
                 		wedList.add(wedMap);
                 		thursMap.put("time",rec.Time);
                 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Thursday];
                 		subjectName = if(lmp.count() == 0,if(rec.Thursday == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		thursMap.put("className",subjectName);
                 		if(zoho.currentdate.weekday() == 5)
                 		{
                 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 			roomNo = session.Room.Room_Number;
                 			thursMap.put("roomNo",roomNo);
                 		}
                 		thursList.add(thursMap);
                 		friMap.put("time",rec.Time);
                 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Friday];
                 		subjectName = if(lmp.count() == 0,if(rec.Friday == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		friMap.put("className",subjectName);
                 		if(zoho.currentdate.weekday() == 6)
                 		{
                 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 			roomNo = session.Room.Room_Number;
                 			friMap.put("roomNo",roomNo);
                 		}
                 		friList.add(friMap);
                 		satMap.put("time",rec.Time);
                 		lmp = Lesson_Plan_Mapping[Student == stud.ID && Subject_field == rec.Saturday];
                 		subjectName = if(lmp.count() == 0,if(rec.Saturday == lunchy.ID,lunchy.Subject_Name,"Free Period"),lmp.Subject_field.Subject_Name);
                 		satMap.put("className",subjectName);
                 		if(zoho.currentdate.weekday() == 7)
                 		{
                 			session = Session_Subform[Sessions.Date_field == zoho.currentdate && Subject_form == lmp.Subject_field && Session_Name == rec.Time && Staff == lmp.Staff];
                 			roomNo = session.Room.Room_Number;
                 			satMap.put("roomNo",roomNo);
                 		}
                 		satList.add(satMap);
                 	}
                 	// 	info mondayList ;
                 	allMap.put("monday",mondayList);
                 	allMap.put("tuesday",tuesdayList);
                 	allMap.put("wednesday",wedList);
                 	allMap.put("thursday",thursList);
                 	allMap.put("friday",friList);
                 	allMap.put("saturday",satList);
                 	info allMap;
                 }
