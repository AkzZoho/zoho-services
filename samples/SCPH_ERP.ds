		list Return_Books
		{
			displayName = "Borrowers List"
			show all rows from Borrowed_Books_Subform  [Status == "Borrowed" || Status == "Extended" || Status == "Overdue"]  
			(
				Borrow_Books as "Borrow Books"
				Book
				Status
				Expected_Return_Date as "Expected Return Date"
				Return_Date as "Return Date"
				Fine
				custom action "Extend"
				(
	  			workflow = extendReturn
				show action in edit record menu = true
				column header = "Extend"
				condition = (Status == "Borrowed")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to extend the book?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Borrow_Books.Student
				custom action "Return"
				(
	  			workflow = returnBook
				show action in edit record menu = true
				column header = "Return"
				confirmation before execution
				(
					message for individual record = "Are you sure you want to return the book?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Borrow_Books.Borrowed_Date as "Borrowed Date"
			)
			group by
			(
				Status ascending
			)
			conditional formatting
			(
				"overDue"
				{
				condition = (Expected_Return_Date < zoho.currentdate)
				fields = [Expected_Return_Date]
				format = "color:#fa2525;"
				}
				"returningToday"
				{
				condition = (Expected_Return_Date is today)
				fields = [Expected_Return_Date]
				format = "color:#ef8216;"
				}
			)
		}
