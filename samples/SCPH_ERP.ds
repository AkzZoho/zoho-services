		page Parent_Dashboard
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet8' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet8()\ncontent\n&lt;%{\n\tmyStudInfo = Student[Primary_Contact_Email == zoho.loginuserid];\n\topenUrl = &quot;#Page:Student_Dashboard_Parents?Child_Mail=&quot; + encodeUrl(myStudInfo.Email) + &quot;&amp;zc_LoadIn=embed-pageTest&quot;;\n\topenurl(openUrl,&quot;same window&quot;);\n\t%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t\t* {\n\t\t   padding: 0;\n\t\t   margin: 0;\n\t\t   border: none;\n\t\t}\n\t  \n\t \tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t.parent-div{\n\t\t\theight:100%;\n\t\t}\n\t\t\n\t\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\theight: 100%;\n\t\t}\n\t\t\n\t\t.no-data {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tfont-size: 20px;\n\t\t\tcolor: red;\n\t\t\tfont-weight: 600;\n\t\t}\n\t\t\n\t\t.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n\t\t\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-table .form-header{\n         display: none !important;\n      }\n\t  \n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .zc-form-scroll-wrapper{\n  margin:unset !important;\n  }\n  \n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n\t  \n\t  div.view-outer-wrapper:is([id*=&quot;Consent_Form_Parents&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:last-of-type a.zc-custom-btn {\n    color: #ef2929;\n    border-color: #ef2929;\n}\n\n\tdiv.view-outer-wrapper:is([id*=&quot;Consent_Form_Parents&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:last-of-type a.zc-custom-btn:hover{\n\tbackground: #ef2929;\n    color: #fff;\n    border-color: #ef2929;\n}\n\ndiv.view-outer-wrapper:is([id*=&quot;Consent_Form_Parents&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:nth-last-of-type(2) a.zc-custom-btn {\n    color: #0ca829;\n    border-color: #0ca829;\n}\n\n\tdiv.view-outer-wrapper:is([id*=&quot;Consent_Form_Parents&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:nth-last-of-type(2) a.zc-custom-btn:hover{\n\tbackground: #0ca829;\n    color: #fff;\n    border-color: #0ca829;\n}\n\n\t&lt;\/style&gt;\n&lt;div name=&apos;pageTest&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Dashboard_Parents&apos; params=&apos;Child_Mail=&lt;%=encodeurl(myStudInfo.Email)%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page All_Students1
