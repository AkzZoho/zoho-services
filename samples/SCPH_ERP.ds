				type =  form
				form = Vehicle_Repair_Details
				record event = on edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Upload_Bill in {"",null})
										{
											alert(Upload_Bill,"Upload Bill is Mandatory");
										}
										VehicleInfo = Vehicle[ID == input.Vehicle];
										vehicles = Vehicle[Bus_Route == VehicleInfo.Bus_Route && ID != VehicleInfo.ID];
										studentList = VehicleInfo.Students;
										// info input.Students;
										for each  data in vehicles
										{
											studentList = data.Students;
											studentList.removeAll(studentList);
											data.Students=studentList;
											VehicleInfo.Status="Available";
										}
						)
					}
				}

			}
