			on_load1 as "on load"
			{
				type =  form
				form = Student_Remarks
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											attitudeList = {"Behaviour","Academic Excellance","Time Management"};
										rows = Collection();
										for each  rec in attitudeList
										{
											row1 = Student_Remarks.Remark_Details();
											row1.Aspect=rec;
											rows.insert(row1);
										}
										input.Remark_Details.insert(rows);
						)
					}
				}

			}
