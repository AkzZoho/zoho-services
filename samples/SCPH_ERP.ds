			addSubjectData1 as "addSubjectData"
			{
				type =  form
				form = Subject_form
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  rec in input.Lesson_Plan_Mapping
										{
											rec.Subject_field=input.ID;
										}
										monTimeTable = Time_Table_Subform[Monday1 in input.ID];
										if(monTimeTable.count() != 0)
										{
											for each  mtime in monTimeTable
											{
												disFormat = "<div>";
												for each  sub in mtime.Monday1
												{
