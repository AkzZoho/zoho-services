			check_transport_type as "check transport type"
			{
				type =  form
				form = Student
				record event = on add or edit

				on user input of Transport_Type
				{
					actions 
					{
						custom deluge script
						(
											hide Requested_for_Bus;
										input.Transport_Service_Type = "";
										input.Pickup_Point = null;
										input.Requested_for_Bus = false;
