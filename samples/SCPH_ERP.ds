				 list Akz.BDayToday()
                 {
                 	IDs = List();
                 	for each  Stud in Student[Date_of_Birth != null]
                 	{
                 		if(Stud.Date_of_Birth.day() == zoho.currentdate.day() && Stud.Date_of_Birth.month() == zoho.currentdate.month())
                 		{
                 			IDs.add(Stud.ID);
                 		}
                 	}
                 	return IDs;
                 }
				 void Akz.Delete_Fees()
                 {
                 	//
                 }
				 void Akz.Fix_Concession()
                 {
                 	Count = 0;
                 	for each  Temp_Concession in Concession_Temp_Data[Concession_Given_on_Which_fee_head == "Annual Fund" && Concession_Master == 287310000000560023 && Added = false && Regn_No == "999"]
                 	{
                 		info Temp_Concession.Regn_No;
                 		ConcessionInfo = Concession_Master[ID == Temp_Concession.Concession_Master];
                 		StudentInfo = Student[Registration_Number == Temp_Concession.Regn_No];
                 		if(StudentInfo.count() > 0)
                 		{
                 			StudentFeeDetailsSubform = Student_Fee_Subform[Student_Fee_Details.Student == StudentInfo.ID && Fee_Head == ConcessionInfo.Applicable_To];
                 			ConcessionPercentage = ConcessionInfo.Concession_Percentage;
                 			ConcessionAmount = (ifnull(StudentFeeDetailsSubform.Fee_Amount,0) * ConcessionPercentage) / 100;
                 			insert into Concession_Details_Students
                 			[
                 				Added_User=zoho.loginuser
                 				Concession=ConcessionInfo.ID
                 				Concession_Amount=ConcessionAmount
                 				Fee_Head=ConcessionInfo.Applicable_To
                 				Student_Fee_Subform=StudentFeeDetailsSubform.ID
                 			]
                 			StudentFeeDetailsSubform.Total_Concession_Amount=Concession_Details_Students[Student_Fee_Subform == StudentFeeDetailsSubform.ID].sum(Concession_Amount);
                 			StudentFeeDetailsSubform.Net_Amount=ifnull(StudentFeeDetailsSubform.Fee_Amount,0) - ifnull(StudentFeeDetailsSubform.Total_Concession_Amount,0);
                 			StudentFeeDetailsSubform.Balance_Amount=ifnull(StudentFeeDetailsSubform.Net_Amount,0) - ifnull(StudentFeeDetailsSubform.Paid_Amount,0);
                 			if(StudentFeeDetailsSubform.Balance_Amount == 0)
                 			{
                 				StudentFeeDetailsSubform.Disable_Concession=true;
                 			}
                 			StudentFee = Student_Fee_Details[ID == StudentFeeDetailsSubform.Student_Fee_Details];
                 			StudentFee.Total_Amount_Paid=Student_Fee_Subform[Student_Fee_Details == StudentFeeDetailsSubform.Student_Fee_Details].sum(Paid_Amount);
                 			StudentFee.Total_Amount_Due=Student_Fee_Subform[Student_Fee_Details == StudentFeeDetailsSubform.Student_Fee_Details].sum(Balance_Amount);
                 			StudentFee.Total_Concession_Amount=Student_Fee_Subform[Student_Fee_Details == StudentFeeDetailsSubform.Student_Fee_Details].sum(Total_Concession_Amount);
                 			StudentFee.Total_Net_Amount=ifnull(StudentFee.Total_Fee_Amount,0) - ifnull(StudentFee.Total_Concession_Amount,0);
                 			for each  MonthlyFeeSubform in Monthly_Fee_Subform[Monthly_Fees.Student_Fee_Details == StudentFeeDetailsSubform.Student_Fee_Details && Fee_Head == StudentFeeDetailsSubform.Fee_Head]
                 			{
                 				if(StudentFeeDetailsSubform.Fee_Head.Monthly_Recurring == true)
                 				{
                 					ActiveAcademicYear = Educational_Year[Status == "Current"];
                 					NumberofMonths = ActiveAcademicYear.Educational_Year_Start_Date.monthsDiff(ActiveAcademicYear.Educational_Year_End_Date);
                 					MonthlyFeeSubform.Fee_Amount=StudentFeeDetailsSubform.Net_Amount / NumberofMonths;
                 				}
                 				else
                 				{
                 					MonthlyFeeSubform.Fee_Amount=StudentFeeDetailsSubform.Net_Amount;
                 				}
                 				MonthlyFeeSubform.Balance_Amount=MonthlyFeeSubform.Fee_Amount - MonthlyFeeSubform.Received_Amount;
                 				MonthlyFee = Monthly_Fees[ID == MonthlyFeeSubform.Monthly_Fees];
                 				MonthlyFee.Total_Fee_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Fee_Amount);
                 				MonthlyFee.Total_Received_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Received_Amount);
                 				MonthlyFee.Total_Balance_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Balance_Amount);
                 			}
                 			StudentFeeDetailsSubform.Update_Concession=if(StudentFeeDetailsSubform.Disable_Concession,"<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>","<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Student_Fee_Subform?recLinkID=" + StudentFeeDetailsSubform.ID + "&viewLinkName=Student_Fee_Subform_Report&action_field=updateconcession&zc_LoadIn=dialog\">Update</a>");
                 		}
                 		Temp_Concession.Added=true;
                 		info "-------------------------";
                 		Count = Count + 1;
                 	}
                 	info Count;
                 }
