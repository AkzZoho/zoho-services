			changeDriver as "changeDriver"
			{
				type =  functions
				form = Vehicle
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						driver = Staff[Staff_Type == "Driver"].ID.getAll();
										workingStaff = Vehicle[ID != 0].Driver.getAll();
										driver.removeAll(workingStaff);
										if(driver.size() == 0)
										{
											openUrl("#Form:Alert?alert=There are no available drivers&zc_Header=false","popup window");
										}
										else
										{
											openUrl("#Form:Change_Driver?Vehicle=" + input.ID,"popup window");
										}
					)
					}
