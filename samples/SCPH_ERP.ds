		{
			displayname = "template"
			Content="<zml    \n\t\t\tisPdfEnabled='true'\n\t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet46' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet46()\ncontent\n&lt;%{\n\t\/\/ \tpage = thisapp.vishal.employeePayslip(templateNo.toLong());\n\t%&gt;\n&lt;style&gt;\n\/\/ \t\ttd.zc-live-primary-btn {\n\/\/ \t\t\tdisplay: none !important;\n\/\/ \t\t}\n * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.zc-pb-page-content-wrapper .elemContainment,\n\t\tdiv#row_1{\n\t\t\theight: 100%;\n\t\t}\n\t&lt;\/style&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
