			onSubmission14 as "onSubmission"
			{
				type =  form
				form = Promote
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						upcomingYear = Educational_Year[Status == "Upcoming"];
										for each  student in input.Student
										{
											className = Class[ID == student.Class_UID];
											classDb = Class_DB[ID == className.Class];
											if(classDb.Order != 12)
											{
												nextClass = Class_DB[Order == classDb.Order + 1];
												promotedClassSection = nextClass.Class + "-" + className.Class_Name.getsuffix("-");
												promotedClass = Class[Educational_Year == upcomingYear && Class_Name == promotedClassSection];
												promotedClass.Student.add(student);
												if(promotedClass.Student_Capacity == 0)
												{
													promotedClass.Status="Active";
												}
												promotedClass.Student_Capacity=promotedClass.Student_Capacity + 1;
											}
											if(className.Student_Capacity == promotedClass.Student_Capacity)
											{
												className.Status="In-Active";
											}
											student.Class_UID=promotedClass;
										}
										for each  clas in input.Class
										{
											clas.Status="In-Active";
										}
					)
					}
				}
			}
			addStock as "addStock"
			{
				type =  form
				form = Add_Stock
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						item = Add_Item[ID == input.Add_Item];
										presentQuantity = item.Quantity + input.Quantity;
										if(presentQuantity > item.Threshold_Value)
										{
											item.Status="Available";
										}
										else if(presentQuantity > 0 && presentQuantity < item.Threshold_Value)
										{
											item.Status="Restocking Required";
										}
										item.Quantity=presentQuantity;
										openUrl("#Script:page.parent.reload","parent window");
					)
					}
				}
			}
