=&quot;content-row1&quot;&gt;\n\t\t\t    &lt;div class=&quot;content-row1-column1&quot;&gt;\n\t\t\t\t  &lt;p&gt;Total Days Present&lt;\/p&gt;\n\t\t\t\t  &lt;span&gt;&lt;%=totalDaysPresent%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;content-row1-column2&quot;&gt;\n\t\t\t\t  &lt;p&gt;Total Days Absent&lt;\/p&gt;\n\t\t\t\t  &lt;span&gt;&lt;%=totalDaysAbsent%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t &lt;\/div&gt;\n\t\t\t &lt;div class=&quot;content-row2&quot;&gt;\n\t\t\t   &lt;p&gt;Attendance %&lt;\/p&gt;\n\t\t\t   &lt;div class=&quot;half-circle-container&quot;&gt;\n\t\t\t   &lt;div class=&quot;multigraph&quot; style=&quot;--pbar-height:65px;--pbar-width:calc(var(--pbar-height) * 2);--pbar-border-width:15px;&quot;&gt;\n&lt;%\n\ttry \n\t{\n\t\tPercentage = totalDaysPresent \/ (totalDaysPresent + totalDaysAbsent) * 100;\n\t}\n\tcatch (e)\n\t{\n\t\tPercentage = 0;\n\t}\n\tdeg = Percentage * 1.8;\n\t%&gt;\n&lt;span class=&quot;tooltip&quot;&gt;&lt;%=Percentage.round(2)%&gt;%&lt;\/span&gt;\n\t\t\t\t\t\t&lt;span class=&quot;graph&quot; style=&quot;--percentage:&lt;%=deg.round(2)%&gt;deg&quot;&gt;&lt;\/span&gt;\n                &lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t &lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;div class=&quot;holiday-div&quot;&gt;\n\t\t    &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Upcoming Holidays&lt;\/h4&gt;&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;content&quot;&gt;\n&lt;%\n\tholidayList = Holidays[Date_field &gt;= zoho.currentdate &amp;&amp; Holiday_Type == &quot;Common Holiday&quot; || Holiday_Type == &quot;Local Holiday&quot;] sort by Date_field;\n\tif(holidayList.count() &gt; 0)\n\t{\n\t\tfor each  holiday in holidayList\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;timeline-outer&quot;&gt;\n\t\t\t\t\t\t\t&lt;div class=&quot;timeline-inner&quot;&gt;\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t&lt;span class=&quot;timeline-value&quot;&gt;&lt;%=holiday.Holiday%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t&lt;div class = &quot;timeline-date-day-container&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-date&quot;&gt;&lt;%=holiday.Date_field%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-day&quot;&gt;&lt;%=holiday.Date_field.toString(&quot;EEEE&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot; style=&quot;box-shadow:unset;&quot;&gt;No More Holidays&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t  &lt;div class=&quot;home-container-row2&quot;&gt;\n\t     &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Time Table&lt;\/h4&gt;&lt;\/div&gt;\n\t\t &lt;div class=&quot;content time-table-content&quot;&gt;\n&lt;%\n\ttimeTableList = Time_Table_Subform[Time_Table == time_table.ID];\n\tsaturdayList = timeTableList.count(Saturday);\n\tif(timeTableList.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;table class=&quot;time-table&quot;&gt;\n\t\t\t   &lt;thead&gt;\n\t\t\t      &lt;th class=&quot;day-period&quot;&gt;&lt;span&gt;Day\/Period&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot; &gt;&lt;%=date1.Time%&gt;&lt;\/th&gt;\n&lt;%\n\t\t\tif(date1.Time.contains(break1Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=break1TimeString%&gt; &lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(date1.Time.contains(break2Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=break2TimeString%&gt; &lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(1 == 2)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=lunchTimeString%&gt; &lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t\t%&gt;\n&lt;\/thead&gt;\n\t\t\t   &lt;tbody&gt;\n\t\t\t      &lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Monday&lt;\/td&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Monday1 &amp;&amp; Student == myInfo.ID];\n\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\tsubjectName = &quot;&quot;;\n\t\t\troomNo = null;\n\t\t\tif(lmp.count() == 0)\n\t\t\t{\n\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\tsubjectName = if(date1.Monday1 == lunchy.ID,lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tif(zoho.currentdate.weekday() == 2)\n\t\t\t\t{\n\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t}\n\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\tif(date1.Time.contains(break1Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Break&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(date1.Time.contains(break2Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Break&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t\tif(1 == 2)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Lunch&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t  &lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Tuesday&lt;\/td&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Tuesday1 &amp;&amp; Student == myInfo.ID];\n\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\tsubjectName = &quot;&quot;;\n\t\t\troomNo = null;\n\t\t\tif(lmp.count() == 0)\n\t\t\t{\n\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\tsubjectName = if(date1.Tuesday1 == lunchy.ID,lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tif(zoho.currentdate.weekday() == 3)\n\t\t\t\t{\n\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t}\n\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t  &lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Wednesday&lt;\/td&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Wednesday &amp;&amp; Student == myInfo.ID];\n\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\tsubjectName = &quot;&quot;;\n\t\t\troomNo = null;\n\t\t\tif(lmp.count() == 0)\n\t\t\t{\n\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\tsubjectName = if(date1.Wednesday == lunchy.ID,lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tif(zoho.currentdate.weekday() == 4)\n\t\t\t\t{\n\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t}\n\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t  &lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Thursday&lt;\/td&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Thursday &amp;&amp; Student == myInfo.ID];\n\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\tsubjectName = &quot;&quot;;\n\t\t\troomNo = null;\n\t\t\tif(lmp.count() == 0)\n\t\t\t{\n\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\tsubjectName = if(date1.Thursday == lunchy.ID,lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tif(zoho.currentdate.weekday() == 5)\n\t\t\t\t{\n\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t}\n\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t  &lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Friday&lt;\/td&gt;\n&lt;%\n\t\tfor each  date1 in all_dates\n\t\t{\n\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Friday &amp;&amp; Student == myInfo.ID];\n\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\tsubjectName = &quot;&quot;;\n\t\t\troomNo = null;\n\t\t\tif(lmp.count() == 0)\n\t\t\t{\n\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\tsubjectName = if(date1.Friday == lunchy.ID,lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tif(zoho.currentdate.weekday() == 6)\n\t\t\t\t{\n\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t}\n\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\tif(saturdayList &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t     &lt;td&gt;Saturday&lt;\/td&gt;\n&lt;%\n\t\t\tfor each  date1 in all_dates\n\t\t\t{\n\t\t\t\tlmp = Lesson_Plan_Mapping[Subject_field == date1.Saturday &amp;&amp; Student == myInfo.ID];\n\t\t\t\tmainSubject = Subject_form[ID == lmp.Subject_field];\n\t\t\t\tsubjectName = &quot;&quot;;\n\t\t\t\troomNo = null;\n\t\t\t\tif(lmp.count() == 0)\n\t\t\t\t{\n\t\t\t\t\troomNo = &quot;&quot;;\n\t\t\t\t\tsubjectName = if(date1.Saturday == lunchy.ID,subjectName = lunchy.Subject_Name,subjectName = &quot;Free Period&quot;);\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tif(zoho.currentdate.weekday() == 7)\n\t\t\t\t\t{\n\t\t\t\t\t\tsession = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Subject_form == mainSubject &amp;&amp; Session_Name == date1.Time &amp;&amp; Staff == lmp.Staff];\n\t\t\t\t\t\troomNo = session.Room.Room_Number;\n\t\t\t\t\t}\n\t\t\t\t\tsubjectName = mainSubject.Subject_Name;\n\t\t\t\t}\n\t\t\t\t%&gt;\n&lt;td&gt;&lt;%=subjectName%&gt;\/&lt;%=roomNo%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tbody&gt;\n\t\t\t&lt;\/table&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot;&gt;No Time Table Available&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t  &lt;\/div&gt;  \n\t  &lt;div class=&quot;home-container-row3&quot;&gt;\n\t     &lt;div name=&quot;leadpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;My_Gate_Pass&apos; class=&quot;leadpagereport&quot; params=&apos;zc_ReportName=true&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=true&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t  &lt;\/div&gt;  \n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_Home
		{
			displayname = "Staff Home"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet91' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet91()\ncontent\n&lt;%{\n\tlogin = zoho.loginuserid;\n\tstaffInfo = Staff[Email_ID == login];\n\tannouncements = Communication_Form[Mode_of_Communication == &quot;Internal&quot;] sort by Added_Time desc range from 0 to 4;\n\t\/\/ \ttimeTable = thisapp.Jaz.getstafftimetable(staffInfo.ID);\n\ttotalDaysPresent = Staff_Attendance[Staff == staffInfo.ID &amp;&amp; Status != &quot;Absent&quot;].count();\n\ttotalDaysAbsent = Staff_Attendance[Staff == staffInfo.ID &amp;&amp; Status == &quot;Absent&quot;].count();\n\ttime_table = Time_Table[Class == Lesson_Plan_Mapping[Staff.Email_ID == login].Class];\n\tbreakDurationMins = if(time_table.Break_Duration_in_Mins != null,time_table.Break_Duration_in_Mins,0);\n\tbreak1Time = zoho.currentdate + &quot; &quot; + time_table.Break_1.toString();\n\tbreak1TimeString = break1Time.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + break1Time.toTime().addMinutes(breakDurationMins).toString(&quot;HH:mm&quot;);\n\tbreak2Time = zoho.currentdate + &quot; &quot; + time_table.Break_2_Time.toString();\n\tbreak2TimeString = break2Time.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + break2Time.toTime().addMinutes(breakDurationMins).toString(&quot;HH:mm&quot;);\n\t\/\/ \tlunchTime = zoho.currentdate + &quot; &quot; + time_table.Lunch_Time.toString();\n\t\/\/ \tlunchTimeString = lunchTime.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + lunchTime.toTime().addMinutes(time_table.Lunch_Duration_in_Mins).toString(&quot;HH:mm&quot;);\n\t%&gt;\n&lt;style&gt;\n   \n\t\t:root{\n\t\t  --main-container-color:#fff;\n\t\t  --half-circle-filled-color:#47C20E;\n\t\t  --half-circle-full-color:#d9f8eb;\n\t\t  }\n\t\t.home-container{\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t\t  gap:10px;\n\t\t   box-sizing: border-box;\n       }\n\t   div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t.home-container-row1\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:250px;\n\t\t}\n\t\t.announcement-div,.attendance-div,.holiday-div\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t\theight:100%;\n\t\t\tborder-radius:5px;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t.holiday-div {\n\t\t\twidth: 30%;\n\t\t}\n\t\t.attendance-div\n\t\t{\n\t\t\twidth:35%;\n\t\t}\n\t\t\n\t\t.announcement-div .content\n\t\t{\n\t\t\talign-items: center;\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 10px;\n\t\t}\n\t\t\n\t\t.announcement-div {\n\t\t\twidth: 35%;\n\t\t}\n\t\t\n\t\t.home-container-row2\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\theight: fit-content;\n\t\t\tborder-radius:5px;\n\t\t\twidth:100%;\n\t\t\tpadding:10px;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t.home-container-row3\n\t\t{\n\t\t\theight:450px;\n\t\t\tborder-radius:5px;\n\t\t\twidth:100%;\n\t\t}\n\t\t\n\t\t.home-container-row3&gt;div{\n\t\t\theight:100% !important;\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius:5px;\n\t\t\toverflow:hidden;\n\t\t}\n\t\t\n\t\t.content-row1, .content-row2 {\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\theight: calc((100% - 10px) \/ 2);\n\n\t\t}\n\t\t.content-row2\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tposition: relative;\n\t\t\tjustify-content: space-around;\n\t\t}\n\t\t.content-row1-column1,.content-row1-column2\n\t\t{\n\t\t\theight: 100%;\n\t\t\twidth: 100%;\n\t\t\tbox-shadow: 0px 0px 5px 1px rgb(0 0 0 \/ 25%);\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 3px;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tborder-radius: 5px;\n\t\t}\n\t\t.content-row1-column1 span\n\t\t{\n\t\t\tfont-size:20px;\n\t\t\tcolor:#47C20E;\n\t\t}\n\t\t.content-row1-column2 span\n\t\t{\n\t\t\tfont-size:20px;\n\t\t\tcolor:#F15656;\n\t\t}\n\t\t\n\t\t\/*halfcircle progress*\/\n\t\t*:after, *:before {\n\t\t  box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.half-circle-container{\n\t\t\theight: 100%;\n\t\t\twidth: 50%;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t}\n\t\t.multigraph {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  overflow: hidden;\n\t\t}\n\n\t\t.multigraph:before {\n\t\t  content: &apos;&apos;;\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  border: var(--pbar-border-width) solid var(--half-circle-full-color);\n\t\t  border-radius: var(--pbar-width) var(--pbar-width) 0 0;\n\t\t  border-bottom: none;\n\t\t}\n\n\t\t.tooltip {\n\t\t  width: 80px;\n\t\t  height: 30px;\n\t\t  text-align: center;\n\t\t  font-size: 20px;\n\t\t  line-height: 30px;\n\t\t  font-weight: 200;\n\t\t  color: #000;\n\t\t  position: absolute;\n\t\t  left: 50%;\n\t\t  transform:translateX(-50%);\n\t\t  bottom: 0%;\n\t\t  transition: all 0.2s ease-in;\n\t\t}\n\n\t\t.graph {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t}\n\n\t\t.graph:before, .graph:after {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  top: 100%;\n\t\t  border: var(--pbar-border-width) solid var(--half-circle-filled-color);\n\t\t  content: &apos;&apos;;\n\t\t  border-radius:0 0 var(--pbar-width) var(--pbar-width);\n\t\t  border-top: none;\n\t\t  animation: demo 3s;\n\t\t  transform-origin: center top;\n\t\t  --progress-size:var(--percentage);\n\t\t}\n\n\t\t.graph:after {\n\t\t  transform: rotate(var(--progress-size));\n\t\t}\n\n\t\t@keyframes demo {\n\t\t  0% { transform: rotate(0deg) }\n\t\t  100% { transform: rotate(var(--progress-size)) }\n\t\t}\n\t\t\n\t\/* Timeline Design *\/\n\t.holiday-div .content{\n\t\tpadding-top:10px;\n\t\t box-sizing: border-box;\n\t}\n\t\n\t\t.header {\n\t\t\theight: calc(100% - 115px);\n\t\t}\n\t\t\n\t\t.header&gt;div:last-child {\n\t\t\theight: calc(100% - 30px) !important;\n\t\t\tpadding-top: 10px !important;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.leadpagereport{\n\t\t\theight:100% !important;\n\t\t}\n\t\t\/*time-table design*\/\n\t\t.time-table\n\t\t{\n\t\t\twidth:100%;\n\t\t\theight:100%;\n\t\t\tborder-collapse: collapse;\n\t\t}\n\t\t.time-table thead\n\t\t{\n\t\t\theight: 30px;\n\t\t\tcolor: #000;\n\t\t}\n\t\t.time-table tbody\n\t\t{\n\t\t\theight:calc(100% - 30px);\n\t\t\toverflow:auto;\n\t\t}\n\t\t.time-table tbody td\n\t\t{\n\t\t\tborder-bottom: 1px solid #ebebeb;\n\t\t\tborder-left: 1px solid #ebebeb;\n\t\t\theight:45px;\n\t\t\ttext-align:center;\n\t\t}\n\t\t\n\t\t.time-table tbody td:last-child\n\t\t{\n\t\t\tborder-right: 1px solid #ebebeb;\n\t\t}\n\t\tul.announcements-list {\n\t\t\twidth: 100%;\n\t\t\theight: 100%;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t\n\t\tul.announcements-list&gt;li {\n\t\t\ttext-align: justify;\n\t\t\tmargin-bottom: 10px;\n\t\t}\n\t\t\n\t\t.break-td {\n    border-left: 1px solid #ebebeb;\n    border-right: 1px solid #ebebeb;\n    position: relative;\n    box-sizing: border-box;\n    border-bottom: 1px solid #ebebeb;\n}\n\n\t\t.break-td&gt;span{\n\t\t\t  writing-mode: vertical-lr;\n\t\t\t  letter-spacing: 20px;\n\t\t\t  text-orientation: upright;\n\t\t\t  position: absolute;\n\t\t\t  top: 50%;\n\t\t\t  left: 50%;\n\t\t\t  transform: translate(-50%,-50%);\n\t\t}\n\t\t\n\/* \t.time-table tbody td:last-child,\n\t.time-table thead th:last-child {\n\t\tborder-right: 1px solid #ebebeb;\n\t} *\/\n\t\n\tth.day-period {\n    background: #F1F1F1;\n    border: 1px solid #f1f1f1;\n}\n\n\/\/ \t.time-table tbody td:first-child, .time-table thead th:first-child {\n\/\/ \t\tborder-left: 2px solid var(--report-header-background-color);\n\/\/ \t}\n\t\n\t.time-table tbody td&gt;span:first-child {\n\t\tcolor: #999999;\n\t\tfont-size: 12px;\n    \tfont-weight: 600;\n\t}\n\n\t.time-table tbody td&gt;span {\n\t\tdisplay: block;\n\t}\n\tspan.announcement-sub {\n    font-size: 14px;\n    font-weight: bold;\n}\n\nspan.announcement-det {\n    font-size: 12px;\n\tpadding-right: 10px;\n}\n.announcements-list&gt;li {\n    margin-bottom: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    gap: 10px;\n\t    padding: 0 18px;\n    \n}\n.announcements-list&gt;li:not(:last-child){\n\tborder-bottom: 1px solid #E1E1E1;\n}\n.li-announcement-content-div {\n    text-align: justify;\n    margin-bottom: 7px;\n    width: 350px;\n    height: 65px;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 8px;\n    justify-content: center;\n    padding-left: 15px;\n    position: relative;\n}\n.li-announcement-cont {\n    text-align: justify;\n    margin-bottom: 7px;\n    width: 350px;\n    height: 75px;\n    background: #F8F8F8;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 8px;\n    justify-content: center;\n    padding-left: 15px;\n    position:relative\n}\n.li-announcement-cont::before {\n    content: &quot;&quot;;\n    position: absolute;\n    width: 2px;\n    height: 48px;\n    background: var(--theme_brand_color);\n    left:0;\n\ttop: 50%;\n    transform: translateY(-50%);\n    border-radius:10px;\n}\n.li-announcement-date-div{\n\tcolor: #868686;\n    font-size: 13px;\n    font-weight: 600;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    gap: 5px;\n\twidth:40px;\n}\nspan.announcement-det &gt; * {\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n    text-align: justify;\n    overflow: hidden;\n}\n\nth.day-period {\n    font-weight: 600;\n}\n\nth.day-period {\n    background: #F1F1F1;\n}\n\nth.day-period&gt;span {\n\/*     border-radius: 5px; *\/\n    background: #F1F1F1;\n    display: flex;\n    height: 100%;\n    width: 100%;\n    justify-content: center;\n    align-items: center;\n\n}\n\nth.day-period:nth-child(1) {\n    padding: 0 10px;\n}\n\n\/* th.day-period:nth-child(2){\n    border-top-left-radius: 5px;\n\tborder-bottom-left-radius: 5px;\n}\n th.day-period:last-child {\n      border-top-right-radius: 5px;\n\tborder-bottom-right-radius: 5px;\n} *\/\n\n\t&lt;\/style&gt;\n\t&lt;div class=&quot;home-container&quot;&gt;\n\t  &lt;div class=&quot;home-container-row1&quot;&gt;\n\t &lt;div class=&quot;announcement-div&quot;&gt;\n\t\t   &lt;div class=&quot;sub-header&quot;&gt; &lt;h4 class=&quot;common-header&quot;&gt;Announcement&lt;\/h4&gt;&lt;\/div&gt;\n\t\t   &lt;div class=&quot;content&quot;&gt;\n&lt;%\n\tif(announcements.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;ul class=&quot;announcements-list&quot;&gt;\n&lt;%\n\t\tfor each  announcement in announcements\n\t\t{\n\t\t\taddedMonth = announcement.Added_Time.toString(&quot;MMM&quot;);\n\t\t\t%&gt;\n&lt;li&gt;&lt;div class=&quot;announcement-icon-div&quot;&gt;\n&lt;svg width=&quot;36&quot; height=&quot;36&quot; viewBox=&quot;0 0 36 36&quot; fill=&quot;none&quot; xmlns=&quot;http:\/\/www.w3.org\/2000\/svg&quot;&gt;\n&lt;circle cx=&quot;18&quot; cy=&quot;18&quot; r=&quot;18&quot; fill=&quot;var(--theme_brand_color)&quot; fill-opacity=&quot;0.2&quot;\/&gt;\n&lt;path d=&quot;M20.4203 10.0149C20.2229 10.0565 20.0591 10.1771 19.9275 10.3742L10.4996 16.3241L8.75363 16.6932C7.5611 16.9454 6.79607 18.1205 7.04799 19.3127L7.39709 20.9636C7.51868 21.5394 7.85904 22.0342 8.35492 22.357C8.71969 22.5945 9.13537 22.7171 9.5585 22.7171C9.71094 22.7171 9.86441 22.7012 10.0166 22.6691L11.5464 22.3457L12.9178