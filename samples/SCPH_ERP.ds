				 void LIVE.CreateFee_V2(int StdID)
                 {
                 	StudentInfo = Student[ID == StdID];
                 	if(StudentInfo.Pricing_Type == "Monthly Cycle" && StudentInfo.Student_Type1 != "Left")
                 	{
                 		ActiveAcademicYear = Educational_Year[Status == "Current"];
                 		NumberofMonths = 12;
                 		FeeStructure = Fee_Cycle[Class_Name = StudentInfo.Class_UID && Educational_Year == ActiveAcademicYear.ID];
                 		if(FeeStructure.count() > 0)
                 		{
                 			NewOverallStudentFee = insert into Student_Fee_Details
                 			[
                 				Added_User=zoho.loginuser
                 				Academic_Year=ActiveAcademicYear
                 				Student=StudentInfo.ID
                 				Class=StudentInfo.Class_UID
                 			];
                 			ComponentIDs = List();
                 			AllComponents = Components[ID in FeeStructure.Components];
                 			ComponentIDs.addAll(AllComponents.ID.getall());
                 			if(StudentInfo.Student_Type1 == "Old")
                 			{
                 				ExcludeComponents = Components[Fee_Component.Component_Name in {"Admission Fee","Registration Fee"}].ID.getAll();
                 				ComponentIDs.removeAll(ExcludeComponents);
                 			}
                 			ComponentTotal = 0;
                 			for each  SubModules in Components[ID in ComponentIDs]
                 			{
                 				SubModuleAmount = ifnull(SubModules.Amount,0);
                 				if(SubModules.Fee_Component.Component_Name == "Tution Fee")
                 				{
                 					SubModuleAmount = ifnull(SubModules.Amount,0) * NumberofMonths;
                 				}
                 				StudentFeeSubformID = insert into Student_Fee_Subform
                 				[
                 					Added_User=zoho.loginuser
                 					Student_Fee_Details=NewOverallStudentFee
                 					Fee_Head=SubModules.Fee_Component
                 					Fee_Amount=SubModuleAmount
                 					Total_Concession_Amount=0
                 					Net_Amount=SubModuleAmount
                 					Paid_Amount=0
                 					Balance_Amount=SubModuleAmount
                 				];
                 				StudentFeeSubformDetails = Student_Fee_Subform[ID == StudentFeeSubformID];
                 				StudentFeeSubformDetails.Update_Concession=if(StudentFeeSubformDetails.Disable_Concession,"<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>","<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Student_Fee_Subform?recLinkID=" + StudentFeeSubformDetails.ID + "&viewLinkName=Student_Fee_Subform_Report&action_field=updateconcession&zc_LoadIn=dialog\">Update</a>");
                 				ComponentTotal = ComponentTotal + SubModuleAmount;
                 			}
                 			Componentname = Fee_Component[Component_Name == "Transportation Fee"];
                 			Busfee = 0;
                 			if(StudentInfo.Pickup_Point != null)
                 			{
                 				if(StudentInfo.Transport_Service_Type == "One Way")
                 				{
                 					Busfee = Bus_Stops[ID == StudentInfo.Pickup_Point].One_Way_Charges;
                 				}
                 				else
                 				{
                 					Busfee = Bus_Stops[ID == StudentInfo.Pickup_Point].Two_Way_Charges;
                 				}
                 				Busfee = Busfee * NumberofMonths;
                 			}
                 			StudentFeeSubformID_2 = insert into Student_Fee_Subform
                 			[
                 				Added_User=zoho.loginuser
                 				Student_Fee_Details=NewOverallStudentFee
                 				Fee_Head=Componentname.ID
                 				Fee_Amount=Busfee
                 				Total_Concession_Amount=0
                 				Net_Amount=Busfee
                 				Paid_Amount=0
                 				Balance_Amount=Busfee
                 			];
                 			StudentFeeSubformDetails_2 = Student_Fee_Subform[ID == StudentFeeSubformID_2];
                 			StudentFeeSubformDetails_2.Update_Concession=if(StudentFeeSubformDetails_2.Disable_Concession,"<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>","<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Student_Fee_Subform?recLinkID=" + StudentFeeSubformDetails_2.ID + "&viewLinkName=Student_Fee_Subform_Report&action_field=updateconcession&zc_LoadIn=dialog\">Update</a>");
                 			ComponentTotal = ComponentTotal + Busfee;
                 			NewStudentFeeDetails = Student_Fee_Details[ID == NewOverallStudentFee];
                 			NewStudentFeeDetails.Total_Fee_Amount=ComponentTotal;
                 			NewStudentFeeDetails.Total_Concession_Amount=0;
                 			NewStudentFeeDetails.Total_Net_Amount=ComponentTotal;
                 			NewStudentFeeDetails.Total_Amount_Due=ComponentTotal;
                 		}
                 	}
                 }
				 void LIVE.CreateMonthlyFee(int StdID)
                 {
                 	StudentInfo = Student[ID == StdID];
                 	if(StudentInfo.Pricing_Type == "Monthly Cycle")
                 	{
                 		ActiveAcademicYear = Educational_Year[Status == "Current"];
                 		FeeStructure = Fee_Cycle[Class_Name = StudentInfo.Class_UID && Educational_Year == ActiveAcademicYear.ID];
                 		if(FeeStructure.count() > 0)
                 		{
                 			NewOverallStudentFee = Student_Fee_Details[Academic_Year == ActiveAcademicYear && Student == StudentInfo.ID && Class == StudentInfo.Class_UID];
                 			NumberofMonths = 12;
                 			LoopSplitList = "1".repeat(NumberofMonths - 1).toList("1");
                 			SDate = ActiveAcademicYear.Educational_Year_Start_Date.eomonth(-1).addDay(1).totime();
                 			for each index LoopNo in LoopSplitList
                 			{
                 				MonthVal = SDate.tostring("MMMM");
                 				New_MonthlyFee = insert into Monthly_Fees
                 				[
                 					Added_User=zoho.loginuser
                 					Class=StudentInfo.Class_UID
                 					Date_field=SDate
                 					Educational_Year=ActiveAcademicYear.ID
                 					Month_field1=MonthVal
                 					Student=StudentInfo.ID
                 					Student_Fee_Details=NewOverallStudentFee
                 				];
                 				if(MonthVal == ActiveAcademicYear.Educational_Year_Start_Date.tostring("MMMM"))
                 				{
                 					StudentFeeSubform = Student_Fee_Subform[ID in NewOverallStudentFee.Fee_Details];
                 				}
                 				else
                 				{
                 					StudentFeeSubform = Student_Fee_Subform[ID in NewOverallStudentFee.Fee_Details && Fee_Head.Monthly_Recurring];
                 				}
                 				MonthTotal = 0;
                 				for each  EachStudentfee in StudentFeeSubform
                 				{
                 					if(EachStudentfee.Fee_Head.Monthly_Recurring)
                 					{
                 						MonthlySubform_Amount = Student_Fee_Subform[Student_Fee_Details == NewOverallStudentFee.ID && Fee_Head == EachStudentfee.Fee_Head].Net_Amount / NumberofMonths;
                 					}
                 					else
                 					{
                 						MonthlySubform_Amount = Student_Fee_Subform[Student_Fee_Details == NewOverallStudentFee.ID && Fee_Head == EachStudentfee.Fee_Head].Net_Amount;
                 					}
                 					insert into Monthly_Fee_Subform
                 					[
                 						Added_User=zoho.loginuser
                 						Fee_Head=EachStudentfee.Fee_Head
                 						Monthly_Fees=New_MonthlyFee
                 						Fee_Amount=MonthlySubform_Amount
                 						Balance_Amount=MonthlySubform_Amount
                 						Received_Amount=0
                 					]
                 					MonthTotal = MonthTotal + ifnull(MonthlySubform_Amount,0);
                 				}
                 				update Monthly_Fees[ID == New_MonthlyFee]
                 				[
                 					Total_Balance_Amount=MonthTotal
                 					Total_Fee_Amount=MonthTotal
                 					Total_Received_Amount=0
                 					Update1="<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Monthly_Fees?recLinkID=" + New_MonthlyFee + "&viewLinkName=All_Monthly_Fees&action_field=updatefromstudentfee&zc_LoadIn=dialog\">Update</a>"
                 				];
                 				SDate = SDate.addMonth(1);
                 			}
                 		}
                 	}
                 }
				 void questionPaper.createQuestionPaper(int cqp)
                 {
                 	quesPapers = Map();
                 	quesPaper = "";
                 	ques = Create_Question_Paper[ID == input.cqp];
                 	// 	info ques.Questions;
                 	for each  rec in ques.Questions
                 	{
                 		quesPaper = quesPaper + " Marks " + rec.Marks;
                 		listMap = List();
                 		str = "";
                 		questions = Question_Paper_DB[Marks == rec.Marks && Subject_form == ques.Subject_form && Module == rec.Module].Question.getAll();
                 		str = str.leftpad(rec.Total_Number_of_Questions - 1);
                 		strList = str.toList(" ");
                 		for each  data in strList
                 		{
                 			quesPaper = quesPaper + " ";
                 			rand = randomNumber(0,questions.size() - 1);
                 			quesPaper = quesPaper + questions.get(rand);
                 			listMap.add(questions.get(rand));
                 			questions.remove(rand);
                 		}
                 		quesPapers.put(rec.Marks.Marks,listMap);
                 		// 		info quesPapers;
                 	}
                 	ques.Questions1=quesPapers.toString();
                 }
				 void questionPaper.createQuestionPaperV2(String cqp)
                 {
                 	bluePrint = Create_Question_Paper[ID == input.cqp.toNumber()];
                 	allMarks = CQP_Sub[Create_Question_Paper == bluePrint.ID].Marks.getAll();
                 	allQuesList = List();
                 	for each  ele in allMarks
                 	{
                 		mark = Marks[ID == ele];
                 		quesMap = Map();
                 		quesMap.put("marks",mark.Marks);
                 		totalQuestions = 0;
                 		totalOptionalQuestions = 0;
                 		quesList = List();
                 		allQuesInMarks = CQP_Sub[Create_Question_Paper == bluePrint.ID && Marks == mark.ID];
                 		for each  ques in allQuesInMarks
                 		{
                 			totalQuestions = totalQuestions + ques.Total_Number_of_Questions;
                 			totalOptionalQuestions = totalOptionalQuestions + ques.Number_of_Optional_Questions;
                 			questions = Question_Paper_DB[Marks == mark.ID && Subject_form == bluePrint.Subject_form && Module == ques.Module].Question.getAll();
                 			str = "";
                 			str = str.leftpad(ques.Total_Number_of_Questions - 1);
                 			strList = str.toList(" ");
                 			for each  data in strList
                 			{
                 				rand = randomNumber(0,questions.size() - 1);
                 				quesList.add(questions.get(rand));
                 				questions.remove(rand);
                 			}
                 		}
                 		quesMap.put("option",totalOptionalQuestions);
                 		quesMap.put("totalQuestions",totalQuestions);
                 		quesMap.put("questions",quesList);
                 		allQuesList.add(quesMap);
                 	}
                 	bluePrint.Questions1=allQuesList;
                 }
				 string schoolManagement.findTeacherLocation(date Date_Time, String staffId)
                 {
                 	//4598862000000136390
                 	staff = Staff[ID == staffId.toNumber()];
                 	if(input.Date_Time == null)
                 	{
                 		Date_Time = zoho.currenttime;
                 	}
                 	if(input.Date_Time.toDate() == zoho.currentdate)
                 	{
                 		staffAttendance = Staff_Attendance[Staff == staff && Date_field == input.Date_Time.toDate()];
                 		if(staffAttendance.Status == "Absent")
                 		{
                 			return "Absent";
                 		}
                 		else
                 		{
                 			searchTimeVal = input.Date_Time;
                 			st = "09:00";
                 			en = "17:00";
                 			schoolStartTime = (input.Date_Time.toDate().toString() + " " + st.toString()).toTime();
                 			schoolEndTime = (input.Date_Time.toDate().toString() + " " + en.toString()).toTime();
                 			if(searchTimeVal < schoolStartTime || searchTimeVal > schoolEndTime)
                 			{
                 				returnText = "Out of working hours";
                 				return returnText;
                 			}
                 			else
                 			{
                 				allAvailableSessions = Session_Subform[Session_Start_Time == input.Date_Time.toDate() && Staff == staff.ID];
                 				staffRoom = "Yet to allocate session";
                 				for each  sesy in allAvailableSessions
                 				{
                 					startTime = sesy.Session_Name.toList("-").get(0).trim();
                 					startTimeToday = input.Date_Time.toDate().toString() + " " + startTime.toString();
                 					startTimeVal = startTimeToday.toTime();
                 					endTime = sesy.Session_Name.toList("-").get(1).trim();
                 					endTimeToday = input.Date_Time.toDate().toString() + " " + endTime.toString();
                 					endTimeVal = endTimeToday.toTime();
                 					if(startTimeVal <= searchTimeVal && endTimeVal >= searchTimeVal)
                 					{
                 						reqBlock = Block1[ID == sesy.Room.block];
                 						staffRoom = sesy.Session_Name + " is happening in " + sesy.Room.Room_Number + "-" + reqBlock.Block_Name;
                 						break;
                 					}
                 				}
                 				return staffRoom;
                 			}
                 		}
                 	}
                 	else
                 	{
                 		searchTimeVal = input.Date_Time;
                 		st = "09:00";
                 		en = "17:00";
                 		schoolStartTime = (input.Date_Time.toDate().toString() + " " + st.toString()).toTime();
                 		schoolEndTime = (input.Date_Time.toDate().toString() + " " + en.toString()).toTime();
                 		if(searchTimeVal < schoolStartTime || searchTimeVal > schoolEndTime)
                 		{
                 			returnText = "Out of working hours";
                 			return returnText;
                 		}
                 		else
                 		{
                 			allAvailableSessions = Session_Subform[Sessions.Date_field == input.Date_Time.toDate() && Staff == staff.ID];
                 			staffRoom = "Yet to allocate session";
                 			for each  sesy in allAvailableSessions
                 			{
                 				startTime = sesy.Session_Name.toList("-").get(0).trim();
                 				startTimeToday = input.Date_Time.toDate().toString() + " " + startTime.toString();
                 				startTimeVal = startTimeToday.toTime();
                 				endTime = sesy.Session_Name.toList("-").get(1).trim();
                 				endTimeToday = input.Date_Time.toDate().toString() + " " + endTime.toString();
                 				endTimeVal = endTimeToday.toTime();
                 				if(startTimeVal <= searchTimeVal && endTimeVal >= searchTimeVal)
                 				{
                 					reqBlock = Block1[ID == sesy.Room.block];
                 					staffRoom = "Available in Room " + sesy.Room.Room_Number + "-" + reqBlock.Block_Name + " at " + searchTimeVal;
                 					break;
                 				}
                 			}
                 			return staffRoom;
                 		}
                 	}
                 	return "";
                 }
				 list schoolManagement.getAbsentTeachers()
                 {
                 	staff = Staff_Attendance[Date_field == zoho.currentdate && Status == "Absent"].Staff.getAll();
                 	return staff;
                 }
				 int schoolManagement.getCurrentEducationalYear()
                 {
                 	eduYear = Educational_Year[Status == "Current"];
                 	return eduYear.ID;
                 }
				 int schoolManagement.getRoomType()
                 {
                 	roomType = Room_Type[Room_Type == "Class Room"];
                 	return roomType.ID;
                 }
				 int schoolManagement.getStaffId()
                 {
                 	staff = Staff[Email_ID == zoho.loginuserid];
                 	return staff.ID;
                 }
				 list schoolManagement.getStaffSubjects()
                 {
                 	eduYear = Educational_Year[Status == "Current"];
                 	subjects = Lesson_Plan_Mapping[Staff.Email_ID == zoho.loginuserid && Subject_field.Educational_Year == eduYear].Subject_field.getAll();
                 	return subjects;
                 }
				 int schoolManagement.getStudentId()
                 {
                 	stud = Student[Email == zoho.loginuserid];
                 	return stud.ID;
                 }
				 string schoolManagement.SchoolLogo(int width, int height)
                 {
                 	SchoolInfo = School_Details[ID != 0];
                 	image_name = SchoolInfo.Logo.getSuffix("/image/").getPrefix("\"");
                 	ReportLinkName = "All_School_Details";
                 	FormID = SchoolInfo.ID;
                 	ImageFieldName = "Logo";
                 	image_link = "https://creatorapp.zoho.in" + zoho.appuri + "report/" + ReportLinkName + "/" + FormID + "/" + ImageFieldName + "/download-file?filepath=/" + image_name;
                 	return "<img src=\"" + image_link + "\" width=\"" + width + "\" height=\"" + height + "\">";
                 }
				 void schoolManagement.staffLogIn()
                 {
                 	staff = Staff[Email_ID == zoho.loginuserid];
                 	logRec = Staff_Attendance[Staff == staff && Date_field == zoho.currentdate];
                 	if(logRec.count() != 0)
                 	{
                 		if(logRec.Status == "Absent")
                 		{
                 			logRec.Login_Time=zoho.currenttime;
                 		}
                 		logRec.Status="Logged In";
                 	}
                 }
				 void schoolManagement.staffLogOut()
                 {
                 	staff = Staff[Email_ID == zoho.loginuserid];
                 	logRec = Staff_Attendance[Date_field == zoho.currentdate && Staff == staff];
                 	if(logRec.count() != 0)
                 	{
                 		logRec.Status="Away";
                 		logRec.Logout_Time=zoho.currenttime;
                 		logRec.Log_Time=logRec.Login_Time.timeBetween(logRec.Logout_Time);
                 	}
                 }
				 int ServiceRequest.checkDuplicateAssetId()
                 {
                 	randomNumber = randomNumber(100000000,999999999);
                 	asset = Asset_Mapping[Asset_ID == randomNumber.toString()];
                 	if(asset.count() == 0)
                 	{
                 		return randomNumber;
                 	}
                 	else
                 	{
                 		thisapp.ServiceRequest.checkDuplicateAssetId();
                 		return "oh";
                 	}
                 }
