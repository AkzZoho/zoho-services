			createDailyStaffAttendanc as "createDailyStaffAttendance"
			{
				type =  schedule
				form = Educational_Year
				start = Educational_Year_Start_Date at "08:10:00"
				end   = Educational_Year_End_Date
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						// str = "";
										// str = str.leftpad(100);
										// str = str.toList(" ");
										// for each data in str
										// {
										//4598862000000136199
										if(zoho.currentdate.weekday() != 1)
										{
											for each  staff in Staff[Status == "Active"]
											{
												resp = insert into Staff_Attendance
												[
													Added_User=zoho.loginuser
													Staff=staff.ID
													Status="Absent"
													Date_field=zoho.currentdate
												];
											}
										}
										// }
										//4254807000205986063
					)
					}
				}
			}
			modifyStatusOnStart1 as "modifyStatusOnStart"
			{
				type =  schedule
				form = Exam_Schedule
					status = inactive
				start = Exam_Start_Time
