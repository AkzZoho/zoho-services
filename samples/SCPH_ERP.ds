		{
			displayname = "Room Requests"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet50' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet50()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t\t\t\n&lt;div class=&quot;main-container&quot;&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;Room_Requests1&apos; params=&apos;zc_Header=true&amp;zc_AddRec=false&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Hostel_Dashboard
		{
			displayname = "Hostel Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet51' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet51()\ncontent\n&lt;%{\n\tstudents = Student[Hosteller == true &amp;&amp; Status == &quot;Active&quot; &amp;&amp; Hostel_Room_Allotted == true].count();\n\trooms = Room[Room_Type1 == Room_Type[Room_Type == &quot;Hostel&quot;].ID].count();\n\thostel = Room_Type[Room_Type == &quot;Hostel&quot;].ID;\n\toccupied = Room[Room_Type1 == hostel &amp;&amp; Room_Status == &quot;Occupied&quot;].count();\n\tvacancy = Room[Room_Type1 == hostel &amp;&amp; Room_Status == &quot;Empty&quot;].count();\n\t%&gt;\n&lt;%=rooms%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\t&lt;style&gt;\n\t\t*{\n\t\t\tmargin:0;\n\t\t\tpadding:0;\n\t\t\tbox-sizing:border-box;\n\t\t}\n\t\t\n\t\t.panels{\n\t\t\tdisplay: flex;\n\t\t\tpadding-bottom:10px;\n\t\t\tgap: 10px;\n\t\t  }\n\n\t\t  .panels .panel {\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tflex: 1;\n\t\t\theight: 95px;\n\t\t\tbackground:var(--panel-background-color);\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t\tborder-radius: 5px;\n\t\t\tposition:relative;\n\t\t\toverflow:hidden;\n\t\t  }\n\n\t\t  .panels .panel span:nth-child(2) {\n\t\t\t  font-size: 2rem;\n\t\t  }\n\t\t  \n\t\t  .panels .panel span:first-child {\n\t\t\t  font-size: 16px;\n\t\t  }\n\t\t  \n\t\t  .panel{\n\t\t\tgap:5px;\n\t\t  }\n\t\t   .panel-icon img {\n    \t\theight: 100%;\n\t\t\tpadding: 7px;\n\t\t\tfilter: brightness(0) invert(1);\n\t\t}\n\t\t\n\t\t.panel-icon {\n\t\t\theight: 50px;\n\t\t\twidth: 50px;\n\