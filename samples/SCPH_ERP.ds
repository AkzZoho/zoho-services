			onUserInputOfStaff as "onUserInputOfStaff"
			{
				type =  form
				form = Find_Person
				record event = on add

				on user input of Staff
				{
					actions 
					{
						custom deluge script
						(
											if(input.Staff != null)
										{
											if(input.Date_Time == null)
											{
												alert "Please Enter the Time First";
												input.Staff = null;
											}
											else
											{
												if(input.Date_Time.toDate() == zoho.currentdate)
												{
													staffAttendance = Staff_Attendance[Staff == input.Staff && Date_field == input.Date_Time.toDate()];
													if(staffAttendance.Status == "Absent")
													{
														input.plain = "The Selected Staff is Absent";
													}
													else
													{
														searchTime = input.Date_Time.toDate().toString() + " " + input.Time.toString();
														searchTimeVal = input.Date_Time;
														st = "09:00";
														en = "17:00";
														schoolStartTime = (input.Date_Time.toDate().toString() + " " + st.toString()).toTime();
														schoolEndTime = (input.Date_Time.toDate().toString() + " " + en.toString()).toTime();
														if(searchTimeVal < schoolStartTime)
														{
															returnText = "School is yet to Start";
															input.plain = returnText;
														}
														else if(searchTimeVal > schoolEndTime)
														{
															returnText = "School is already Closed";
															input.plain = returnText;
														}
														else
														{
															allAvailableSessions = Session_Subform[Sessions.Date_field == input.Date_Time.toDate() && Staff == input.Staff.ID];
															staffRoom = "Not Available";
															for each  sesy in allAvailableSessions
															{
																startTime = sesy.Session_Name.toList("-").get(0).trim();
																startTimeToday = input.Date_Time.toDate().toString() + " " + startTime.toString();
																startTimeVal = startTimeToday.toTime();
																endTime = sesy.Session_Name.toList("-").get(1).trim();
																endTimeToday = input.Date_Time.toDate().toString() + " " + endTime.toString();
																endTimeVal = endTimeToday.toTime();
																if(startTimeVal <= searchTimeVal && endTimeVal >= searchTimeVal)
																{
																	reqBlock = Block1[ID == sesy.Room.block];
																	staffRoom = "The Required Person is available in Room " + sesy.Room.Room_Number + " at " + reqBlock.Block_Name + " at " + searchTimeVal;
																	break;
																}
															}
															input.plain = staffRoom;
														}
													}
												}
												else
												{
													searchTime = input.Date_Time.toDate().toString() + " " + input.Time.toString();
													searchTimeVal = input.Date_Time;
													st = "09:00";
													en = "17:00";
													schoolStartTime = (input.Date_Time.toDate().toString() + " " + st.toString()).toTime();
													schoolEndTime = (input.Date_Time.toDate().toString() + " " + en.toString()).toTime();
													if(searchTimeVal < schoolStartTime)
													{
														returnText = "School is yet to Start";
														input.plain = returnText;
													}
													else if(searchTimeVal > schoolEndTime)
													{
														returnText = "School is already Closed";
														input.plain = returnText;
													}
													else
													{
														allAvailableSessions = Session_Subform[Sessions.Date_field == input.Date_Time.toDate() && Staff == input.Staff.ID];
														staffRoom = "Not Available";
														for each  sesy in allAvailableSessions
														{
															startTime = sesy.Session_Name.toList("-").get(0).trim();
															startTimeToday = input.Date_Time.toDate().toString() + " " + startTime.toString();
															startTimeVal = startTimeToday.toTime();
															endTime = sesy.Session_Name.toList("-").get(1).trim();
															endTimeToday = input.Date_Time.toDate().toString() + " " + endTime.toString();
															endTimeVal = endTimeToday.toTime();
															if(startTimeVal <= searchTimeVal && endTimeVal >= searchTimeVal)
															{
																reqBlock = Block1[ID == sesy.Room.block];
																staffRoom = "The Required Person is available in Room " + sesy.Room.Room_Number + " at " + reqBlock.Block_Name + " at " + searchTimeVal;
																break;
															}
														}
														input.plain = staffRoom;
													}
												}
											}
										}
										else
										{
											input.plain = "Enter Staff or Student to Search";
										}
						)
					}
				}

			}
			onUserInputOfStudent as "onUserInputOfStudent"
			{
				type =  form
				form = Find_Person
				record event = on add

				on user input of Student
				{
					actions 
					{
						custom deluge script
						(
											if(input.Student != null)
										{
											lunchy = Subject_form[Subject_Name.equalsIgnoreCase("Lunch")];
											if(input.Date_Time == null)
											{
												alert "Please Enter the Time First";
												input.Student = null;
											}
											else
											{
												// 		classAttendance =  Student_Attendance [ Date_field == <expression> ];
												returnText = "";
												searchTime = input.Date_Time.toDate().toString() + " " + input.Time.toString();
												searchTimeVal = input.Date_Time;
												// 		timTab =  Time_Table_Subform [ Time_Table.Class == input.Student.Class] sort by Added_Time  ;
												// 		timTabEnd =  Time_Table_Subform [ Time_Table.Class == input.Student.Class] sort by Added_Time Desc;
												st = "09:00";
												en = "17:00";
												schoolStartTime = (input.Date_Time.toDate().toString() + " " + st.toString()).toTime();
												schoolEndTime = (input.Date_Time.toDate().toString() + " " + en.toString()).toTime();
												if(searchTimeVal < schoolStartTime)
												{
													returnText = "School is yet to Start";
												}
												else if(searchTimeVal > schoolEndTime)
												{
													returnText = "School is already Closed";
												}
												else
												{
													timeTable = Time_Table_Subform[Class == input.Student.Class_UID];
													allStaffRelatedToStudent = Lesson_Plan_Mapping[Subject_field.Educational_Year == thisapp.schoolManagement.getCurrentEducationalYear() && Student == input.Student].Staff.getAll();
													studentRelatedStaff = Session_Subform[Sessions.Date_field == input.Date_Time && Staff == allStaffRelatedToStudent];
													for each  sesy in timeTable
													{
														startTime = sesy.Time.toList("-").get(0).trim();
														startTimeToday = input.Date_Time.toDate().toString() + " " + startTime.toString();
														startTimeVal = startTimeToday.toTime();
														endTime = sesy.Time.toList("-").get(1).trim();
														endTimeToday = input.Date_Time.toDate().toString() + " " + endTime.toString();
														endTimeVal = endTimeToday.toTime();
														if(startTimeVal <= searchTimeVal && endTimeVal >= searchTimeVal)
														{
															if(input.Date_Time.weekday() == 2)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Monday1 && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Monday1 == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time.toDate() && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															if(input.Date_Time.weekday() == 3)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Tuesday1 && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Tuesday1 == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form.Subject_Name + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															if(input.Date_Time.weekday() == 4)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Wednesday && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Wednesday == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form.Subject_Name + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															if(input.Date_Time.weekday() == 5)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Thursday && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Thursday == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form.Subject_Name + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															if(input.Date_Time.weekday() == 6)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Friday && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Friday == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form.Subject_Name + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															if(input.Date_Time.weekday() == 7)
															{
																studentCount = Lesson_Plan_Mapping[Subject_field == sesy.Saturday && Student == input.Student];
																if(studentCount.count() == 0)
																{
																	if(sesy.Saturday == lunchy.ID)
																	{
																		returnText = "The Required Person is in Lunch";
																	}
																}
																else
																{
																	sessionValue = Session_Subform[Sessions.Date_field == input.Date_Time && ID == studentRelatedStaff.ID.getall() && Session_Name == sesy.Time];
																	relatedBlock = Block1[ID == sessionValue.Room.block];
																	returnText = "The Selected Student is attending the " + sessionValue.Subject_form.Subject_Name + " class in Room No - " + sessionValue.Room.Room_Number + " at " + relatedBlock.Block_Name + " at " + searchTimeVal;
																}
															}
															break;
														}
													}
													returnText = if(returnText != "",returnText,"The Student is in Break");
													// 		input.plain = staffRoom;
												}
												input.plain = returnText;
											}
										}
										else
										{
											input.plain = "Enter Staff or Student to Search";
										}
						)
					}
				}

			}
