			On_Load20 as "On Load"
			{
				type =  form
				form = Student_Fee_Subform
				record event = on edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.action_field == "updateconcession")
										{
											disable Fee_Head;
											disable Fee_Amount;
											disable Net_Amount;
											disable Paid_Amount;
											disable Total_Concession_Amount;
											disable Balance_Amount;
											hide Student_Fee_Details;
											hide Update_Concession;
											hide Concession_Details.Fee_Head;
											disable Concession_Details.Concession_Amount;
										}
						)
					}
				}

			}
			Update_of_Concession as "Update of Concession"
			{
				type =  form
				form = Student_Fee_Subform
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.action_field == "updateconcession")
										{
											StudentFee = Student_Fee_Details[ID == input.Student_Fee_Details];
											StudentFee.Total_Amount_Paid=Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details].sum(Paid_Amount);
											StudentFee.Total_Amount_Due=Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details].sum(Balance_Amount);
											StudentFee.Total_Concession_Amount=Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details].sum(Total_Concession_Amount);
											StudentFee.Total_Net_Amount=ifnull(StudentFee.Total_Fee_Amount,0) - ifnull(StudentFee.Total_Concession_Amount,0);
											for each  MonthlyFeeSubform in Monthly_Fee_Subform[Monthly_Fees.Student_Fee_Details == input.Student_Fee_Details && Fee_Head == input.Fee_Head]
											{
												if(input.Fee_Head.Monthly_Recurring == true)
												{
													ActiveAcademicYear = Educational_Year[Status == "Current"];
													NumberofMonths = 12;
													MonthlyFeeSubform.Fee_Amount=input.Net_Amount / NumberofMonths;
												}
												else
												{
													MonthlyFeeSubform.Fee_Amount=input.Net_Amount;
												}
												MonthlyFeeSubform.Balance_Amount=MonthlyFeeSubform.Fee_Amount - MonthlyFeeSubform.Received_Amount;
												MonthlyFee = Monthly_Fees[ID == MonthlyFeeSubform.Monthly_Fees];
												MonthlyFee.Total_Fee_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Fee_Amount);
												MonthlyFee.Total_Received_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Received_Amount);
												MonthlyFee.Total_Balance_Amount=Monthly_Fee_Subform[Monthly_Fees == MonthlyFee].sum(Balance_Amount);
											}
											input.Update_Concession = if(input.Disable_Concession,"<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>","<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Student_Fee_Subform?recLinkID=" + input.ID + "&viewLinkName=Student_Fee_Subform_Report&action_field=updateconcession&zc_LoadIn=dialog\">Update</a>");
										}
										input.action_field = "";
										openUrl("#Script:page.parent.reload","parent window");
						)
					}
				}

			}
