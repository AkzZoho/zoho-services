			addClasses as "addClasses"
			{
				type =  form
				form = Student_Selection
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											// clear input.Class ;
										hide Registration;
										hide Vacancy_after_adding_the_student;
										// vacantClasses = Vacancy[Vacant_Seats != 0].Class.getAll();
										upEduYear = Educational_Year[Status == "Upcoming"];
										if(upEduYear.count() == 1)
										{
											classes = Class[Educational_Year == upEduYear && Vacancy > 0 && Class == input.Registration.Applying_for_Class].ID.getAll();
										}
										else
										{
											eduYear = Educational_Year[Status == "Current"];
											classes = Class[Educational_Year == eduYear && Vacancy > 0 && Class == input.Registration.Applying_for_Class].ID.getAll();
										}
										if(classes.size() == 0)
										{
											openUrl("#Script:page.dialog.close","same window");
											alert "No Vaccancy";
										}
										else
										{
											input.Class:ui.add(classes);
										}
						)
					}
				}

			}
