				 void dataImport.addClass()
                 {
                 	departments = {"MECH","AERO","ROBO","CIVIL","ELEC","COMP","BIOMED"};
                 	for each  dept in departments
                 	{
                 		resp = insert into Class_DB
                 		[
                 			Added_User=zoho.loginuser
                 			Class=dept
                 			Upcoming_Classes_Creation_Status="Yet to Create"
                 		];
                 	}
                 	classes = {"I-MECH-A","II-MECH-A","III-MECH-A","IV-MECH-A","I-AERO-A","II-AERO-A","III-AERO-A","IV-AERO-A","I-ROBO-A","II-ROBO-A","III-ROBO-A","IV-ROBO-A","I-CIVIL-A","II-CIVIL-A","III-CIVIL-A","IV-CIVIL-A","I-ELEC-A","II-ELEC-A","III-ELEC-A","IV-ELEC-A","I-COMP-A","II-COMP-A","III-COMP-A","IV-COMP-A","I-BIOMED-A","II-BIOMED-A","III-BIOMED-A","IV-BIOMED-A"};
                 	deptId = 0;
                 	for each  clas in classes
                 	{
                 		if(clas.containsIgnoreCase("MECH"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("MECH")];
                 		}
                 		else if(clas.containsIgnoreCase("AERO"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("AERO")];
                 		}
                 		else if(clas.containsIgnoreCase("ROBO"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("ROBO")];
                 		}
                 		else if(clas.containsIgnoreCase("CIVIL"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("CIVIL")];
                 		}
                 		else if(clas.containsIgnoreCase("BIOMED"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("BIOMED")];
                 		}
                 		else if(clas.containsIgnoreCase("ELEC"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("ELEC")];
                 		}
                 		else if(clas.containsIgnoreCase("COMP"))
                 		{
                 			deptId = Class_DB[Class.equalsIgnoreCase("COMP")];
                 		}
                 		cla = insert into Class
                 		[
                 			Student_Capacity=60
                 			Educational_Year=thisapp.schoolManagement.getCurrentEducationalYear()
                 			Class=deptId
                 			Added_User=zoho.loginuser
                 			Status="Active"
                 			Class_Name=clas
                 		];
                 	}
                 }
				 void dataImport.addEducationalYear()
                 {
                 	resp = insert into Educational_Year
                 	[
                 		Academic_Year=zoho.currentdate.subDay(30).subYear(2).getYear() + " - " + zoho.currentdate.subDay(30).subYear(1).getYear()
                 		Educational_Year_End_Date=zoho.currentdate.subDay(30).subYear(1)
                 		Educational_Year_Start_Date=zoho.currentdate.subDay(30).subYear(2)
                 		Added_User=zoho.loginuser
                 		Status="Past"
                 	];
                 	resp = insert into Educational_Year
                 	[
                 		Academic_Year=zoho.currentdate.subDay(30).subYear(1).getYear() + " - " + zoho.currentdate.subDay(30).getYear()
                 		Educational_Year_End_Date=zoho.currentdate.subDay(30)
                 		Educational_Year_Start_Date=zoho.currentdate.subDay(30).subYear(1)
                 		Added_User=zoho.loginuser
                 		Status="Past"
                 	];
                 	resp = insert into Educational_Year
                 	[
                 		Academic_Year=zoho.currentdate.subDay(30).getYear() + " - " + zoho.currentdate.subDay(30).addYear(1).getYear()
                 		Educational_Year_End_Date=zoho.currentdate.subDay(30).addYear(1)
                 		Educational_Year_Start_Date=zoho.currentdate.subDay(30)
                 		Added_User=zoho.loginuser
                 		Status="Current"
                 	];
                 }
