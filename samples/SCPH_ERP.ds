			substitution as "substitution"
			{
				type =  functions
				form = Session_Subform
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						// session = Session_Subform[ID == input.Session_Subform];
										mainSession = Sessions[ID == input.Sessions];
										sess = Session_Subform[Sessions.Date_field == mainSession.Date_field && Session_Name == input.Session_Name].Staff.getAll();
										allStaff = Staff[Status == "Active" && Staff_Type == "Teaching Staff"].ID.getAll();
										allStaff.removeAll(sess);
										if(allStaff.size() == 0)
										{
											openUrl("#Form:Alert?alert=There are no available teachers for the selected session&zc_Header=false","popup window");
										}
										else
										{
											openUrl("#Form:Substitution?Session_Subform=" + input.ID,"popup window");
										}
					)
					}
				}
			}
