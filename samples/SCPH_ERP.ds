stom-btn top-btn&quot;  href=&quot;#Form:Create_Event?zc_LoadIn=dialog&quot;&gt;Add Event&lt;\/a&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;event-content&quot;&gt;\n&lt;%\n\tif(myEvents.count() &gt; 0)\n\t{\n\t\tfor each  event in myEvents\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;event-wrapper&quot;&gt;\n\t\t\t\t&lt;div class=&quot;date&quot;&gt;\n\t\t\t\t\t&lt;span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;MMM&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;dd&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;yyyy&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;event-info&quot;&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Location%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-events&quot;&gt;\n\t&lt;img style=&quot;filter: drop-shadow(0px 0px 1px black);&quot; src=&quot;https:\/\/img.icons8.com\/external-outline-design-circle\/2x\/external-Events-seo-development-and-marketing-outline-design-circle.png&quot; width=&quot;50px&quot;&gt;\n\t&lt;p style=&apos;margin-top:10px;&apos;&gt;No Events Available...&lt;\/p&gt;\n\t&lt;a class=&quot;custom-btn&quot; href=&quot;#Form:Create_Event?zc_LoadIn=dialog&quot;&gt;Add Event&lt;\/a&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;exams-tab&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Exams&apos; params=&apos;zc_Header=true&amp;zc_MoreAction=true&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;student-percentage-pivot&quot;&gt;\n\n\t\n\t\t&lt;div class=&quot;student-percentage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Percentage&apos; params=&apos;&apos;&gt;&lt;\/div&gt;\n\n\t\n\t\t\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Admission_Dashboard2
		{
			displayname = "Admission Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet16' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet16()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;%\n\tmyLeads = Lead[Agent.Email_ID == zoho.loginuserid];\n\tmyLeads_count = myLeads.count();\n\tallLeads = Lead[ID != 0].count();\n\tregistrations = Registration[Lead in myLeads].count();\n\twaitingList = Registration[Status == &quot;Waiting List&quot; &amp;&amp; Lead in myLeads].count();\n\tconversions = Registration[Status == &quot;Class Assigned&quot; &amp;&amp; Lead in myLeads].count();\n\t%&gt;\n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  \tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n      .zc-form-popup-container {\n\t\t  background: white !important;\n\t\t  }\n\t  \n     .row1-panels {\n\/*           padding: 10px 0; *\/\n      }\n\t  .header\n\t  {\n\t\t padding: 10px 0; \n\t  }\n      \n      .panels{\n          display: flex;\n          padding: 10px 0;\n      }\n     \n      .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        cursor: pointer;\n        padding: 15px;\n        position:relative;\n        overflow:hidden;\n      }\n      \n\t  .panels .panel span:nth-child(2) {\n          font-size: 2rem;\n      }\n      .panels .panel span:first-child {\n          font-size: 16px;\n      }\n      .panel{\n        gap:5px;\n      }\n        .circle-design,.circle-design:before,.circle-design:after\n        {\n            position:absolute;\n            border-radius:50%;\n            width: 56px;\n            height: 56px;\n        }\n        .circle-design {\n\t\t\tbackground: var(--circle-color);\n\t\t\ttop: calc(100% - 40px);\n\t\t\tleft: calc(100% - 40px);\n\t\t\tz-index: 1;\n\t\t\ttransform-style: preserve-3d;\n\t\t}\n\t\t.circle-design:before {\n\t\t\tbackground: var(--before-circle-color);\n\t\t\ttop: calc(100% - 82px);\n\t\t\tleft: calc(100% - 42px);\n\t\t\tcontent: &quot;&quot;;\n\t\t\tz-index: 0;\n\t\t\ttransform: translateZ(-1px);\n\t\t}\n\t\t.circle-design:after {\n\t\t\tbackground: var(--after-circle-color);\n\t\t\ttop: calc(100% - 42px);\n\t\t\tleft: calc(100% - 82px);\n\t\t\tcontent: &quot;&quot;;\n\t\t\ttransform: translateZ(-1px);\n\t\t}\n\/*form styles *\/\n\t\t.tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.tab_search .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t.tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.tab_search form[name=&quot;Report_Search&quot;].label-left {\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t.tab_search .flLeft.tempContDiv.zc-Radio {\n           width: 100% !important;\n        }\n\t\t.tab_search .flLeft.tempContDiv.zc-Radio {\n    grid-template-columns: 60% 40% 0%;\n    display: grid !important;\n    width: 100% !important;\n    border-bottom: 2px solid var(--header-line-color);\n}\n\t.tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t.tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\t\n\t\tdiv#All_Students_ZC_OZFMQ5\n\t\t{\n\t\t\t box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%) !important;\n\t\t}\n\t\t  \n\t\tdiv[formlinkname=&quot;Report_Search&quot;] {\n\t\t\theight: 30px !important;\n\t\t}\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t}\n\t\t\n\t\t.header {\n\t\t\theight: calc(100% - 115px);\n\t\t}\n\t\t\n\t\t.header&gt;div:last-child {\n\t\t\theight: calc(100% - 30px) !important;\n\t\t\tmargin-top: 10px !important;\n\t\t}\n\t\t\n\t\t\/* Hide - Form Loader Icon *\/\n\t\t.tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n      &lt;div class=&quot;row1-panels&quot;&gt;\n          &lt;div class=&quot;panels&quot;&gt;\n              &lt;div class=&quot;panel allleads-panel-container&quot; &gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;All Leads&lt;\/span&gt;\n                  &lt;span class=&quot;total-leads-value&quot;&gt;&lt;%=allLeads%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel myleads-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Leads&lt;\/span&gt;\n                  &lt;span class=&quot;myleads-value&quot;&gt;&lt;%=myLeads_count%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel potential-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Registrations&lt;\/span&gt;\n                  &lt;span class=&quot;potentials-value&quot;&gt;&lt;%=registrations%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel conversion-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Conversion&lt;\/span&gt;\n                  &lt;span class=&quot;conversion-value&quot;&gt;&lt;%=conversions%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel waitinglist-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Waiting List&lt;\/span&gt;   \n                  &lt;span class=&quot;waitinglist-value&quot;&gt;&lt;%=waitingList%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;                 \n              &lt;\/div&gt;\n          &lt;\/div&gt;\n    &lt;\/div&gt;\n    &lt;div class=&quot;header&quot;&gt;\n        &lt;div elName=&apos;zc-component&apos; class=&quot;tab_search&quot; formLinkName=&apos;Report_Search&apos; params=&apos;zc_Header=false&amp;amp;zc_SuccMsg=Data Added Successfully!&amp;amp;zc_SubmitVal=Submit&amp;amp;zc_ResetVal=Reset&apos;&gt;&lt;\/div&gt;\n\t  &lt;div name=&quot;leadpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;My_Leads&apos; class=&quot;pagereport&quot; params=&apos;zc_ReportName=false&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=true&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Admission_Admin_Dashboard
		{
			displayname = "Admission Admin Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"card\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet17' elementName=\"HTML Snippet 1\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet17()\ncontent\n&lt;%{\n\tallLeads = Lead[ID != null].count();\n\tregistrations = Registration[Lead != null].count();\n\tinterviewScheduled = Registration[Status == &quot;Interview Scheduled&quot;].count();\n\twaitingList = Registration[Status == &quot;Waiting List&quot;].count();\n\tselection = Registration[Status == &quot;Selected&quot;].count();\n\t%&gt;\n&lt;style&gt;\n\t* {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t.row1-panels {\n\/*           padding: 10px 0; *\/\n      }\n\t  .header\n\t  {\n\t\t padding: 10px 0; \n\t  }\n      \n      .panels{\n          display: flex;\n          padding: 10px 0;\n      }\n     \n      .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        padding: 15px;\n\t\tpadding-right:70px;\n        position:relative;\n\t\tcursor:pointer;\n      }\n      \n\t  .panels .panel span:nth-child(2) {\n          font-size: 2rem;\n      }\n\t  \n      .panels .panel span:first-child {\n          font-size: 16px;\n      }\n\t  \n      .panel{\n        gap:5px;\n      }\n\t  .panel-icon img {\n    \t\theight: 100%;\n\t\t\tpadding: 7px;\n\t\t\tfilter: brightness(0) invert(1);\n\t\t}\n\t\t\n\t\t.panel-icon {\n\t\t\theight: 50px;\n\t\t\twidth: 50px;\n\t\t\tposition: absolute;\n\t\t\tright: 20px;\n\t\t\tborder-radius: 8px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;row1-panels&quot;&gt;\n          &lt;div class=&quot;panels&quot;&gt;\n              &lt;a href=&quot;#Report:All_Leads?zc_LoadIn=dialog&quot; class=&quot;panel allleads-panel-container&quot; style=&quot;border-left: 5px solid #62c2cc;&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Total Leads&lt;\/span&gt;\n                  &lt;span class=&quot;total-leads-value&quot;&gt;&lt;%=allLeads%&gt;&lt;\/span&gt;\n\t\t\t\t  &lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #62c2cc&quot;&gt;\n\t\t\t\t  &lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/512\/5671\/5671821.png&quot;&gt;\n\t\t\t\t  &lt;\/div&gt;\n              &lt;\/a&gt;\n              &lt;a href=&quot;#Report:All_Registrations?zc_LoadIn=dialog&quot; target=&quot;popup&quot;  class=&quot;panel myleads-panel-container&quot; style=&quot;border-left: 5px solid #ef9a24;&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Total Regstrations&lt;\/span&gt;\n                  &lt;span class=&quot;myleads-value&quot;&gt;&lt;%=registrations%&gt;&lt;\/span&gt;\n\t\t\t\t  &lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #ef9a24;&quot;&gt;\n\t\t\t\t  &lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/512\/942\/942830.png&quot;&gt;\n\t\t\t\t  &lt;\/div&gt;\n              &lt;\/a&gt;\n              &lt;a href=&quot;#Report:Scheduled_Interviews?zc_LoadIn=dialog&quot; class=&quot;panel potential-panel-container&quot; style=&quot;border-left: 5px solid  #60bd03;&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Interview Scheduled&lt;\/span&gt;\n                  &lt;span class=&quot;potentials-value&quot;&gt;&lt;%=interviewScheduled%&gt;&lt;\/span&gt;\n\t\t\t\t  &lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #60bd03&quot;&gt;\n\t\t\t\t  &lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/512\/4745\/4745448.png&quot;&gt;\n\t\t\t\t  &lt;\/div&gt;\n              &lt;\/a&gt;\n              &lt;a href=&quot;#Report:Waiting_List1?zc_LoadIn=dialog&quot; class=&quot;panel conversion-panel-container&quot; style=&quot;border-left: 5px solid  #eadf18;&quot;&gt;\n                  \t&lt;span class=&quot;panel-label&quot; &gt;Waiting List&lt;\/span&gt;\n                  \t&lt;span class=&quot;conversion-value&quot;&gt;&lt;%=waitingList%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #eadf18&quot;&gt;\n\t\t\t\t  \t&lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/128\/2914\/2914250.png&quot;&gt;\n\t\t\t\t  \t&lt;\/div&gt;\n              &lt;\/a&gt;\n              &lt;a href=&quot;#Report:Selected_List?zc_LoadIn=dialog&quot; class=&quot;panel waitinglist-panel-container&quot; style=&quot;border-left: 5px solid #f2489f&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Selection&lt;\/span&gt;   \n                  &lt;span class=&quot;waitinglist-value&quot;&gt;&lt;%=selection%&gt;&lt;\/span&gt;\n\t\t\t\t  &lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #f2489f&quot;&gt;\n\t\t\t\t  &lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/512\/8980\/8980691.png&quot;&gt;\n\t\t\t\t  &lt;\/div&gt;\n              &lt;\/a&gt;\n\t\t\t  &lt;a style=&quot;cursor:unset&quot; class=&quot;panel waitinglist-panel-container&quot; style=&quot;border-left: 5px solid #f2489f&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Registration Fee&lt;\/span&gt;   \n                  &lt;span class=&quot;waitinglist-value&quot;&gt;\u20B9.&lt;%=thisapp.getReportFee()%&gt;&lt;\/span&gt;\n\t\t\t\t  &lt;div class=&quot;panel-icon&quot; style=&quot;background-color: #f2489f&quot;&gt;\n\t\t\t\t  &lt;img src=&quot;https:\/\/cdn-icons-png.flaticon.com\/512\/8980\/8980691.png&quot;&gt;\n\t\t\t\t  &lt;\/div&gt;\n              &lt;\/a&gt;\n          &lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row><row>\n\t<column\n   \t\t width=\"50%\"\n   \t>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet18' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet18()\ncontent\n&lt;%{\n\tenquiry = Lead[ID != 0].count();\n\tregistration = Registration[ID != 0].count();\n\tinterview_scheduled = Registration[Status == &quot;Interview Scheduled&quot;].count();\n\twaiting_list = Registration[Status == &quot;Waiting List&quot;].count();\n\tselection = Registration[Status == &quot;Selected&quot;].count();\n\tall_list = List();\n\tall_list.addAll({registration,interview_scheduled,waiting_list,selection});\n\tmax = enquiry;\n\tfor each  rec in all_list\n\t{\n\t\tif(max &lt; rec)\n\t\t{\n\t\t\tmax = rec;\n\t\t}\n\t}\n\tmod = max % 4;\n\tmax_value = max + 4 - mod;\n\tvalue = max_value \/ 4;\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n*{\n\tmargin:0;\n\tpadding:0;\n\tbox-sizing:border-box;\n}\n div#chart_1 .canvas-component:before {\n    content: &quot;Registration Fee Chart&quot;;\n\tfont-size:16.38px;\n\tfont-weight:700;\n\tposition: absolute;\n    top: 10px;\n    left: 10px;\n }\n  div#chart_2 .canvas-component:before {\n    content: &quot;Student Selection Chart&quot;;\n\tfont-size:16.38px;\n\tfont-weight:700;\n\tposition: absolute;\n    top: 10px;\n    left: 10px;\n }\n\n\n.header\n\t{\n\t\tmargin:10px;\n\t}\n.barchart-Wrapper {\n      display: table;\n      position: relative;\n      margin: 20px;\n      height: 200px;\n    }\n\t\n    .barChart-Container {\n      display: table-cell;\n      width: 100%;\n      height: 100%;\n      padding-left: 15px;\n    }\n    .barchart {\n     display: table;\n     table-layout: fixed;\n     height: 100%;\n     width: 100%;\n    }\n    .barchart-Col {\n      position: relative;\n      vertical-align: bottom;\n      display: table-cell;\n      height: 100%;\n    }\n    .barchart-Col + .barchart-Col {\n      border-left: 4px solid transparent;\n    }\n    .barchart-Bar {\n      position: relative;\n      height: 0;\n      transition: height 0.5s 2s;\n      width: 55px;\n      margin: auto;\n    }\n    .barchart-Bar:after {\n      content: attr(attr-height);\n      color: white;\n      position: absolute;\n      text-align: center;\n      width: 100%;\n    }\n    .barchart-BarFooter {\n      position: absolute;\n      text-align: center;\n      height: 10%;\n      width: 100%;\n\t  padding:5px;\n    }\n    .barchart-BarFooter p {\n      color: #000000;\n    }\n    .barchart-TimeCol {\n      position: absolute;\n      top: 0;\n      height: 100%;\n      width: 100%;\n    }\n    .barchart-Time {\n      height: 25%;\n      vertical-align: middle;\n      position: relative;\n    }\n    .barchart-Time:after {\n      border-bottom: 1px solid #AAAAAA;\n      content: &quot;&quot;;\n      position: absolute;\n      width: 100%;\n      left: 0;\n      top: 0em;\n    }\n    .barchart-TimeText {\n      position: absolute;\n      top: -8px;\n      z-index: 1;\n      background: white;\n      padding-right: 5px;\n      color: #000000;\n      font-size: 12px;\n      font-family: &apos;Avenir Medium&apos;;\n    }\n    .enquiry-bar,.registration-bar,.potential-bar,.interview-bar,.selection-bar {\n      background-color:#79B1FE;\n    }\n    .zc-pb-tile-card {\n     overflow: hidden;\n    }\n\n&lt;\/style&gt;\n\n  &lt;div class=&quot;header&quot;&gt;\n   &lt;h3&gt;Admission Info Chart &lt;\/h3&gt;\n  &lt;\/div&gt;\n   &lt;div class=&quot;barchart-Wrapper&quot;&gt;\n     &lt;div class=&quot;barchart-TimeCol&quot;&gt;\n      &lt;div class=&quot;barchart-Time&quot;&gt;\n        &lt;span class=&quot;barchart-TimeText&quot;&gt;&lt;%=value * 4%&gt;&lt;\/span&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Time&quot;&gt;\n        &lt;span class=&quot;barchart-TimeText&quot;&gt;&lt;%=value * 3%&gt;&lt;\/span&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Time&quot;&gt;\n        &lt;span class=&quot;barchart-TimeText&quot;&gt;&lt;%=value * 2%&gt;&lt;\/span&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Time&quot;&gt;\n        &lt;span class=&quot;barchart-TimeText&quot;&gt;&lt;%=value * 1%&gt;&lt;\/span&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Time&quot;&gt;\n        &lt;span class=&quot;barchart-TimeText&quot;&gt;0&lt;\/span&gt;\n      &lt;\/div&gt;\n     &lt;\/div&gt;\n        \n     &lt;div class=&quot;barChart-Container&quot;&gt;\n      &lt;div class=&quot;barchart&quot;&gt;\n       &lt;div class=&quot;barchart-Col&quot;&gt;\n\t   &lt;div class=&quot;barchart-Bar enquiry-bar&quot; style=&quot;height:&lt;%=enquiry \/ max_value * 100%&gt;%;&quot;&gt;&lt;\/div&gt;\n          &lt;div class=&quot;barchart-BarFooter&quot;&gt;\n            &lt;p&gt;Lead&lt;\/p&gt;\n          &lt;\/div&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Col&quot;&gt;\n\t  &lt;div class=&quot;barchart-Bar registration-bar&quot; style=&quot;height:&lt;%=registration \/ max_value * 100%&gt;%;&quot;&gt;&lt;\/div&gt;\n        &lt;div class=&quot;barchart-BarFooter&quot;&gt;\n         &lt;p&gt;Registration&lt;\/p&gt;\n        &lt;\/div&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Col&quot;&gt;\n\t  &lt;div class=&quot;barchart-Bar potential-bar&quot; style=&quot;height:&lt;%=interview_scheduled \/ max_value * 100%&gt;%;&quot;&gt;&lt;\/div&gt;\n         &lt;div class=&quot;barchart-BarFooter&quot;&gt;\n           &lt;p&gt;Interview Scheduled&lt;\/p&gt;\n         &lt;\/div&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Col&quot;&gt;\n\t  &lt;div class=&quot;barchart-Bar interview-bar&quot; style=&quot;height:&lt;%=waiting_list \/ max_value * 100%&gt;%;&quot;&gt;&lt;\/div&gt;\n        &lt;div class=&quot;barchart-BarFooter&quot;&gt;\n         &lt;p&gt;Waiting List&lt;\/p&gt;\n        &lt;\/div&gt;\n      &lt;\/div&gt;\n      &lt;div class=&quot;barchart-Col&quot;&gt;\n\t  &lt;div class=&quot;barchart-Bar selection-bar&quot; style=&quot;height:&lt;%=selection \/ max_value * 100%&gt;%;&quot;&gt;&lt;\/div&gt;\n        &lt;div class=&quot;barchart-BarFooter&quot;&gt;\n         &lt;p&gt;Selection&lt;\/p&gt;\n        &lt;\/div&gt;\n      &lt;\/div&gt;\n     &lt;\/div&gt;\n    &lt;\/div&gt;\n   &lt;\/div&gt;\n   &lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row><row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart\"\n\n\ttype = 'Funnel'\n\tbgColor = 'rgb(255, 255, 255)'\n\ttheme = 'theme1'\n\tlegendPos = 'center.bottom'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Registration'\n\txfield = 'Status'\n\tyfields = 'count:Status'\n\/>\n\n<\/column>\n<\/row>\n<\/column><column\n   \t\t width=\"50%\"\n   \t>\n\t<chart \n\telementName=\"Chart 1\"\n\n\ttype = 'Pie'\n\tbgColor = 'rgb(255, 255, 255)'\n\ttheme = 'theme2'\n\tlegendPos = 'right.center'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Lead'\n\txfield = 'Status'\n\tyfields = 'count:Status'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
