			displayname = "Staff Dashboard Test 2"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet2' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet2()\ncontent\n&lt;%{\n\tphoto = Staff[Email_ID == zoho.loginuserid];\n\t%&gt;\n&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n\t   box-sizing: border-box;\n      }\n\t  \n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  .profile-header-div\n\t  {\n\t\t  width:100%;\n\t\t  height:100px;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t  display:flex;\n\t  }\n\t  .row2-div\n\t  {\n\t\t  width:100%;\n\t\t  height:calc(100% - 100px);\n\t\t  display: flex;\n\t\t  padding-top:1px;\n\t  }\n\t  .column1-container\n\t  {\n\t\t  height:100%;\n\t\t  width:22%;\n\t\t  background:#fff;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t  }\n\t  .profile-pic\n\t  {\n\t\t  align-items: center;\n\t\t  display: flex;\n\t\t  width:10%;\n\t   }\n\t  img.profile-photo\n\t  {\n\t\t  width:80px;\n\t\t  height:80px;\n\t\t  border-radius:50%;\n\t  }\n\t .name-div\n\t {\n\t\t font-size:20px;\n\t\t font-weight:bold;\n\t }\n\t  .information-div\n\t  {\n\t\t  display: flex;\n\t\t  flex-direction: column;\n\t\t  align-items: center;\n\t\t  justify-content: center;\n\t\t  gap: 10px;\n\t\t  width:90%;\n\t\t  padding-left:10%;\n\t  }\n\t  .information-div-row2\n\t  {\n\t\t  display:flex;\n\t\t  gap:60px;\n\t\t  font-size: 15px;\n\t  }\n\t  .row2-subdiv\n\t  {\n\t     display: flex;\n         gap: 5px;\n\t   }\n\t   .information-div-row2-header\n\t   {\n\t\t   color:#7F7F7F;\n\t   }\n\t  .column2-container\n\t  {\n\t\t  height:100%;\n\t\t  width:78%;\n\t\t  padding:10px;\n\t\t  overflow: auto;\n\t  }\n\t  \/*New form style*\/\n\t  .label-left .formColumn .form-group label.form-label {\n            display: none !important;\n      }\n\t  .formColumn.first-column {\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 10px;\n       }\n\t   .form-field.clearfix,.flLeft.tempContDiv.zc-Home,.flLeft.tempContDiv.zc-LMS,.flLeft.tempContDiv.zc-My_Class_Info,.flLeft.tempContDiv.zc-Other_Info,.flLeft.tempContDiv.zc-Classes\n\t   {\n\t\t   width:100% !important;\n\t   }\n\t   .flLeft.tempContDiv.zc-Classes {\n\t\t\tpadding-left: 60px;\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 5px;\n\t\t\tmax-height: 350px;\n\t\t\toverflow: auto;\n\t\t}\n\t  \/*form style *\/\t\n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.student_tab_search .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .student_tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t \n\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.student_tab_search .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t{\n\t\tcolor:green;\n\t}\n\t\n\t.student_tab_search form.form-table {\n\t\twidth: 100% !important;\n\t}\n\t\t\n\t\t.student_tab_search form.form-table .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t.student_tab_search form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.student_tab_search form.form-table .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 3px 15px;\n\t\t\twidth: 100%;\n\t\t  \tdisplay: flex;\n\t\t\tjustify-content: left;\n    \t\tpadding-left: 20px;\n\t\t}\n\t\t\n\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t\tflex-direction:column;\n\t\tdisplay:flex !important;\n\t\tgap: 15px;\n\t}\n\t\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t   z-index: 0;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tbackground: var(--header-checked-line-color);\n\t\ttop: 0%;\n\t\twidth: calc(100% - 20px);\n\t\theight: 100%;\n\t\tposition: absolute;\n\t\tz-index: -1;\n\t\tborder-radius:3px;\n\t\tleft:10px;\n\t}\n\t\n\t.student_tab_search .choice-table-cell input:checked~label{\n\t\tcolor:white;\t\n\t}\n\t\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.student_tab_search .zc-form-fullheight,\n\t.student_tab_search .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.student_tab_search{\n\t\t width:100%;\n    \