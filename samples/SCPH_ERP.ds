		page Staff_LMS
		{
			displayname = "Staff LMS"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet85' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet85()\ncontent\n&lt;%{\n\tlogin = zoho.loginuserid;\n\tstaffClass = Lesson_Plan_Mapping[Staff.Email_ID == login].Class.Class_Name.getAll();\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;style&gt;\n\t\t\/*form styles *\/\n\t\t.stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t margin-right: 10px;\n\t }\n\t \n\t.stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.stateless-form .customRadio:checked+label+choice-label-text\n\t{\n\t\tcolor:green;\n\t}\n\t\n\t.stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t\theight: 100%;\n\t\toverflow: auto;\n\t}\n\t\t\n\t.stateless-form .zc-form-fullheight,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper,\n\t.stateless-form .form-outer-wrapper&gt;.row{\n\t\theight:100% !important;\n\t}\n\t\t\n\t.stateless-form .zc-form-fullheight,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.stateless-form form.form-table .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 0px 15px;\n\t\t\twidth: 100%;\n\t\t    display: flex;\n\t\t    justify-content: center;\n\t\t}\n\t\t\n\t.stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t}\n\t\n\t.stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\twidth: 100%;\n\t\tmargin-bottom: 10px;\n\t}\n\t\n\t.stateless-form .choice-table-cell input~label {\n       position: relative;\n\t   cursor:pointer;\n\t   font-size: 16px;\n\t   width: 100%;\n\t   padding: 5px 0 5px 10px;\n\t}\n\t\n\t.stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.stateless-form.divEmbedContainer {\n\t\theight: 100% !important;\n\t\twidth: 250px !important;\n\t\tpadding: 10px;\n\t\tbackground: white;\n\t\tbox-shadow: 1px 0px 5px #cdcdcd;\n\t\tz-index: 1;\n\t\tborder-radius: 5px 0px 0px 5px;\n\t}\n\t\n\t.stateless-form .customRadio {\n\t  display: none;\n\t}\n\t\/* Hide - Form Loader Icon *\/\n\t.stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t \n\t .container-wrapper{\n\t\theight: calc(100%);\n\t\tbackground: var(--main-container-color);\n\t\tdisplay: flex;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\toverflow: hidden;\n\t\twidth: calc(100%);\n\t\tborder-radius: 5px;\n\t}\n\t\n\t\/* stateless - new design *\/\n\t.stateless-form .choice-table-cell span {\n\t\tdisplay: contents;\n\t}\n\t\n\t.stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tbackground: var(--header-checked-line-color);\n\t\twidth: 100%;\n\t\theight: 100%;\n\t\tposition: absolute;\n\t\tz-index: -1;\n\t\tright: 0;\n\t\ttop:0;\n\t\tborder-radius: 3px;\n\t}\n\n\t.stateless-form .choice-table-cell input:checked~label {\n\t\tcolor: white;\n\t\tz-index:0;\n\t}\n\t\n\t.frame-div{\n\t\twidth:100%;\n\t}\n\t\n\t.container-wrapper .content-div\n\t{\n\t\theight: 100%;\n\t\twidth: calc(100% - 250px);\n\t}\n\t\n\t.zc-pb-embed-placeholder-content{\n\t\tpadding: 5px 20px;\n\t}\n\t&lt;\/style&gt;\n\t\n\t&lt;div class=&quot;container-wrapper&quot;&gt;\n&lt;%\n\tif(staffClass.size() &gt; 1)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;stateless-form&quot; elName=&apos;zc-component&apos; formLinkName=&apos;Staff_Classes&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;div elName=&apos;zc-component&apos; name=&apos;content-div&apos; class=&apos;content-div&apos;&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Lead_Page
		{
			displayname = "Lead Page"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet86' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet86()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t:root{\n          --header-checked-line-color: #19A66A;\n\t\t  --header-line-color: #cdcaca;\n\t\t  --header-hover-color:#45b6fe;\n\t\t  --circle-color:#7BFF51;\n\t\t  --before-circle-color:#5561FC;\n\t\t  --after-circle-color:#FF5E5E;\n\t\t  --panel-background-color:white;\n\t\t  --main-container-color:#F3F3F3;\n\t\t  --report-header-background-color:#1CB75E;\n         }\n        .main-container{\n          height: 100vh;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\n      \n     .row1 {\n          \n          padding: 10px 0;\n      }\n      \n      .panels{\n          display: flex;\n          padding: 10px 0;\n      }\n      .header\n\t  {\n\t\t  padding:0 10px;\n\t  }\n      .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        cursor: pointer;\n        padding: 15px;\n        position:relative;\n        overflow:hidden;\n      }\n      \n\t  .panels .panel span:nth-child(2) {\n          font-size: 2rem;\n      }\n      .panels .panel span:first-child {\n          font-size: 20px;\n      }\n      .panel{\n        gap:5px;\n      }\n      .tab-labels::before {\n            content: &apos;&apos;;\n            width: calc(100% \/ 6);\n            top: 100%;\n\t\t\tborder-bottom: 2px solid var( --header-checked-line-color);\n            position: absolute;\n            transition: .5s;\n            z-index: 1;\n        }\n        \n        .tab-labels&gt;label {\n            flex: 1;\n           z-index: 1;\n           text-align: center;\n           display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        \n        .tab-labels {\n            display: flex;\n            height: 30px;\n\t\t\tborder-bottom:2px solid var( --header-line-color) ;\n\t\t\tfont-size:1rem;\n        }\n        \n        .tab-content&gt;div {\n            transform: scale(0, 0);\n            transform-origin: center;\n            transition: all 0.5s ease;\n        }\n        \n        input#tab1-button:checked~.tab-content&gt;.tab1-content,\n        input#tab2-button:checked~.tab-content&gt;.tab2-content,\n        input#tab3-button:checked~.tab-content&gt;.tab3-content,\n        input#tab4-button:checked~.tab-content&gt;.tab4-content,\n        input#tab5-button:checked~.tab-content&gt;.tab5-content,\n\t\t input#tab6-button:checked~.tab-content&gt;.tab6-content\n         {\n            transform: scale(1, 1);\n        }\n        \n        .tab-labels {\n            position: relative;\n        }\n        \n        input#tab1-button:checked~.tab-labels::before {\n            left: 0%;\n        }\n        \n        input#tab2-button:checked~.tab-labels::before {\n\t\t\tleft: calc(calc(100% \/ 6) * 1);\n        }\n        \n        input#tab3-button:checked~.tab-labels::before {\n            left:  calc(calc(100% \/ 6) * 2);\n        }\n        input#tab4-button:checked~.tab-labels::before {\n            left: calc(calc(100% \/ 6) * 3);\n        }\n        input#tab5-button:checked~.tab-labels::before {\n            left:  calc(calc(100% \/ 6) * 4);\n        }\n\t\t input#tab6-button:checked~.tab-labels::before {\n            left:  calc(calc(100% \/ 6) * 5);\n        }\n        \n        .tab-labels&gt;label:hover {\n            color: var(--header-hover-color) ;\n        }\n        .tab-content&gt;.tab1-content {\n            height: 100%;\n            width: 100%;\n            position: absolute;\n            \n        }\n        \n        .tab-content&gt;.tab2-content {\n            height: 100%;\n            width: 100%;\n        }\n        \n        .tab-content&gt;.tab3-content {\n            height: 100%;\n            width: 100%;\n            position: absolute;\n            top: 0;\n        }\n        \n        .tab-content&gt;.tab4-content {\n            height: 100%;\n            width: 100%;\n            position: absolute;\n            top: 0;\n        }\n        .tab-content&gt;.tab5-content {\n            height: 100%;\n            width: 100%;\n            position: absolute;\n            top: 0;\n        }\n\t\t.tab-content&gt;.tab6-content {\n            height: 100%;\n            width: 100%;\n            position: absolute;\n            top: 0;\n        }\n\n          .header input[type=radio] {\n              display: none;\n          }\n        .tab-content {\n            position: relative;\n            width: 100%;\n            height: calc(100vh - 30px);\n        }\n        label{\n          cursor: pointer;\n        }\n        .circle-design,.circle-design:before,.circle-design:after\n        {\n            position:absolute;\n            border-radius:50%;\n            width: 56px;\n            height: 56px;\n        }\n        .circle-design\n        {   \n\t\t\tbackground: var(--circle-color);\n            top: calc(100% - 40px);\n            left: calc(100% - 40px);\n            z-index: 1;\n        }\n        .circle-design:before\n        {\n\t\t\tbackground:var(--before-circle-color);\n            top: calc(100% - 95px);\n            left: calc(100% - 40px);\n            content: &quot;&quot;;\n            z-index: 0;\n        }\n        .circle-design:after\n        {\n            background:var(--after-circle-color) ;\n            top: calc(100% - 42px);\n            left: calc(100% - 82px);\n            content: &quot;&quot;;\n        }\n\/*  Report styles  *\/\n\t\tspan.colHeader i.zc-report-sortOrder {\n          display: none !important;\n        }\n\t\t .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td {\n            border-right: none !important; \n\t\t\tborder-bottom:2px solid var(--report-header-background-color) !important;\n        }\n\t\t.divEmbedContainer\n\t\t{\n\t\t\tpadding-top:50px;\n\t\t}\n\t\ta.zc-image-placeholder {\n\t\t\theight:25px !important;\n        }\n\t\ttd.zcReport_Text.zc-mapping-field.htDimmed\n\t\t{\n\t\t\tvertical-align:middle;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th\n\t\t{\n\t\t\tbackground:var(--report-header-background-color) !important;\n\t\t\tborder-right:none !important;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th .relative .colHeader span\n\t\t{\n\t\t\tcolor:white !important;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th a {\n          color: white !important;\n        }\n\t\tdiv#All_Students_ZC_OZFMQ5\n\t\t{\n\t\t\t box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%) !important;\n\t\t}\n        \n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n      &lt;div class=&quot;row1&quot;&gt;\n          &lt;div class=&quot;panels&quot;&gt;\n              &lt;div class=&quot;panel allleads-panel-container&quot; &gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;All Leads&lt;\/span&gt;\n                  &lt;span class=&quot;total-leads-value&quot;&gt;0&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel myleads-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Leads&lt;\/span&gt;\n                  &lt;span class=&quot;myleads-value&quot;&gt;0&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel potential-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Potentials&lt;\/span&gt;\n                  &lt;span class=&quot;potentials-value&quot;&gt;0&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel conversion-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Conversion&lt;\/span&gt;\n                  &lt;span class=&quot;conversion-value&quot;&gt;0&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel waitinglist-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Waiting List&lt;\/span&gt;   \n                  &lt;span class=&quot;waitinglist-value&quot;&gt;0&lt;\/span&gt;\n                  &lt;div class=&quot;circle-design&quot;&gt;&lt;\/div&gt;                 \n              &lt;\/div&gt;\n          &lt;\/div&gt;\n    &lt;\/div&gt;\n    &lt;div class=&quot;header&quot;&gt;\n        &lt;input type=&quot;radio&quot; id=&quot;tab1-button&quot; name=&quot;tabs-button&quot; checked&gt;\n        &lt;input type=&quot;radio&quot; id=&quot;tab2-button&quot; name=&quot;tabs-button&quot;&gt;\n        &lt;input type=&quot;radio&quot; id=&quot;tab3-button&quot; name=&quot;tabs-button&quot;&gt;\n        &lt;input type=&quot;radio&quot; id=&quot;tab4-button&quot; name=&quot;tabs-button&quot;&gt;\n        &lt;input type=&quot;radio&quot; id=&quot;tab5-button&quot; name=&quot;tabs-button&quot;&gt;\n\t\t&lt;input type=&quot;radio&quot; id=&quot;tab6-button&quot; name=&quot;tabs-button&quot;&gt;\n  \n        &lt;div class=&quot;tab-labels&quot;&gt;\n            &lt;label for=&quot;tab1-button&quot; class=&quot;tab1-label&quot;&gt;My Leads&lt;\/label&gt;\n            &lt;label for=&quot;tab2-button&quot; class=&quot;tab2-label&quot;&gt;All Leads&lt;\/label&gt;\n            &lt;label for=&quot;tab3-button&quot; class=&quot;tab3-label&quot;&gt;Registration&lt;\/label&gt;\n            &lt;label for=&quot;tab4-button&quot; class=&quot;tab4-label&quot;&gt;Potential&lt;\/label&gt;\n            &lt;label for=&quot;tab5-button&quot; class=&quot;tab5-label&quot;&gt;Evaluation&lt;\/label&gt;\n\t\t\t&lt;label for=&quot;tab6-button&quot; class=&quot;tab6-label&quot;&gt;Selection&lt;\/label&gt;\n             \n        &lt;\/div&gt;\n  \n  &lt;!--    &lt;div class=&quot;tab-content&quot;&gt;\n        &lt;div class=&quot;tab1-content&quot; &gt;\n            &lt;p&gt;tab1&lt;\/p&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;tab2-content&quot;&gt;\n            &lt;p&gt;tab2&lt;\/p&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;tab3-content&quot;&gt;\n            &lt;p&gt;tab3&lt;\/p&gt;         \n        &lt;\/div&gt;\n        &lt;div class=&quot;tab4-content&quot;&gt;\n            &lt;p&gt;tab4&lt;\/p&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;tab5-content&quot;&gt;\n            &lt;p&gt;tab5&lt;\/p&gt;\n        &lt;\/div&gt;\n\t\t&lt;div class=&quot;tab6-content&quot;&gt;\n            &lt;p&gt;tab5&lt;\/p&gt;\n        &lt;\/div&gt;\n      &lt;\/div&gt; --&gt;\n\t  &lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;All_Students&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Extended_View(SBP)
		{
			displayname = "Extended View"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet87' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet87()\ncontent\n&lt;%{\n\tif(input.SBP == &quot;abcd123&quot;)\n\t{\n\t\tbackicon = true;\n\t\tsearchbook_report = true;\n\t}\n\telse if(input.SBP == &quot;efgh456&quot;)\n\t{\n\t\tbackicon = true;\n\t\tmembershipreport_report = true;\n\t}\n\telse if(input.SBP == &quot;ijkl789&quot;)\n\t{\n\t\tbackicon = true;\n\t\tborrowbook_form = true;\n\t}\n\telse if(input.SBP == &quot;mnop123&quot;)\n\t{\n\t\tbackicon = true;\n\t\taddbookform = true;\n\t}\n\telse if(input.SBP == &quot;etsy234&quot;)\n\t{\n\t\tbackicon = true;\n\t\tadd_menu_item = true;\n\t\thostelbackicon = true;\n\t}\n\telse if(input.SBP == &quot;dsl195&quot;)\n\t{\n\t\tbackicon = true;\n\t\taddvisitorentry = true;\n\t}\n\telse\n\t{\n\t\tsearchbook_report = true;\n\t\tadmissionbackicon = false;\n\t\treportView = true;\n\t\tbackicon = false;\n\t\treportName = &quot;&quot;;\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n      * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\n\t\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t.add_book .form-header,.borrow_book .form-header\n\t\t{\n\t\t\tbackground:#fff !important;\n\t\t}\n\t\t\n\t\tspan.zc-view-name {\n\t\t\tpadding-left: 30px;\n\t\t}\n\t\t\n\t\t .back-icon\n        {\n            position: absolute;\n\t\t\ttop: 13px;\n\t\t\tleft: 10px;\n\t\t\tz-index: 9;\n\t\t\twidth: 25px;\n\t\t\tbackground: white;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tborder-radius: 3px;\n        }\n\t\t\n\t\t.row2-container&gt;a {\n\t\t\tposition: relative;\n\t\t\tz-index: 101;\n\t\t\theight: auto;\n\t\t\twidth: auto;\n\t\t\tdisplay: block;\n\t\t}\n\t\t\n\t\t.row2-container{\n\t\t\theight:100%;\n\t\t}\n\t\t\n\t\t.pagereport{\n\t\t\theight:100% !important;\n\t\t}\n\t\t\n\t\tspan#formTitleElem {\n\t\t\tpadding-left: 55px;\n\t\t}\n&lt;\/style&gt;\n &lt;div class=&quot;row2-container&quot;&gt;\n&lt;%\n\tif(backicon == true)\n\t{\n\t\t%&gt;\n&lt;a href=&quot;#Page:Library_Dashboard&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/ios-filled\/2x\/less-than.png&quot; class=&quot;back-icon&quot;&gt;&lt;\/a&gt;\n&lt;%\n\t}\n\tif(admissionbackicon == true)\n\t{\n\t\t%&gt;\n&lt;a href=&quot;#Page:Admission_Admin_Dashboard&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/ios-filled\/2x\/less-than.png&quot; class=&quot;back-icon&quot;&gt;&lt;\/a&gt;\n&lt;%\n\t}\n\tif(hostelbackicon == true)\n\t{\n\t\t%&gt;\n&lt;a href=&quot;#Page:Hostel_Dashboard1&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/ios-filled\/2x\/less-than.png&quot; class=&quot;back-icon&quot;&gt;&lt;\/a&gt;\n&lt;%\n\t}\n\tif(add_menu_item == true)\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;add_menu_item&quot; formLinkName=&apos;Hostel_Menu&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(searchbook_report == true)\n\t{\n\t\t%&gt;\n&lt;div name=&quot;reportdiv&quot; class=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Resources&apos; params=&apos;zc_Footer=false&amp;zc_SecHeader=true&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&amp;zc_ColMenu=false&amp;zc_SaveRec=false&amp;zc_MoreAction=true&amp;zc_ShowAs=true&amp;zc_Print=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(membershipreport_report == true)\n\t{\n\t\t%&gt;\n&lt;div name=&quot;searchpage&quot; class=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Memberships&apos; params=&apos;zc_Footer=false&amp;zc_SecHeader=true&amp;zc_AddRec=true&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&amp;zc_ColMenu=false&amp;zc_SaveRec=false&amp;zc_MoreAction=false&amp;zc_ShowAs=false&amp;zc_Print=false&amp;zc_Search=false&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(reportView == true)\n\t{\n\t\t%&gt;\n&lt;div name=&quot;searchpage&quot; class=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;&lt;%=reportName%&gt;&apos; params=&apos;zc_Footer=false&amp;zc_SecHeader=true&amp;zc_AddRec=true&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&amp;zc_ColMenu=false&amp;zc_SaveRec=false&amp;zc_MoreAction=false&amp;zc_ShowAs=false&amp;zc_Print=false&amp;zc_Search=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(borrowbook_form == true)\n\t{\n\t\tavailableBooks = Resources[Category.Category == &quot;Novel&quot; &amp;&amp; Status == &quot;available&quot;];\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;borrow_book&quot; formLinkName=&apos;Borrow_Books&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(addbookform == true)\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;add_book&quot; formLinkName=&apos;Add_Resources&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\tif(addvisitorentry == true)\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;visitor_entry&quot; formLinkName=&apos;Library_Visitor_Record&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Other_Info
		{
			displayname = "Student Other Info"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet88' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet88()\ncontent\n&lt;%{\n\tmyClass = Student[Email == zoho.loginuserid];\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt; \n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t:root{\n\t\t  --main-container-color:#fff;\n\t\t  }\n\t\t.other-info-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t\t  gap:10px;\n       }\n\t   div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t.other-info-container-row1\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:55%;\n\t\t}\n\t\t.other-info-container-row2\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:45%;\n\t\t}\n\t\t.exam-div,.info-div\n\t\t{\n\t\t\theight:100%;\n\t\t\twidth:50%;\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius:5px;\n\t\t\tpadding:10px;\n\t\t}\n\t\t.exam-div\n\t\t{\n\t\t\toverflow:auto;\n\t\t}\n\t\t.statistics-div,.upcoming-exams-div\n\t\t{\n\t\t\theight:100%;\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius:5px;\n\t\t\tpadding:10px;\n\t\t}\n\t\t.statistics-div\n\t\t{\n\t\t\twidth:60%;\n\t\t}\n\t\t.upcoming-exams-div\n\t\t{\n\t\t\twidth:40%;\n\t\t}\n\t\t.sub-header {\n\t\t\theight: 25px;\n\t\t}\n\t\t.content\n\t\t{\n\t\t\theight: calc( 100% - 25px);\n\t\t\toverflow:auto;\n\t\t}\n\t\t.upcoming-exams-div .content\n\t\t{\n\t\t\tpadding-top:10px;\n\t\t}\n\t\t\/* Timeline Design *\/\n\t.holiday-div .content{\n\t\tpadding-top:10px;\n\t}\n\t\n\t.timeline-inner&gt;span {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\tpadding: 5px 0px;\n\t}\n\n\tspan.timeline-date {\n\t\tborder-bottom: 1px solid #17a56a;\n\t}\n\n\t.timeline-outer {\n\t\twidth: calc(100% - 70px);\n\t\tmargin-left: 60px;\n\t\tmargin-bottom: 10px;\n\t\tposition:relative;\n\t}\n\t\n\t.timeline-inner{\n\t\tbackground: white;\n\t\tfilter: drop-shadow(0px 0px 1px #cdcdcd);\n\t\tposition:relative;\n\t\tborder-radius: 5px;\n\t\tz-index:1;\n\t}\n\t\n\t.timeline-inner:before {\n\t\tcontent: &quot;&quot;;\n\t\tposition: absolute;\n\t\twidth: 0;\n\t\theight: 0;\n\t\tborder-top: 0px solid transparent;\n\t\tborder-bottom: 20px solid transparent;\n\t\tborder-right: 20px solid white;\n\t\ttop: 5px;\n\t\tright: 97%;\n\t\ttransform: rotate(-18deg);\n\t}\n\n\/\/ \t.timeline-outer:before {\n\/\/ \t\tbox-shadow: 0 0 0 3px;\n\/\/ \t\tborder-radius: 50%;\n\/\/ \t\theight: 7px;\n\/\/ \t\twidth: 7px;\n\/\/ \t\tcontent: &quot;&quot;;\n\/\/ \t\tposition: absolute;\n\/\/ \t\ttop: 5px;\n\/\/ \t\tright: calc(100% + 30px);\n\/\/ \t\tz-index: 1;\n\/\/ \t}\n\t\n\/\/ \t.timeline-outer:after {\n\/\/ \t\tcontent: &apos;&apos;;\n\/\/ \t\theight: 100%;\n\/\/ \t\twidth: 3px;\n\/\/ \t\tposition: absolute;\n\/\/ \t\ttop: 13px;\n\/\/ \t\tright: calc(100% + 32px);\n\/\/ \t\tz-index: 0;\n\/\/ \t\tbackground-color: #17a56a;\n\/\/ \t}\n\t\n\t.timeline-outer:last-child .timeline-inner {\n\t\tposition: relative;\n\t}\n\n\t.timeline-outer:last-child .timeline-inner:after {\n\t\tcontent: &quot;X&quot;;\n\t\tbackground: white;\n\t\tborder-radius: 50%;\n\t\tborder: 1px solid #17a56a;\n\t\tpadding: 2px 6px;\n\t\tfont-weight: bolder;\n\t\tposition: absolute;\n\t\tright: calc(100% + 22px);\n\t\tz-index: 3;\n\t}\n\t\/*  Report styles  *\/\n\t\tspan.colHeader i.zc-report-sortOrder {\n          display: none !important;\n        }\n\t\t .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td {\n            border-right: none !important; \n\t\t\tborder-bottom:2px solid var(--report-header-background-color) !important;\n        }\n\t\ta.zc-image-placeholder {\n\t\t\theight:50px !important;\n        }\n\t\ttd.zcReport_Text.zc-mapping-field.htDimmed\n\t\t{\n\t\t\tvertical-align:middle;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .ht_clone_top.handsontable {\n              height: 45px!important;\n         }\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th\n\t\t{\n\t\t\tbackground:var(--report-header-background-color) !important;\n\t\t\tborder-right:none !important;\n\t\t\tborder-bottom: unset !important;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th .relative .colHeader span\n\t\t{\n\t\t\tcolor:white !important;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th a {\n          color: white !important;\n        }\n\t\tdiv#All_Students_ZC_OZFMQ5\n\t\t{\n\t\t\t box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%) !important;\n\t\t}\n\t\t\n\t\t.reportfullwidth {\n           background: white !important;\n\t\t    border-radius: 3px;\n    \t\toverflow: hidden;\n        }\n        .zc-reports-footer-sec {\n           background: white !important;\n\t\t  }\n\t\t\n\t\t\n\t\t\n\t\t\/* Report Header Background And Height Style *\/\n\t\t.leadpagereport .view-header{\n\t\t\tbackground:transparent !important;\n\t\t\theight: 40px !important; \n\t\t}\n\t\t\n\t\t\/* Report Group tr Style *\/\n\t\t.leadpagereport .handsontable tbody tr[elname*=&quot;zc-grouprow&quot;] {\n\t\t\theight: auto;\n\t\t}\n\t\t.leadpagereport .handsontable tbody tr[elname*=&quot;zc-grouprow&quot;] td {\n\t\t\tbackground: #e1e6e1 !important;\n\t\t}\n\t\t\n\t\t.leadpagereport .view-outer-wrapper .view-header .zc-new-report-header{\n\t\t\theight: 40px !important;\n    \t\tborder-bottom: unset !important;\n\t\t}\n\t\t\n\t\t.leadpagereport .view-header .zc-new-report-header .zc-reportoptionheader,\n\t\t.leadpagereport .view-options{\n\t\t\tpadding: unset !important;\n\t\t}\n\t\t.leadpagereport.divEmbedContainer {\n\t\t\theight: calc(100% - 30px) !important;\n\t\t}\n\t\t\/*form styles *\/\n\t\t.tab_search1 label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search1 .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.tab_search1 .formbutton {\n          padding: 0 !important;\n       }\n\t\t.tab_search1 .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.tab_search1 label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.tab_search1 .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.tab_search1 .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.tab_search1 .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search1 .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search1 .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t \n\t   }\n\t .tab_search1 .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .tab_search1 .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .tab_search1 .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t.tab_search1 .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search1 .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.tab_search1 form[name=&quot;Student_Dashboard_tab&quot;].label-left {\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t.tab_search1 .flLeft.tempContDiv.zc-Radio {\n           width: 100% !important;\n        }\n\t\t.tab_search1 .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: grid !important;\n\t\t\twidth: 100% !important;\n     }\n\t.tab_search1 .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t.tab_search1 .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t\n\t.tab_search1 .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tbackground: var(--header-checked-line-color);\n\t\twidth: 100%;\n\t\theight: 100%;\n\t\tposition: absolute;\n\t\tz-index: -1;\n\t\ttop: 0;\n\t\tborder-radius: 3px;\n    }\n\t.tab_search1 .choice-table-cell input:checked~label {\n    color: white;\n    z-index: 0;\n}\n\t.tab_search1 label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.tab_search1 .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t      div[formlinkname=&quot;Student_Dashboard_tab&quot;] {\n\t\t\t   height: 30px !important;\n\t\t    }\n\t\t   div[formlinkname=&quot;Student_Dashboard_tab&quot;] .zc-form-fullheight{\n\t\t\t   background:transparent !important;\n\t\t\t}\n\t\t\tdiv[formlinkname=&quot;Student_Dashboard_tab&quot;] .zc-form-fullheight .form-outer-wrapper {\n\t\t\t\tanimation: unset !important;\n\t\t\t }\n\t\t\tdiv[formlinkname=&quot;Student_Dashboard_tab&quot;] .choice-label-text {\n\t\t\t\t\tfont-size: 18px !important;\n\t\t\t\t\tfont-weight: 400;\n\t\t\t\t\tcolor: #000000;\n\t\t\t\t\tmix-blend-mode: normal;\n\t\t\t}\n\t\t\t\/* Hide - Form Loader Icon *\/\n\t\t.tab_search1 i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n\t\t\n\t\t\t\n &lt;\/style&gt;\n\t&lt;div class=&quot;other-info-container&quot;&gt;\n\t  &lt;div class=&quot;other-info-container-row1&quot;&gt;\n\t     &lt;div class=&quot;statistics-div&quot;&gt;\n\t\t     &lt;div class=&quot;sub-header&quot;&gt;&lt;h4&gt;My Statistics&lt;\/h4&gt;&lt;\/div&gt;\n\t\t\t &lt;div class=&quot;content&quot;&gt;\n\t\t       &lt;div name=&quot;studentpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Subject_Marks&apos; class=&quot;studentpage&quot;&gt;&lt;\/div&gt;\n\t\t\t &lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t\t &lt;div class=&quot;upcoming-exams-div&quot;&gt;\n\t\t    &lt;div class=&quot;sub-header&quot;&gt;&lt;h4&gt;Upcoming Exams&lt;\/h4&gt;&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;content&quot;&gt;\n&lt;%\n\tallExams = Exam[Assessment_Start_Date &gt;= zoho.currentdate &amp;&amp; Class == myClass.Class_UID];\n\tif(allExams.count() &gt; 0)\n\t{\n\t\tfor each  exam in allExams\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;timeline-outer&quot;&gt;\n\t\t\t\t\t\t\t&lt;div class=&quot;timeline-inner&quot;&gt;\n\t\t\t\t\t\t\t\t&lt;span class=&quot;timeline-date&quot;&gt;&lt;%=exam.Assessment_Start_Date%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t&lt;span class=&quot;timeline-value&quot;&gt;&lt;%=exam.Assessment_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot; style=&quot;box-shadow:unset;&quot;&gt;No Upcoming Exams&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t  &lt;div class=&quot;other-info-container-row2&quot;&gt;\n\t    &lt;div class=&quot;exam-div&quot;&gt;\n\t\t     &lt;div  elName=&apos;zc-component&apos; viewLinkName=&apos;Exam_Marks2&apos; class=&quot;leadpagereport&quot; params=&apos;zc_ReportName=true&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=false&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;info-div&quot;&gt;\n\t\t    &lt;div elName=&apos;zc-component&apos; class=&quot;tab_search1&quot; formLinkName=&apos;Student_Dashboard_tab&apos; params=&apos;zc_Header=false&amp;amp;zc_SuccMsg=Data Added Successfully!&amp;amp;zc_SubmitVal=Submit&amp;amp;zc_ResetVal=Reset&apos;&gt;&lt;\/div&gt;\n\t  &lt;div name=&quot;leadpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;My_Library_Visitor_Record&apos; class=&quot;leadpagereport&quot; params=&apos;zc_Header=false&amp;zc_ReportName=false&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=false&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Personal_Info(Child_Mail)
		{
			displayname = "Student Personal Info"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet89' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet89()\ncontent\n&lt;%{\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\tmyinfo = Student[Email == zoho.loginuserid];\n\t}\n\telse\n\t{\n\t\tChild_Mail1 = input.Child_Mail.replaceFirst(&quot;%2B&quot;,&quot;+&quot;);\n\t\tmyinfo = Student[Email == Child_Mail1];\n\t}\n\t%&gt;\n&lt;style&gt;\n     * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n      }\n\t  :root{\n\t\t  --main-container-color:#fff;\n\t\t  --personal-info-td-color:#7F7F7F;\n\t }\n\t  div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .personal-info-container{\n          height: 100%;\n          width: 100%;\n\t\t  padding: 10px;\n\t\t   box-sizing: border-box;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t\t  gap:15px;\n      }\n\t  .row1-personal-info\n\t  {\n\t\t  display:flex;\n\t\t  width:100%;\n\t\t  gap:15px;\n\t  }\n\t  .general-info-div,.sibiling-info-div\n\t  {\n\t\t  border-radius:5px;\n\t\t  height:100%;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t  overflow:hidden;\n\t  }\n\t  .general-info-div\n\t  {\n\t\t  width:70%;\n\t  }\n\t  .sibiling-info-div\n\t  {\n\t\t  width:30%;\n\t  }\n\t  .row2-personal-info\n\t  {\n\t\t  border-radius:5px;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t  width:100%;\n\t\t  overflow:hidden;\n\t  }\n\/* \t  .general-info-header,.sibiling-info-header,.Parents-info-header{\n\t\t  \ttext-align: center;\n\t\t\tbackground: #f8f8f8;\n    \t\tcolor: #000;\n\t\t\theight: 31px;\n\t\t\tpadding: 2px;\n\t\t\tbox-sizing: border-box;\n\t\t    font-size:16px;\n\t\t\tfont-weigth:700;\n\t\t\tdisplay:flex;\n\t\t\talign-items:center;\n\t\t\tjustify-content:center;\n\t  } *\/\n\t  .general-info-content,.Parents-info-content\n\t  {\n\t\t  height:calc(100% - 46px);\n\t\t  display:flex;\n\t  }\n\t  table.general-info-table\n\t  {\n\t\t  height: 170px;\n\t\t  width: 50%;\n\t\t  padding: 15px;\n\t\t   box-sizing: border-box;\n\t  }\n\t  table.parents-info-table\n\t  {\n\t\t  height: 140px;\n\t\t  width: 50%;\n\t\t  padding: 15px;\n\t\t   box-sizing: border-box;\n\t  }\n\t  table.general-info-table td,table.parents-info-table td {\n       font-size: 14px;\n\t   width:50%;\n\t   height:20px;\n      }\n\t  table.general-info-table td:first-child, table.parents-info-table td:first-child\n\t  {\n\t\t  color:var(--personal-info-td-color);\n\t  }\n\t  .sibiling-info-content\n\t  {\n\t\t  display: flex;\n\t\t  justify-content: center;\n\t\t  align-items: center;\n\t\t  font-size: 14px;\n\t\t  height: calc(100% - 31px);\n\t\t  width: 100%;\n\t  }\n\t  \n\t  .no-siblings-container{\n\t\t  height:100%;\n\t\t  display:flex;\n\t\t  align-items:center;\n\t\t  justify-content:center;\n\t  }\n  &lt;\/style&gt;\n  &lt;div class=&quot;personal-info-container&quot;&gt;\n    &lt;div class=&quot;row1-personal-info&quot;&gt;\n\t   &lt;div class=&quot;general-info-div&quot;&gt;\n\t      &lt;div class=&quot;general-info-header&quot;&gt;\n\t\t      &lt;span class=&quot;common-header&quot;&gt;General Info&lt;\/span&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;div class=&quot;general-info-content&quot;&gt;\n\t\t   &lt;table class=&quot;general-info-table&quot;&gt;\n\t\t      &lt;tr&gt;\n\t\t\t    &lt;td&gt;DOB&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Date_of_Birth%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;DOJ&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Date_of_Joining%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;Blood Group&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Blood_Group%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;!--&lt;tr&gt;\n\t\t\t    &lt;td&gt;Nationality&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;\t&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;--&gt;\n\t\t   &lt;\/table&gt;\n\t\t   &lt;table class=&quot;general-info-table&quot;&gt;\n\t\t      &lt;tr&gt;\n\t\t\t    &lt;td&gt;Gender&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Gender%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td style=&quot;vertical-align: top;&quot;&gt;Address&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Primary_Communication_Address.address_line_1%&gt;,&lt;br&gt;&lt;%=myinfo.Primary_Communication_Address.address_line_2%&gt;,&lt;br&gt;&lt;%=myinfo.Primary_Communication_Address.district_city%&gt;,&lt;br&gt;&lt;%=myinfo.Primary_Communication_Address.state_province%&gt; - &lt;%=myinfo.Primary_Communication_Address.postal_Code%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t   &lt;\/table&gt;\n\t\t  &lt;\/div&gt;\n\t   &lt;\/div&gt;\n\t   &lt;div class=&quot;sibiling-info-div&quot;&gt;\n\t     &lt;div class=&quot;sibiling-info-header&quot;&gt;\n\t\t      &lt;span class=&quot;common-header&quot;&gt;Sibiling Info&lt;\/span&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;div class=&quot;sibiling-info-content&quot;&gt;\n&lt;%\n\tif(myinfo.Sibling_Details.length() &gt; 0)\n\t{\n\t\tfor each  sibling in myinfo.Sibling_Details\n\t\t{\n\t\t\tif(sibling.Same_School == true)\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&quot;sibling&quot;&gt;\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-siblings-container&quot;&gt;\n\t\t\t\t\t\t\t&lt;p&gt;No Sibilings&lt;\/p&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t   &lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;row2-personal-info&quot;&gt;\n\t    &lt;div class=&quot;Parents-info-header&quot;&gt;\n\t\t      &lt;span class=&quot;common-header&quot;&gt;Parents Info&lt;\/span&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;div class=&quot;Parents-info-content&quot;&gt;\n\t\t  &lt;table class=&quot;parents-info-table&quot;&gt;\n\t\t      &lt;tr&gt;\n\t\t\t    &lt;td&gt;Father&apos;s\/Guardian&apos;s  Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Father_s_Name%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;Father&apos;s\/Guardian&apos;s  Occupation&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;\n&lt;%\n\tif(myinfo.Father_s_Occupation != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;%=myinfo.Father_s_Occupation%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n-\n&lt;%\n\t}\n\t%&gt;\n&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;Father&apos;s Mobile Number&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Father_s_Phone%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t   &lt;\/table&gt;\n\t\t   &lt;table class=&quot;parents-info-table&quot;&gt;\n\t\t      &lt;tr&gt;\n\t\t\t    &lt;td&gt;Mother&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&lt;%=myinfo.Mother_s_Name%&gt;&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;Mother&apos;s Occupation&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;\n&lt;%\n\tif(myinfo.Mother_s_Occupation != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;%=myinfo.Mother_s_Occupation%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n-\n&lt;%\n\t}\n\t%&gt;\n&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t\t  &lt;tr&gt;\n\t\t\t    &lt;td&gt;Mother&apos;s Mobile Number&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;\n&lt;%\n\tif(myinfo.Mother_s_Phone != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;%=myinfo.Mother_s_Phone%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n-\n&lt;%\n\t}\n\t%&gt;\n&lt;\/td&gt;\n\t\t\t  &lt;\/tr&gt;\n\t\t   &lt;\/table&gt;\n\t\t  &lt;\/div&gt;\n\t&lt;\/div&gt;\n  &lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Home(Child_Mail)
		{
			displayname = "Student Home"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet90' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet90()\ncontent\n&lt;%{\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\tmyInfo = Student[Email == zoho.loginuserid];\n\t}\n\telse\n\t{\n\t\tChild_Mail1 = input.Child_Mail.replaceFirst(&quot;%2B&quot;,&quot;+&quot;);\n\t\tmyInfo = Student[Email == Child_Mail1];\n\t}\n\tmy_class = myInfo.Class_UID;\n\ttotalBothDaysPresent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalMorningPresent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalAfternoonPresent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalDaysPresent = totalBothDaysPresent + (totalMorningPresent + totalAfternoonPresent) \/ 2;\n\ttotalBothDaysAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalMorningAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalAfternoonAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == myInfo.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalDaysAbsent = totalBothDaysAbsent + (totalMorningAbsent + totalAfternoonAbsent) \/ 2;\n\ttime_table = Time_Table[Class == my_class];\n\tall_dates = Time_Table_Subform[Time_Table == time_table.ID];\n\tannouncements = Communication_Form[Student == myInfo.ID &amp;&amp; Mode_of_Communication == &quot;Internal&quot;] sort by Added_Time desc range from 0 to 4;\n\tbreak1Time = zoho.currentdate + &quot; &quot; + time_table.Break_1.toString();\n\tbreakDurationMins = if(time_table.Break_Duration_in_Mins != null,time_table.Break_Duration_in_Mins,0);\n\tbreak1TimeString = break1Time.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + break1Time.toTime().addMinutes(breakDurationMins).toString(&quot;HH:mm&quot;);\n\tbreak2Time = zoho.currentdate + &quot; &quot; + time_table.Break_2_Time.toString();\n\tbreak2TimeString = break2Time.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + break2Time.toTime().addMinutes(breakDurationMins).toString(&quot;HH:mm&quot;);\n\t\/* \t\tlunchTime = zoho.currentdate + &quot; &quot; + time_table.Lunch_Time.toString();\n\t\tlunchTimeString = lunchTime.toTime().toString(&quot;HH:mm&quot;) + &quot; - &quot; + lunchTime.toTime().addMinutes(time_table.Lunch_Duration_in_Mins).toString(&quot;HH:mm&quot;); *\/\n\tlunchTimeString = &quot;lunchTimeString&quot;;\n\tlunchy = Subject_form[Subject_Name.equalsIgnoreCase(&quot;Lunch&quot;)];\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt; \n&lt;%=thisapp.Styles.getReportStyle()%&gt; \n&lt;%=thisapp.Styles.getLoaderStyle()%&gt; \n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n       \n        }\n\t\t.home-container{\n          width: 100%;\n          padding: 10px;\n\t\t  box-sizing: border-box;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t\t  gap:10px;\n\t\t  overflow:auto;\n       }\n\t   div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t.home-container-row1\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:225px;\n\t\t}\n\t\t.announcement-div,.attendance-div,.holiday-div\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\theight:225px;\n\t\t\tborder-radius:5px;\n\/\/ \t\t\tpadding:10px;\n\t\t\tbox-sizing: border-box;\n\t\t\t\n\t\t}\n\t\t.announcement-div,.attendance-div\n\t\t{\n\t\t\twidth:35%;\n\t\t}\n\t\t.announcement-div .content\n\t\t{\n\t\t\talign-items: center;\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 10px;\n\t\t}\n\t\t.holiday-div\n\t\t{\n\t\t\twidth:30%;\n\t\t}\n\t\t.home-container-row2\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\theight:fit-content;\n\t\t\tborder-radius:5px;\n\t\t\twidth:100%;\n\/\/ \t\t\tpadding:10px;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t.home-container-row3\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\theight:250px;\n\t\t\tborder-radius:5px;\n\t\t\twidth:100%;\n\t\t}\n\t\t.sub-header {\n\/*     height: 46px; *\/\n\/*     padding: 0 15px; *\/\n    display: flex;\n    align-items: center;\n    background: #f7f7f7;\n\t    border-top-left-radius: 5px;\n    border-top-right-radius: 5px;\n}\nh4 {\n    font-size: 16px;\n    font-weight: 700;\n}\n\n\n\n\t\t.content {\n    height: calc(100% - 46px);\n    overflow: auto;\n    padding-top: 5px;\n}\n\t\t.attendance-div .content\n\t\t{\n\t\t\t    display: flex;\n                flex-direction: column;\n                gap: 10px;\n                padding: 8px 10px;\n                height: calc(100% - 60px);\n\t\t}\n\t\t.content-row1,.content-row2\n\t\t{\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\theight: 50%;\n\t\t\tmargin: 2px;\n\t\t}\n\t\t.content-row2\n\t\t{\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tposition: relative;\n\t\t\tjustify-content: space-around;\n\t\t}\n\t\t\n\t\t.content-row1-column1,\n\t\t.content-row1-column2\n\t\t{\n\t\t\theight: 100%;\n\t\t\twidth: 100%;\n\t\t\tbox-shadow: 0px 0px 5px 1px rgb(0 0 0 \/ 25%);\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 3px;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tborder-radius: 5px;\n\t\t}\n\t\t.content-row1-column1 span\n\t\t{\n\t\t\tfont-size:20px;\n\t\t\tcolor:#80EE17;\n\t\t}\n\t\t.content-row1-column2 span\n\t\t{\n\t\t\tfont-size:20px;\n\t\t\tcolor:#FB4545;\n\t\t}\n\t\t\n\t\t\/*halfcircle progress*\/\n\t\t*:after, *:before {\n\t\t  box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.half-circle-container{\n\t\t\theight: 100%;\n\t\t\twidth: 50%;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t}\n\t\t.multigraph {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  overflow: hidden;\n\t\t}\n\n\t\t.multigraph:before {\n\t\t  content: &apos;&apos;;\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  border: var(--pbar-border-width) solid var(--half-circle-full-color);\n\t\t  border-radius: var(--pbar-width) var(--pbar-width) 0 0;\n\t\t  border-bottom: none;\n\t\t}\n\n\t\t.tooltip {\n\t\t  width: 80px;\n\t\t  height: 30px;\n\t\t  text-align: center;\n\t\t  font-size: 20px;\n\t\t  line-height: 30px;\n\t\t  font-weight: 200;\n\t\t  color: #000;\n\t\t  position: absolute;\n\t\t  left: 50%;\n\t\t  transform:translateX(-50%);\n\t\t  bottom: 0%;\n\t\t  transition: all 0.2s ease-in;\n\t\t}\n\n\t\t.graph {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t}\n\n\t\t.graph:before, .graph:after {\n\t\t  width: var(--pbar-width);\n\t\t  height: var(--pbar-height);\n\t\t  position: absolute;\n\t\t  top: 100%;\n\t\t  border: var(--pbar-border-width) solid var(--half-circle-filled-color);\n\t\t  content: &apos;&apos;;\n\t\t  border-radius:0 0 var(--pbar-width) var(--pbar-width);\n\t\t  border-top: none;\n\t\t  animation: demo 0.5s;\n\t\t  transform-origin: center top;\n\t\t  --progress-size:var(--percentage);\n\t\t}\n\n\t\t.graph:after {\n\t\t  transform: rotate(var(--progress-size));\n\t\t}\n\n\t\t@keyframes demo {\n\t\t  0% { transform: rotate(0deg) }\n\t\t  100% { transform: rotate(var(--progress-size)) }\n\t\t}\n\t\t\n\t\/* Timeline Design *\/\n\t.holiday-div .content{\n\/\/ \t\tpadding-top:10px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t\t.timeline-inner&gt;span {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\tpadding: 5px 0px;\n\t\tbox-sizing: border-box;\n\t}\n\t.timeline-outer {\n\t\twidth: 100%;\n\t\tposition:relative;\n\t\tborder-bottom: 1px solid #e1e1e1;\n\t}\n\t.timeline-outer:last-child {\n    border-bottom: unset;\n}\n\t.timeline-inner {\n    background: white;\n    position: relative;\n    z-index: 1;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    height: 49px;\n    padding: 0 15px;\n}\n\t\t\n.announcements-list&gt;li:last-child {\n    border-bottom: unset;\n}\n\n\t\t\/* Report Header Background And Height Style *\/\n\t\t\n\t\t\n\t\t.header {\n\t\t\theight: calc(100% - 115px);\n\t\t}\n\t\t\n\t\t.header&gt;div:last-child {\n\t\t\theight: calc(100% - 30px) !important;\n\t\t\tpadding-top: 10px !important;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t\n\t\t.leadpagereport{\n\t\t\theight:100% !important;\n\t\t}\n\t\t\/*time-table design*\/\n\t\t.time-table\n\t\t{\n\t\t\twidth:100%;\n\t\t\theight:100%;\n\t\t\tborder-collapse: collapse;\n\t\t}\n\t\t.time-table thead\n\t\t{\n\t\t\theight: 30px;\n\t\t\tcolor: #000;\n\t\t}\n\t\t.time-table tbody\n\t\t{\n\t\t\theight:calc(100% - 30px);\n\t\t\toverflow:auto;\n\t\t}\n\t\t\n\t\t.time-table tbody td:last-child{\n\t\t\tborder-right:1px solid #ebebeb;\n\t\t}\n\t\t\n\t\t.time-table tbody td\n\t\t{\n\t\t\tborder-bottom:1px solid #ebebeb;\n\t\t\tborder-left:1px solid #ebebeb;\n\t\t\theight:40px;\n\t\t\ttext-align:center;\n\t\t}\n\t\t\n\t\tul.announcements-list {\n\t\t\twidth: 100%;\n\t\t\theight: 100%;\n\/\/ \t\t\tpadding-left: 25px;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t\n\t\tul.announcements-list&gt;li {\n\t\t\ttext-align: justify;\n\t\t\tmargin-bottom: 10px;\n\t\t}\n\t\t\n\t\t.break-td {\n    border-left: 1px solid #ebebeb;\n    border-right: 1px solid #ebebeb;\n    position: relative;\n    box-sizing: border-box;\n    border-bottom: 1px solid #ebebeb;\n}\n\n\t\t.break-td&gt;span{\n\t\t\t  writing-mode: vertical-lr;\n\t\t\t  letter-spacing: 20px;\n\t\t\t  text-orientation: upright;\n\t\t\t  position: absolute;\n\t\t\t  top: 50%;\n\t\t\t  left: 50%;\n\t\t\t  transform: translate(-50%,-50%);\n\t\t}\n\t\t\n\t\t.time-table tbody td:last-child,.time-table thead th:last-child {\n\/\/     border-right: 1px solid #ebebeb;\n}\n\n\/\/ .time-table tbody td:first-child, .time-table thead th:first-child {\n\/\/     border-left: 1px solid #ebebeb;\n\/\/ }\nspan.announcement-sub {\n    font-size: 14px;\n    font-weight: bold;\n}\n\nspan.announcement-det {\n    font-size: 12px;\n\tpadding-right: 10px;\n}\n.announcements-list&gt;li {\n    margin-bottom: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    gap: 10px;\n\tpadding: 0 18px;\n\tborder-bottom: 1px solid #E1E1E1;\n}\n\n.li-announcement-cont {\n    text-align: justify;\n    margin-bottom: 7px;\n    width: 350px;\n    height: 65px;\n\/\/     background: #F8F8F8;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 8px;\n    justify-content: center;\n    padding-left: 15px;\n    position:relative\n}\n\n.li-announcement-date-div{\n\tcolor: #868686;\n    font-size: 13px;\n    font-weight: 600;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    gap: 5px;\n}\nspan.announcement-det &gt; * {\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    text-align: justify;\n    overflow: hidden;\n}\nth.day-period {\n    font-weight: 600;\n}\n\nth.day-period{\n    background: #F1F1F1;\n}\n\nth.day-period&gt;span {\n    border-radius: 5px;\n\/*     background: #F1F1F1; *\/\n    display: flex;\n    height: 100%;\n    width: 100%;\n    