			User_Input_Script as "User Input Script"
			{
				type =  form
				form = Asset_Mapping
				record event = on add

				on user input of Map_to
				{
					actions 
					{
						custom deluge script
						(
											hide Staff;
										hide Room;
										hide Block;
										input.Staff = null;
										input.Room = null;
										input.Block = null;
										if(input.Map_to == "Staff")
										{
											show Staff;
										}
										else if(input.Map_to == "Room")
										{
											show Room;
										}
										else if(input.Map_to == "Block")
										{
											show Block;
										}
						)
					}
				}

			}
