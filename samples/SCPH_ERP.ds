			send_offer_letter as "send offer letter"
			{
				type =  form
				form = Candidate
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											getKey = thisapp.getPublishKey();
										orgInfo = School_Details[ID != 0];
										imagefile = orgInfo.Logo.getSuffix("fieldName/image/").getPrefix("\" lowqual");
										if(thisapp.portal.isUserInProfile("Admin") == true || thisapp.portal.isUserInProfile("Student") == true)
										{
											appurl = thisapp.getPortalUrl();
										}
										else
										{
											appurl = "https://creatorapp.zohopublic.in";
										}
										imageUrl = appurl + "/file" + zoho.appuri + "All_School_Details/" + orgInfo.ID + "/Logo/image-download/" + getKey + "?filepath=/" + imagefile;
										input.Offer_Letter_Content = "<style> * { padding: 0; margin: 0; border: none; }  .offer-card-container{ /* width: 100%; */ position: relative; background:#fff; padding:20px 30px; } .offer-card-header{ display: flex; align-items: center; height: 40px; justify-content: center; width: 100%; gap: 30px; position:relative; } .org-logo{ height:25px; /* border-radius:20px; */ object-fit: contain; /* position:absolute; left:0; */ } .school-name { font-size: 20px !important; font-weight: 600 !important; } .personal-detail-header{ font-size: 15px; font-weight: 600; text-align:center; } .terms-condition-div { padding-left: 30px; } .terms-condition-div p { margin-top: 15px !important; } .offer-content p{ margin-top:17px; } .personal-detail-div,.personal-detail-div p{ margin-top:20px; } table.personal-detail-table td { padding: 5px; padding-right: 25px; } table.personal-detail-table{ margin-top:20px; } </style> <div class='offer-card-container'> <div class='offer-card-header'> <img class='org-logo' src=" + imageUrl + " class='org-logo' /> <p class='school-name'>" + orgInfo.School_Name + "</p> </div> <div class='offer-content'> <p>To</p> <span style='font-weight:600;margin-top:10px;'>" + input.Name + "</span> <p>Ref. / MGRS / Appointment / " + zoho.currentdate.toString("MMMM YYYY") + " </p> <p style='font-weight:600;'>Subject: Offer of Appointment to the post of " + input.Designation.Designation + "</p> <p>With reference to your application and subsequent interview, you are hereby informed that you have been selected for the post of " + input.Designation.Designation + " in our school on the following terms and conditions. <p> <div class='terms-condition-div'> <p>1)You shall be paid a consolidated pay of Rs <span style='font-weight:600;'>" + input.Consolidated_Pay + "</span> Inclusive of E.P. F & E.S.I & Other taxes. </p> <p>2)You shall be on probation for the period of one academic year from the date of your appointment to the last working day of the Summer Vacation. </p> <p>3)During the entire tenure of your employment, your services may be terminated with three months notice on either side or payment of three months’ salary in lieu of notice without assigning any reasons. Vacation period will not be considered for notice period. However, on disciplinary grounds, the management reserves the right to terminate your services without any notice or pay in lieu. </p> <p>4)After the confirmation of your services, the conditions indicated in the above point (Point 3) about notice and termination from services remains the same. </p> <p>5)Your leave entitlement will be as follows: a.School vacations as per state Govt. G.O or School Calendar b.Ten days casual leave in an academic year. </p> <p>6)You will be permitted one day casual leave for each month of academic year. No accumulation of casual leave is allowed or to be carried to the next year. Obtain prior sanction of leave in written before availing it. </p> <p>7)You shall be committed to serve the institution for the complete academic session. </p> <p>8)You will be permitted to give your acceptance to the undersigned on or before <span style='font-weight:600;'>" + input.Last_Date_of_Offer_Letter_Acceptance + "</span>. You should report on duty on <span style='font-weight:600;'>" + input.Joining_Date + "</span>. In case acceptance is not received by the given date, it will be presumed that you are not interested and this offer will be treated as cancelled. </p> <p>9)We welcome you to " + orgInfo.School_Name + " Family and hope that our association will be mutually beneficial. </p> </div> <p>We wish you good luck. </p> <p>Date : " + zoho.currentdate + " </p> </div> <div class='personal-detail-div'> <div class='personal-detail-header'>Appendix</div> <p>These are the personal details we have received from you as needed for processing your profile.</p> <table class='personal-detail-table'> <tr><td>Date of Birth</td><td>:</td><td>" + input.Date_of_Birth + "</td></tr> <tr><td>Aadhar No</td><td>:</td><td>" + input.Aadhar_No + "</td></tr> <tr><td>PAN No</td><td>:</td><td>" + input.PAN_No + "</td></tr> <tr><td>Account No</td><td>:</td><td>" + input.Account_No + "</td></tr> <tr><td>Bank Name</td><td>:</td><td>" + input.Bank_Name + "</td></tr> <tr><td>Branch</td><td>:</td><td>" + input.Branch + "</td></tr> <tr><td>IFSC Code</td><td>:</td><td>" + input.IFSC_Code + "</td></tr> </table> </div> </div>";
										sendmail
										[
											from :zoho.adminuserid
											to :input.Email_ID
											subject :"Job Offer from " + orgInfo.School_Name
											message :"<div>Dear " + input.Name + ",<br></div><div><br></div><div>We are pleased to offer you the position of " + input.Designation.Designation + " at " + orgInfo.School_Name + ", starting " + input.Joining_Date + ". We are excited about the potential you will bring to our institution and look forward to you joining us.<br></div><div><br></div><p>Please find attached the detailed offer letter outlining your job title, duties, compensation, benefits, and other terms and conditions of employment. Kindly review the offer carefully and let us know if you have any questions or require any clarifications.<br></p><p>To accept this offer, please sign and date the enclosed offer letter and email it back to us by " + input.Last_Date_of_Offer_Letter_Acceptance + ", along with any other documents as mentioned in the offer letter.<br></p><div>If you accept this offer, we would also appreciate it if you could inform us of your anticipated start date and provide any additional information required for employment purposes.<br></div><div><br></div><div>We look forward to your favorable response.<br></div><div><br></div><div><br></div><div><br></div><div>Warm regards,<br></div><div>" + orgInfo.School_Name + "<br></div><div><br></div><div><br></div><div><br></div><div><br></div><div><br></div><div><br></div><div><br></div><div><br></div><div><br></div>"
											Attachments :template:Offer_Letter as PDF
										]
						)
					}
				}

			}
