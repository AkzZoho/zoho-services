		page Admin_Dashboard
		{
			displayname = "Admin Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet1041' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1041()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n.zcs_admindash_container{\n\tpadding:15px;\n}\n.zcs_admindash_cardbackground{\n\tbackground: #F7F7F7;\n    border-radius: 10px;\n    padding: 15px;\n    margin: 10px;\n}\n.zcs_admindash_Header{\n\tdisplay: flex;\n\ttext-align: center;\n\/\/ \tpadding-bottom: 13px;\n}\n.zcs_admindash_HeaderLogo {\n\twidth: 90px;\n\taspect-ratio: 1;\n\tmargin-left: 45px;\n}\n.zcs_admindash_HeaderDev{\n\tflex: 1;\n\tdisplay: flex;\n\tflex-direction: column;\n\tjustify-content: center;\n\tmargin-right: 60px;\n\tletter-spacing: .75px;\n}\n.zcs_admindash_cardHeader{\n\tcolor: #4F4F4F;\n\tfont-size: 15px;\n\tfont-family: Lato;\n\tfont-weight: 600;\n\tword-wrap: break-word;\n\tpadding-bottom: 10px;\n}\n.zcs_admindash_allcard{\n\tdisplay: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    justify-content: space-between;\n}\n.zcs_admindash_card{\n\twidth: calc(25% - 20px);\n    min-width: 250px;\n    height: 80px;\n    background: white;\n    border-radius: 15px;\n    display: flex;\n    align-items: center;\n    justify-content: space-around;\n    font-family: Arial, sans-serif;\n    font-weight: bold;\n    box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n\toverflow: hidden;\n\tposition: relative;\n}\n \/* Color Variants *\/\n  .zcs_card--purple::after { background: #A054FF; }\n  .zcs_card--blue::after { background: #62CEFF; }\n  .zcs_card--orange::after { background: #FF8550; }\n  .zcs_card--pink::after { background: #FF5594; }\n\n  \/* Common Border Styling *\/\n  .zcs_admindash_card::after {\n    content: &apos;&apos;;\n    position: absolute;\n    right: 0;\n    top: 0;\n    height: 100%;\n    width: 4px;\n    border-radius: 0 15px 15px 0;\n  }\n.zcs_logoinsidecard {\n\twidth: 53px;\n\theight: 53px;\n\tborder-radius: 10px;\n\tdisplay: flex;\n\tjustify-content: center;\n}\n.zcs_cardtitle {\n\twidth: 211px;\n\tleft: 194px;\n\ttop: 256px;\n\tcolor: #5D5D5D;\n\tfont-size: 13px;\n\tfont-family: Lato;\n\tfont-weight: 500;\n\tword-wrap: break-word;\n}\n.zcs_carddatacount{\n\tcolor: #323030; \n\tfont-size: 18px; \n\tfont-family: Lato; \n\tfont-weight: 700; \n\tword-wrap: break-word;\n}\n.zcs_logoinsidecard img {\n    width: 35px;\n    object-fit: contain;\n  }\n\n  \/* Responsive adjustments *\/\n  @media (max-width: 768px) {\n    .zcs_logoinsidecard {\n      width: 56px;\n      height: 55px;\n    }\n    .zcs_logoinsidecard img {\n      width: 36px;\n      height: 36px;\n    }\n  }\n  @media (max-width: 1200px) {\n    .zcs_card {\n      width: calc(50% - 10px);\n    }\n  }\n\n  @media (max-width: 600px) {\n    .zcs_card {\n      width: 100%;\n    }\n}\n.zcs_admindash_Body{\n  display: flex;\n  gap: 15px;\n}\n.zcs_admindash_Report {\n\tflex: 1;\n    min-width: 0; \/* Crucial for containment *\/\n    background: white;\n    border-radius: 10px;\n    overflow: hidden; \/* Ensures content stays within bounds *\/\n    box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n}\n.zcs_admindash_ReportHead {\n\tpadding: 15px 20px;\n    background: #F7F7F7;\n    font-weight: 600;\n    font-size: 18px;\n    color: #4F4F4F;\n}\n.zcs_admindash_ReportBody {\n\tmin-height: 431px;\n\toverflow-y: auto;\n\toverflow-x: hidden;\n}\n.zcs_admindash_ReportHead_Data {\n\tpadding: 5px;\n\tcolor: #4F4F4F; \n\tfont-size: 15px; \n\tfont-family: Lato; \n\tfont-weight: 600; \n\tword-wrap: break-word;\n}\n.no_record_subtext {\n    display: inline-block;\n    color: transparent; \/* Hide original text *\/\n    position: relative;\n}\n\n[id*=&quot;Upcoming_Holidays_ZC&quot;] .no_record_subtext::after {\n    content: &quot;No Upcoming Holidays&quot;;\n    color: black;\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 100%;\n}\n\n[id*=&quot;Announcements_ZC&quot;] .no_record_subtext::after {\n    content: &quot;No new Announcements&quot;;\n    color: black;\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 100%;\n}\n\n[id*=&quot;Students_with_Birthdays_Today_ZC&quot;] .no_record_subtext::after {\n    content: &quot;No Birthday&apos;s Today&quot;;\n    color: black;\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 100%;\n}\n\n.zcs_birthday_student {\n\/\/ \tborder: 1px solid #ccc;\n\tborder-radius: 5px;\n    box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);\n\tpadding: 10px;\n\tmargin: 5px 10px;\n}\n\n.zcs_student_row1 {\n\tdisplay: flex;\n\tjustify-content: space-between;\n}\n\n.zcs_student_row1 p {\n\tline-height: 0.5;\n}\n\n.zcs_student_row2 {\n\tdisplay: flex;\n\tjustify-content: center;\n}\n\n.zcs_student_row2 p {\n\tline-height: 0.5px;\n\tcolor: grey;\n}\n\n.zcs_announcement {\n\tborder-radius: 5px;\n    box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);\n\tpadding: 10px;\n\tmargin: 5px 10px;\n}\n\n.zcs_announcement p {\n\tline-height: 0.5;\n}\n\n.zcs_upcoming_holiday {\n\tborder-radius: 5px;\n    box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);\n\tpadding: 10px;\n\tmargin: 5px 10px;\n}\n\n.zcs_holiday_row1 {\n\tdisplay: flex;\n\tjustify-content: space-between;\n}\n\n.zcs_holiday_row1 p {\n\tline-height: 0.5;\n}\n\n.zcs_holiday_row2 {\n\tdisplay: flex;\n\tjustify-content: center;\n}\n\n.zcs_holiday_row2 p {\n\tline-height: 0.5px;\n\tcolor: grey;\n}\n\n.zcs_view_more {\n\tmargin: 10px;\n\tdisplay: flex;\n    justify-content: center;\n}\n\n.zcs_view_more a {\n    color: #0d6cf0;\n    font-weight: 500;\n    font-size: 12px;\n}\n\n.zcpopup.compact .popupbox-wrapper .popupbox {\n\t    max-width: 78% !important;\n}\n\n@media (max-width: 1200px) {\n    .zcs_admindash_card {\n        width: calc(33.33% - 10px);\n    }\n}\n@media (max-width: 768px) {\n    .zcs_admindash_card {\n        width: 100%;\n    }\n}\n.divEmbedContainer{\n\theight:100%;\n}\n.record.recordlive.zc-multiline .gridCont{\n\tmin-height: 0px !important;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;zcs_admindash_container&quot;&gt;\n&lt;div class=&quot;zcs_admindash_Header&quot; &gt;\n&lt;%\n\tActiveAcademicYear = Educational_Year[Status == &quot;Current&quot; || Status == &quot;Upcoming&quot;];\n\tSchoolInfo = School_Details[ID != 0];\n\timage_name = SchoolInfo.Logo.getSuffix(&quot;\/image\/&quot;).getPrefix(&quot;\\&quot;&quot;);\n\t%&gt;\n&lt;img class=&quot;zcs_admindash_HeaderLogo&quot; src=&quot;https:\/\/creatorapp.zoho.in&lt;%=zoho.appuri%&gt;report\/All_School_Details\/&lt;%=SchoolInfo.ID%&gt;\/Logo\/download-file?filepath=\/&lt;%=image_name%&gt;&quot; style=&quot;width: 90px; height: 90px;&quot;&gt;\n&lt;div class=&quot;zcs_admindash_HeaderDev&quot;&gt;\n&lt;h3 style=&quot;font-size: 20px;margin: 0px;&quot;&gt;&lt;%=SchoolInfo.School_Name%&gt; - Dashboard&lt;\/h3&gt;\n&lt;p style=&quot;font-size: 15px;margin: 0px;margin-top: 10px;&quot;&gt;Academic Year : &lt;%=ActiveAcademicYear.Academic_Year%&gt;&lt;\/p&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n\n&lt;div class=&quot;zcs_admindash_cardbackground&quot;&gt;\n&lt;div class=&quot;zcs_admindash_cardHeader&quot;&gt;Student Details&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_allcard&quot;&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--purple&quot;&gt;\n&lt;%\n\tTotalLogo = thisapp.Akz.ImageUrl(&quot;Total Icon Dashboard&quot;);\n\tStudentPresent = thisapp.Akz.ImageUrl(&quot;Student Present&quot;);\n\tStaffPresent = thisapp.Akz.ImageUrl(&quot;Staff Present&quot;);\n\tAbsentIcon = thisapp.Akz.ImageUrl(&quot;Absent&quot;);\n\tAdmissionIcon = thisapp.Akz.ImageUrl(&quot;Admissions&quot;);\n\tNonTeachingStaffIcon = thisapp.Akz.ImageUrl(&quot;Non Teaching Staff&quot;);\n\tTotalStudents = Student[ID != 0].count();\n\tPresentToday = Student_Attendance[Date_field == zoho.currentdate].sum(Present_Students);\n\tAbsentToday = TotalStudents - PresentToday;\n\tActiveAcademicYear = Educational_Year[Status == &quot;Current&quot; || Status == &quot;Upcoming&quot;];\n\tThisYearAdmissions = Registration[Educational_Year == ActiveAcademicYear.ID].count();\n\tAllTeachers = Staff[ID != 0].count();\n\tTeacher_PresentToday = Staff_Attendance[Date_field == zoho.currentdate &amp;&amp; Status in {&quot;Present&quot;,&quot;Away&quot;,&quot;On Duty&quot;}].count();\n\tTeacher_AbsentToday = Staff_Attendance[Date_field == zoho.currentdate &amp;&amp; Status == &quot;Absent&quot;].count();\n\tNonteachingStaff = Staff[Staff_Type == &quot;Non Teaching Staff&quot;].count();\n\t\/\/ \tTotalStudents = \n\t%&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #F0E4FF;&quot;&gt;&lt;img src=&quot;&lt;%=TotalLogo%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Total Students&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=TotalStudents%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--blue&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #EFFAFF;&quot;&gt;&lt;img src=&quot;&lt;%=StudentPresent%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Presents Today&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=PresentToday%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--orange&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #FEF7F4;&quot;&gt;&lt;img src=&quot;&lt;%=AbsentIcon%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Absents Today&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=AbsentToday%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--pink&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #FFEDF3;&quot;&gt;&lt;img src=&quot;&lt;%=AdmissionIcon%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;2025 Admissions&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=ThisYearAdmissions%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_cardbackground&quot;&gt;\n&lt;div class=&quot;zcs_admindash_cardHeader&quot;&gt;Staff Details&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_allcard&quot;&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--purple&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #F0E4FF;&quot;&gt;&lt;img src=&quot;&lt;%=TotalLogo%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Teachers Strength&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=AllTeachers%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--blue&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #EFFAFF;&quot;&gt;&lt;img src=&quot;&lt;%=StaffPresent%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Presents Today&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=Teacher_PresentToday%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--orange&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #FEF7F4;&quot;&gt;&lt;img src=&quot;&lt;%=AbsentIcon%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Absents Today&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=Teacher_AbsentToday%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_card zcs_card--pink&quot;&gt;\n&lt;div class=&quot;zcs_logoinsidecard&quot; style=&quot;background: #FFEDF3;&quot;&gt;&lt;img src=&quot;&lt;%=NonTeachingStaffIcon%&gt;&quot; alt=&quot;Students Icon&quot;&gt;&lt;\/div&gt;\n&lt;div class=&quot;zcs_cardtitle&quot;&gt;Non-teaching Staff&lt;br&gt;&lt;span class=&quot;zcs_carddatacount&quot;&gt;&lt;%=NonteachingStaff%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_Body&quot;&gt;\n&lt;div class=&quot;zcs_admindash_Report&quot;&gt;\n&lt;div class=&quot;zcs_admindash_ReportHead&quot;&gt;\n\t&lt;div class=&quot;zcs_admindash_ReportHead_Data&quot;&gt;Today\u2019s Birthdays&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_ReportBody&quot;&gt;\n&lt;!-- &lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;Students_with_Birthdays_Today&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Import=false&amp;zc_AddRec=false&apos;&gt;Loading View...&lt;\/div&gt; --&gt;\n&lt;%\n\t\/\/--------------------------- Today&apos;s Birthdays -------------------------\n\tstudent_count = 0;\n\tfor each  student in Student[Date_of_Birth != null]\n\t{\n\t\tdate_of_birth = student.Date_of_Birth.getDay() + &quot;-&quot; + student.Date_of_Birth.getMonth();\n\t\tdate_today = today.getDay() + &quot;-&quot; + today.getMonth();\n\t\tif(date_of_birth == date_today &amp;&amp; student_count &lt; 7)\n\t\t{\n\t\t\tstudent_count = student_count + 1;\n\t\t\t%&gt;\n&lt;div class=&quot;zcs_birthday_student&quot;&gt;\n\t\t\t\t&lt;div class=&quot;zcs_student_row1&quot;&gt;\n\t\t\t\t\t&lt;p style=&quot;font-weight: 600;&quot;&gt;&lt;%=student.Student_Name%&gt;&lt;\/p&gt;\n\t\t\t\t\t&lt;p&gt;&lt;%=student.Admission_Number%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;zcs_student_row2&quot;&gt;\n\t\t\t\t\t&lt;p&gt;&lt;%=student.Class_UID.Class_Name%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\tif(student_count &gt;= 8)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_view_more&quot;&gt;\n\t\t\t\t&lt;a href=&quot;https:\/\/creatorapp.zoho.in\/girimservices_in_zohotest\/environment\/development\/scph-erp#Page:All_Students1&quot;&gt;View All&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_Report&quot;&gt;\n&lt;div class=&quot;zcs_admindash_ReportHead&quot;&gt;\n\t&lt;div class=&quot;zcs_admindash_ReportHead_Data&quot;&gt;Announcements&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_ReportBody&quot;&gt;\n&lt;!--\t&lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;Announcements&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Import=false&amp;zc_AddRec=false&apos;&gt;Loading View...&lt;\/div&gt; --&gt;\n&lt;%\n\t\/\/------------------------ Announcements ---------------------------\n\tfor each  news in Communication_Form[ID != 0] sort by Added_Time desc range from 1 to 3\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_announcement&quot;&gt;\n\t\t\t\t&lt;p style=&quot;font-weight: 600;&quot;&gt;&lt;%=news.Subject_field%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;p&gt;&lt;%=news.Message%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;p style=&quot;color: grey;&quot;&gt;&lt;%=news.Added_Time%&gt;&lt;\/p&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\tannouncements = Communication_Form[ID != 0];\n\tif(announcements.count() &gt; 3)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_view_more&quot;&gt;\n\t\t\t\t&lt;a href=&quot;https:\/\/creatorapp.zoho.in\/girimservices_in_zohotest\/environment\/development\/scph-erp#Report:Communications_Report&quot;&gt;View All&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_Report&quot;&gt;\n&lt;div class=&quot;zcs_admindash_ReportHead&quot;&gt;\n\t&lt;div class=&quot;zcs_admindash_ReportHead_Data&quot;&gt;Upcoming Holidays&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;zcs_admindash_ReportBody&quot;&gt;\n&lt;!--\t&lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;Upcoming_Holidays&apos; params=&apos;zc_Header=false&amp;zc_Footer=false&amp;zc_Import=false&amp;zc_AddRec=false&apos;&gt;Loading View...&lt;\/div&gt; --&gt;\n&lt;%\n\t\/\/------------------------ Upcoming Holidays ------------------------\n\tfor each  holiday in Holidays[Date_field &gt;= zoho.currentdate] sort by Date_field range from 1 to 7\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_upcoming_holiday&quot;&gt;\n\t\t\t\t&lt;div class=&quot;zcs_holiday_row1&quot;&gt;\n\t\t\t\t\t&lt;p style=&quot;font-weight: 600;&quot;&gt;&lt;%=holiday.Holiday%&gt;&lt;\/p&gt;\n\t\t\t\t\t&lt;p&gt;&lt;%=holiday.Date_field%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;zcs_holiday_row2&quot;&gt;\n\t\t\t\t\t&lt;p&gt;&lt;%=holiday.Holiday_Type%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\tupcomingHolidays = Holidays[Date_field &gt;= zoho.currentdate];\n\tif(upcomingHolidays.count() &gt; 7)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_view_more&quot;&gt;\n\t\t\t\t&lt;a href=&quot;https:\/\/creatorapp.zoho.in\/girimservices_in_zohotest\/environment\/development\/scph-erp\/#Report:Upcoming_Holidays&quot;&gt;View All&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
			script
			{
				/* Write your script logic here. You can assign values to the page variables you've created in the previous tab. Enter 'input.' to list the created page variables. */
			}
