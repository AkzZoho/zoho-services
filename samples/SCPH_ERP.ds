			openStudentAttendance as "openStudentAttendance"
			{
				type =  functions
				form = Student_Attendance
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						allStudentAttendance = Class_Attendance[Student_Attendance == input.ID];
										if(allStudentAttendance.count() == 0)
										{
											studetns = Student[Class_UID == input.Class && Status == "Active"];
											input.Tota = studetns.count();
											input.Present_Students = studetns.count();
											for each  stude in studetns
											{
												resp = insert into Class_Attendance
												[
													Added_User=zoho.loginuser
													Date_field=zoho.currentdate
													Type_field="Normal"
													Student=stude
													Class=stude.Class_UID
													Student_Attendance=input.ID
													Is_Present_in_Morning=true
													Is_Present_in_Afternoon=true
												];
											}
										}
										openUrl("#Report:Class_Attendances?Date_field=" + input.Date_field + "&Class.ID=" + input.Class + "&Student_Attendance=" + input.ID,"popup window","width=80%,height=90%");
					)
					}
				}
			}
