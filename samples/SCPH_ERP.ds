			addAvailableSections as "addAvailableSections"
			{
				type =  form
				form = Select_Section_Stateless
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											eduYear = Educational_Year[Status == "Current"];
										upYear = Educational_Year[Status == "Upcoming"];
										student = Student[ID == input.Student];
										preClass = Class[ID == student.Class_UID && Educational_Year == eduYear];
										clsDb = Class_DB[ID == preClass.Class];
										classSections = Class[Class.Order == clsDb.Order + 1 && Educational_Year == upYear].Section2.getAll();
										input.Sections:ui.add(classSections);
						)
					}
				}

			}
			onSubmission20 as "onSubmission"
			{
				type =  form
				form = Select_Section_Stateless
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						eduYear = Educational_Year[Status == "Current"];
										upYear = Educational_Year[Status == "Upcoming"];
										student = Student[ID == input.Student];
										preClass = Class[ID == student.Class_UID && Educational_Year == eduYear];
										clsDb = Class_DB[ID == preClass.Class];
										info upYear.Academic_Year;
										// upClassDb =  Class_DB [ Order == clsDb ];
										futureClass = Class[Educational_Year == upYear && Class.Order == clsDb.Order + 1 && Section2 == input.Sections];
										info futureClass;
										resp = Student[Annual_Exam_Result != "Yet to Start" && Class_UID.Class == clsDb && Class_UID.Educational_Year == eduYear];
										if(futureClass.Student.size() + 1 <= futureClass.Student_Capacity)
										{
											info "kahsbdfj";
											student.Class_UID=futureClass;
											student.Annual_Exam_Result="Yet to Start";
											if(resp.count() == 0)
											{
												clsDb.Class_Promotion_Status="Finished";
											}
										}
										openUrl("#Page:Promote_Students1","same window");
					)
					}
				}
			}
			On_user_Input as "On user Input"
			{
				type =  form
				form = Report_Search
				record event = on add

				on user input of Radio
				{
					actions 
					{
						custom deluge script
						(
											if(input.Radio == "New Leads")
										{
											openUrl("#Report:My_Leads?zc_LoadIn=embed-leadpage&zc_ReportName=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false&zc_Search=true&zc_MoreAction=true","same window");
										}
										else if(input.Radio == "Registration Form Issued")
										{
											openUrl("#Report:Registration_Forms_Issued?zc_LoadIn=embed-leadpage&zc_Header=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false","same window");
										}
										else if(input.Radio == "Registrations")
										{
											openUrl("#Report:All_Registrations?zc_LoadIn=embed-leadpage&zc_ReportName=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false&zc_AddRec=true&zc_Search=true&zc_MoreAction=true","same window");
										}
										else if(input.Radio == "Scheduled Entrance Exams")
										{
											openUrl("#Report:Scheduled_Entrance_Exams?zc_LoadIn=embed-leadpage&zc_Header=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false","same window");
										}
										else if(input.Radio == "Waiting List")
										{
											openUrl("#Report:Waiting_List1?zc_LoadIn=embed-leadpage&zc_Header=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false","same window");
										}
										else if(input.Radio == "Selected List")
										{
											openUrl("#Report:Selected_List?zc_LoadIn=embed-leadpage&zc_Header=false&zc_Footer=false&zc_ColMenu=false&zc_EditRec=false&zc_DuplRec=false&zc_DelRec=false","same window");
										}
						)
					}
				}

			}
