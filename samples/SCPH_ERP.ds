		page Hostel_Dashboard1
		{
			displayname = "Hostel Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet52' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet52()\ncontent\n&lt;%{\n\tblock = Block1[Warden.Email_ID == zoho.loginuserid].ID;\n\tstudents = Student[Hosteller == true &amp;&amp; Status == &quot;Active&quot; &amp;&amp; Hostel_Room_Allotted == true].count();\n\thostel = Room_Type[Room_Type == &quot;Hostel&quot;].ID;\n\trooms = Room[Room_Type1 == hostel].count();\n\toccupied = Room[Room_Type1 == hostel &amp;&amp; Room_Status == &quot;Occupied&quot;].count();\n\tvacancy = Room[Room_Type1 == hostel &amp;&amp; Room_Status == &quot;Empty&quot; || Room_Status == &quot;Partially Occupied&quot;].sum(Vacancy);\n\tcurrentDay = zoho.currentdate.getDayOfWeek();\n\tcurrentTime = zoho.currenttime.toList(&quot; &quot;).get(1);\n\tcurrentHour = currentTime.toList(&quot;:&quot;).get(0).toNumber();\n\tif(currentDay == 1)\n\t{\n\t\tsunday_hostel_menu = Hostel_Menu[Day == &quot;Sunday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = sunday_hostel_menu.Breakfast;\n\t\tlunch = sunday_hostel_menu.Lunch1;\n\t\tevening_snacks = sunday_hostel_menu.Evening_Snacks;\n\t\tdinner = sunday_hostel_menu.Dinner;\n\t}\n\telse if(currentDay == 2)\n\t{\n\t\tmonday_hostel_menu = Hostel_Menu[Day == &quot;Monday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = monday_hostel_menu.Breakfast;\n\t\tlunch = monday_hostel_menu.Lunch1;\n\t\tevening_snacks = monday_hostel_menu.Evening_Snacks;\n\t\tdinner = monday_hostel_menu.Dinner;\n\t}\n\telse if(currentDay == 3)\n\t{\n\t\ttuesday_hostel_menu = Hostel_Menu[Day == &quot;Tuesday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = tuesday_hostel_menu.Breakfast;\n\t\tlunch = tuesday_hostel_menu.Lunch1;\n\t\tevening_snacks = tuesday_hostel_menu.Evening_Snacks;\n\t\tdinner = tuesday_hostel_menu.Dinner;\n\t}\n\telse if(currentDay == 4)\n\t{\n\t\twednesday_hostel_menu = Hostel_Menu[Day == &quot;Wednesday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = wednesday_hostel_menu.Breakfast;\n\t\tlunch = wednesday_hostel_menu.Lunch1;\n\t\tevening_snacks = wednesday_hostel_menu.Evening_Snacks;\n\t\tdinner = wednesday_hostel_menu.Dinner;\n\t}\n\telse if(currentDay == 5)\n\t{\n\t\tthursday_hostel_menu = Hostel_Menu[Day == &quot;Thursday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = thursday_hostel_menu.Breakfast;\n\t\tlunch = thursday_hostel_menu.Lunch1;\n\t\tevening_snacks = thursday_hostel_menu.Evening_Snacks;\n\t\tdinner = thursday_hostel_menu.Dinner;\n\t}\n\telse if(currentDay == 6)\n\t{\n\t\tfriday_hostel_menu = Hostel_Menu[Day == &quot;Friday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = friday_hostel_menu.Breakfast;\n\t\tlunch = friday_hostel_menu.Lunch1;\n\t\tevening_snacks = friday_hostel_menu.Evening_Snacks;\n\t\tdinner = friday_hostel_menu.Dinner;\n\t}\n\telse\n\t{\n\t\tsaturday_hostel_menu = Hostel_Menu[Day == &quot;Saturday&quot; &amp;&amp; Block1 == block];\n\t\tbreakfast = saturday_hostel_menu.Breakfast;\n\t\tlunch = saturday_hostel_menu.Lunch1;\n\t\tevening_snacks = saturday_hostel_menu.Evening_Snacks;\n\t\tdinner = saturday_hostel_menu.Dinner;\n\t}\n\tif(block != null)\n\t{\n\t\tall_breakfast_items = breakfast;\n\t\tall_lunch_items = lunch;\n\t\tall_evening_snacks_items = evening_snacks;\n\t\tall_dinner_items = dinner;\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\t&lt;style&gt;\n\t\t*{\n\t\t\tmargin:0;\n\t\t\tpadding:0;\n\t\t\t\n\t\t}\n\t\t\n\t\t.panels{\n\t\t\tdisplay: flex;\n\t\t\tpadding-bottom:10px;\n\t\t\tbox-sizing:border-box;\n\t\t\tgap: 10px;\n\t\t  }\n\t\t  \n\n\t\t  .panels .panel {\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tflex: 1;\n\t\t\theight: 95px;\n\t\t\tbackground:var(--panel-background-color);\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t\tborder-radius: 10px;\n\t\t\tposition:relative;\n\t\t\toverflow:hidden;\n\t\t\tpadding-left: 70px;\n\t\t  }\n\n\t\t  .panels .panel span:nth-child(1) {\n\t\t\t  font-size: 20px;\n\t\t\t  font-weight: 700;\n\t\t  }\n\t\t  \n\t\t  .panels .panel span:nth-child(2){\n\t\t\t  font-size: 14px;\n\t\t\t  color: #7D7D7D;\n\t\t\t  font-weight: 500;\n\t\t  }\n\t\t  \n\t\t  .panel{\n\t\t\tgap:5px;\n\t\t  }\n\t\t  .column1\n\t\t  {\n\t\t\t  width:50%;\n\t\t  }\n\t\t  .column2\n\t\t  {\n\t\t\theight: 200px;\n\t\t\tbackground: var(--panel-background-color);\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t\tborder-radius: 5px;\n\/* \t\t\tpadding: 10px 15px; *\/\n\t\t\tbox-sizing:border-box;\n\t\t\twidth:30%;\n\t\t  }\n\t\t  .column2-subheading\n\t\t  {\n\t\t\t  color:grey;\n\t\t  }\n\t\t  .column2 h3\n\t\t  {\n\/* \t\t\t  height:25px; *\/\n\t\t  }\n\t\t  .menu-table {\n\t\t\t    width: 100%;\n    height: calc(100% - 46px);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    gap: 10px;\n    font-size: 14px;\n    font-weight: 500;\n    padding-top: 15px;\n    box-sizing: border-box;\n\t\t\t}\n\t\t\t.menu-table h4\n\t\t\t{\n\t\t\t\theight:20px;\n\t\t\t}\n\t\t\t.menu-items\n\t\t\t{\n\t\t\t\theight: calc(100% - 20px);\n\t\t\t\toverflow: auto;\n\t\t\t\twidth: 100%;\n\t\t\t\tdisplay: flex;\n\t\t\t\tflex-direction: column;\n\t\t\t\tgap: 5px;\n\t\t\t\talign-items: center;\n\t\t\t}\n\t\t  .main-container .row1{\n\t\t\t  display:flex;\n\t\t\t  height:200px;\n\t\t\t  gap:10px;\n\t\t   }\n\t\t\t\n\t\t   .main-container .row2{\n\t\t\t   height: 350px;\n\t\t\t   display: flex;\n               gap: 10px;\n\t\t   }\n\t\t   .main-container .row2&gt;div\n\t\t   {\n\t\t\t   width:50%;\n\t\t   }\n\t\t  \n\t\t   .main-container {\n\t\t\t\tpadding: 10