		default list Substitution_Requests1
		{
			displayName = "Substitution Requests"
			show all rows from Substitution_Requests  [Request_To.Email_ID == zoho.loginuserid]  
			(
				Request_From as "Request From"
				Request_To as "Request To"
				Status
				Session.Session_Name as "Session Name"
				custom action "Accept"
				(
	  			workflow = acceptRequest
				show action in edit record menu = true
				column header = "Accept"
				condition = (Status == "Requested")
				confirmation before execution
				(
					message for individual record = "Execute the Accept action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Reject"
				(
	  			workflow = reject2
				show action in edit record menu = true
				column header = "Reject"
				condition = (Status == "Requested")
				confirmation before execution
				(
					message for individual record = "Execute the Rejected action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Date_field as "Date"
			)
			group by
			(
				Status custom
			)
			sort by
			(
				Status custom
			)
			conditional formatting
			(
				"New Formatting"
				{
				condition = (Status == "Requested")
				fields = [Status]
				format = "color:#2f78d0;background-color:#ffffff;"
				}
				"New Formatting"
				{
				condition = (Status == "Rejected")
				fields = [Status]
				format = "color:#e64d3b;"
				}
				"New Formatting"
				{
				condition = (Status == "Accepted")
				fields = [Status]
				format = "color:#19bc9f;"
				}
			)
		}
