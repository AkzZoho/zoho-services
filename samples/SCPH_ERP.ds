			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet3' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet3()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n         \n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  box-sizing: border-box;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:10px;\n\t\t  overflow:hidden;\n\t  }\n\t  \n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;All_Teachers&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page My_Details1
		{
			displayname = "My Details"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet4' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet4()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n          \n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  box-sizing: border-box;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:5px;\n\t\t  overflow:hidden;\n\t  }\n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n\n&lt;div class=&quot;main-container&quot;&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;My_Details&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Test_Page1
		{
			displayname = "Test Page"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet6' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet6()\ncontent\n&lt;%{\n\tphoto = Staff[ID != 0];\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt; \n\t&lt;%=thisapp.Styles.getReportStyle()%&gt; \n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt; \n\t\n&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n\t   box-sizing: border-box;\n      }\n\t  \n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  .profile-header-div\n\t  {\n\t\t \twidth: 100%;\n\t\t\theight: 100px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tdisplay: flex;\n\t\t\tz-index: 36;\n\t\t\tposition: relative;\n\t  }\n\t  .row2-div\n\t  {\n\t\t  width:100%;\n\t\t  height:calc(100% - 100px);\n\t\t  display: flex;\n\t\t  padding-top:1px;\n\t\t  flex-direction:column;\n\t  }\n\t  .column1-container\n\t  {\n\t\t  height: 45px;\n\t\t  width: 100%;\n\t  }\n\t  .profile-pic\n\t  {\n\t\t  align-items: center;\n\t\t  display: flex;\n\t\t  width:10%;\n\t\t  justify-content: center;\n\t   }\n\t   \n\t   span.image-div {\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\tflex-direction: column;\n\t\t\tpadding: 5px 0;\n\t\t}\n\n\t   img.profile-photo {\n\t\t\twidth: 70px;\n\t\t\theight: 70px;\n\t\t\tborder-radius: 50%;\n\t\t}\n\t \n\t .name-div\n\t {\n\t\t font-size:20px;\n\t\t font-weight:bold;\n\t }\n\t  .information-div\n\t  {\n\t\t  display: flex;\n\t\t  flex-direction: column;\n\t\t  align-items: center;\n\t\t  justify-content: center;\n\t\t  gap: 10px;\n\t\t  width:90%;\n\t  }\n\t  .information-div-row2\n\t  {\n\t\t  display:flex;\n\t\t  gap:60px;\n\t\t  font-size: 15px;\n\t  }\n\t  .row2-subdiv\n\t  {\n\t     display: flex;\n         gap: 5px;\n\t   }\n\t   .information-div-row2-header\n\t   {\n\t\t   color:#7F7F7F;\n\t   }\n\t  .column2-container\n\t  {\n\t\t  height:calc(100% - 45px);\n\t\t  width:100%;\n\t\t  overflow: auto;\n\t  }\n\t  \n\t  \/*form style *\/\n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.student_tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.student_tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.student_tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-row:not(:last-of-type)\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t width: 50%;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t\t.student_tab_search .form-outer-wrapper .formContainer\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .zc-form-fullheight,\n\t\t.student_tab_search .zc-form-fullheight{\n\t\t  background: transparent !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.student_tab_search form[name=&quot;student_stateless_tab&quot;].label-left {\n\t\t\twidth: 1392px;\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: flex !important;\n\t\t\twidth: calc(100% - 40px) !important;\n    \t\tmargin: 0px 20px;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\t\t\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.student_tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t.column2-container .student_tab_search.divEmbedContainer\n\t{\n\t\theight:45px !important;\n\t}\n\t\n\t\/* Hide - Form Loader Icon *\/\n\t.student_tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t\/* New Css *\/\n\t[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer{\n\t\tborder:unset !important;\n\t}\n\t\n\tform[name=&quot;Staff_Nav&quot;].label-left {\n\t\twidth: 100% !important;\n\t}\n\t\n\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\theight: 100%;\n\t\t}\n\t\t\n\t\t.no-data {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tfont-size: 20px;\n\t\t\tcolor: red;\n\t\t\tfont-weight: 600;\n\t\t}\n\t\t\n\t\t.staffpage.divEmbedContainer {\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t\/* Timeline Design*\/\n\t .timeline-inner&gt;span {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\tpadding: 5px 0px;\n\t}\n\n\tspan.timeline-date {\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t}\n\n\t.timeline-outer {\n\t\twidth: calc(100% - 70px);\n\t\tmargin-left: 60px;\n\t\tmargin-bottom: 10px;\n\t\tposition:relative;\n\t}\n\t\n\t.timeline-inner{\n\t\tbackground: white;\n\t\tfilter: drop-shadow(0px 0px 1px #cdcdcd);\n\t\tposition:relative;\n\t\tborder-radius: 5px;\n\t\tz-index:1;\n\t}\n\t\n\t.timeline-inner:before {\n\t\tcontent: &quot;&quot;;\n\t\tposition: absolute;\n\t\twidth: 0;\n\t\theight: 0;\n\t\tborder-top: 0px solid transparent;\n\t\tborder-bottom: 20px solid transparent;\n\t\tborder-right: 20px solid white;\n\t\ttop: 5px;\n\t\tleft: -13px;\n\t\ttransform: rotate(-18deg);\n\t}\n\n\t.timeline-outer:before {\n\t\tbox-shadow: 0 0 0 3px;\n\t\tborder-radius: 50%;\n\t\theight: 7px;\n\t\twidth: 7px;\n\t\tcontent: &quot;&quot;;\n\t\tposition: absolute;\n\t\ttop: 5px;\n\t\tright: calc(100% + 30px);\n\t\tz-index: 1;\n\t}\n\t\n\t.timeline-outer:after {\n\t\tcontent: &apos;&apos;;\n\t\theight: 100%;\n\t\twidth: 3px;\n\t\tposition: absolute;\n\t\ttop: 13px;\n\t\tright: calc(100% + 32px);\n\t\tz-index: 0;\n\t\tbackground-color: var(--header-checked-line-color);\n\t}\n\t\n\t.timeline-outer:last-child .timeline-inner {\n\t\tposition: relative;\n\t}\n\n\t.timeline-outer:last-child .timeline-inner:after {\n\t\tcontent: &quot;X&quot;;\n\t\tbackground: white;\n\t\tborder-radius: 50%;\n\t\tborder: 1px solid var(--header-checked-line-color);\n\t\tpadding: 2px 6px;\n\t\tfont-weight: bolder;\n\t\tposition: absolute;\n\t\tright: calc(100% + 22px);\n\t\tz-index: 3;\n\t}\t\n\t\n\t.checkout .zc-footer-wrapper{\n\t\tdisplay:none;\n\t}\n\t\n\t.checkout .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.checkout form[name=&quot;Checkout&quot;].label-left {\n\t\twidth: auto !important;\n\t}\n\t\n\t.checkout label.form-label.decision-box-label {\n\t\tdisplay: none;\n\t}\n\t\n\t.checkout.divEmbedContainer {\n\t\twidth: 150px;\n\t}\n\n\t.checkout .form-group\n\t{\n\t\tmargin:0px !important;\n\t}\n\t\n\t.checkout .zcform_Checkout .first-column .notes-field\n\t{\n\t\twidth:unset !important;\t\n\t}\n\t\n\t.checkout .form-group.clearfix.zc-Checkin_Checkout-group.zc-decisionbox-field-group{\n\t\twidth:150px;\n\t}\n\t\n\t.checkout .formColumn.first-column{\n\t\theight: 100px;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tjustify-content: center;\n\t\tflex-direction: column;\n\t\tgap: 25px;\n\t}\n\t\n\t.checkout .zcform_Checkout.zc-form-fullheight {\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t}\n\t\/* Hide - Form Loader Icon *\/\n\t\t.checkout i.cogLoader.fa.fa-spinner.fa-spin {\n\t\t\tdisplay: none;\n\t\t}\n\t\n\t:root {\n      \t--color-white: #ffffff;\n\t\t--color-checkbox-on: #4ed164;\n\t\t--color-checkbox-off: #ffb82d;\n\t\t--color-background: #fdfdfd;\n\t\t--button-width: 34px;\n\t\t--button-height: 18px;\n\t\t--toggle-diameter: 17px;\n\t\t--button-toggle-offset: calc((var(--button-height) - var(--toggle-diameter)) \/ 2);\n\t\t--toggle-shadow-offset: 13px;\n\t\t--toggle-wider: 5px;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox + label:after{\n\t\tborder-color:unset !important;\t\n\t}\n\t\n\t.checkout .customCheckbox.zc_decisionbox + label:after,\n\t.checkout .customCheckbox.zc_decisionbox + label{\n\t\tborder:unset !important;\n\t}\n\t\n\t.checkout .customCheckbox.zc_decisionbox + label {\n\t  background-color: var(--color-checkbox-off);\n\t  display: inline-block;\n\t  width: var(--button-width);\n\t  height: var(--button-height);\n\t  border-radius: calc(var(--button-height) \/ 2);\n\t  position: relative;\n\t  transition: .3s all ease-in-out;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox + label::after {\n\t  content: &apos;&apos;;\n\t  display: inline-block;\n\t  width: var(--toggle-diameter);\n\t  height: var(--toggle-diameter);\n\t  background-color: var(--color-white);\n\t  border-radius: calc(var(--toggle-diameter) \/ 2);\n\t  position: absolute;\n\t  top: var(--button-toggle-offset);\n\t  transform: translateX(var(--button-toggle-offset));\n\t  box-shadow: var(--toggle-shadow-offset) 0 calc(var(--toggle-shadow-offset) * 4) rgba(0, 0, 0, .10);\n\t  transition: .3s all ease-in-out;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked + label {\n\t  background-color: var(--color-checkbox-on);\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked + label::after {\n\t  transform: translateX(calc(var(--button-width) - var(--toggle-diameter) - var(--button-toggle-offset) - 4px));\n\t  box-shadow: calc(var(--toggle-shadow-offset) * -1) 0 calc(var(--toggle-shadow-offset) * 4) rgba(0, 0, 0, .10);\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:active + label::after {\n\t  width: var(--toggle-wider);\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked:active + label::after {\n\t  transform: translateX(calc(var(--button-width) - var(--toggle-wider) - var(--button-toggle-offset)));\n\t}\n\n\t.checkout .decision-box-field.clearfix\n\t{\n\t\twidth: 100%;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tjustify-content: center;\n\t}\n&lt;\/style&gt;\n\n&lt;div class=&quot;student-container&quot;&gt;\n   &lt;div class=&quot;profile-header-div&quot;&gt;\n   &lt;div elName=&apos;zc-component&apos; class=&quot;checkout&quot; formLinkName=&apos;Checkout&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n      &lt;div class=&quot;information-div&quot;&gt;\n\t       &lt;span class=&quot;name-div&quot;&gt;&lt;%=photo.Name%&gt;&lt;\/span&gt;\n\t\t   &lt;div class=&quot;information-div-row2&quot;&gt;\n\t\t       &lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Designation :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Role.Designation%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Email ID :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Email_ID%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Contact Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Contact_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;profile-pic&quot;&gt;\n&lt;%\n\tprofile_image1 = photo.Photo.replaceAll(&quot;\/sharedBy\/appLinkName\/viewLinkName\/fieldName\/image&quot;,&quot;\/file&quot; + zoho.appuri + &quot;My_Details\/&quot; + photo.ID + &quot;\/Photo\/image-download?filepath=&quot;);\n\tprofile_image = profile_image1.replaceAll(&quot;&lt;img&quot;,&quot;&lt;img class=&apos;profile-photo&apos;&quot;);\n\t%&gt;\n&lt;span class=&quot;image-div&quot;&gt;\n&lt;%=profile_image%&gt;\n&lt;\/span&gt;  \n\t\t&lt;\/div&gt;\n   &lt;\/div&gt;\n   &lt;div class=&quot;row2-div&quot;&gt;\n\t   &lt;div class=&quot;column1-container&quot;&gt;\n\t\t\t&lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot; formLinkName=&apos;Staff_Nav&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t   &lt;\/div&gt;\n\t\t&lt;div class=&quot;column2-container&quot;&gt;\n\t\t   &lt;div name=&quot;staffpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Staff_Home&apos; class=&quot;staffpage&quot;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_Dashboard1
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet5' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet5()\ncontent\n&lt;%{\n\tphoto = Staff[Email_ID == zoho.loginuserid];\n\tif(photo.count() &gt; 0)\n\t{\n\t\topenUrl(&quot;#Page:Staff_Home?zc_LoadIn=embed-staffpage&quot;,&quot;same window&quot;);\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt; \n\t&lt;%=thisapp.Styles.getReportStyle()%&gt; \n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt; \n\t\n&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n\t   \n      }\n\t  .inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-table .form-header{\n         display: none !important;\n      }\n\t  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .zc-form-scroll-wrapper{\n\t\t  margin:unset !important;\n\t  }\n\t  \n\t  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  .profile-header-div\n\t  {\n\t\t \twidth: 100%;\n\t\t\theight: 100px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tdisplay: flex;\n\t\t\tz-index: 36;\n\t\t\tposition: relative;\n\t  }\n\t  .row2-div\n\t  {\n\t\t  width:100%;\n\t\t  height:calc(100% - 100px);\n\t\t  display: flex;\n\t\t  padding-top:1px;\n\t\t  flex-direction:column;\n\t\t  box-sizing: border-box;\n\t  }\n\t  .column1-container\n\t  {\n\t\t  height: 45px;\n\t\t  width: 100%;\n\t\t  padding-top:10px;\n\t  }\n\t  .profile-pic\n\t  {\n\t\t  align-items: center;\n\t\t  display: flex;\n\t\t  width:10%;\n\t\t  justify-content: center;\n\t   }\n\t   \n\t   span.image-div {\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\tflex-direction: column;\n\t\t\tpadding: 5px 0;\n\t\t}\n\n\t   img.profile-photo {\n\t\t\twidth: 70px;\n\t\t\theight: 70px;\n\t\t\tborder-radius: 50%;\n\t\t}\n\t \n\t .name-div\n\t {\n\t\t font-size:20px;\n\t\t font-weight:bold;\n\t }\n\t  .information-div\n\t  {\n\t\t  display: flex;\n\t\t  flex-direction: column;\n\t\t  align-items: center;\n\t\t  justify-content: center;\n\t\t  gap: 10px;\n\t\t  width:90%;\n\t  }\n\t  .information-div-row2\n\t  {\n\t\t  display:flex;\n\t\t  gap:60px;\n\t\t  font-size: 15px;\n\t  }\n\t  .row2-subdiv\n\t  {\n\t     display: flex;\n         gap: 5px;\n\t   }\n\t   .information-div-row2-header\n\t   {\n\t\t   color:#7F7F7F;\n\t   }\n\t  .column2-container\n\t  {\n\t\t  height:calc(100% - 45px);\n\t\t  width:100%;\n\t\t  overflow: auto;\n\t  }\n\t  \n\t  \/*form style *\/\n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.student_tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.student_tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.student_tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:17px !important;\n\t\t}\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-row:not(:last-of-type)\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t width: 50%;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t\t.student_tab_search .form-outer-wrapper .formContainer\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .zc-form-fullheight,\n\t\t.student_tab_search .zc-form-fullheight{\n\t\t  background: transparent !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.student_tab_search form[name=&quot;student_stateless_tab&quot;].label-left {\n\t\t\twidth: 1392px;\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: flex !important;\n\t\t\twidth: calc(100% - 40px) !important;\n    \t\tmargin: 0px 20px;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\t\t\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.student_tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t.column2-container .student_tab_search.divEmbedContainer\n\t{\n\t\theight:45px !important;\n\t}\n\t\n\t\/* Hide - Form Loader Icon *\/\n\t.student_tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t\/* New Css *\/\n\t[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer{\n\t\tborder:unset !important;\n\t}\n\t\n\tform[name=&quot;Staff_Nav&quot;].label-left {\n\t\twidth: 100% !important;\n\t}\n\t\n\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\theight: 100%;\n\t\t}\n\t\t\n\t\t.no-data {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tfont-size: 20px;\n\t\t\tcolor: red;\n\t\t\tfont-weight: 600;\n\t\t}\n\t\t\n\t\t.staffpage.divEmbedContainer {\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t\/* Timeline Design*\/\n\t \n\t\n\t.checkout .zc-footer-wrapper{\n\t\tdisplay:none;\n\t}\n\t\n\t.checkout .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.checkout form[name=&quot;Checkout&quot;].label-left {\n\t\twidth: auto !important;\n\t}\n\t\n\t.checkout label.form-label.decision-box-label {\n\t\tdisplay: none;\n\t}\n\t\n\t.checkout.divEmbedContainer {\n\t\twidth: 150px;\n\t}\n\n\t.checkout .form-group\n\t{\n\t\tmargin:0px !important;\n    \theight: 17px;\n\t}\n\t\n\t.checkout .form-group.clearfix.zc-Checkin_Checkout-group.zc-decisionbox-field-group{\n\t\twidth:150px;\n\t}\n\t\n\t.checkout .formColumn.first-column {\n    height: 35px;\n    width: 120px !important;\n    gap: 20px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n\tborder: 1px solid var(--color-checkbox-off);\n    border-radius: 25px;\n    padding: 0px 10px;\n    margin: 10px;\n}\n\t\n\t.checkout .zcform_Checkout.zc-form-fullheight {\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t}\n\t\n\t:root {\n      \t--color-white: #ffffff;\n\t\t--color-checkbox-on: #47C20E;\n\t\t--color-checkbox-off: #F15656;\n\t\t--color-background: #fdfdfd;\n\t\t--button-width: 34px;\n\t\t--button-height: 18px;\n\t\t--toggle-diameter: 17px;\n\t\t--button-toggle-offset: calc((var(--button-height) - var(--toggle-diameter)) \/ 2);\n\t\t--toggle-shadow-offset: 13px;\n\t\t--toggle-wider: 5px;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox + label:after{\n\t\tborder-color:unset !important;\t\n\t}\n\t\n\t.checkout .customCheckbox.zc_decisionbox + label:after,\n\t.checkout .customCheckbox.zc_decisionbox + label{\n\t\tborder:unset !important;\n\t}\n\t.checkout .zcform_Checkout .first-column .notes-field {\n    width: 80px !important;\n}\n\t\n\t.checkout .customCheckbox.zc_decisionbox + label {\n\t  background-color: var(--color-checkbox-off);\n\t  display: inline-block;\n\t  width: var(--button-width);\n\t  height: var(--button-height);\n\t  border-radius: calc(var(--button-height) \/ 2);\n\t  position: relative;\n\t  transition: .3s all ease-in-out;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox + label::after {\n\t  content: &apos;&apos;;\n\t  display: inline-block;\n\t  width: var(--toggle-diameter);\n\t  height: var(--toggle-diameter);\n\t  background-color: var(--color-white);\n\t  border-radius: calc(var(--toggle-diameter) \/ 2);\n\t  position: absolute;\n\t  top: var(--button-toggle-offset);\n\t  transform: translateX(var(--button-toggle-offset));\n\t  box-shadow: var(--toggle-shadow-offset) 0 calc(var(--toggle-shadow-offset) * 4) rgba(0, 0, 0, .10);\n\t  transition: .3s all ease-in-out;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked + label {\n\t  background-color: var(--color-checkbox-on);\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked + label::after {\n\t  transform: translateX(calc(var(--button-width) - var(--toggle-diameter) - var(--button-toggle-offset) - 3px));\n\t  box-shadow: calc(var(--toggle-shadow-offset) * -1) 0 calc(var(--toggle-shadow-offset) * 4) rgba(0, 0, 0, .10);\n\t  top: 0.5px !important;\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:active + label::after {\n\t  width: var(--toggle-wider);\n\t}\n\n\t.checkout .customCheckbox.zc_decisionbox:checked:active + label::after {\n\t  transform: translateX(calc(var(--button-width) - var(--toggle-wider) - var(--button-toggle-offset)));\n\t}\n\n\t.checkout .decision-box-field.clearfix\n\t{\n\t\twidth: 100%;\n\t}\n\t.holiday-div .content&gt;div:not(:last-child),.announcement-div .content&gt;div:not(:last-child) {\n    border-bottom: 1px solid #e1e1e1;\n}\n.timeline-outer {\n    width: 100%;\n    position: relative;\n}\n.holiday-div .content {\n    padding-top: 10px;\n    box-sizing: border-box;\n}\n.content {\n    height: calc(100% - 46px);\n    overflow: auto;\n    padding-top: 5px;\n}\n.timeline-date-day-container {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 3px;\n}\nspan.timeline-day {\n    color: #8D8D8D;\n    font-size: 12px;\n}\n.attendance-div .content {\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 10px;\n\t\t\tpadding: 10px;\n\t\t\tbox-sizing: border-box;\n\t\t\t}\n\t\t\t.timeline-inner {\n    background: white;\n    position: relative;\n    z-index: 1;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    height: 49px;\n    padding: 0 15px;\n}\n\n.sub-header {\n\/* \t\t\theight: 46px;\n\t\t\tpadding: 0 15px; *\/\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t\tbackground: #f7f7f7;\n\t\t}\n\nspan.day-span {\n    color: #8d8d8d;\n    font-size: 12px;\n}\n\n.student_tab_search .choice-table-cell input:checked~label{\n\tfont-weight: 700;\n\tcolor: var(--theme_brand_color);\n}\n\n.checkout .formColumn.first-column:has(input:checked) {\n\tborder-color: var(--color-checkbox-on);\n}\n\n.customCheckbox:focus+label{\n\toutline: unset !important;\n}\n&lt;\/style&gt;\n&lt;%\n\tif(photo.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;student-container&quot;&gt;\n   &lt;div class=&quot;profile-header-div&quot;&gt;\n   &lt;div elName=&apos;zc-component&apos; class=&quot;checkout&quot; formLinkName=&apos;Checkout&apos; params=&apos;zc_Header=false&amp;zc_Focus=false&apos; zc_mobileview=&apos;inline&apos;&gt;&lt;\/div&gt;\n      &lt;div class=&quot;information-div&quot;&gt;\n\t       &lt;span class=&quot;name-div&quot;&gt;&lt;%=photo.Name%&gt;&lt;\/span&gt;\n\t\t   &lt;div class=&quot;information-div-row2&quot;&gt;\n\t\t       &lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Designation :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Role.Designation%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Email ID :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Email_ID%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Contact Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Contact_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;profile-pic&quot;&gt;\n&lt;%\n\t\tprofile_image1 = photo.Photo.replaceAll(&quot;\/sharedBy\/appLinkName\/viewLinkName\/fieldName\/image&quot;,&quot;\/file&quot; + zoho.appuri + &quot;My_Details\/&quot; + photo.ID + &quot;\/Photo\/image-download?filepath=&quot;);\n\t\tprofile_image = profile_image1.replaceAll(&quot;&lt;img&quot;,&quot;&lt;img class=&apos;profile-photo&apos;&quot;);\n\t\t%&gt;\n&lt;span class=&quot;image-div&quot;&gt;\n&lt;%=thisapp.Akz.PopulateStaffImage(photo.ID)%&gt;\n&lt;\/span&gt;  \n\t\t&lt;\/div&gt;\n   &lt;\/div&gt;\n   &lt;div class=&quot;row2-div&quot;&gt;\n\t   &lt;div class=&quot;column1-container&quot;&gt;\n\t\t\t&lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot; formLinkName=&apos;Staff_Nav&apos; params=&apos;zc_Header=false&apos; zc_mobileview=&apos;inline&apos;&gt;&lt;\/div&gt;\n\t   &lt;\/div&gt;\n\t\t&lt;div class=&quot;column2-container&quot;&gt;\n\t\t   &lt;div name=&quot;staffpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Staff_Home&apos; class=&quot;staffpage&quot;  zc_mobileview=&apos;inline&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data-container&quot;&gt;\n\t\t&lt;div class=&quot;no-data&quot;&gt;You do not have access to view the Staff Dashboard&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_Dashboard
		{
			displayname = "Staff Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet1' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1()\ncontent\n&lt;%{\n\tphoto = Staff[Email_ID == zoho.loginuserid];\n\treportstyles = thisapp.Styles.getReportStyle();\n\t%&gt;\n&lt;%=reportstyles%&gt;\n&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n\t   box-sizing: border-box;\n      }\n\t  \n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display: flex;\n      }\n\t  .column1-container\n\t  {\n\t\t  height:100%;\n\t\t  width:22%;\n\t\t  background:#fff;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t  }\n\t  img.profile-photo\n\t  {\n\t\t  width:145px;\n\t\t  height:145px;\n\t\t  border-radius:50%;\n\t  }\n\t  .profile-pic\n\t  {\n\t\t  display: flex;\n\t\t  align-items: center;\n\t\t  height:210px;\n\t\t  flex-direction: column;\n\t\t  gap: 10px;\n\t\t  border-bottom: 1px solid #AAAAAA;\n\t\t  margin: 25px 30px 0 30px;\n\t  }\n\t  \n\t  .name-div\n\t  {\n\t\t  font-size:17px;\n\t\t  font-weight:600;\n\t  }\n\t  .id-div\n\t  {\n\t\t  font-size: 15px;\n          font-weight: 500;\n\t  }\n\t  .information-div\n\t  {\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t  }\n\t  .info-heading\n\t  {\n\t\t  color:#7F7F7F;\n\t\t  display: flex;\n          justify-content: left;\n\t\t  padding-left:13%;\n\t\t  font-size:17px;\n\t\t  font-weight:500;\n\t\t  padding-top:10%;\n\t  }\n\t  .info-content\n\t  {\n\t\t  display: flex;\n          justify-content: left;\n\t\t  padding-left:23%;\n\t\t  font-size:15px;\n\t\t  font-weight:500;\n\t\t  padding-top:5%;\n\t  }\n\t  .column2-container\n\t  {\n\t\t  height:100%;\n\t\t  width:78%;\n\t\t  padding:10px;\n\t\t  overflow: auto;\n\t  }\n\t  \/*form style *\/\n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.student_tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.student_tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.student_tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-row:not(:last-of-type)\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t width: 50%;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.student_tab_search form[name=&quot;student_stateless_tab&quot;].label-left {\n\t\t\twidth: 1392px;\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: flex !important;\n\t\t\twidth: calc(100% - 40px) !important;\n    \t\tmargin: 0px 20px;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\t\t\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.student_tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t.column2-container .student_tab_search.divEmbedContainer\n\t{\n\t\theight:45px !important;\n\t}\n\t\n\t\/* New Css *\/\n\t[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer{\n\t\tborder:unset !important;\n\t}\n\t\n\tform[name=&quot;Staff_Nav&quot;].label-left {\n\t\twidth: 100% !important;\n\t}\n\t\n\t.student_tab_search .zc-form-fullheight{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\theight: 100%;\n\t\t}\n\t\t\n\t\t.no-data {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t\tborder-radius: 5px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tfont-size: 20px;\n\t\t\tcolor: red;\n\t\t\tfont-weight: 600;\n\t\t}\n\t\t\n\t\t.staffpage.divEmbedContainer {\n\t\t\theight: calc(100% - 45px) !important;\n\t\t}\n\t\t\n\t\t\/* Hide - Form Loader Icon *\/\n\t.student_tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t \n\t\/* Timeline Design*\/\n\t .timeline-inner&gt;span {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\tpadding: 5px 0px;\n\t}\n\n\tspan.timeline-date {\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t}\n\n\t.timeline-outer {\n\t\twidth: calc(100% - 70px);\n\t\tmargin-left: 60px;\n\t\tmargin-bottom: 10px;\n\t\tposition:relative;\n\t}\n\t\n\t.timeline-inner{\n\t\tbackground: white;\n\t\tfilter: drop-shadow(0px 0px 1px #cdcdcd);\n\t\tposition:relative;\n\t\tborder-radius: 5px;\n\t\tz-index:1;\n\t}\n\t\n\t.timeline-inner:before {\n\t\tcontent: &quot;&quot;;\n\t\tposition: absolute;\n\t\twidth: 0;\n\t\theight: 0;\n\t\tborder-top: 0px solid transparent;\n\t\tborder-bottom: 20px solid transparent;\n\t\tborder-right: 20px solid white;\n\t\ttop: 5px;\n\t\tright: 97%;\n\t\ttransform: rotate(-18deg);\n\t}\n\n\t.timeline-outer:before {\n\t\tbox-shadow: 0 0 0 3px;\n\t\tborder-radius: 50%;\n\t\theight: 7px;\n\t\twidth: 7px;\n\t\tcontent: &quot;&quot;;\n\t\tposition: absolute;\n\t\ttop: 5px;\n\t\tright: calc(100% + 30px);\n\t\tz-index: 1;\n\t}\n\t\n\t.timeline-outer:after {\n\t\tcontent: &apos;&apos;;\n\t\theight: 100%;\n\t\twidth: 3px;\n\t\tposition: absolute;\n\t\ttop: 13px;\n\t\tright: calc(100% + 32px);\n\t\tz-index: 0;\n\t\tbackground-color: var(--header-checked-line-color);\n\t}\n\t\n\t.timeline-outer:last-child .timeline-inner {\n\t\tposition: relative;\n\t}\n\n\t.timeline-outer:last-child .timeline-inner:after {\n\t\tcontent: &quot;X&quot;;\n\t\tbackground: white;\n\t\tborder-radius: 50%;\n\t\tborder: 1px solid var(--header-checked-line-color);\n\t\tpadding: 2px 6px;\n\t\tfont-weight: bolder;\n\t\tposition: absolute;\n\t\tright: calc(100% + 22px);\n\t\tz-index: 3;\n\t}\n&lt;\/style&gt;\n&lt;%\n\tif(photo.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;student-container&quot;&gt;\n   &lt;div class=&quot;column1-container&quot;&gt;\n        &lt;div class=&quot;profile-pic&quot;&gt;\n&lt;%\n\t\tprofile_image1 = photo.Photo.replaceAll(&quot;\/sharedBy\/appLinkName\/viewLinkName\/fieldName\/image&quot;,&quot;\/file&quot; + zoho.appuri + &quot;All_Teachers\/&quot; + photo.ID + &quot;\/Photo\/image-download?filepath=&quot;);\n\t\tprofile_image = profile_image1.replaceAll(&quot;&lt;img&quot;,&quot;&lt;img class=&apos;profile-photo&apos;&quot;);\n\t\t%&gt;\n&lt;span class=&quot;image-div&quot;&gt;\n\t&lt;%=profile_image%&gt;\n&lt;\/span&gt;\n\t\t  &lt;span class=&quot;name-div&quot;&gt;&lt;%=photo.Name%&gt;&lt;\/span&gt;\n\t\t  &lt;span class=&quot;id-div&quot;&gt;&lt;%=photo.Role.Designation%&gt;&lt;\/span&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;information-div&quot;&gt;\n\t\t\t&lt;span class=&quot;info-heading&quot;&gt;Mail ID&lt;\/span&gt;\n\t\t\t&lt;span class=&quot;info-content&quot;&gt;&lt;%=photo.Email_ID%&gt;&lt;\/span&gt;\n\t\t\t&lt;span class=&quot;info-heading&quot;&gt;Mobile&lt;\/span&gt;\n\t\t\t&lt;span class=&quot;info-content&quot;&gt;&lt;%=photo.Spouse_Contact_Number%&gt;&lt;\/span&gt;\n\t\t&lt;\/div&gt;\n   &lt;\/div&gt;\n    &lt;div class=&quot;column2-container&quot;&gt;\n\t   &lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot; formLinkName=&apos;Staff_Nav&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t   &lt;div name=&quot;staffpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Staff_Home&apos; class=&quot;staffpage&quot;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data-container&quot;&gt;\n\t\t&lt;div class=&quot;no-data&quot;&gt;This page is accesible only for the Staff&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_Dashboard_Test_2
