			calculateBookLateFee as "calculateBookLateFee"
			{
				type =  schedule
				form = Borrowed_Books_Subform[Status == "Borrowed" || Status == "Extended" || Status == "Overdue"]
					status = inactive
				start = Expected_Return_Date at "10:29:08"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						student = Student[ID == input.Borrow_Books.Student];
										membership = Membership[ID == student.Library_Membership];
										fine = 0;
										if(membership.count() != 0)
										{
											fine = input.Expected_Return_Date.daysBetween(zoho.currentdate) * membership.Fine_Per_Day;
										}
										input.Fine = fine;
										if(input.Status != "Overdue")
										{
											input.Status = "Overdue";
										}
					)
					}
				}
			}
