			openPromoteReport as "openPromoteReport"
			{
				type =  functions
				form = Class_DB
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						upComingEducationalYear = Educational_Year[Status == "Upcoming"];
										currentClasses = Class[Educational_Year.Status == "Current" && Class == input.ID];
										uclass = Class_DB[Order == input.Order + 1];
										if(uclass != null)
										{
											if(Upcoming_Classes_Creation_Status == "Yet to Create")
											{
												for each  data in currentClasses
												{
													rclass = Class[Class == uclass && Section2 == data.Section2];
													section = Sections[ID == data.Section2];
													resp = insert into Class
													[
														Added_User=zoho.loginuser
														Educational_Year=upComingEducationalYear
														Section2=data.Section2
														Class=uclass
														Status="In-Active"
														Room=rclass.Room
														Class_Name=uclass.Class + " - " + section.Section_Name
														Student_Capacity=data.Student_Capacity
													];
												}
												input.Upcoming_Classes_Creation_Status = "Created";
											}
											openUrl("#Page:Promote_Students1?Class_DB=" + input.ID,"new window");
										}
					)
					}
				}
			}
