				 string apiJson.getAssignmentValue(string actionType)
                 {
                 	getAssignmentDetails = Assignments[Staff.Email_ID == zoho.loginuserid];
                 	info getAssignmentDetails;
                 	returnJson = Map();
                 	assignmentListListJson = List();
                 	for each  assignmentDetails in getAssignmentDetails
                 	{
                 		assignmentListMap = Map();
                 		assignmentListMap.put("assignmentTitle",assignmentDetails.Assignment_Title);
                 		assignmentListMap.put("assignmentSubject",assignmentDetails.Subject_form.Subject_Name);
                 		assignmentListMap.put("assignmentSubmission",assignmentDetails.Submission_Date_and_Time);
                 		assignmentListMap.put("assignmentStatus",assignmentDetails.Status);
                 		assignmentListMap.put("assignmentNotes",zoho.encryption.base64Encode(assignmentDetails.Notes));
                 		assignmentListMap.put("assignmentStaff",assignmentDetails.Staff.Name);
                 		assignmentListMap.put("assignmentID",assignmentDetails.ID.toString());
                 		assignmentListListJson.add(assignmentListMap);
                 	}
                 	returnJson.put("allAssignmentValue",assignmentListListJson);
                 	return returnJson;
                 }
				 string apiJson.getClassStudentsJson(string values)
                 {
                 	classValues = values;
                 	classValuesList = classValues.toList();
                 	// info classValuesList;
                 	getEducationalYear = Educational_Year[Status == "Current"];
                 	returnJson = Map();
                 	allClassStudentList = List();
                 	for each  clasval in classValuesList
                 	{
                 		getclassStudents = Student[Class_UID == clasval];
                 		info getclassStudents.Student_Name;
                 		for each  classStudent in getclassStudents
                 		{
                 			allClassStudentMap = Map();
                 			allClassStudentMap.put("studentName",classStudent.Student_Name);
                 			allClassStudentMap.put("studentID",classStudent.ID.toString());
                 			allClassStudentList.add(allClassStudentMap);
                 		}
                 	}
                 	returnJson.put("classStudents",allClassStudentList);
                 	return returnJson;
                 }
				 string apiJson.getCommunicationConsentJson(string actionType)
                 {
                 	if(actionType == "communications and consent")
                 	{
                 		getClassTeacher = Class[Educational_Year.Status == "Current" && Class_Teacher.Email_ID == "mathiselva811@gmail.com"];
                 		info getClassTeacher;
                 		getClassTacherEmail = getClassTeacher.Class_Teacher.Email_ID;
                 		getClassTacherClass = getClassTeacher.Class_Name;
                 		getClassTacherName = getClassTeacher.Class_Teacher;
                 		// 		info getClassTeacher.Class_Teacher;
                 		getExamName = Exam[Status in {"Marks Entry Completed","Reports Generated"}] sort by Assessment_End_Date desc;
                 		info getExamName.Assessment_Name;
                 		// info getClassTacherEmail;
                 		getEducationalYear = Educational_Year[Status == "Current"];
                 		// info getEducationalYear.Status;
                 		getCommuCon = Communication_Form[ID != 0];
                 		// 	getCommuCon  = Communication_Form[Added_User == zoho.loginuserid];
                 		getConsentRecored = Consent_Form[ID != 0];
                 		// 	getConsentRecored = Consent_Form[Added_User == zoho.loginuserid];
                 		info getConsentRecored;
                 		info getCommuCon;
                 		getEventrecords = Create_Event[ID != 0];
                 	}
                 	returnJson = Map();
                 	allEventList = List();
                 	communicationsList = List();
                 	consentListJson = List();
                 	for each  event in getEventrecords
                 	{
                 		allEventMap = Map();
                 		allEventMap.put("eventName",event.Event_Name);
                 		allEventMap.put("eventSelectionType",event.Selection_Type);
                 		allEventMap.put("ID",event.ID.toString());
                 		allEventMap.put("eventStatus",event.Status);
                 		// 		getEventClasses  = event[ Consent_Form == ConData.ID];
                 		// 		info getConsentFromParent ;
                 		eventClassList = List();
                 		for each  classes in event.Class
                 		{
                 			eventClassMap = Map();
                 			eventClassMap.put("className",classes.Class_Name);
                 			eventClassMap.put("classID",classes.ID.toString());
                 			eventClassList.add(eventClassMap);
                 			info eventClassList;
                 		}
                 		allEventMap.put("EventClasses",eventClassList);
                 		eventStudentsList = List();
                 		for each  students in event.Student
                 		{
                 			eventStudentMap = Map();
                 			eventStudentMap.put("className",students.Student_Name);
                 			eventStudentMap.put("classID",students.ID.toString());
                 			eventStudentsList.add(eventStudentMap);
                 		}
                 		allEventMap.put("EventStudents",eventStudentsList);
                 		allEventList.add(allEventMap);
                 	}
                 	for each  CommuCon in getCommuCon
                 	{
                 		communicationsMap = Map();
                 		communicationsMap.put("communicationName",CommuCon.Subject_field);
                 		communicationsMap.put("communicationMsg",CommuCon.Message);
                 		communicationsMap.put("ID",CommuCon.ID.toString());
                 		communicationsMap.put("addedTime",CommuCon.Added_Time.getDate());
                 		communicationsList.add(communicationsMap);
                 	}
                 	for each  ConData in getConsentRecored
                 	{
                 		consentMap = Map();
                 		consentMap.put("consentName",ConData.Subject_field);
                 		consentMap.put("consentMsg",ConData.Message);
                 		consentMap.put("consentID",ConData.ID.toString());
                 		consentMap.put("consentAddedTime",ConData.Added_Time.getDate());
                 		getConsentFromParent = Consent_Form_Parents[Consent_Form == ConData.ID];
                 		info getConsentFromParent;
                 		consentFromParentList = List();
                 		for each  consentParent in getConsentFromParent
                 		{
                 			consentFromParentMap = Map();
                 			consentFromParentMap.put("StudentName",consentParent.Student.Student_Name);
                 			consentFromParentMap.put("StudentPhNo",consentParent.Student.Primary_Contact_Number);
                 			consentFromParentMap.put("Status",consentParent.Status);
                 			consentFromParentList.add(consentFromParentMap);
                 		}
                 		consentMap.put("consentParent",consentFromParentList);
                 		consentListJson.add(consentMap);
                 	}
                 	returnJson.put("eventDetail",allEventList);
                 	returnJson.put("communicationsConsent",communicationsList);
                 	returnJson.put("ConsentData",consentListJson);
                 	return returnJson;
                 }
				 string apiJson.getCurrentSession(string sessonName, string className, String resDate)
                 {
                 	currentYearRec = Educational_Year[Status == "Current"];
                 	currentYear = currentYearRec.Academic_Year;
                 	info currentYear;
                 	myClass = className.toList(",");
                 	date = resDate;
                 	time = sessonName;
                 	classRec = Class[Class_Name == myClass && Educational_Year.Academic_Year == currentYear];
                 	info classRec.ID;
                 	getsession = Session_Subform[Sessions.Date_field == date && Session_Name == time && Staff.Email_ID == zoho.loginuserid || From_staff.Email_ID == zoho.loginuserid];
                 	info getsession;
                 	info getsession.Session_Name;
                 	info getsession.Subject_form.Subject_Name;
                 	info getsession.Session_Mode;
                 	info getsession.count();
                 	returnJson = Map();
                 	sessionList = List();
                 	sessionMap = Map();
                 	sessionMap.put("sessionID",getsession.ID.toString());
                 	sessionMap.put("sessionName",getsession.Session_Name);
                 	sessionMap.put("subJectName",getsession.Subject_form.Subject_Name);
                 	sessionMap.put("subJectID",getsession.Subject_form.ID.toString());
                 	sessionMap.put("sessonMode",getsession.Session_Mode);
                 	sessionMap.put("sessonTeacher",getsession.Staff.ID.toString());
                 	sessionMap.put("sessonTeacherName",getsession.Staff.Name);
                 	sessionMap.put("roomNo",getsession.Room.Room_Number);
                 	sessionMap.put("sessionType",getsession.Session_Type);
                 	sessionList.add(sessionMap);
                 	returnJson.put("selectedSessonValues",sessionList);
                 	return returnJson;
                 }
