		page Fee_Receipt_Template(int FeeID)
		{
			displayname = "Fee Receipt Template"
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet10311' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet10311()\ncontent\n&lt;%{\n\t\/\/ \tinput.FeeID = 276743000000535379;\n\tFeeDetails = Fees_Receipt1[ID == input.FeeID];\n\tDated = FeeDetails.Date_field;\n\tMonth = FeeDetails.Date_field.tostring(&quot;MMMM&quot;);\n\tStudentInfo = Student[ID == FeeDetails.Student_Name];\n\tReceipt_No = FeeDetails.Receipt_Number;\n\tStudentName = StudentInfo.Student_Name;\n\tFatherName = StudentInfo.Father_s_Name;\n\tClass = StudentInfo.Class_DB1.Class;\n\tSection = StudentInfo.Class_UID.Section2.Section_Name;\n\tRegistrationNo = StudentInfo.Registration_Number;\n\tRollNumber = StudentInfo.Roll_Number;\n\t%&gt;\n&lt;style&gt;\n:root{\n--jsHorizontalPagePadding:1.75cm;\n--jsVerticalPagePadding:1.75cm;\n}\n\n.js_page_container *{\nmargin:0;\npadding:0;\nbox-sizing:border-box;\n}\n\n.js_page_container{\nfont-family: &apos;Lato&apos;;\n}\n\n.js_page{\npadding:12px;\nbackground: white;\nwidth: 21cm;\nheight: 29.7cm;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n}\n\n.js_page:not(.js_page1){\npage-break-before:always;\n}\n\n.js_page_section{\nborder:0.5px solid #000;\nwidth: calc(21cm - var(--jsHorizontalPagePadding));\nheight: calc(29.7cm - var(--jsVerticalPagePadding));\npadding:20px;\ndisplay: flex;\nflex-direction: column;\nposition:relative;\n}\n\n\/*** Marksheet Header ****\/\n.jsc_markSheetHeader{\n\tdisplay:flex;\n\ttext-align:center;\n\tpadding-bottom: 13px;\n}\n\n.jsc_markSheetHeader img{\n\twidth:90px;\n\taspect-ratio:1;\n\tmargin-left:45px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-right:60px;\n\tletter-spacing:.75px;\n}\n\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content h4{\n\tfont-size:17px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content &gt; *{\n\tline-height:20px;\n}\n\n.js_page_section h4.jsc_fee_receipt_header{\n\t text-transform: uppercase;\n\t line-height:35px;\n\t border-top:0.5px solid #000;\n\t border-bottom:0.5px solid #000;\n\t text-align:center;\n\t margin-top:12px;\n\t font-size:18px\n\t letter-spacing:1px;\n}\n\n\/**** Student Details ****\/\n.jsc_student_details{\n\tdisplay:flex;\n\tpadding: 15px 0;\n    justify-content: space-between;\n\talign-items:center;\n}\n\n.jsc_student_details table.jsc_student_details_table{\n\tflex:1;\n\tmargin:0 auto;\n}\n\n\n.jsc_student_details table.jsc_student_details_table td{\n\tline-height:30px;\n\twidth:50%;\n}\n\n\/****** Fees table ******\/\n\n\n\ntable.jsc_fees, table.jsc_fees td, table.jsc_fees th{\n  border-collapse: collapse;\n  padding:8px;\n}\n\ntable.jsc_fees thead th{\n\t     line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n }\n \n table.jsc_fees td:nth-child(1), table.jsc_fees th:nth-child(1){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:20%;\n }\n  table.jsc_fees td:nth-child(2), table.jsc_fees th:nth-child(2){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:50%;\n }\n   table.jsc_fees td:nth-child(3), table.jsc_fees th:nth-child(3){\n\t\twidth:30%;\n }\n\ntable.jsc_fees tfoot tr{\n\t\t line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n}\n\n.jsc_footer{\n\tdisplay:flex;\n\tlist-style-type: none;\n\twidth: 100%;\n    justify-content: space-between;\n    margin-top: 1rem;\n}\n\n.jsc_footer label{\n\tfont-weight:bold;\n}\n\n.jsc_sign{\n\tposition:absolute;\n\tright:20px;\n\tbottom:20px;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;js_page_container&quot;&gt;\n&lt;div class=&quot;js_page js_page1&quot;&gt;\n&lt;div class=&quot;js_page_section&quot;&gt;\n\t&lt;div class=&quot;jsc_markSheetHeader&quot;&gt;\n\t\t&lt;img src=&quot;https:\/\/creatorapp.zohopublic.in\/file\/girimservices_in_zohotest\/education-erp-new-trail-app\/All_School_Details\/276743000000095056\/Logo\/image-download\/wQHXYMJm4StWZR1GJ90YMVgfrCDbOpefx6m93qRZEMyJ0pGwxNYm1jdXzaKXBSKXpqBpxMwHPYVpeZunpuR1Ttgg7atjv3FH8sj6?filepath=\/1741779052418_School_Logo_3.PNG&quot;\/&gt;\n\t\t&lt;div class=&quot;jsc_markSheetHeader_content&quot;&gt;\n\t\t\t&lt;h4&gt;Shiv Chand Public High School &lt;\/h4&gt;\n\t\t\t&lt;p&gt;Vill: Sakohpur, SBS Nagar, CBSE Affiliated&lt;\/p&gt;\n\t\t\t&lt;p&gt;9876419067, 9876549067 (Aff. No. 1631245)&lt;\/p&gt;\n\t\t\t&lt;p&gt;Email shiv.chand.public.school@gmail.com&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;h4 class=&quot;jsc_fee_receipt_header&quot;&gt;Fee Receipt&lt;\/h4&gt;\n\t&lt;div class=&quot;jsc_student_details&quot;&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Receipt No.&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=Receipt_No%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Student Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=StudentName%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Father&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt; : &lt;%=FatherName%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Class&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=Class%&gt; &lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Regn. No.&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=RegistrationNo%&gt; &lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Dated&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=Dated.tostring(&quot;dd-MM-yy&quot;)%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Section&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=Section%&gt; &lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Roll No.&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=RollNumber%&gt; &lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t&lt;\/div&gt;\n\t&lt;table class=&quot;jsc_fees&quot;&gt;\n\t&lt;thead&gt;\n\t&lt;tr&gt;\n\t\t&lt;th&gt;Month&lt;\/th&gt;\n\t\t&lt;th&gt;Fee Head&lt;\/th&gt;\n\t\t&lt;th&gt;Amount&lt;\/th&gt;\n\t&lt;\/tr&gt;\n\t&lt;\/thead&gt;\n&lt;%\n\tTableBody = &quot;&lt;tbody&gt;&quot;;\n\tAllMonths = Fee_Receipt_Subform[ID in FeeDetails.Fee_Details].Month_field.Month_field1.getAll().distinct();\n\tfor each  Monthdata in AllMonths\n\t{\n\t\tTableBody = TableBody + &quot;&lt;tr&gt;&lt;td&gt;&quot; + Monthdata + &quot;&lt;\/td&gt;&quot;;\n\t\tAllFeeHead = &quot;&quot;;\n\t\tAllFeeAmount = &quot;&quot;;\n\t\tfor each  ReceiptSubform in Fee_Receipt_Subform[ID in FeeDetails.Fee_Details &amp;&amp; Month_field.Month_field1 == Monthdata]\n\t\t{\n\t\t\tAllFeeHead = AllFeeHead + ReceiptSubform.Fee_Head + &quot;&lt;br&gt;&quot;;\n\t\t\tAllFeeAmount = AllFeeAmount + ReceiptSubform.Received_Amount + &quot;&lt;br&gt;&quot;;\n\t\t\t\/\/ \t\t\tTableBody = TableBody + &quot;&lt;tr&gt;&lt;td&gt;&quot; + ReceiptSubform.Month_field.Month_field1 + &quot;&lt;\/td&gt;&lt;td&gt;&quot; + ReceiptSubform.Fee_Head + &quot;&lt;\/td&gt;&lt;td&gt;&quot; + ReceiptSubform.Received_Amount + &quot;&lt;\/td&gt;&lt;\/tr&gt;&quot;;\n\t\t}\n\t\tTableBody = TableBody + &quot;&lt;td&gt;&quot; + AllFeeHead + &quot;&lt;\/td&gt;&lt;td&gt;&quot; + AllFeeAmount + &quot;&lt;\/td&gt;&lt;\/tr&gt;&lt;tr&gt;&lt;td style=\\&quot;border-bottom: 0.5px solid #000;\\&quot;&gt;&lt;\/td&gt;&lt;td style=\\&quot;border-bottom: 0.5px solid #000;\\&quot;&gt;&lt;\/td&gt;&lt;td style=\\&quot;border-bottom: 0.5px solid #000;\\&quot;&gt;&lt;\/td&gt;&lt;td style=\\&quot;border-bottom: 0.5px solid #000;\\&quot;&gt;&lt;\/td&gt;&lt;\/tr&gt;&quot;;\n\t}\n\tTableBody = TableBody + &quot;&lt;\/tbody&gt;&quot;;\n\tFeeAmount = FeeDetails.Fee_Amount;\n\tReceivedAmount = FeeDetails.Received_Amount;\n\tBalance = FeeDetails.Balance_Amount;\n\tTableFooter = &quot;&lt;tfoot&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;Fee Amount&lt;br&gt;Received Amount&lt;br&gt;Balance Amount&lt;\/td&gt;&lt;td&gt;&quot; + FeeAmount + &quot;0&lt;br&gt;&quot; + ReceivedAmount + &quot;0&lt;br&gt;&quot; + Balance + &quot;0&lt;\/td&gt;&lt;\/tfoot&gt;&quot;;\n\t%&gt;\n&lt;%=TableBody%&gt;\n&lt;%=TableFooter%&gt;\n&lt;\/table&gt;\n&lt;%\n\tPaymentHistory = Fee_Detail[Fee == input.FeeID];\n\tif(PaymentHistory.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;h3 style=&quot;margin-top:35px;margin-bottom:5px;&quot;&gt;Payment History&lt;\/h3&gt;\n\t&lt;table class=&quot;jsc_fees&quot;&gt;\n\t&lt;tbody&gt;\n&lt;%\n\t\tfor each  PayHis in Fee_Detail[Fee == input.FeeID]\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;\n\t\t&lt;td&gt;Amount Paid on &lt;%=PayHis.Payment_Date%&gt; By &lt;%=PayHis.Mode_of_Payment%&gt;&lt;\/td&gt;&lt;td&gt;&lt;%=PayHis.Amount%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tbody&gt;\n&lt;\/table&gt;\n&lt;%\n\t}\n\t\/\/ \t&lt;ul class=&quot;jsc_footer&quot;&gt;\n\t\/\/ \t\t&lt;li&gt;\n\t\/\/ \t\t\t&lt;label&gt;Mode:&lt;\/label&gt;\n\t\/\/ \t\t\t&lt;span class=&quot;jsc_value&quot;&gt;&lt;%=Dated.tostring(&quot;dd-MM-yy&quot;)%&gt;&lt;\/span&gt;\n\t\/\/ \t\t&lt;\/li&gt;\n\t\/\/ \t\t&lt;li&gt;\n\t\/\/ \t\t\t&lt;label&gt;Date: &lt;\/label&gt;\n\t\/\/ \t\t\t&lt;span class=&quot;jsc_value&quot;&gt;&lt;%=Dated.tostring(&quot;dd-MM-yy&quot;)%&gt;&lt;\/span&gt;\n\t\/\/ \t\t&lt;\/li&gt;\n\t\/\/ &lt;\/ul&gt;\n\t%&gt;\n&lt;div class=&quot;jsc_sign&quot;&gt;Auth. Sign. &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
