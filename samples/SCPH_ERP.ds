			morningAttendance as "morningAttendance"
			{
				type =  functions
				form = Class_Attendance
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						input.Is_Present_in_Morning = false;
										edu = School_Details[ID != 0];
										sendmail
										[
											from :zoho.adminuserid
											to :input.Student.Primary_Contact_Email
											subject :"Notification of Student Absence " + zoho.currentdate
											message :"Dear Parent, <br> I am writing to inform you that your child, " + input.Student.Student_Name + ", was absent from school today in the Morning session, " + zoho.currentdate + ". We wanted to ensure you were made aware of their absence as soon as possible. " + " <br> If you could please provide a reason for your child's absence, we would appreciate it. This will help us ensure that we are meeting the needs of all our students. <br> Thank you for your continued support in helping us provide the best possible education for your child. <br> Sincerely, <br> Admin office <br> " + edu.School_Name
										]
										if(input.Is_Present_in_Afternoon == true)
										{
											att = Student_Attendance[ID == input.Student_Attendance];
											att.Present_Students=att.Present_Students - 1;
										}
					)
					}
				}
			}
