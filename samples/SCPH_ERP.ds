		list Unpaid_Students_List
		{
			displayName = "Unpaid Students List"
			show all rows from Fee  [Fee_Status != "Paid"]  
			(
				Student as "Student "
				Payment_Date as "Payment Date"
				Fee_Status as "Fee Status"
				Last_Date as "Due Date "
				Total_Fee as "Agreed Fees"
				Sub_Total_Fee as "Sub Total Fee"
				Late_Fee as "Late Fee"
				custom action "Update Payment"
				(
	  			workflow = offlinePayment
				show action in edit record menu = true
				column header = "Update Payment"
				)
				Paid_Amount as "Paid Amount"
				Unpaid_Amount as "Unpaid Amount"
				custom action "Print Fee Receipt  "
				(
	  			workflow = Print_Fee_Receipt
				show action in edit record menu = true
				column header = "Print Fee Receipt  "
				condition = (Paid_Amount != 0)
				)
				Student.Father_s_Name  as "Father's Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Educational_Year as "Academic Year"
				Fee_Cycle as "Fee Cycle"
				Student.Class_UID as "Class"
			)
			filters
			(
				"Students Yet to Pay Fees"  :  Fee_Status == "Pending" && Fee_Cycle.Status == "Open"
			)
			group by
			(
				Fee_Status ascending
			)
			custom actions
			(
				"Pay Fee"
				(
	  			workflow = payFee1
				show action in view header = true
				show action in edit record menu = true
				condition = (Fee_Status != "Paid")
				)
			)
		}
