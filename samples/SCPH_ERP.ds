			checkDuplicates as "checkDuplicates"
			{
				type =  form
				form = Borrow_Books
				record event = on add

				on user input of Borrow_Books.Book
				{
					actions 
					{
						custom deluge script
						(
											bookCount = 0;
										for each  book in input.Borrow_Books
										{
											if(book.Book == row.Book)
											{
												bookCount = bookCount + 1;
												if(bookCount > 1)
												{
													alert "Book already exists";
													row.Book=null;
												}
											}
										}
						)
					}
				}

			}
			onSubmission1 as "onSubmission"
			{
				type =  form
				form = Borrow_Books
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  rec in input.Borrow_Books
										{
											rec.Status="Borrowed";
											book = Resources[ID == rec.Book];
											book.Status="Borrowed";
										}
										libVR = Library_Visitor_Record[Student == input.Student && Status == "Student has Entered the Library"];
										if(libVR.count() != 0)
										{
											libVR.is_Borrowing="Borrowers";
										}
										openUrl("#Page:Library_Dashboard","parent window");
						)
					}
				}

			}
			addExpectedReturnDate1 as "addExpectedReturnDate"
			{
				type =  form
				form = Borrow_Books
				record event = on add

				on add row of Borrow_Books
				{
					actions 
					{
						custom deluge script
						(
											if(input.Student != null)
										{
											membership = Membership[ID == input.Student.Library_Membership];
											if(membership.count() != 0)
											{
												row.Expected_Return_Date=input.Borrowed_Date.addDay(membership.Due_Days);
											}
											else
											{
												row.Expected_Return_Date=input.Borrowed_Date.addDay(15);
											}
											getBooks = Resources[Status == "Available"].ID.getAll();
											row.Book:ui.add(getBooks);
										}
						)
					}
				}

			}
			addQuantity as "addQuantity"
			{
				type =  form
				form = Add_Resources
				record event = on add

				on user input of Quantity
				{
					actions 
					{
						custom deluge script
						(
											str = "";
										str = str.leftpad(input.Quantity - 1);
										str = str.toList("");
										resourceCollection = Collection();
										counter = 1;
										for each  rec in str
										{
											ro = Add_Resources.Details();
											ro.Sno=counter;
											resourceCollection.insert(ro);
											counter = counter + 1;
										}
										input.Details.insert(resourceCollection);
						)
					}
				}

			}
			modifyQuantityAndSno as "modifyQuantityAndSno"
			{
				type =  form
				form = Add_Resources
				record event = on add

				on add row of Details
				{
					actions 
					{
						custom deluge script
						(
											// input.Quantity = input.Quantity + 1;
										row.Sno=input.Details.count();
						)
					}
				}

			}
			modifyQuantityAndSno1 as "modifyQuantityAndSno"
			{
				type =  form
				form = Add_Resources
				record event = on add

				on delete row of Details
				{
					actions 
					{
						custom deluge script
						(
											counter = row.Sno;
										for each  rec in input.Details
										{
											if(row.Sno < rec.Sno)
											{
												rec.Sno=counter;
												counter = counter + 1;
											}
										}
						)
					}
				}

			}
			addResources as "addResources"
			{
				type =  form
				form = Add_Resources
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  rec in input.Details
										{
											resp = insert into Resources
											[
												Added_User=zoho.loginuser
												Name=input.Name
												Category=input.Category
												ISBN=input.ISBN
												Library_Sections=rec.Library_Sections
												Library_Rows=rec.Library_Rows
												Genre=input.Genre
												Publication=input.Publication
												Author1=input.Author1
												Status="Available"
												Barcode_Value=rec.Barcode_Value
											];
										}
						)
					}
				}

			}
