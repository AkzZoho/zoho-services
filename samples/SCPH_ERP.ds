			onSubmission29 as "onSubmission"
			{
				type =  form
				form = Select_Bus
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						student = Student[ID == input.Student];
										student.Bus_allotted=true;
										transportRequests = Transport_Request[Student == input.Student && Status == "Raised"];
										// transportRequests.Status="Approved";
										transportRequests.Status="Approved";
										vehicle = Vehicle[ID == input.Vehicle];
										// vehicle.Students.add(input.Student.ID);
										allStudents = vehicle.Students;
										allStudents.add(student);
										vehicle.Students=allStudents;
										if(vehicle.Students.size() < vehicle.Vehicle_Total_Capacity)
										{
											vehicle.Status="Available";
										}
										if(vehicle.Students.size() == vehicle.Vehicle_Total_Capacity)
										{
											vehicle.Status="Vehicle Capacity Reached";
										}
										bus = Vehicle[ID == input.Vehicle];
										driver = Staff[ID == bus.Driver];
										sendmail
										[
											from :zoho.adminuserid
											to :input.Student.Primary_Contact_Email
											subject :"Regarding Pickup Vehicle Request"
											message :"Dear Parent, <br> This is to inform you that your pickup vehicle request has been approved. <br><br><br> Vehicle Number - " + input.Vehicle.Bus_Name + "<br> Bus Registration Number - " + input.Vehicle.Bus_Registration_Number + " <br> Driver Name - " + driver.Name + " <br> Driver Contact Number - " + driver.Contact_Number + "<br>Regards, <br> Transport Admin "
										]
										openUrl("#Script:page.parent.reload","parent window");
					)
					}
				}
			}
