					status = inactive
				start = after 1 days from Last_Date_of_Offer_Letter_Acceptance at "09:00:00"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						if(input.Status == "Offer Letter Sent")
										{
											input.Status = "Offer Letter Expired";
										}
					)
					}
				}
			}
