                 	/* 	update the published key for All School Details report in publishKey String */
                 	publishKey = "bkUsN0hhDJXveFstQJpWvCHqGY1ExBKvmSQBFJkSusJ2dfVzTmHpbGW1OMPR6qkvMZvS60sBGEtsWa2p3vH3w8X9APt35xDvfyGJ";
                 	return publishKey;
                 }
				 int getReportFee()
                 {
                 	allRegis = Registration[ID != 0];
                 	totalFee = 0;
                 	for each  data in allRegis
                 	{
                 		fee = Registration_Fee[Class == data.Applying_for_Class];
                 		if(fee.count() != 0)
                 		{
                 			totalFee = totalFee + fee.Registration_Fee.toNumber();
                 		}
                 	}
                 	return totalFee;
                 }
				 string superAdminRole()
                 {
                 	return "Super Admin";
                 }
				 void updateRanking(int yearID)
                 {
                 	studentList = Cumulative_Ranking[Educational_Year == yearID].distinct(Student);
                 	classList = Student[ID in studentList].distinct(Class_UID);
                 	for each  rec in classList
                 	{
                 		rank = 1;
                 		for each  stud in Cumulative_Ranking[Student.Class_UID == rec && Educational_Year == yearID] sort by Overall_Performance desc
                 		{
                 			stud.Rank=rank;
                 			rank = rank + 1;
                 		}
                 	}
                 }
