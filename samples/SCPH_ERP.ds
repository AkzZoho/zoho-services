			onSubmission13 as "onSubmission"
			{
				type =  form
				form = Educational_Year
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Educational_Year_Start_Date > zoho.currentdate)
										{
											input.Status = "Upcoming";
										}
										else if(input.Educational_Year_Start_Date <= zoho.currentdate && input.Educational_Year_End_Date >= zoho.currentdate)
										{
											input.Status = "Current";
										}
										else if(input.Educational_Year_Start_Date < zoho.currentdate && input.Educational_Year_End_Date < zoho.currentdate)
										{
											input.Status = "Past";
										}
