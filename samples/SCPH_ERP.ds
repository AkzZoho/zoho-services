				 string Akz.PopulateImage(int FormID, int width, int height, string ImageType)
                 {
                 	StudentInfo = Student[ID == FormID];
                 	if(ImageType == "Student")
                 	{
                 		ImageDetails = StudentInfo.Photo;
                 		ReportLinkName = "Students1";
                 		ImageFieldName = "Photo";
                 	}
                 	else if(ImageType == "Mother")
                 	{
                 		ImageDetails = StudentInfo.Mother_s_Photo;
                 		ReportLinkName = "Students1";
                 		ImageFieldName = "Mother_s_Photo";
                 	}
                 	else if(ImageType == "Father")
                 	{
                 		ImageDetails = StudentInfo.Father_s_Photo;
                 		ReportLinkName = "Students1";
                 		ImageFieldName = "Father_s_Photo";
                 	}
                 	else if(ImageType == "Guardian")
                 	{
                 		ImageDetails = StudentInfo.Guardian_s_Photo;
                 		ReportLinkName = "Students1";
                 		ImageFieldName = "Guardian_s_Photo";
                 	}
                 	if(ImageDetails in {"",null})
                 	{
                 		ImageFetchedInfo = Images[Name == "People_Placeholder"];
                 		ImageDetails = ImageFetchedInfo.Image;
                 		ReportLinkName = "All_Images";
                 		ImageFieldName = "Image";
                 		FormID = ImageFetchedInfo.ID;
                 	}
                 	ImageNam = ImageDetails.getSuffix("/image/").getPrefix("\"");
                 	image_link = "https://creatorapp.zoho.in" + zoho.appuri + "report/" + ReportLinkName + "/" + FormID + "/" + ImageFieldName + "/download-file?filepath=/" + ImageNam;
                 	return "<img src=\"" + image_link + "\" width=\"" + width + "\" height=\"" + height + "\">";
                 }
				 string Akz.PopulateStaffImage(int Staffid)
                 {
                 	// 	Staffid = 276743000000334064;
                 	StaffInfo = Staff[ID == Staffid];
                 	ImageDetails = StaffInfo.Photo;
                 	ReportLinkName = "My_Details";
                 	ImageFieldName = "Photo";
                 	FormID = StaffInfo.ID;
                 	if(ImageDetails in {"",null})
                 	{
                 		ImageFetchedInfo = Images[Name == "People_Placeholder"];
                 		ImageDetails = ImageFetchedInfo.Image;
                 		ReportLinkName = "All_Images";
                 		ImageFieldName = "Image";
                 		FormID = ImageFetchedInfo.ID;
                 	}
                 	ImageNam = ImageDetails.getSuffix("/image/").getPrefix("\"");
                 	image_link = "https://creatorapp.zoho.in" + zoho.appuri + "report/" + ReportLinkName + "/" + FormID + "/" + ImageFieldName + "/download-file?filepath=/" + ImageNam;
                 	return "<img class='profile-photo' src=\"" + image_link + "\">";
                 }
				 list Akz.UpcomingHolidayFilter()
                 {
                 	holidayList = Holidays[Date_field >= zoho.currentdate && Holiday_Type == "Common Holiday" || Holiday_Type == "Local Holiday"] sort by Date_field;
                 	return holidayList.ID.getall();
