			Hide_Show3 as "Hide/Show"
			{
				type =  form
				form = Fees_Receipt1
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide Student_Fee_Details;
						disable Balance_Amount,Fee_Amount,Previous_Balance_Amount,Previously_Received_Amount,Received_Amount;
					}
					actions 
					{
					hide add row of Fee_Details;
					hide delete row of Fee_Details;
					}
					actions  (Populate_Fees == true)
					{
						disable Monthly_Fees;
						show Fee_Details,Section1;
					}
				}

			}
			Populate_Fields as "Populate Fields"
			{
				type =  form
				form = Fees_Receipt1
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Student_Fee_Details != null)
										{
											disable Student_Name;
											input.Student_Name = input.Student_Fee_Details.Student;
											LastReceiptNumber = Fees_Receipt1[ID != null].maximum(Receipt_Number);
											input.Receipt_Number = ifnull(LastReceiptNumber,0) + 1;
										}
										else
										{
											openUrl("#Report:Fees_Receipt1_Report","same window");
										}
						)
					}
				}

			}
			Populate_Subform_Rows as "Populate Subform Rows"
			{
				type =  form
				form = Fees_Receipt1
				record event = on add

				on user input of Populate_Fees
				{
					actions 
					{
						custom deluge script
						(
											clear Fee_Details;
										disable Fee_Details.Month_field;
										hide Fee_Details.Monthly_Fee_Subform;
										if(input.Populate_Fees)
										{
											if(Monthly_Fees == null)
											{
												alert "Monthly Fees is Mandatory";
												input.Populate_Fees = false;
											}
											else
											{
												AllSubformdata = Collection();
												for each  MonthData in input.Monthly_Fees
												{
													for each  Month_Subform_Data in Monthly_Fee_Subform[ID in MonthData.Fee_Details]
													{
														SubformRow = Fees_Receipt1.Fee_Details();
														SubformRow.Month_field=MonthData.ID;
														SubformRow.Monthly_Fee_Subform=Month_Subform_Data.ID;
														SubformRow.Received_Amount=Month_Subform_Data.Balance_Amount;
														AllSubformdata.insert(SubformRow);
													}
												}
												input.Fee_Details.insert(AllSubformdata);
											}
											input.Fee_Amount = input.Fee_Details.sum(Fee_Amount);
											input.Previously_Received_Amount = input.Fee_Details.sum(Previously_Received);
											input.Received_Amount = input.Fee_Details.sum(Received_Amount);
											input.Previous_Balance_Amount = input.Fee_Details.sum(Balance_Amount);
											input.Balance_Amount = ifnull(input.Previous_Balance_Amount,0) - ifnull(input.Received_Amount,0);
										}
						)
					}
				}

			}
			Re_Calculate_Fees as "Re-Calculate Fees"
			{
				type =  form
				form = Fees_Receipt1
				record event = on add

				on user input of Fee_Details.Received_Amount
				{
					actions 
					{
						custom deluge script
						(
											if(row.Received_Amount < 0)
										{
											alert "Received Amount should be Zero or Greater";
											row.Received_Amount=0;
										}
										else if(row.Received_Amount > row.Balance_Amount)
										{
											alert "Received Amount should not be greater than Balance Amount";
											row.Received_Amount=row.Balance_Amount;
										}
										input.Fee_Amount = input.Fee_Details.sum(Fee_Amount);
										input.Previously_Received_Amount = input.Fee_Details.sum(Previously_Received);
										input.Received_Amount = input.Fee_Details.sum(Received_Amount);
										input.Previous_Balance_Amount = input.Fee_Details.sum(Balance_Amount);
										input.Balance_Amount = ifnull(input.Previous_Balance_Amount,0) - ifnull(input.Received_Amount,0);
						)
					}
				}

			}
			Calculate_based_on_Receip as "Calculate based on Receipt"
			{
				type =  form
				form = Fees_Receipt1
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  FeesData in input.Fee_Details
										{
											MonthlyFeeSubform = Monthly_Fee_Subform[ID == FeesData.Monthly_Fee_Subform];
											MonthlyFeeSubform.Received_Amount=ifnull(MonthlyFeeSubform.Received_Amount,0) + FeesData.Received_Amount;
											MonthlyFeeSubform.Balance_Amount=ifnull(MonthlyFeeSubform.Balance_Amount,0) - FeesData.Received_Amount;
											MonthlyFeeForm = Monthly_Fees[ID == FeesData.Month_field];
											MonthlyFeeForm.Total_Received_Amount=Monthly_Fee_Subform[Monthly_Fees == FeesData.Month_field].sum(Received_Amount);
											MonthlyFeeForm.Total_Balance_Amount=Monthly_Fee_Subform[Monthly_Fees == FeesData.Month_field].sum(Balance_Amount);
											if(MonthlyFeeForm.Total_Balance_Amount == 0)
											{
												MonthlyFeeForm.Update1="<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>";
											}
										}
										for each  StudentFee_Subform in Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details]
										{
											StudentFee_Subform.Paid_Amount=Monthly_Fee_Subform[Monthly_Fees.Student_Fee_Details == input.Student_Fee_Details && Fee_Head == StudentFee_Subform.Fee_Head].sum(Received_Amount);
											StudentFee_Subform.Balance_Amount=Monthly_Fee_Subform[Monthly_Fees.Student_Fee_Details == input.Student_Fee_Details && Fee_Head == StudentFee_Subform.Fee_Head].sum(Balance_Amount);
											StudentFee_Subform.Disable_Concession=true;
											StudentFee_Subform.Update_Concession=if(StudentFee_Subform.Disable_Concession,"<a style=\"pointer-events:none; opacity:0.6; cursor:not-allowed;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" >Update</a>","<a style=\"cursor:pointer;\" class=\"zc-custom-btn zc_transition zcs_relatedblockbutton\" elname=\"zc-custaction-el\" href=\"#Form:Student_Fee_Subform?recLinkID=" + StudentFee_Subform.ID + "&viewLinkName=Student_Fee_Subform_Report&action_field=updateconcession&zc_LoadIn=dialog\">Update</a>");
										}
										StudentFee = Student_Fee_Details[ID == input.Student_Fee_Details];
										StudentFee.Total_Amount_Paid=Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details].sum(Paid_Amount);
										StudentFee.Total_Amount_Due=Student_Fee_Subform[Student_Fee_Details == input.Student_Fee_Details].sum(Balance_Amount);
										openUrl("#Script:page.parent.reload","parent window");
						)
					}
				}

			}
