bold; } .fee-table td { padding: 5px 10px; } .fees-details { display: flex; } .row2-column2 { width: 35%; } .bottom-div { position: relative; height: 65px;margin-top:15px; } .bottom1-div { position: absolute; bottom: 15px; left: 15px; } .bottom2-div { position: absolute; bottom: 15px; right: 15px; } .siganture-div { height: 30px; width: 80px; overflow: hidden; border-radius: 3px; } .siganture-div img { width: 100%; height: 100%; object-fit: contain; } .fee-table tr td:last-child, .fee-table tr th:last-child { text-align: right; }.bottom-fee-detail-div{margin-top:15px;} </style> </head> <body> <div class="receipt-div"> <div class="receipt-header">' + logoDiv + '<div class="school-div"> <h3 class="school-name-div">' + schoolDetails.School_Name + '</h3> <p class="school-address-div">' + schoolDetails.Address + '</p> <p>Phone ' + schoolDetails.Contact_Number + '</p> </div> </div> <div class="row2"> <div class="row2-column1"> <table class="row2-table"> <tr> <td> Student Name </td> <td>:</td> <td>' + fee.Student.Student_Name + '</td> </tr><tr> <td> Student ID </td> <td>:</td> <td>' + fee.Student.Registration_Number + '</td> </tr> <tr> <td>Class</td> <td>:</td> <td>' + fee.Student.Class_UID.Class_Name + '</td> </tr> </table> </div> <div class="row2-column2"> <table class="row2-table"> <tr> <td>Parent Name</td> <td>:</td> <td>' + fee.Student.Father_Guardian_Name + '</td> </tr><tr> <td>Fee Type</td> <td>:</td> <td>' + fee.Fee_Cycle.Fee_Type + '</td> </tr> <tr> <td>Date</td> <td>:</td> <td>' + zoho.currentdate + '</td> </tr> </table> </div> </div> <div class="fees-details"> <table class="fee-table"> <thead> <th>Sl.No</th> <th>Payment Date</th> <th>Mode of Payment</th> <th>Fees Paid</th><th>Cumulative Fees Paid</th> </thead> <tbody>';
