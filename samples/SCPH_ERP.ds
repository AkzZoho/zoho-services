			acceptRequest as "acceptRequest"
			{
				type =  functions
				form = Substitution_Requests
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						session = Session_Subform[ID == input.Session];
										curTeacher = Staff[Email_ID == zoho.loginuserid];
										session.Additional_Details="Session substitution by " + input.Request_From.Name + " to " + input.Request_To.Name;
										session.From_staff=input.Request_From;
										session.Staff=input.Request_To;
										session.Session_Type="Substitution";
										session.Subject_form=null;
										input.Status = "Accepted";
										allRequests = Substitution_Requests[Session == input.Session.ID && Status == "Requested"];
										for each  request in allRequests
										{
											request.Status="Rejected";
										}
					)
					}
				}
			}
