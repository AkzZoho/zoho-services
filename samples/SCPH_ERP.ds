				condition = (Status == "Yet to Start")
				fields = [Status]
				format = "color:#efb116;"
				}
				"Ongoing"
				{
				condition = (Status == "Ongoing")
				fields = [Status]
				format = "color:#398ef3;"
				}
				"Finished"
				{
				condition = (Status == "Finished")
				fields = [Status]
				format = "color:#4ea64c;"
				}
			)
