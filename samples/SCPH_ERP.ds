quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel conversion-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;My Conversion&lt;\/span&gt;\n                  &lt;span class=&quot;conversion-value&quot;&gt;&lt;%=conversions%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;line-design&quot;&gt;&lt;\/div&gt;\n              &lt;\/div&gt;\n              &lt;div class=&quot;panel waitinglist-panel-container&quot;&gt;\n                  &lt;span class=&quot;panel-label&quot; &gt;Waiting List&lt;\/span&gt;   \n                  &lt;span class=&quot;waitinglist-value&quot;&gt;&lt;%=waitingList%&gt;&lt;\/span&gt;\n                  &lt;div class=&quot;line-design&quot;&gt;&lt;\/div&gt;                 \n              &lt;\/div&gt;\n          &lt;\/div&gt;\n    &lt;\/div&gt;\n    &lt;div class=&quot;header&quot;&gt;\n        &lt;div elName=&apos;zc-component&apos; class=&quot;tab_search&quot; formLinkName=&apos;Report_Search&apos; params=&apos;zc_Header=false&amp;amp;zc_SuccMsg=Data Added Successfully!&amp;amp;zc_SubmitVal=Submit&amp;amp;zc_ResetVal=Reset&apos;&gt;&lt;\/div&gt;\n\t  &lt;div name=&quot;leadpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;My_Leads&apos; class=&quot;leadpagereport&quot; params=&apos;zc_ReportName=false&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=true&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Other_Info1(Child_Mail)
		{
			displayname = "Student Other Info1"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet95' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet95()\ncontent\n&lt;%{\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\tmyClass = Student[Email == zoho.loginuserid];\n\t}\n\telse\n\t{\n\t\tmyClass = Student[Email == input.Child_Mail];\n\t}\n\tborrowList = Borrow_Books[Student == myClass.ID &amp;&amp; Status == &quot;Open&quot;].ID.getAll();\n\tbookList = Borrowed_Books_Subform[Borrow_Books in borrowList &amp;&amp; Status != &quot;Returned&quot;];\n\tfirstDueDate = bookList.minimum(Expected_Return_Date);\n\tfineAmount = bookList.sum(Fine);\n\tMyRoomInfo = Room[Room_Type1.Room_Type == &quot;Hostel&quot; &amp;&amp; Student == myClass.ID];\n\tmyRoommates = MyRoomInfo.Student;\n\tmyEvents = Create_Event[Event_Start_Date1 &gt; zoho.currentdate &amp;&amp; Student == myClass.ID];\n\tbusStopName = &quot;&quot;;\n\trouteName = &quot;&quot;;\n\tbusName = &quot;&quot;;\n\tbusNo = &quot;&quot;;\n\tif(myClass.Hosteller == false)\n\t{\n\t\tresp = Transport_Request[Status == &quot;Approved&quot;];\n\t\ttrans = Vehicle[Students == resp.Student];\n\t\tbusStopName = resp.Bus_Stops.Stop_Name;\n\t\trouteName = trans.Bus_Route.Route_Name;\n\t\tbusName = trans.Bus_Name;\n\t\tbusNo = trans.Bus_Registration_Number;\n\t}\n\t%&gt;\n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n         \n        }\n\t\t:root{\n\t\t  --main-container-color:#fff;\n\t\t  }\n\t\t.other-info-container{\n          width: 100%;\n          padding: 10px;\n\t\t  box-sizing: border-box;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display:flex;\n\t\t  flex-direction:column;\n\t\t  gap:10px;\n       }\n\t   div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t.other-info-container-row1\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:300px;\n\t\t}\n\t\t.other-info-container-row2\n\t\t{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\n\t\t\theight:300px;\n\t\t}\n\t\t.exam-div,.info-div\n\t\t{\n\t\t\theight:100%;\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius:5px;\n\t\t\t\n\t\t}\n\t\t.exam-div\n\t\t{\n\t\t\toverflow:auto;\n\t\t\twidth: calc(100% - 450px);\n\t\t}\n\t\t\n\t\t.info-div {\n\t\t  width: 45%;\n\t\t  padding:10px;\n\t\t  box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.statistics-div,.upcoming-exams-div\n\t\t{\n\t\t\theight:100%;\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius:5px;\n\t\t}\n\t\t.upcoming-exams-div{\n\t\t\t\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t.statistics-div\n\t\t{\n\t\t\twidth:55%;\n\/* \t\t\tpadding: 20px 10px 10px 10px; *\/\n\t\t\tbox-sizing: border-box;\n\/* \t\t\toverflow: hidden; *\/\n\t\t\tbox-shadow: 0px 0px 5px rgb(0 0 0 \/ 20%);\n\t\t\tborder-radius: 5px;\n\t\t\tposition: relative;\n\t\t}\n\t\t.upcoming-exams-div\n\t\t{\n\t\t\twidth:450px;\n\t\t}\n\t\t.sub-header {\n\/* \t\t\theight: 25px; *\/\n\t\t}\n\t\t.content\n\t\t{\n\t\t\theight: calc( 100% - 46px);\n\t\t\toverflow:auto;\n\t\t}\n\t\t.upcoming-exams-div .content\n\t\t{\n\t\t\tpadding-top:10px;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t\/* Timeline Design *\/\n\t.holiday-div .content{\n\t\tpadding-top:10px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t.timeline-inner&gt;span {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\tpadding: 5px 0px;\n\t\tbox-sizing: border-box;\n\t}\n\n\t\n\n.timeline-outer {\n    width: 100%;\n    position: relative;\n   \n}\n.timeline-outer:not(:last-child){\n\t border-bottom: 1px solid #e1e1e1;\n}\n.timeline-inner {\n    background: white;\n    position: relative;\n    z-index: 1;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    height: 49px;\n    padding: 0 15px;\n}\n\t.timeline-outer:last-child .timeline-inner {\n\t\tposition: relative;\n\t}\n\n\t.timeline-outer:last-child .timeline-inner:after {\n\t\tcontent: &quot;X&quot;;\n\t\tbackground: white;\n\t\tborder-radius: 50%;\n\t\tborder: 1px solid var(--header-checked-line-color);\n\t\tpadding: 2px 6px;\n\t\tbox-sizing: border-box;\n\t\tfont-weight: bolder;\n\t\tposition: absolute;\n\t\tright: calc(100% + 22px);\n\t\tz-index: 3;\n\t}\n\t\n\t\t.leadpagereport.divEmbedContainer {\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\/*form styles *\/\n\t\t.tab_search1 label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search1 .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.tab_search1 .formbutton {\n          padding: 0 !important;\n       }\n\t\t.tab_search1 .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.tab_search1 label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.tab_search1 .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.tab_search1 .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.tab_search1 .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search1 .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search1 .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t \n\t   }\n\t .tab_search1 .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .tab_search1 .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .tab_search1 .form-field .tempContDiv .choice-tab