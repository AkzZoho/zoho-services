		page Student_Dashboard1(Child_Mail)
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet11' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet11()\ncontent\n&lt;%{\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\tphoto = Student[Email == zoho.loginuserid];\n\t}\n\telse\n\t{\n\t\tphoto = Student[Email == input.Child_Mail];\n\t}\n\t\/\/ \topenUrl(&quot;#Page:Student_Home?zc_LoadIn=embed-studentpage&quot;,&quot;same window&quot;);\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\t\n\t&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n      }\n\t  \n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display: flex;\n\t\t  flex-direction:column;\n      }\n\t  .column1-container\n\t  {\n\t\t  height:100px;\n\t\t  width:100%;\n\t\t  background:#fff;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t  display:flex;\n\t  }\n\t  \n\t  .id-div\n\t  {\n\t\t  font-size: 15px;\n          font-weight: 500;\n\t  }\n\t  \n\t  .information-div\n\t  {\n\t\t  \tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\twidth: calc(100% - 100px);\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tgap: 10px;\n\t  }\n\t  \n\t  .info-heading\n\t  {\n\t\t  color:#7F7F7F;\n\t\t  display: flex;\n          justify-content: left;\n\t\t  padding-left:13%;\n\t   \t  box-sizing: border-box;\n\t\t  font-size:17px;\n\t\t  font-weight:500;\n\t\t  padding-top:10%;\n\t  }\n\t  \n\t  .info-content\n\t  {\n\t\t  display: flex;\n          justify-content: left;\n\t   \t  box-sizing: border-box;\n\t\t  padding-left:23%;\n\t\t  font-size:15px;\n\t\t  font-weight:500;\n\t\t  padding-top:5%;\n\t  }\n\t  .column2-container\n\t  {\n\t\t  height: calc(100% - 100px);\n\t\t  width: 100%;\n\t\t  padding:10px;\n\t      box-sizing: border-box;\n\t\t  overflow:auto;\n\t  }\n\t  \/*form style *\/\n\t  .student_tab_search{\n\t\tpadding:0px 10px;  \n\t   box-sizing: border-box;\n\t  }\n\t  \n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.student_tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.student_tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.student_tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:16px !important;\n\t\t\t    \n\t\t}\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.student_tab_search form[name=&quot;student_stateless_tab&quot;].label-left {\n\t\t\twidth: 1392px;\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n           width: 100% !important;\n        }\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: grid !important;\n\t\t\twidth: 100% !important;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.student_tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t.column2-container .student_tab_search.divEmbedContainer\n\t{\n\t\theight:45px !important;\n\t}\n\t\/* Hide - Form Loader Icon *\/\n\t\t.student_tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n\t\t\n\t\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\tbox-sizing: border-box;\n\t\t\theight: 100%;\n\t\t}\n\t.no-data {\n\t\theight: 100%;\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tborder-radius: 5px;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\tfont-size: 20px;\n\t\tcolor: red;\n\t\tfont-weight: 600;\n\t}\n\t\n\t[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer {\n\t\tborder-bottom: unset !important;\n\t\tborder-right: unset !important;\n\t}\n\t\n\t.studentpage.divEmbedContainer {\n\t\theight: calc(100% - 45px) !important;\n\t}\n\n\t.mail-content\n\t{\n\t\twidth: 250px;\n\t\twhite-space: nowrap;\n\t\toverflow: hidden;\n\t\ttext-overflow: ellipsis;\n\t\tdisplay: block;\n\t}\n\t\n\t.profile-pic\n\t  {\n\t\t  align-items: center;\n\t\t  display: flex;\n\t\t  width:100px;\n\t\t  justify-content: center;\n\t   }\n\t   \n\t   span.image-div {\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\tflex-direction: column;\n\t\t\tpadding: 5px 0;\n\t\t}\n\n\t   img.profile-photo {\n\t\t\twidth: 70px;\n\t\t\theight: 70px;\n\t\t\tborder-radius: 50%;\n\t\t}\n\t \n\t .name-div\n\t {\n\t\t font-size:20px;\n\t\t font-weight:bold;\n\t }\n\t \n\t .information-div-row2-header\n\t   {\n\t\t   color:#7F7F7F;\n\t   }\n\t   \n\t   .information-div-row2 {\n\t\t\tdisplay: flex;\n\t\t\tgap: 60px;\n\t\t\tfont-size: 15px;\n\t\t}\n\t\t\n\t\t.row2-subdiv {\n\t\t\tdisplay: flex;\n\t\t\tgap: 5px;\n\t\t}\n&lt;%\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t}\n\telse\n\t{\n\t\t%&gt;\n.student_tab_search .flLeft.tempContDiv.zc-Radio{\n\t\t\t\t\t grid-template-columns: 75% 0% 0% 25%;\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t.student_tab_search .choice-table-cell span label {\n\t\t\t\t\twidth: 100%;\n\t\t\t\t\theight: 100%;\n\t\t\t\t\tfont-size: 17px !important;\n\t\t\t\t\tdisplay: flex;\n\t\t\t\t\tjustify-content: center;\n\t\t\t\t\tcursor:pointer;\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t.student_tab_search .customRadio{\n\t\t\t\t\tdisplay:none;\t\n\t\t\t\t}\n&lt;%\n\t}\n\t%&gt;\n.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-table .form-header{\n         display: none !important;\n      }\n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .zc-form-scroll-wrapper{\n  margin:unset !important;\n  }\n  \n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n\t  .student_tab_search .choice-table-cell input:checked~label {\n    font-weight: 800;\n\tcolor: var(--theme_brand_color);\n}\n&lt;\/style&gt;\n&lt;%\n\tif(photo.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;student-container&quot;&gt;\n   &lt;div class=&quot;column1-container&quot;&gt;\n        &lt;div class=&quot;information-div&quot;&gt;\n\t       &lt;span class=&quot;name-div&quot;&gt;&lt;%=photo.Student_Name%&gt;&lt;\/span&gt;\n\t\t   &lt;div class=&quot;information-div-row2&quot;&gt;\n\t\t       &lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Roll Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Registration_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Email ID :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Email%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Contact Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Primary_Contact_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;profile-pic&quot;&gt;\n&lt;%\n\t\timagefile = photo.Photo.getSuffix(&quot;fieldName\/image\/&quot;).getPrefix(&quot;\\&quot; lowqual&quot;);\n\t\tif(thisapp.portal.isUserInProfile(&quot;Admin&quot;) == true || thisapp.portal.isUserInProfile(&quot;Student&quot;) == true)\n\t\t{\n\t\t\tappurl = thisapp.getPortalUrl();\n\t\t}\n\t\telse\n\t\t{\n\t\t\tappurl = &quot;https:\/\/creatorapp.zoho.in&quot;;\n\t\t}\n\t\timageUrl = appurl + &quot;\/file&quot; + zoho.appuri + &quot;All_Students\/&quot; + photo.ID + &quot;\/Photo\/image-download?filepath=\/&quot; + imagefile;\n\t\t%&gt;\n&lt;span class=&quot;image-div&quot;&gt;\n\n  &lt;img class=&quot;profile-photo&quot; src=&quot;&lt;%=imageUrl%&gt;&quot; \/&gt;\n&lt;\/span&gt;  \n\t\t&lt;\/div&gt;\n   &lt;\/div&gt;\n    &lt;div class=&quot;column2-container&quot;&gt;\n\t   &lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot;\n&lt;%\n\t\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t\t{\n\t\t\t%&gt;\nformLinkName=&apos;student_stateless_tab&apos;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\nformLinkName=&apos;student_stateless_tab?Email=&lt;%=encodeUrl(photo.Email)%&gt;&apos;\n&lt;%\n\t\t}\n\t\t%&gt;\nparams=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t   &lt;div name=&quot;studentpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Home&apos; params=&quot;Child_Mail=&lt;%=encodeUrl(photo.Email)%&gt;&quot; class=&quot;studentpage&quot;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data-container&quot;&gt;\n\t\t&lt;div class=&quot;no-data&quot;&gt;You do not have access to view the Student Dashboard&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Promote_Students1(Class_DB)
		{
			displayname = "Promote Students"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet9' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet9()\ncontent\n&lt;%{\n\tif(input.Class_DB != &quot;&quot;)\n\t{\n\t\turl = &quot;Promote_Students?Class_DB1=&quot; + input.Class_DB;\n\t}\n\telse\n\t{\n\t\turl = &quot;Promote_Students&quot;;\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:5px;\n\t\t  overflow:hidden;\n\t  }\n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n\t&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;&lt;%=url%&gt;&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Admin_Dashboard_Academic_Based
		{
			displayname = "Academic Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet10' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet10()\ncontent\n&lt;%{\n\tstaffpresentcount = Staff_Attendance[Date_field == zoho.currentdate &amp;&amp; Status != &quot;Absent&quot;].count();\n\ttotalstaff = Staff[Staff_Type == &quot;Teaching Staff&quot;].count();\n\ttotalstaff1 = totalstaff;\n\tif(totalstaff == 0)\n\t{\n\t\ttotalstaff1 = 1;\n\t}\n\tstaffAttendancePercent = (staffpresentcount \/ totalstaff1 * 100).round(2);\n\tstudentpresentcount = Class_Attendance[Date_field == zoho.currentdate &amp;&amp; Is_Present_in_Morning == true].count();\n\ttotalstudent = ifnull(Student[ID != 0].count(),0);\n\ttotalstudent1 = totalstudent;\n\tif(totalstudent == 0)\n\t{\n\t\ttotalstudent1 = 1;\n\t}\n\tstudentAttendancePercent = (studentpresentcount \/ totalstudent1 * 100).round(2);\n\tmyEvents = Create_Event[Event_Start_Date1 &gt; zoho.currentdate];\n\tannouncements = Communication_Form[Mode_of_Communication == &quot;Internal&quot;];\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;style&gt;\n\t\t*{\n\t\t\tpadding:0;\n\t\t\tmargin:0;\n\t\t\tbox-sizing:border-box;\n\t\t}\n\t\t\n\t\t:root{\n\t\t\t--staff-chart-color: #693fe5;\n    \t\t--staff-content-border-clr: #9477e7;\n\t\t\t--stu-chart-color:#2e82df;\n\t\t\t--stu-content-border-clr:#97c7fb;\n\t\t\t--chart-height-width:150px;\n\t\t\t--inner-content-height: 85%;\n\t\t\t--content-size: 70%;\n\t\t\t--content-font-size: 17px;\n\t\t}\n\t\t\n\t\tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t \theight: 100% !important;\n\t\t}\n\t  \n\t\t.admin-container{\n\t\t\theight: 100%;\n\t\t\tpadding: 10px 20px;\n\t\t\toverflow: auto;\n\t\t}\n\t\t\n\t\t.row1-container{\n\t\t\theight: 300px;\n\t\t}\n\t\t\n\t\t.row1-container,\n\t\t.row2-container{\n\t\t\tdisplay: flex;\n    \t\tgap: 15px;\n\t\t}\n\t\t\n\t\t.attendance-percentage-chart-wrapper,\n\t\t.announcements,\n\t\t.row2-container&gt;div,\n\t\t.quick-links{\n\/* \t\t\tpadding: 10px; *\/\n\t\t\theight:100%;\n\t\t\tbackground: white;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\tborder-radius: 5px;\n\t\t}\n\t\t\n\t\t.attendance-percentage-chart-wrapper {\n\t\t\twidth: 500px;\n\t\t}\n\t\t\n\t\t.announcements\n\t\t{\n\t\t\twidth: calc(100% - 750px);\n\t\t\toverflow: hidden;\n\t\t}\n\t\t\n\t\t.attendance-percentage-chart {\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: space-evenly;\n\t\t\talign-items: center;\n\t\t\theight: calc(100% - 46px);\n\t\t}\n\t\t\n\t\t.student-chart.new-chart,\n\t\t.staff-chart.new-chart{\n\t\t\theight: var(--chart-height-width);\n\t\t\twidth: var(--chart-height-width);\n\t\t\tborder-radius: 50%;\n\t\t\tpadding: 10px;\n\t\t}\n\t\t\n\t\t.student-chart.new-chart{\n\t\t\tborder: 2px solid var(--stu-chart-color);\n\t\t}\n\t\t\n\t\t.staff-chart.new-chart\n\t\t{\n\t\t\tborder: 2px solid var(--staff-chart-color);\n\t\t}\n\t\t\n\t\t.inner-progress-circle {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t\tborder-radius: 50%;\n\t\t\tanimation-name:animate 0.5s ease-in;\n\t\t}\n\t\t\n\t\t.student-chart.new-chart .inner-progress-circle{\n\t\t\tbackground: conic-gradient(var(--stu-chart-color) var(--chart-percent), 0, #e8e8e8 100%);\n\t\t\t--chart-color: var(--stu-chart-color);\n\t\t}\n\t\t\n\t\t.staff-chart.new-chart .inner-progress-circle{\n\t\t\tbackground: conic-gradient(var(--staff-chart-color) var(--chart-percent), 0, #e8e8e8 100%);\n\t\t\t--chart-color: var(--staff-chart-color);\n\t\t}\n\t\t\n\t\t@keyframes animate{\n\t\t\t0%{\n\t\t\t\tbackground: conic-gradient(var(--chart-color) 0%, 0, white 100%);\n\t\t\t}\n\t\t\t100%{\n\t\t\t\tbackground: conic-gradient(var(--chart-color) var(--chart-percent), 0, white 100%);\n\t\t\t}\n\t\t}\n\t\t\n\t\tspan.content {\n\t\t\tpadding: 10px 5px;\n\t\t\tborder-radius: 50%;\n\t\t\theight: var(--content-size);\n\t\t\twidth: var(--content-size);\n\t\t\tcolor: white;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tfont-size: var(--content-font-size);\n\t\t}\n\t\t\n\t\t.student-chart.new-chart span.content{\n\t\t\tbackground: var(--stu-chart-color);\n\t\t\tborder: 5px solid var(--stu-content-border-clr);\n\t\t}\n\t\t\n\t\t.staff-chart.new-chart span.content{\n\t\t\tbackground: var(--staff-chart-color);\n\t\t\tborder: 5px solid var(--staff-content-border-clr);\n\t\t}\n\t\t\n\t\t.chart-content {\n\t\t\tbackground: white;\n\t\t\tborder-radius: 50%;\n\t\t\theight: var(--inner-content-height);\n\t\t\twidth: var(--inner-content-height);\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\talign-items: center;\n\t\t}\n\t\t\n\t\t.student-chart-container,\n\t\t.staff-chart-container{\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\tgap: 15px;\n\t\t\talign-items: center;\n\t\t}\n\n\t\t.student-chart-container .chart-name,\n\t\t.staff-chart-container .chart-name{\n\t\t\tfont-size:16px;\n\t\t}\n\t\t\n\t\t.announcement-container {\n\t\t\theight: calc(100% - 20px);\n\t\t}\n\t\t\n\t\t.no-announcement-div,\n\t\t.no-events{\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\theight: 100%;\n\t\t}\n\t\t\n\t\ta.custom-btn {\n\t\t\tborder: 1px solid var(--live_primary_btn_h_bClr);\n\t\t\tpadding: 5px 10px;\n\t\t\tmargin-top: 15px;\n\t\t\tborder-radius: 3px;\n\t\t\tcolor: var(--live_primary_btn_h_bClr);\n\t\t\tcursor: pointer;\n\t\t\ttransition: all 0.2s ease-in;\n\t\t\tright: 10px;\n\t\t\tposition: absolute;\n\t\t}\n\t\t\n\t\ta.custom-btn:hover{\n\t\t\tbackground: var(--live_primary_btn_h_bClr);\n\t\t\tcolor: white;\n\t\t}\n\t\t\n\t\ta.custom-btn.top-btn {\n\t\t\tmargin: unset;\n\t\t}\n\n\t\t.row2-container{\n\t\t\theight:300px;\n\t\t\tmargin-top: 15px;\n\t\t}\n\t\t\n\t\t.quick-links {\n\t\t\twidth: 250px;\n\t\t}\n\t\t\n\t\t.quickLinksUL \n\t\t{\npadding: 0px 15px;\n    margin-top: 15px;\n    width: 100%;\n    list-style: none;\n    box-sizing: border-box;\n\t\t}\n\t\t.quickLinksLI\n\t\t{\n\t\t\ttext-align: center;\n    margin-bottom: 10px;\n    margin-left: 12px;\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: left;\n\t\t}\n\t\t.quickLinksLI &gt; a\n\t\t{\n\t\t\tcolor: #494747;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t\tgap: 5px;\n\t\t}\n\t\t\n\t\t.event-wrapper {\n\t\t  height: 55px;\n\/* \t\t  border-bottom: 1px solid var(--header-checked-line-color); *\/\n\t\tdisplay: flex;\n\t}\n\t\n\t.event-wrapper:not(:last-child){\n\t\t margin-bottom: 10px;\n\t}\n\t\n\t.event-wrapper .date {\n\t  background: var(--header-checked-line-color);\n\t  color: white;\n\t  width: 95px;\n\t  height: 100%;\n\t  display: flex;\n\t\tflex-direction: column;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tborder-radius: 5px 0 0 5px;\n\t}\n\t\n\t.event-wrapper .date &gt; span:first-child {\n\t  \tfont-size: 13px;\n\t    display: flex;\n  \t\tgap: 5px;\n\t}\n\t\n\t.event-wrapper .date &gt; span:last-child {\n\t  font-size: 13px;\n\t}\n\t\n\t.event-content {\n\t\t    height: calc(100% - 46px);\n    width: 100%;\n    padding: 10px 5px;\n    overflow: auto;\n\t}\n\t\n\t.event-info span:last-child {\n\t  font-size: 12px;\n\t  color: #7a7a7a;\n\t}\n\t\n\t.event-info span:first-child {\n\t  font-size: 13px;\n\t}\n\t\n\t.event-info {\n\t  width: 100%;\n\t  padding-left: 10px;\n\t  display: flex;\n\t  flex-direction: column;\n\t  justify-content: center;\n\t  border-bottom: 1px solid var(--header-checked-line-color);\n\t}\n\t\n\t.event-container .header {\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tjustify-content: space-between;\n\t\tposition: relative;\n\t}\n\t\n\t.announcements .header {\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t}\n\t\n\t\tul.announcements-list {\n\t\t\twidth: 100%;\n\t\t\theight: 100%;\n\t\t\tpadding-left: 25px;\n\t\t}\n\t\t\n\t\tul.announcements-list&gt;li {\n\t\t\ttext-align: justify;\n\t\t\tmargin-bottom: 10px;\n\t\t}\n\t\t\n\t\t.event-container\n\t\t{\n\t\t\twidth: 350px;\n\t\t}\n\t\t\n\t\t.exams-tab{\n\t\t\twidth: calc(100% - 350px);\n\t\t}\n\t\t\n\t\t.exams-tab.divEmbedContainer {\n\t\t\twidth: calc(100% - 350px);\n\t\t\theight: 100% !important;\n\t\t\tpadding: unset;\n\t\t\toverflow: hiddent;\n\t\t}\n\t\t\n\t\/* Popup Form Styles Start*\/\n\/* \t.popupbox.formWithinPopup,\n\t.zc-form-popup-container .popupbox{\n\t\tborder-radius: 5px;\n\t\toverflow: hidden;\n\t\theight: 80%;\n\t} *\/\n\t\n\t.popupbox.formWithinPopup .form-action.formbutton,\n\t.zc-form-popup-container .popupbox .form-action.formbutton {\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t}\n\t\n\t.popupbox.formWithinPopup .form-action.formbutton .form-label,\n\t.zc-form-popup-container .popupbox .form-action.formbutton .form-label{\n\t\tdisplay:none;\t\n\t}\n\t.funnel.divEmbedContainer {\n    height: calc(100% - 46px);\n}\n\n[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer {\n    border-bottom: 0px !important;\n    border-right: 0px !important;\n}\n\ndiv[elementname=&quot;Chart&quot;] {\n    min-height: unset !important;\n\t\theight:100% !important;\n\n\t\n}\n.zcpage-chart-livetemplate {\n    min-height: unset !important;\n\theight:100% !important;\n}\n.student-percentage {\n    margin-top: 15px;\n}\n\n.student-percentage.divEmbedContainer {box-shadow: 0px 0px 5px #cdcdcd;\n\tborder-radius: 5px;\n\theight: 100% !important;\n\toverflow: hidden;\n\t}\n.view-outer-wrapper.view-outer-pivot-wrapper .reportfullwidth div[elname=recordcontainerwrapper] &gt; div {\n\t    height: calc(100% - 20px);\n\n}\n.view-outer-wrapper.view-outer-pivot-wrapper .reportfullwidth div[elname=recordcontainerwrapper] {\n    height: 100% !important;\n}\n\n.view-outer-wrapper.view-outer-pivot-wrapper .reportfullwidth div[elname=recordcontainerwrapper]&gt;div iframe {\n    height: 100%;\n}\n\t\/* Popup Form Styles End*\/\n\n\n.link-span:hover{\n\ttext-decoration: underline;\n}\n\n .student-percentage-pivot {\n    height: 450px !important;\n}\n.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td{\n\tvertical-align:middle !important;\n}\n\ndiv#zctooltip2{\n    opacity: 1 !important;\n}\n   \n\t&lt;\/style&gt;\n&lt;div class=&quot;admin-container&quot;&gt;\n\t&lt;div class=&quot;row1-container&quot;&gt;\n\t&lt;div class=&quot;announcements&quot;&gt;\n\t\t\t\t&lt;h3 class=&quot;common-header&quot;&gt;Admission Info&lt;\/h3&gt;\n\n\t\n\t\t&lt;div class=&quot;funnel&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Admission_Info1&apos; params=&apos;&apos;&gt;&lt;\/div&gt;\n\n\t\n\t\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;attendance-percentage-chart-wrapper&quot;&gt;\n\t\t\t&lt;h3 class=&quot;common-header&quot;&gt;Today&apos;s Attendance Chart&lt;\/h3&gt;\n\t\t\t &lt;div class=&quot;attendance-percentage-chart&quot;&gt;\n\t\t\t\t&lt;div class=&quot;student-chart-container&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;student-chart new-chart&quot;&gt;\n\t\t\t\t\t\t&lt;div class=&quot;inner-progress-circle&quot; style=&quot;--chart-percent:&lt;%=studentAttendancePercent%&gt;%&quot;&gt;\n\t\t\t\t\t\t\t&lt;div class=&quot;chart-content&quot;&gt;\n\t\t\t\t\t\t\t\t&lt;span class=&quot;content&quot;&gt;&lt;%=studentAttendancePercent%&gt;%&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;span class=&quot;chart-name&quot;&gt;Student Attendance Chart&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;staff-chart-container&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;staff-chart new-chart&quot;&gt;\n\t\t\t\t\