			promoteAll as "promoteAll"
			{
				type =  functions
				form = Student
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						eduYear = Educational_Year[Status == "Current"];
										upYear = Educational_Year[Status == "Upcoming"];
										clsDb = Class_DB[ID == input.Class_UID.Class];
										tempOrder = clsDb.Order + 1;
										upclass = Class[Educational_Year == upYear && Class.Order == tempOrder && Section2 == input.Class_UID.Section2];
										resp = Student[Annual_Exam_Result != "Yet to Start" && Class_UID.Class == input.Class_UID.Class];
										// info resp;
										studentList = upclass.Student;
										if(upclass.Student.size() + 1 < upclass.Student_Capacity)
										{
											input.Class_UID = upclass.ID;
											studentList.add(input.ID);
											upclass.Student=studentList;
											input.Annual_Exam_Result = "Yet to Start";
											if(resp.count() <= 1)
											{
												clsDb.Class_Promotion_Status="Finished";
											}
										}
					)
					}
				}
			}
