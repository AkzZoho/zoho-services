8532 13.7031 24.8953 13.4785 25.0601 13.3659L27.3228 11.8213C27.4873 11.7088 27.7123 11.7512 27.8249 11.9159C27.9375 12.0804 27.8953 12.3053 27.7303 12.4179ZM29.394 19.3363C29.3619 19.5103 29.2099 19.6322 29.039 19.6322C29.0174 19.6322 28.9953 19.6301 28.9732 19.626L26.2791 19.1292C26.083 19.0929 25.9532 18.9045 25.9894 18.7084C26.0254 18.5123 26.2128 18.3819 26.4102 18.4187L29.1043 18.9156C29.3004 18.9518 29.43 19.1399 29.394 19.3363Z&quot; fill=&quot;var(--theme_brand_color)&quot;\/&gt;\n&lt;\/svg&gt;\n&lt;\/div&gt;\n&lt;div class=&quot;li-announcement-content-div&quot;&gt;\n   &lt;span class=&quot;announcement-sub&quot;&gt;&lt;%=announcement.Subject_field%&gt;&lt;\/span&gt;\n   &lt;span class=&quot;day-span&quot;&gt;&lt;%=announcement.Added_Time.toString(&quot;dd-MMM-yyyy&quot;)%&gt;&lt;\/span&gt;\n&lt;\/div&gt;&lt;\/li&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/ul&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;img src=&quot;https:\/\/img.icons8.com\/external-semi-solid-chattapat-\/512\/external-announcement-communication-semi-solid-chattapat-.png&quot; width=&quot;40px&quot;&gt;\n\t\t\t   \t\t&lt;p&gt;No Announcements...&lt;\/p&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t\t   \n\t\t  &lt;div class=&quot;attendance-div&quot;&gt;\n\t\t  &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Attendance Info&lt;\/h4&gt;&lt;\/div&gt;\n\t\t  &lt;div class=&quot;content&quot;&gt;\n\t\t     &lt;div class=&quot;content-row1&quot;&gt;\n\t\t\t    &lt;div class=&quot;content-row1-column1&quot;&gt;\n\t\t\t\t  &lt;p&gt;Total Days Present&lt;\/p&gt;\n\t\t\t\t  &lt;span&gt;&lt;%=totalDaysPresent%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;content-row1-column2&quot;&gt;\n\t\t\t\t  &lt;p&gt;Total Days Absent&lt;\/p&gt;\n\t\t\t\t  &lt;span&gt;&lt;%=totalDaysAbsent%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t &lt;\/div&gt;\n\t\t\t &lt;div class=&quot;content-row2&quot;&gt;\n\t\t\t   &lt;p&gt;Attendance %&lt;\/p&gt;\n\t\t\t   &lt;div class=&quot;half-circle-container&quot;&gt;\n\t\t\t    &lt;div class=&quot;multigraph&quot; style=&quot;--pbar-height:65px;--pbar-width:calc(var(--pbar-height) * 2);--pbar-border-width:15px;&quot;&gt;\n&lt;%\n\ttry \n\t{\n\t\tPercentage = totalDaysPresent \/ (totalDaysPresent + totalDaysAbsent) * 100;\n\t}\n\tcatch (e)\n\t{\n\t\tPercentage = 0;\n\t}\n\tdeg = Percentage * 1.8;\n\t%&gt;\n&lt;span class=&quot;tooltip&quot;&gt;&lt;%=Percentage.round(2)%&gt;%&lt;\/span&gt;\n\t\t\t\t\t&lt;span class=&quot;graph&quot; style=&quot;--percentage:&lt;%=deg.round(2)%&gt;deg&quot;&gt;&lt;\/span&gt;\n                &lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t &lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;\/div&gt;\n\t\t  &lt;div class=&quot;holiday-div&quot;&gt;\n\t\t    &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Upcoming Holidays&lt;\/h4&gt;&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;content&quot;&gt;\n&lt;%\n\tholidayList = Holidays[Date_field &gt;= zoho.currentdate &amp;&amp; Holiday_Type == &quot;Common Holiday&quot; || Holiday_Type == &quot;Local Holiday&quot;] sort by Date_field;\n\tif(holidayList.count() &gt; 0)\n\t{\n\t\tfor each  holiday in holidayList\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;timeline-outer&quot;&gt;\n\t\t\t\t\t\t\t&lt;div class=&quot;timeline-inner&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-value&quot;&gt;&lt;%=holiday.Holiday%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;div class = &quot;timeline-date-day-container&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-date&quot;&gt;&lt;%=holiday.Date_field%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-day&quot;&gt;&lt;%=holiday.Date_field.toString(&quot;EEEE&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot; style=&quot;box-shadow:unset;&quot;&gt;No More Holidays&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t  &lt;div class=&quot;home-container-row2&quot;&gt;\n\t     &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Time Table&lt;\/h4&gt;&lt;\/div&gt;\n\t\t &lt;div class=&quot;content&quot;&gt;\n\t\t     &lt;table class=&quot;time-table&quot;&gt;\n\t\t\t &lt;thead&gt;\n\t\t\t &lt;tr&gt;\n&lt;%\n\tlessonPlan = Lesson_Plan_Mapping[Staff.Email_ID == login].Class;\n\ttimeTable = Time_Table[Class == lessonPlan];\n\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;span&gt;Day\/Period&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\tfor each  data in timeTable.Time_Table_Subform\n\t{\n\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=data.Time%&gt;&lt;\/th&gt;\n&lt;%\n\t\tif(data.Time.contains(break1Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t{\n\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=break1TimeString%&gt; &lt;\/th&gt;\n&lt;%\n\t\t}\n\t\tif(data.Time.contains(break2Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t{\n\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;&lt;%=break2TimeString%&gt; &lt;\/th&gt;\n&lt;%\n\t\t}\n\t\tif(1 == 2)\n\t\t{\n\t\t\t%&gt;\n&lt;th class=&quot;day-period&quot;&gt;lunchTimeString &lt;\/th&gt;\n&lt;%\n\t\t}\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n &lt;\/thead&gt;\n&lt;%\n\tallMap = thisapp.test.test();\n\t%&gt;\n&lt;tbody&gt;\n&lt;tr&gt; &lt;td&gt;Monday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;monday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\tif(sub.get(&quot;time&quot;).contains(break1Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t{\n\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Break&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t}\n\t\tif(sub.get(&quot;time&quot;).contains(break2Time.toTime().toString(&quot;HH:mm&quot;)))\n\t\t{\n\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Break&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t}\n\t\tif(sub.get(&quot;time&quot;) == &quot;1000&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;th rowspan=&quot;7&quot; class=&quot;break-td&quot;&gt;&lt;span&gt;Lunch&lt;\/span&gt;&lt;\/th&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n\t&lt;tr&gt;&lt;td&gt;Tuesday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;tuesday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n\t&lt;tr&gt;&lt;td&gt;Wednesday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;wednesday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n\t&lt;tr&gt;&lt;td&gt;Thursday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;thursday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n\t&lt;tr&gt;&lt;td&gt;Friday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;friday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n\t&lt;tr&gt;&lt;td&gt;Saturday&lt;\/td&gt;\n&lt;%\n\tfor each  sub in allMap.get(&quot;saturday&quot;)\n\t{\n\t\t%&gt;\n&lt;td&gt;\n&lt;%\n\t\tif(sub.get(&quot;className&quot;) != &quot;no&quot;)\n\t\t{\n\t\t\tsessionData = Session_Subform[Sessions.Date_field == zoho.currentdate &amp;&amp; Session_Name == sub.get(&quot;time&quot;) &amp;&amp; Staff.Email_ID == zoho.loginuserid];\n\t\t\t%&gt;\n&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(0)%&gt;&lt;\/span&gt;\n\t\t\t&lt;span&gt;&lt;%=sub.get(&quot;className&quot;).toList(&quot;\/&quot;).get(1)%&gt;&lt;\/span&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n-\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/td&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tr&gt;\n &lt;\/tbody&gt;\n\t\t\t &lt;\/table&gt;\n\t\t &lt;\/div&gt;\n\t  &lt;\/div&gt;  \n\t  &lt;div class=&quot;home-container-row3&quot;&gt;\n\t  \t&lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;Session_Subform_Report&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
