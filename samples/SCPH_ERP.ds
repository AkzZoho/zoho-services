		page All_Fee_Cycles1
		{
			displayname = "All Fee Cycles"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet26' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet26()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            \n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  box-sizing: border-box;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:10px;\n\t\t  overflow:hidden;\n\t  }\n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n\t&lt;div elName=&apos;zc-component&apos; name=&quot;reportdiv&quot; class=&quot;pagereport&quot; viewLinkName=&apos;All_Fee_Cycles&apos; params=&apos;zc_Header=true&amp;zc_ReportName=true&amp;zc_MoreAction=true&amp;zc_Search=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page My_Fee1
		{
			displayname = "My Fee"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet27' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet27()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n       \n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  box-sizing: border-box;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:10px;\n\t\t  overflow:hidden;\n\t  }\n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n\t&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;My_Fee&apos; params=&apos;zc_Header=true&apos;&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Fee_Management
		{
			displayname = "Fee Management"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet25' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet25()\ncontent\n&lt;%{\n\toverdue = Fee[Fee_Status == &quot;Overdue&quot;].count();\n\tpaid = Fee[Fee_Status == &quot;Paid&quot;].count();\n\tunpaid = Fee[Fee_Status == &quot;Pending&quot; || Fee_Status == &quot;Overdue&quot; || Fee_Status == &quot;Partially Paid&quot;].count();\n\ttoBePaid = Fee[Fee_Status != &quot;Paid&quot;].sum(Unpaid_Amount);\n\tpaidAmount = Fee[Fee_Status == &quot;Paid&quot; || Fee_Status == &quot;Partially Paid&quot;].sum(Paid_Amount);\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\n&lt;style&gt;\t\n\t* {\n            padding: 0;\n            margin: 0;\n            border: none;\n         \n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n\t\t  box-sizing: border-box;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t.container-wrapper{\n\t\theight:100%;\n\t\twidth:100%;\n\t\tbackground: var(--main-container-color);\n\t\tpadding: 10px 20px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n\t\t\n\t.second-row{\n\t\theight:calc(100% - 115px);\n\t\twidth:100%;\n\t\tpadding: 10px 0px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t.second-row .pagereport{\n\t\tpadding:10px 10px 0px 10px;\n\t\theight:calc(100% - 30px) !important;\n\t\tbox-sizing: border-box;\n\t}\n\t\/*form styles *\/\n\t.stateless-form{\n\t\tpadding:0px 10px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t\t.stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t .stateless-form .choice-label-text {\n\t\t\tfont-size: 16px !important;\n\t\t\tfont-weight: 400;\n\/* \t\t\tcolor: #d0d0d0; *\/\n\t\t\tmix-blend-mode: normal;\n\t\t}\n\t\t\n\t\t.stateless-form .choice-table-cell input:checked~label {\n\t\t\tcolor: var(--theme_brand_color);\n\t\t\tfont-weight: 700;\n\t\t}\n\t\t\n\/* \t\t.stateless-form .choice-table-cell input:not(:checked) ~ label:hover {\n\t\t\t transform: perspective(200px) translateZ(25px);\n\t\t\t color: var(--report-header-background-color) !important;\n\t\t} *\/\n\t\t\n\t\t.stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t margin-right: 10px;\n\t }\n\t \n\t.stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.stateless-form .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t}\n\t\n\t\t.stateless-form form.form-table {\n\t\t\theight: 30px !important;\n\t\t}\n\t\t\n\t\t.stateless-form form.form-table .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t.stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t\n\t.stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\tdisplay:flex !important;\n\t\tgap:20px;\n\t}\n\t\n\t.stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.stateless-form .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t\n\t.stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.stateless-form.divEmbedContainer {\n\t\theight: 30px !important;\n\t}\n\t\n\t.stateless-form .zc-form-fullheight,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t\/* Hide - Form Loader Icon *\/\n\t.stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t\t\n\t\/* Report Styles *\/\n\t.pagereport{\n\t\theight: calc(100% - 30px) !important;\n\t\tpadding-top: 10px;\n\t\tbox-sizing: border-box;\n\t}\n\n\t.pagereport&gt;.view-outer-wrapper\n\t{\n\t\tborder-radius: 8px;\n\t\toverflow: hidden;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t}\n\t\n\t\/* Panel Design *\/\n\tdiv#row_2&gt;div {\n\t\tpadding: 10px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\tdiv#row_2&gt;.column-container&gt;div\n\t{\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n    \tborder-radius: 5px;\n\t}\n\t\n\t .panels{\n          display: flex;\n          padding: 10px 0;\n\t\t  box-sizing: border-box;\n      }\n     \n      .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: flex-start;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        padding: 15px;\n\t\tbox-sizing: border-box;\n        position:relative;\n        overflow:hidden;\n\t\tpadding-right:70px;\n      }\n      \n\t  .panels .panel span:nth-child(1) {\n          font-size: 20px;\n      }\n\t  \n      .panels .panel span:nth-child(2) {\n          font-size: 14px;\n      }\n      .panel{\n        gap:5px;\n      }\n\t  .panel-icon img {\n    \t\theight: 100%;\n\t\t\tpadding: 7px;\n\t\t\tbox-sizing: border-box;\n\t\t\tfilter: brightness(0) invert(1);\n\t\t}\n\t\t\n\t\t.panel-icon {\n\t\t\theight: 50px;\n\t\t\twidth: 50px;\n\t\t\tposition: absolute;\n\t\t\tright: 20px;\n\t\t\tborder-radius: 8px;\n\/* \t\t\tbox-shadow: 0px 0px 5px #cdcdcd; *\/\n\t\t}\n\t  \n        .zcpopup.compact .popupbox-wrapper .popupbox {\n\t\t\tborder-radius: 5px;\n\t\t}\n\n\/* \t\t.zcpopup.compact .form-group{\n\t\t\tmargin:0px !important;\n\t\t\twidth:100%;\n\t\t} *\/\n\t\t\n\t\t.zcpopup.compact .zcform_Confirm_Payment .first-column .notes-field {\n\t\t\ttext-align: center;\n\t\t\twidth:100%;\n\t\t}\n\t\t\n\t\t.zcpopup.compact .popupbox-wrapper .popupbox .popupboxOuter .form-outer-wrapper form{\n\t\t\t margin-left: unset !important;\n\t\t}\n\t\t\n\t\t.zcpopup.compact .zc-footer-wrapper {\n\t\t\tborder-top: unset !important;;\n\t\t}\n\n\t\t@keyframes iconAnimation{\n    \t50%{\n        \ttransform : rotateY(90deg);\n    \t}\n    \t100%{\n        \ttransform : rotateY(0deg);\n    \t}\n\t\t}\n\t\t.panel-icon:hover img {\n    \tanimation: iconAnimation 1s linear;\n\t\t}\n\t\t\n\t\t.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_searc