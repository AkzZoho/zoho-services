		page School_Details1
		{
			displayname = "School Details"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet92' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet92()\ncontent\n&lt;%{\n\torgInfo = School_Details[ID != 0];\n\tif(orgInfo.count() == 0)\n\t{\n\t\topenURL(&quot;#Form:School_Details&quot;,&quot;popup-window&quot;);\n\t}\n\t%&gt;\n&lt;style&gt;\n\t.school-detail-wrapper{\n\t\tpadding:20px;\n\t\t            box-sizing: border-box;\n\t\tbackground: var(--main-container-color);\n    \theight: 100%;\n\t}\n\t\n\t.org-logo{\n\t\theight:50px;\n\/* \t\tborder-radius:20px; *\/\n\t\tobject-fit: contain;\n\t}\n\t\n\/* \t.school-main-info {\n\t\tdisplay: flex;\n\t\tgap: 20px;\n\t\tposition:relative;\n\t\tpadding-right: 60px;\n\t\t            box-sizing: border-box;\n\t} *\/\n\t\n\t.school-basic-info{\n\t\tpadding: 5px 0px;\n\t\t            box-sizing: border-box;\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\tgap: 4px;\n\t}\n\t\n\tp.school-name {\n\t\tfont-size: 20px;\n\t\tfont-weight: 600;\n\t}\n\t\n\t.school-address {\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\tjustify-content: space-evenly;\n\t\theight: 100%;\n\t}\n\t\n\t.school-details-container {\n\t\tpadding:15px;\n\t\t            box-sizing: border-box;\n\t\tbackground: white;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\twidth: fit-content;\n\t\tborder-radius: 5px;\n\t\tmargin-top: 20px;\n\t\tmax-width: 350px;\n\t\tposition: relative;\n\t}\n\t\n\t.school-other-info {\n\t\tmargin-top: 12px;\n\t}\n\t\n\tspan.other-info-header {\n\t\tfont-size: 14px;\n\t\tcolor: #9c9c9c;\n\t\twidth: 250px;\n\t}\n\t\n\t.school-other-info&gt;div {\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tmargin-top: 8px;\n\t}\n\t\n\t.edit-link{\n\t\tposition: absolute;\n\t\ttop: 0px;\n\t\tright: 10px;\n\t}\n\t\n\t.edit-button{\n\t\t\n\t\tcolor: var(--button-color);\n\t\tbackground-color: var(--button-font-color) !important;\n\t\tborder-radius: 3px;\n\t\theight: 30px !important;\n\t\twidth: auto;\n\t\tdisplay: flex;\n\t\talign-items: center;\n\t\tpadding: 0 10px;\n\t\tborder: 1px solid var(--button-color) !important;\n\t\tposition: absolute;\n\t\tright: 10px;\n\t\ttop: 10px;\n\t\tpadding: 0px 15px;\n\t\t            box-sizing: border-box;\n\t}\n\t\n\t.edit-button:hover\n\t{\n\t\tbackground: var(--button-color) !important;\n\t\tcolor: var(--button-font-color) !important;\n    \t\n\t}\n&lt;\/style&gt;\n&lt;div class=&apos;school-detail-wrapper&apos;&gt;\n\t&lt;h3&gt;Institute Details&lt;\/h3&gt;\n\t&lt;div class=&quot;school-details-container&quot;&gt;\n\t\t&lt;div class=&quot;school-main-info&quot;&gt;\n&lt;%\n\tappurl = &quot;https:\/\/creatorapp.zoho.in&quot;;\n\tif(orgInfo.count() &gt; 0 &amp;&amp; orgInfo.Logo not in {&quot;&quot;,null})\n\t{\n\t\timagefile = orgInfo.Logo.getSuffix(&quot;fieldName\/image\/&quot;).getPrefix(&quot;\\&quot; lowqual&quot;);\n\t\timageUrl = appurl + &quot;\/file&quot; + zoho.appuri + &quot;All_School_Details\/&quot; + orgInfo.ID + &quot;\/Logo\/image-download?filepath=\/&quot; + imagefile;\n\t}\n\t\/\/ \tif(thisapp.portal.isUserInProfile(&quot;Admin&quot;) == true)\n\t\/\/ \t{\n\t\/\/ \t\tappurl = thisapp.getPortalUrl();\n\t\/\/ \t}\n\t\/\/ \telse\n\t\/\/ \t{\n\t\/\/ \t}\t\n\t%&gt;\n&lt;img class=&quot;org-logo&quot; src=&quot;&lt;%=imageUrl%&gt;&quot; class=&quot;org-logo&quot; \/&gt;\n\t\t\t&lt;div class=&quot;school-basic-info&quot;&gt;\n\t\t\t\t&lt;p class=&apos;school-name&apos;&gt;&lt;%=orgInfo.School_Name%&gt;&lt;\/p&gt;\n\t\t\t\t&lt;div class=&quot;school-address&quot;&gt;\n\t\t\t\t\t&lt;%=orgInfo.Address.address_line_1%&gt;,\n\t\t\t\t\t&lt;%=orgInfo.Address.address_line_2%&gt;,\n\t\t\t\t\t&lt;%=orgInfo.Address.district_city%&gt;, &lt;%=orgInfo.Address.state_province%&gt;  \n\t\t\t\t\t&lt;%=orgInfo.Address.postal_Code%&gt;, &lt;%=orgInfo.Address.country%&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;a href=&quot;#Form:School_Details?recLinkID=&lt;%=orgInfo.ID%&gt;&amp;viewLinkName=All_School_Details&amp;zc_LoadIn=dialog&amp;zc_NextUrl=#Script:page.back&quot; class=&quot;edit-button&quot;&gt;Edit&lt;\/a&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;school-other-info&quot;&gt;\n\t\t\t&lt;div&gt;\n\t\t\t\t&lt;span class=&apos;other-info-header&apos;&gt;Affiliation&lt;\/span&gt;\n\t\t\t\t&lt;span class=&apos;other-info-content&apos;&gt;&lt;%=orgInfo.Affiliation%&gt;&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n\t\t\t\t&lt;span class=&apos;other-info-header&apos;&gt;Website&lt;\/span&gt;\n\t\t\t\t&lt;span class=&apos;other-info-content&apos;&gt;&lt;%=orgInfo.Website%&gt;&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n\t\t\t\t&lt;span class=&apos;other-info-header&apos;&gt;Contact Number&lt;\/span&gt;\n\t\t\t\t&lt;span class=&apos;other-info-content&apos;&gt;&lt;%=orgInfo.Contact_Number%&gt;&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Buildings
		{
			displayname = "Buildings"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet93' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet93()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n\t.buildings-wrapper{\n\t\theight:100%;\n\t\tbackground: var(--main-container-color);\n\t\tpadding: 10px 20px;\n\t\t            box-sizing: border-box;\n\t}\n\t\n\t\/*form styles *\/\n\t.inner-stateless-form{\n\t\tpadding:0px 10px;\n\t\t            box-sizing: border-box;\n\t}\n\t\n\t\t.inner-stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.inner-stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.inner-stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.inner-stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.inner-stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.inner-stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.inner-stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .inner-stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .inner-stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t margin-right: 10px;\n\t }\n\t \n\t.inner-stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.inner-stateless-form .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t\n\t.inner-stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t}\n\t\n\t\t.inner-stateless-form form.form-table {\n\t\t\theight: 30px !important;\n\t\t}\n\t\t\n\t\t.inner-stateless-form form.form-table .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t.inner-stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.inner-stateless-form form.form-table .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 0px 15px;\n\t\t\t            box-sizing: border-box;\n\t\t\twidth: 100%;\n\t\t  display: flex;\n\t\t  justify-content: center;\n\t\t}\n\t\n\t\t.inner-stateless-form .choice-table-cell input:checked~label {\n    color: var(--theme_brand_color) !important;\n}\n\t\t\n\t\t\n\t\t\n\t.inner-stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\tdisplay:flex !important;\n\t}\n\t\n\t.inner-stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.inner-stateless-form .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.inner-stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t\n\t.inner-stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.inner-stateless-form.divEmbedContainer {\n\t\theight: 30px !important;\n\t}\n\t\n\t.inner-stateless-form .zc-form-fullheight,\n\t.inner-stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t\/* Hide - Form Loader Icon *\/\n\t.inner-stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t \n\t .pagereport{\n\t\t height:calc(100% - 45px) !important;\n\t\t border-radius:5px;\n\t\t overflow:hidden;\n\t\t margin-top:15px;\n\t\t box-shadow:0px 0px 5px #cdcdcd;\n\t }\n&lt;\/style&gt;\n&lt;div class=&quot;buildings-wrapper&quot;&gt;\n\t&lt;div class=&quot;inner-stateless-form&quot; elName=&apos;zc-component&apos; formLinkName=&apos;Buildings_Nav&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t&lt;div class=&quot;pagereport&quot; name=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Blocks1&apos; params=&apos;zc_Header=true&amp;zc_ReportName=false&amp;zc_MoreAction=true&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Admin_Test
		{
			displayname = "Admin Test"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet94' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet94()\ncontent\n&lt;%{\n\tmyLeads = Lead[Agent.Email_ID == zoho.loginuserid];\n\tmyLeads_count = myLeads.count();\n\tallLeads = Lead[ID != 0].count();\n\tregistrations = Registration[Lead in myLeads].count();\n\twaitingList = Registration[Status == &quot;Waiting List&quot; &amp;&amp; Lead in myLeads].count();\n\tconversions = Registration[Status == &quot;Class Assigned&quot; &amp;&amp; Lead in myLeads].count();\n\t%&gt;\n&lt;style&gt;\n     * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\t\t\n\t\t:root {\n\t\t\t--header-checked-line-color: #5b8cfb;\n\t\t\t--header-background-color:#5b8cfb;\n\t\t\t--label-color:#a7c4fb;\n\t\t\t--header-line-color: #e2e2e2;\n\t\t\t--header-hover-color: #45b6fe;\n\t\t\t--panel-background-color: white;\n\t\t\t--main-container-color: white;\n\t\t\t--button-color: #fff;\n\t\t\t--font-color: #fff;\n\t\t\t--btn-hover-color: #fff;\n\t\t\t--button-background:#4b81f8;\n\t\t\t--report-header-txt-color: #fff;\n\t\t\t--group-background-color: #cfdaf4;\n\t\t\t--line-design-color:#7290d4;\n\t\t\t--tr-hover-color:#f5f5f3;\n\t\t}\n\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  .zc-reporttype-list .list-view-inner .handsontable.ht_master .wtHolder .wtHider .htCore tbody tr:hover td {\n\t\t  background: var(--tr-hover-color);\n\t\t}\n\t\t\n\t  \tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\t  \n\t  .header\n\t  {\n\t\t padding: 10px 0; \n\t  }\n      \n      .panels{\n          display: flex;\n          padding: 10px 0;\n      }\n     \n      .panels .panel {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex: 1;\n        height: 95px;\n\t\tbackground:var(--panel-background-color);\n        box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        cursor: pointer;\n        padding: 15px;\n        position:relative;\n        overflow:hidden;\n      }\n      \n\t  .panels .panel span:nth-child(2) {\n          font-size: 2rem;\n      }\n\t  \n      .panels .panel span:first-child {\n          font-size: 16px;\n      }\n\t  \n      .panel{\n        gap:5px;\n      }\n    \n\t\t\/*form styles *\/\n\t\t.tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.tab_search .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t \n\t\t.tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t\n\t\t.tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t\n\t\t.tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.tab_search .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t\n\t\t.tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t\n\t   .tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t   \n\t .tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t \n\t .tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t}\n\t\t\n\t\t.tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t\n\t\t.tab_search .customRadio.zc_radio:checked+label+label\n\t\t{\n\t\t\tcolor:var(--header-checked-line-color);\n\t\t}\n\t\t\n\t\t.tab_search form[name=&quot;Report_Search&quot;].label-left {\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t\n\t\t.tab_search .flLeft.tempContDiv.zc-Radio {\n           width: 100% !important;\n        }\n\t\t\n\t\t.tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tgrid-template-columns: 60% 40% 0%;\n\t\t\tdisplay: grid !important;\n\t\t\twidth: 100% !important;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\n\t.tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.tab_search .choice-table-cell input~label {\n       position: relative;\n\t   color: var(--label-color);\n\t}\n\n\t.tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t\t\/*  Report styles  *\/\n\t\tspan.colHeader i.zc-report-sortOrder {\n          display: none !important;\n        }\n\t\t\n\t\t .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td {\n            border-right: none !important; \n        }\n\t\t\n\t\ta.zc-image-placeholder {\n\t\t\theight:50px !important;\n        }\n\t\t\n\t\ttd.zcReport_Text.zc-mapping-field.htDimmed\n\t\t{\n\t\t\tvertical-align:middle;\n\t\t}\n\t\t\n\t\t.zc-reporttype-list .list-view-inner .ht_clone_top.handsontable {\n              height: 45px!important;\n         }\n\t\t \n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th\n\t\t{\n\t\t\tbackground:var(--header-background-color) !important;\n\t\t\tborder-right:none !important;\n\t\t}\n\t\t\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th .relative .colHeader span\n\t\t{\n\t\t\tcolor:var(--report-header-txt-color) !important;\n\t\t}\n\t\t\n\t\ta.zc-live-primary-btn{\n\t\t\tbackground:var(--button-background);\t\n\t\t}\n\t\t\n\t\tdiv#All_Students_ZC_OZFMQ5\n\t\t{\n\t\t\t box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%) !important;\n\t\t}\n\t\t\n\t\t.divEmbedContainer\n\t\t{\n\t\t\tpadding:0 10px !important;\n\t\t}\n\t\t\n\t\t.reportfullwidth {\n            background: white !important;\n\t\t\tborder-radius: 3px;\n\t\t\toverflow: hidden;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n        }\n\t\t\n        .zc-reports-footer-sec {\n           background: white !important;\n\t\t }\n\t\t  \n\t\tdiv[formlinkname=&quot;Report_Search&quot;] {\n\t\t\theight: 30px !important;\n\t\t}\n\t\t\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\tdiv[formlinkname=&quot;Report_Search&quot;] .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t}\n\t\t\n\t\t.header {\n\t\t\theight: calc(100% - 115px);\n\t\t}\n\t\t\n\t\t.header&gt;div:last-child {\n\t\t\theight: calc(100% - 30px) !important;\n\t\t\tpadding-top: 10px !important;\n\t\t}\n\t\t\n\t\ta.zc-live-primary-btn.btn-big\n\t\t{\n\t\t\theight:45px !important;\n\t\t}\n\t\t\n\t\ttd.zcReport_Email.zc-mapping-field.htDimmed\n\t\t{\n\t\t\tvertical-align:middle !important;\n\t\t}\n\t\t\n\t\t.fa.fa-plus:after {\n\t\t\tcontent: &quot;Add New&quot;;\n\t\t\tfont-weight: 900;\n\t\t\tcolor: white;\n\t\t\tfont-family: &quot;Raleway&quot;;\n\t\t}\n\t\t\n\t\t.fa-plus:before{\n\t\t\tfont-weight: 900;\n\t\t\tcolor: white;\n\t\t\tpadding-right: 3px;\n\t\t}\n\t\t\n\t\ta.zc_transition.pull-right.zc-add-record.zc-tooltip-el {\n\t\t\tpadding: 0 5px;\n\t\t}\n\t\t\n\t\t.view-header .zc-add-record\n\t\t{\n\t\t\twidth: auto !important;\n\t\t\tborder-radius:3px;\n\t\t\tbackground:var(--button-background);\n\t\t}\n\t\t\n\t\t.view-header .zc-add-record:hover\n\t\t{\n\t\t\tbackground:var(--button-background);\n\t\t}\n\t\t\n\t\t.leadpagereport .handsontable tbody tr {\n\t\t\theight: 45px;\n\t\t}\n\t\t\n\t\t\/* Hide - Form Loader Icon *\/\n\t\t.tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n\t\t\n\t\t\/* Report Header Background And Height Style *\/\n\t\t.leadpagereport .view-header{\n\t\t\tbackground:transparent !important;\n\t\t\theight: 40px !important; \n\t\t}\n\t\t\n\t\t\/* Report Group tr Style *\/\n\t\t.leadpagereport .handsontable tbody tr[elname*=&quot;zc-grouprow&quot;] {\n\t\t\theight: auto;\n\t\t}\n\t\t\n\t\t.leadpagereport .handsontable tbody tr[elname*=&quot;zc-grouprow&quot;] td {\n\t\t\tbackground: var(--group-background-color) !important;\n    \t\t\/\/color: white !important;\n\t\t}\n\t\t\n\t\t.leadpagereport .view-outer-wrapper .view-header .zc-new-report-header{\n\t\t\theight: 40px !important;\n    \t\tborder-bottom: unset !important;\n\t\t}\n\t\t\n\t\t.leadpagereport .view-header .zc-new-report-header .zc-reportoptionheader,\n\t\t.leadpagereport .view-options{\n\t\t\tpadding: unset !important;\n\t\t}\n\t\t\n\t\t.line-design{\n\t\t\tposition: absolute;\n\t\t