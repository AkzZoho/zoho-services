			on_success as "on success"
			{
				type =  form
				form = Create_Event
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  rec in input.Student_Performance
										{
											cumulativeRec = Cumulative_Ranking[Educational_Year == input.Educational_Year && Student == rec.Student];
											if(cumulativeRec.count() != 0)
											{
												totalPoints = 0;
												for each  point in Student_Extracurricular_Activities[Event.Educational_Year == input.Educational_Year && Student == rec.Student && Points != ""]
												{
													totalPoints = totalPoints + point.Points.toNumber();
												}
												cumulativeRec.Extracurricular=totalPoints;
												cumulativeRec.Overall_Performance=cumulativeRec.Academic_Performance + cumulativeRec.Extracurricular + cumulativeRec.Attitude_Performance;
											}
											else
											{
												cumulativeRecord = insert into Cumulative_Ranking
												[
													Educational_Year=input.Educational_Year
													Overall_Performance=rec.Points.toNumber()
													Attitude_Performance=0
													Extracurricular=rec.Points.toNumber()
													Academic_Performance=0
													Student=rec.Student
													Added_User=zoho.loginuser
												];
											}
										}
										thisapp.updateRanking(input.Educational_Year);
										openUrl("#Script:page.refresh","same window");
						)
					}
				}

			}
			Update_Time_Table as "Update Time Table"
			{
				type =  form
