			assignLeadToMe as "assignLeadToMe"
			{
				type =  functions
				form = Lead
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						// Fetch agent based on login ID
										agent = Staff[Email_ID == zoho.loginuserid];
										// Assigning lead to agent
										input.Agent = agent.ID;
										// changing the status to lead assigned
										input.Status = "Lead Assigned";
										// history maintenance
										resp = insert into Lead_History
										[
											Added_User=zoho.loginuser
											Lead=input.ID
											Field_field="Status"
											Changes="Status changed from Lead Generated to Lead Assigned Lead assigned to " + agent.Name
										];
					)
					}
				}
			}
			convertLead as "convertLead"
			{
				type =  functions
				form = Lead
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						registrationsCount = Registration[Added_Time in this year].count();
										registrationsCount = registrationsCount + 1;
										RegistrationId = "Redgis-" + zoho.currentdate.getYear() + registrationsCount;
										previousSchoolCollection = Collection();
										studiedInAnotherSchool = false;
										// if(input.School_Type == "School")
										// {
										// 	row = Registration.Previous_School_Data();
										// 	previousSchoolCollection.insert(row);
										// 	studiedInAnotherSchool = true;
										// }
										if(input.Registration == null)
										{
											resp = insert into Registration
											[
												Added_User=zoho.loginuser
												Student_Name=input.Student_Name
												Father_s_Name=input.Father_Name
												Father_s_Phone=input.Phone_Number
												Gender=input.Gender
												Address=input.Address
												Lead=input.ID
												Registration_ID=RegistrationId
												Applying_for_Class=input.Applying_for_Class
											];
											input.Registration = resp;
											//
											// open Registration Page
											openUrl("#Form:Registration?recLinkID=" + resp + "&viewLinkName=All_Registrations1","popup window");
										}
										else
										{
											openUrl("#Form:Registration?recLinkID=" + input.Registration + "&viewLinkName=All_Registrations1","popup window");
										}
					)
					}
				}
			}
