ortant;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore thead th a {\n          color: white !important;\n        }\n\t\tdiv#All_Students_ZC_OZFMQ5\n\t\t{\n\t\t\t box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%) !important;\n\t\t}\n\t\t.reportfullwidth {\n           background: white !important;\n        }\n        .zc-reports-footer-sec {\n           background: white !important;\n\t\t  }\n\t\t\n\t\ta.zc-live-primary-btn.btn-big\n\t\t{\n\t\t\theight:45px !important;\n\t\t}\n\t\t\n\t\ttd.zcReport_Email.zc-mapping-field.htDimmed\n\t\t{\n\t\t\tvertical-align:middle !important;\n\t\t}\n\t\t\n\t\t.fa-plus:before{\n\t\t\tfont-weight: 900;\n\t\t\tcolor: white;\n\t\t\tpadding-right: 3px;\n\t\t}\n\t\t\n\t\ta.zc_transition.pull-right.zc-add-record.zc-tooltip-el {\n\t\t\tpadding: 0 10px;\n\t\t}\n\t\t\n\t\t.view-header .zc-add-record\n\t\t{\n\t\t\tborder-radius:3px;\n\t\t}\n\t\t\n\t\t.pagereport .handsontable tbody tr {\n\t\t\theight: 45px;\n\t\t}\n\t\t.main-container&gt;div {\n\t\t\theight: 100% !important;\n\t\t}\n\t\t.zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td:nth-child(2) .customCheckbox+label {\n              top: 50%;\n              transform: translateY(-50%);\n         }\n\t\t .handsontable tr&gt;td:first-child&gt;a\n\t\t {\n\t\t\ttop: 57%;\n\t\t\tposition: absolute;\n\t\t\ttransform: translateY(-50%);\n\t\t\tleft: 9px;\n\t\t }\n\t\t \n\t\ttd.zcReport_Number.zcAlginRight.zc-mapping-field.htDimmed,\n\t\ttd.zcReport_Date.zc-mapping-field.htDimmed,\n\t\ttd.zcReport_TextArea.zc-mapping-field.htDimmed,\n\t\ttd.zcReport_CustomAction.htDimmed{\n\t\t\tvertical-align:middle;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;All_School_Details&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
