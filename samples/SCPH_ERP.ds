		list All_Subject
		{
			displayName = "Subjects"
			show all rows from Subject_form  [Educational_Year.Status == "Current" || Educational_Year.Status == "Upcoming" && Subject_Name != "LUNCH"]  
			(
				Subject_Name as "Subject Name"
				Course_ID as "Subject UID"
				Status
				Educational_Year.Academic_Year as "Academic Year"
				Educational_Year as "Educational Year"
				Class
				Lesson_Plan_Mapping.Staff as "Lesson Plan Mapping"
			)
			conditional formatting
			(
				"active"
				{
				condition = (Status == "Course Active")
				fields = [Status]
				format = "color:#4ea64c;"
				}
				"Inactive"
				{
				condition = (Status == "Course In-Active")
				fields = [Status]
				format = "color:#7c7c7c;"
				}
				"Yet to submit"
				{
				condition = (Status == "Yet to Submit Lesson Plan")
				fields = [Status]
				format = "color:#f26a1c;"
				}
				"Submitted"
				{
				condition = (Status == "Lesson Plan Submitted")
				fields = [Status]
				format = "color:#398ef3;"
				}
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = '#FFFFFF'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '17px'\n	paddingLeft = '17px'\n	paddingRight = '0px'\n	paddingBottom = '17px'\n	bgColor = 'transparent'\n\n		width = '50%'\n		hAlign = 'center'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	color = '#000000'\n	size = '20px'\n	uppercase = 'false' \n	underline = 'false' \n	bold = 'true' \n	italic = 'false' \n	type = 'field'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n\n\n	  \n      	lineHeight = '27'\n      	  numOfLines = '1'\n	  value = 'Subject_Name'\n>\n</text>\n\n</pc>\n</pr>\n</pc><pc \n		padding = '17px'\n	bgColor = 'transparent'\n\n		width = '50%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	color = '#000000'\n	size = '20px'\n	uppercase = 'false' \n	underline = 'false' \n	bold = 'true' \n	italic = 'false' \n	type = 'field'\n	bgColor = 'rgba(0, 0, 0, 0)'\n\n\n\n	  \n      	lineHeight = '27'\n      	  numOfLines = '1'\n	  value = 'Educational_Year'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
