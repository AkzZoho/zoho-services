			onSubmission8 as "onSubmission"
			{
				type =  form
				form = Exam
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											// studentList = List();
										// // for each  class in input.Class
										// // {
										// // 	students = Student[Class == class].ID.getAll();
										// // 	studentList.addAll(students);
										// // }
										students = Student[Class_UID in input.Class].ID.getAll();
										input.Student = students;
										subjects = Collection();
										for each  stude in input.Student
										{
											totalMarks = 0;
											subjects.clear();
											for each  subjec in input.Exam_Schedule
											{
												teacher = Lesson_Plan_Mapping[Subject_field == subjec.Subject_form && Class == stude.Class_UID && Student == stude].Staff;
												if(teacher != null)
												{
													rec = Exam_Marks.Subject_Marks();
													rec.Staff=teacher;
													rec.Subject_form=subjec.Subject_form;
													rec.Total_Marks=subjec.Total_Marks;
													rec.Student=stude.ID;
													rec.Exam_Status="Yet to Submit Marks";
													subjects.insert(rec);
													totalMarks = totalMarks + subjec.Total_Marks;
												}
											}
											resp = insert into Exam_Marks
											[
												Added_User=zoho.loginuser
												Exam_Name=input.ID
												Student=stude
												Class1=stude.Class_UID
												Subject_Marks=subjects
												Status="Yet to Submit Marks"
												Class=stude.Class_UID.Class_Name
												Educational_Year=input.Educational_Year
												Total=totalMarks
											];
										}
										if(input.Annual_Exam == true)
										{
											classDb = Class_DB[ID == input.Class.Class];
											for each  classD in classDb
											{
												classD.Class_Promotion_Status="Initiated";
											}
										}
										for each  r in input.Exam_Schedule
										{
											if(r.Question_Paper != "" && r.Question_Paper != null)
											{
												r.Question_Paper_Status="Question Paper Uploaded";
											}
											totalExamDUrationMinutes = r.Exam_Duration.getHour() * 60 + r.Exam_Duration.getMinutes();
											r.Exam_Completed_Time=r.Exam_Start_Time.addMinutes(totalExamDUrationMinutes);
										}
						)
					}
				}

			}
