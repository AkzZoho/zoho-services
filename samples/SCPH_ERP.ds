y: none;\n\t}\n\t\n\tspan.tooltip:after {\n\t\tcontent: &quot;&quot;;\n\t\tborder-color: #111111c2 transparent transparent transparent;\n\t\tposition: absolute;\n\t\ttop: 100%;\n\t\tright: 30px;\n\t\tborder-width: 6px;\n\t\tborder-style: solid;\n\t}\n\t\n\t.my-books-list {\n\t\toverflow: auto;\n\t\theight: calc(100% - 20px);\n\t\tpadding: 0px 5px;\n\t\tbox-sizing: border-box;\n\t}\n\t.current-books-header{\n\t\tcolor:#000;\n\t\tfont-weight:500;\n\t\tfont-size: 14px;\n\t}\n\t.borrow-date&gt;span:nth-child(1),.return-date&gt;span:nth-child(1){\n    color: #7E7E7E;\n}\n.borrow-date&gt;span:nth-child(2),.return-date&gt;span:nth-child(2){\n\tcolor: var(--theme_brand_color);\n}\n\t.date-wrapper{\n\t\tdisplay:flex;\n\t\tgap:20px;\n\t\tfont-size:12px;\n\t\tpadding-top:5px;\n\t}\n\t.timeline-date-day-container {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 3px;\n}\nspan.timeline-day {\n    color: #8D8D8D;\n    font-size: 12px;\n}\n.sub-header {\n\/*     height: 46px; *\/\n\/*     padding: 0 15px; *\/\n    display: flex;\n    align-items: center;\n    background: #f7f7f7;\n    border-top-left-radius: 5px;\n    border-top-right-radius: 5px;\n}\n &lt;\/style&gt;\n\t&lt;div class=&quot;other-info-container&quot;&gt;\n\t  &lt;div class=&quot;other-info-container-row1&quot;&gt;\n\t     &lt;div class=&quot;statistics-div&quot;&gt;\n\t\t       &lt;div name=&quot;studentpage1&quot; elName=&apos;zc-component&apos;  class=&quot;studentmarksinfo&quot; viewLinkName=&quot;Subject_Marks_Student_Chart&quot;&gt;&lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t\t &lt;div class=&quot;info-div&quot;&gt;\n\t\t    &lt;input name=&quot;student-nav&quot; id=&quot;student-nav-1&quot; type=&quot;radio&quot; checked&gt;\n&lt;%\n\tif(myClass.Hosteller == false)\n\t{\n\t\t%&gt;\n&lt;input name=&quot;student-nav&quot; id=&quot;student-nav-2&quot; type=&quot;radio&quot;&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;input name=&quot;student-nav&quot; id=&quot;student-nav-3&quot; type=&quot;radio&quot;&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;input name=&quot;student-nav&quot; id=&quot;student-nav-4&quot; type=&quot;radio&quot;&gt;\n\t\t\t&lt;div class=&quot;student-nav-labels&quot;&gt;\n\t\t\t\t&lt;label for=&quot;student-nav-1&quot;&gt;Library Info&lt;\/label&gt;\n&lt;%\n\tif(myClass.Hosteller == false)\n\t{\n\t\t%&gt;\n&lt;label for=&quot;student-nav-2&quot;&gt;Transport Info&lt;\/label&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;label for=&quot;student-nav-3&quot;&gt;Hostel Info&lt;\/label&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;label for=&quot;student-nav-4&quot;&gt;Events Info&lt;\/label&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;student-nav-content&quot;&gt;\n\t\t\t\t&lt;div class=&quot;library-content&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;panels&quot;&gt;\n\t\t\t\t\t\t&lt;div class=&quot;panel&quot; &gt;\n\t\t\t\t\t\t  &lt;span class=&quot;panel-label&quot; &gt;Total Books Taken&lt;\/span&gt;\n\t\t\t\t\t\t  &lt;span class=&quot;panel-value&quot;&gt;&lt;%=bookList.count()%&gt;&lt;\/span&gt;\n\t\t\t\t\t  \t&lt;\/div&gt;\n\t\t\t\t\t  \t&lt;div class=&quot;panel&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;panel-label&quot; &gt;First Due Date&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;panel-value&quot;&gt;\n&lt;%\n\tif(firstDueDate != null)\n\t{\n\t\t%&gt;\n&lt;%=firstDueDate%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n-\n&lt;%\n\t}\n\t%&gt;\n&lt;\/span&gt;\n\t\t\t\t\t  \t&lt;\/div&gt;\n\t\t\t\t\t  \t&lt;div class=&quot;panel&quot;&gt;\n\t\t\t\t\t\t  \t&lt;span class=&quot;panel-label&quot;&gt;Due Amount&lt;\/span&gt;\n\t\t\t\t\t\t  \t&lt;span class=&quot;panel-value&quot;&gt;\u20B9 &lt;%=fineAmount%&gt;&lt;\/span&gt;\n\t\t\t\t\t \t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;available-books-list&quot;&gt;\n\t\t\t\t\t\t&lt;div class=&quot;current-books-header&quot;&gt;Current Books List&lt;\/div&gt;\n\t\t\t\t\t\t&lt;div class=&quot;my-books-list&quot;&gt;\n&lt;%\n\tif(bookList.count() &gt; 0)\n\t{\n\t\tfor each  book in bookList\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;book-info&quot;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&quot;book-name-container&quot;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=book.Book.Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=book.Book.ISBN%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&quot;date-wrapper&quot;&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&quot;borrow-date&quot;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;Borrow Date : &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=book.Added_Time.toDate()%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;div class=&quot;return-date&quot;&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;Return Date : &lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t\t&lt;span&gt;&lt;%=book.Expected_Return_Date%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-books&quot;&gt;\n\t\t\t\t\t\t\t\t\t\tNo books have been taken by you...\n\t\t\t\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;transport-content&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;bus-room-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Bus Name : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=busName%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;bus-block-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Stop Name : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=busStopName%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;bus-floor-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Route Name : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=routeName%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;bus-warden-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Registration No : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=busNo%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;hostel-content&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;room-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Room Number : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=MyRoomInfo.Room_Number%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;block-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Block : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=MyRoomInfo.block.Block_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;floor-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Floor : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=MyRoomInfo.Floor_Number%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;warden-info&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;Warden : &lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=MyRoomInfo.block.Warden.Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\t%&gt;\n&lt;a class=&quot;zc-live-primary-btn custom-button&quot; href=&quot;#Form:Room_Requests?zc_LoadIn=dialog&quot;&gt;Room Change Request&lt;\/a&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;a class=&quot;zc-live-primary-btn custom-button&quot; href=&quot;#Report:All_Hostel_Menus?Block1=&lt;%=MyRoomInfo.block.Block_Name%&gt;&amp;zc_LoadIn=dialog&quot;&gt;View Hostel Menu&lt;\/a&gt;\n\t\t\t\t\t&lt;div class=&quot;my-roommates&quot;&gt;\n\t\t\t\t\t\t&lt;span&gt;My Roommates&lt;\/span&gt;\n\t\t\t\t\t\t&lt;div class=&quot;roomies&quot;&gt;\n&lt;%\n\tif(myRoommates.size() &gt; 0)\n\t{\n\t\tfor each  mate in myRoommates\n\t\t{\n\t\t\tstudent = Student[ID == mate];\n\t\t\tif(student.ID != myClass)\n\t\t\t{\n\t\t\t\tprofile_image1 = student.Photo.replaceAll(&quot;\/sharedBy\/appLinkName\/viewLinkName\/fieldName\/image&quot;,&quot;\/file&quot; + zoho.appuri + &quot;All_Students\/&quot; + student.ID + &quot;\/Photo\/image-download?filepath=&quot;);\n\t\t\t\t%&gt;\n&lt;span class=&quot;roommates-image-div&quot;&gt;\n&lt;%=profile_image1%&gt;\n&lt;span class=&apos;tooltip&apos;&gt;&lt;%=student.Student_Name%&gt;&lt;\/span&gt;\n&lt;\/span&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-rooms&quot;&gt;No Roommates&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;event-content&quot;&gt;\n&lt;%\n\tif(myEvents.count() &gt; 0)\n\t{\n\t\tfor each  event in myEvents\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;event-wrapper&quot;&gt;\n\t\t\t\t&lt;div class=&quot;date&quot;&gt;\n\t\t\t\t\t&lt;span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;MMM&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;dd&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Start_Date1.toString(&quot;yyyy&quot;)%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;event-info&quot;&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=event.Event_Location%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot;&gt;No Events&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t  &lt;div class=&quot;other-info-container-row2&quot;&gt;\n\t    &lt;div class=&quot;exam-div&quot;&gt;\n\t\t     &lt;div  elName=&apos;zc-component&apos; viewLinkName=&apos;Exam_Marks2&apos; class=&quot;leadpagereport&quot; params=&apos;zc_ReportName=true&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=false&amp;zc_Search=false&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;upcoming-exams-div&quot;&gt;\n\t\t    &lt;div class=&quot;sub-header&quot;&gt;&lt;h4 class=&quot;common-header&quot;&gt;Upcoming Exams&lt;\/h4&gt;&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;content&quot;&gt;\n&lt;%\n\tallExams = Exam[Assessment_Start_Date &gt;= zoho.currentdate &amp;&amp; Class == myClass.Class_UID];\n\tif(allExams.count() &gt; 0)\n\t{\n\t\tfor each  exam in allExams\n\t\t{\n\t\t\tfor each  ex in exam.Exam_Schedule\n\t\t\t{\n\t\t\t\t%&gt;\n&lt;div class=&quot;timeline-outer&quot;&gt;\n\t\t\t\t\t\t\t&lt;div class=&quot;timeline-inner&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-value&quot;&gt;&lt;%=exam.Assessment_Name%&gt; - &lt;%=ex.Subject_form.Subject_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;div class = &quot;timeline-date-day-container&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-date&quot;&gt;&lt;%=ex.Exam_Start_Time.toDate()%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-day&quot;&gt;Monday&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t\t}\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot; style=&quot;box-shadow:unset;&quot;&gt;No Upcoming Exams&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t  &lt;\/div&gt;\n\t  &lt;div class=&quot;my-fee-info&quot;&gt;\n&lt;%\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;Fee_Payment_History&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;My_Fee&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Subject_Marks
		{
			displayname = "Student Subject Marks"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart 1\"\n\n\ttype = 'Column'\n\txtitle = 'Subject'\n\tytitle = 'Marks'\n\tbgColor = 'rgb(255, 255, 255)'\n\ttheme = 'theme2'\n\tlegendPos = 'center.top'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Subject_Marks'\n\txfield = 'Subject_form.Subject_Name'\n\tyfields = 'value:Marks_Secured'\n\t\tDelugeCriteria = 'Student.Email == zoho.loginuserid'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Configurations
		{
			displayname = "Primary Configurations"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet96' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet96()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\t&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n\n        }\n\t\t\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.inner-stateless-form) .form-table .form-header{\n         display: none !important;\n      }\n  .divEmbedContainer:is(.inner-stateless-form) .zc-form-scroll-wrapper{\n  margin:unset !important;\n  }\n  \n  .divEmbedContainer:is(.inner-stateless-form) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n\t\t\n.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n\t\t\t  \n\t  \tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t\/*form styles *\/\t\n\t\t.stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t \n\t.stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.stateless-form .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.stateless-form .customRadio:checked+label+choice-label-text\n\t{\n\t\tcolor:green;\n\t}\n\t\n\t.stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t}\n\t\t\n\t\t.stateless-form form.form-table .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t.stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.stateless-form form.form-table .choice-label-text {\n\t\t\tfont-size: 18px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 3px 15px;\n\t\t\t            box-sizing: border-box;\n\t\t\twidth: 100%;\n\t\t  \tdisplay: flex;\n\t\t\tjustify-content: left;\n    \t\tpadding-left: 20px;\n\t\t}\n\t\t\n\t.stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t\tflex-direction:column;\n\t\tdisplay:flex !important;\n\t\tgap: 15px;\n\t}\n\t\n\t.stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.stateless-form .choice-table-cell input~label {\n       position: relative;\n\t   z-index: 0;\n\t}\n\n\t.stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tbackground: var(--header-checked-line-color);\n\t\ttop: 0%;\n\t\twidth: calc(100% - 20px);\n\t\theight: 100%;\n\t\tposition: absolute;\n\t\tz-index: -1;\n\t\tborder-radius:3px;\n\t\tleft:10px;\n\t}\n\t\n\t.stateless-form .choice-table-cell input:checked~label{\n\t\tcolor:white !important;\t\n\t}\n\t\n\t.stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.stateless-form .zc-form-fullheight,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.stateless-form{\n\t\t width:250px;\n\t\t box-shadow: 0px 0px 5px #cdcdcd;\n    \t z-index: 1;\n\t }\n\t \n\t.stateless-form .zc-form-scroll-wrapper {\n\t\tpadding-top: 20px;\n\t\t            box-sizing: border-box;\n\t}\n\t\n\t.stateless-form .form-header{\n\t\tbackground:transparent !important;\t\n\t}\n\t\n\t\/* Hide - Form Loader Icon *\/\n\t.stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t \n\t .content-wrapper{\n\t\t height:100%;\n\t\t display:flex;\n\t }\n\t \t \n\t .configurations-content{\n\t\t width:calc(100% - 250px);\n\t\t background: var(--main-container-color);\n\t }\n\t a.zc-custom-btn.zc_transition {\n    border-radius: 5px !important;\n}\n\n    .form-header .form-title {\n    font-size: 18px;\n    color: #333;\n    font-weight: 400;\n    padding-left: 30px;\n    line-height: 34px;\n    font-weight: bold;\n    }\n\t.form-header {\n    border-bottom: 1px solid rgba(0,0,0,0.1);\n    padding: 10px 0 0 0;\n    background-color: #f7f7f7;\n    line-height: normal;\n    height: 40px;\n}\n\t&lt;\/style&gt;\n&lt;div class=&quot;content-wrapper&quot;&gt;\n\t&lt;div elName=&apos;zc-component&apos; class=&quot;stateless-form&quot; formLinkName=&apos;Configurations_Nav&apos; params=&apos;zc_Header=true&amp;zc_Footer=false&apos;&gt;&lt;\/div&gt;\n    &lt;div elName=&apos;zc-component&apos; viewLinkName=&apos;School_Details1&apos; name=&apos;configurations-div&apos; class=&quot;configurations-content&quot;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Admission_Info1
		{
			displayname = "Admission Info"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart\"\n\n\ttype = 'Funnel'\n\tbgColor = '#FFFFFF'\n\ttheme = '#5555d9'\n\tlegendPos = 'right.center'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Registration'\n\txfield = 'Status'\n\tyfields = 'count:Status'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Question_Paper(string cqpId)
		{
			displayname = "Question Paper"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet98' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet98()\ncontent\n&lt;%{\n\tques = Create_Question_Paper[ID == input.cqpId.toNumber()].Questions1;\n\tques = ques.toMap();\n\tschool = School_Details[ID != 0];\n\tcqp = Create_Question_Paper[ID == input.cqpId.toNumber()];\n\texam = Exam_Schedule[ID == cqp.Exam_Schedule];\n\texamName = Exam[ID == exam.Exam_Name];\n\tsubject = Subject_form[ID == exam.Subject_form];\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n&lt;head&gt;\n    &lt;meta charset=&quot;UTF-8&quot;&gt;\n    &lt;meta http-equiv=&quot;X-UA-Compatible&quot; content=&quot;IE=edge&quot;&gt;\n    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;\n    &lt;title&gt;Document&lt;\/title&gt;\n    &lt;style&gt;\n        body {\n    box-sizing: border-box;\n    padding: 0;\n    margin: 0;\n}\n.standard {\n    font-size: 16px;\n}\n\n.time {\n    font-size: 16px;\n}\n\n.max-marks {\n    font-size: 16px;\n}\n\n.school-name {\n    text-align: center;\n    padding: 10px;\n    font-size: 25px;\n    font-weight: 500;\n}\n.exam-name{\n    text-align: center;\n    font-size: 24px;\n    padding: 10px;\n    font-weight: 500;\n}\n.subject-name {\n    text-align: center;\n    font-weight: 900;\n    font-size: 30px;\n    padding: 0px 10px 10px 10px;\n}\n.other-information {\n    display: flex;\n    justify-content: space-around;\n}\n.main-container {\n    border: 2px solid black;\n    padding: 0px;\n    margin: 20px;\n}\n.questions-title-content {\n    padding: 15px 150px;\n    font-size: 20px;\n    display: flex;\n    justify-content: space-between;\n}\n.questions-content {\n    padding: 10px 200px;\n    font-size: 16px;\n    word-wrap: break-word;\n}\n\n    &lt;\/style&gt;\n&lt;\/head&gt;\n&lt;body&gt;\n    &lt;div class=&quot;main-container&quot;&gt;\n        &lt;div class=&quot;title-content&quot;&gt;\n            &lt;div class=&quot;school-name&quot;&gt;\n                &lt;%=school.School_Name%&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;exam-name&quot;&gt;\n                    &lt;%=examName.Assessment_Name%&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;subject-name&quot;&gt; &lt;%=subject.Subject_Name%&gt; &lt;\/div&gt;\n            &lt;div class=&quot;other-information&quot;&gt;\n                &lt;div class=&quot;standard&quot;&gt;Department: Aero &lt;\/div&gt;\n                &lt;div class=&quot;time&quot;&gt;Duration: 2hrs&lt;\/div&gt;\n                &lt;div class=&quot;max-marks&quot;&gt;Max-marks: 100&lt;\/div&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;questions&quot;&gt;&lt;\/div&gt;\n&lt;%\n\touterSerial = 1;\n\tfor each  heading in ques\n\t{\n\t\t%&gt;\n&lt;div class=&quot;questions-title-content&quot;&gt;\n\n&lt;div class=&quot;questions-title&quot;&gt; &lt;%=outerSerial%&gt;) Answer any of the following &lt;\/div&gt;\n                &lt;div class=&quot;questions-marks&quot;&gt; Marks-15&lt;\/div&gt;\n\n\n            &lt;\/div&gt;\n&lt;%\n\t\tindividualQuestions = heading.toList(&quot;,&quot;);\n\t\tinnerSerial = 1;\n\t\tfor each  individual in individualQuestions\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;questions-content&quot;&gt; &lt;%=innerSerial%&gt;)&lt;%=individual%&gt; &lt;\/div&gt;\n&lt;%\n\t\t\tinnerSerial = innerSerial + 1;\n\t\t}\n\t\touterSerial = outerSerial + 1;\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\n    &lt;\/div&gt;\n&lt;\/body&gt;\n&lt;\/html&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Question_Paper_v2(string cqpId)
		{
			displayname = "Question Paper v2"
			Content="<zml    \n\t\t\tisPdfEnabled='true'\n\t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet981' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet981()\ncontent\n&lt;%{\n\tques = Create_Question_Paper[ID == input.cqpId.toNumber()].Questions1;\n\tques = ques.toList();\n\tschool = School_Details[ID != 0];\n\tcqp = Create_Question_Paper[ID == input.cqpId.toNumber()];\n\texam = Exam_Schedule[ID == cqp.Exam_Schedule];\n\texamName = Exam[ID == exam.Exam_Name];\n\tsubject = Subject_form[ID == exam.Subject_form];\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n&lt;head&gt;\n    &lt;meta charset=&quot;UTF-8&quot;&gt;\n    &lt;meta http-equiv=&quot;X-UA-Compatible&quot; content=&quot;IE=edge&quot;&gt;\n    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;\n    &lt;title&gt;Document&lt;\/title&gt;\n    &lt;style&gt;\n        body {\n    box-sizing: border-box;\n    padding: 0;\n    margin: 0;\n}\n.standard {\n    font-size: 16px;\n}\n\n.time {\n    font-size: 16px;\n}\n\n.max-marks {\n    font-size: 16px;\n}\n\n.school-name {\n    text-align: center;\n    padding: 10px;\n    font-size: 25px;\n    font-weight: 600;\n}\n.exam-name{\n    text-align: center;\n    font-size: 24px;\n    padding: 10px;\n    font-weight: 500;\n}\n.subject-name {\n    text-align: center;\n    font-weight: 900;\n    font-size: 30px;\n    padding: 0px 10px 10px 10px;\n}\n.other-information {\n    display: flex;\n    justify-content: space-between;\n    padding: 0 21px;\n    margin-bottom: 10px;\n}\n.main-container {\n    border: 2px solid black;\n    padding: 0px;\n    margin: 20px;\n}\n.questions-title-content {\n    padding: 15px 20px;\n    font-size: 20px;\n    display: flex;\n    justify-content: space-between;\n}\n.questions-content {\n    padding: 10px 80px;\n    font-size: 16px;\n    word-wrap: break-word;\n}\n\n    &lt;\/style&gt;\n&lt;\/head&gt;\n&lt;body&gt;\n    &lt;div class=&quot;main-container&quot;&gt;\n        &lt;div class=&quot;title-content&quot;&gt;\n            &lt;div class=&quot;school-name&quot;&gt;\n                &lt;%=school.School_Name%&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;exam-name&quot;&gt;\n                    &lt;%=examName.Assessment_Name%&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;subject-name&quot;&gt; &lt;%=subject.Subject_Name%&gt; &lt;\/div&gt;\n            &lt;div class=&quot;other-information&quot;&gt;\n                &lt;div class=&quot;standard&quot;&gt;Department: Aero &lt;\/div&gt;\n                &lt;div class=&quot;time&quot;&gt;Duration: 2hrs&lt;\/div&gt;\n                &lt;div class=&quot;max-marks&quot;&gt;Max-marks: 100&lt;\/div&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;questions&quot;&gt;&lt;\/div&gt;\n&lt;%\n\touterSerial = 1;\n\tfor each  heading in ques\n\t{\n\t\t%&gt;\n&lt;div class=&quot;questions-title-content&quot;&gt;\n&lt;%\n\t\tif(heading.get(&quot;option&quot;) == 0)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;questions-title&quot;&gt; &lt;%=outerSerial%&gt;) Answer the following questions &lt;\/div&gt;\n&lt;div class=&quot;questions-marks&quot;&gt; &lt;%=heading.get(&quot;marks&quot;)%&gt; * &lt;%=heading.get(&quot;totalQuestions&quot;)%&gt; = &lt;%=heading.get(&quot;marks&quot;) * heading.get(&quot;totalQuestions&quot;)%&gt; &lt;\/div&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;questions-title&quot;&gt; &lt;%=outerSerial%&gt;) Answer any &lt;%=heading.get(&quot;totalQuestions&quot;) - heading.get(&quot;option&quot;)%&gt; from the following questions &lt;\/div&gt;\n&lt;div class=&quot;questions-marks&quot;&gt; &lt;%=heading.get(&quot;marks&quot;)%&gt; * &lt;%=heading.get(&quot;totalQuestions&quot;) - heading.get(&quot;option&quot;)%&gt; = &lt;%=heading.get(&quot;marks&quot;) * (heading.get(&quot;totalQuestions&quot;) - heading.get(&quot;option&quot;))%&gt; &lt;\/div&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\t\tindividualQuestions = heading.get(&quot;questions&quot;);\n\t\tinnerSerial = 1;\n\t\tfor each  individual in individualQuestions\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;questions-content&quot;&gt; &lt;%=innerSerial%&gt;)&lt;%=individual%&gt; &lt;\/div&gt;\n&lt;%\n\t\t\tinnerSerial = innerSerial + 1;\n\t\t}\n\t\touterSerial = outerSerial + 1;\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\n    &lt;\/div&gt;\n&lt;\/body&gt;\n&lt;\/html&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Dashboard_Parents(Child_Mail)
		{
			displayname = "Student Dashboard Parents"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet111' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet111()\ncontent\n&lt;%{\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t\tphoto = Student[Email == zoho.loginuserid];\n\t}\n\telse\n\t{\n\t\tphoto = Student[Email == input.Child_Mail];\n\t}\n\t\/\/ \topenUrl(&quot;#Page:Student_Home?zc_LoadIn=embed-studentpage&quot;,&quot;same window&quot;);\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n\t&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n\t\n\t&lt;style&gt;\n   * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n      }\n\t  \n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .student-container{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display: flex;\n\t\t  flex-direction:column;\n      }\n\t  .column1-container\n\t  {\n\t\t  height:100px;\n\t\t  width:100%;\n\t\t  background:#fff;\n\t\t  box-shadow: 0px 0px 5px rgb(0 0 0 \/ 15%);\n\t\t  display:flex;\n\t  }\n\t  \n\t  .id-div\n\t  {\n\t\t  font-size: 15px;\n          font-weight: 500;\n\t  }\n\t  \n\t  .information-div\n\t  {\n\t\t  \tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\twidth: calc(100% - 100px);\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tgap: 10px;\n\t  }\n\t  \n\t  .info-heading\n\t  {\n\t\t  color:#7F7F7F;\n\t\t  display: flex;\n          justify-content: left;\n\t\t  padding-left:13%;\n\t   \t  box-sizing: border-box;\n\t\t  font-size:17px;\n\t\t  font-weight:500;\n\t\t  padding-top:10%;\n\t  }\n\t  \n\t  .info-content\n\t  {\n\t\t  display: flex;\n          justify-content: left;\n\t   \t  box-sizing: border-box;\n\t\t  padding-left:23%;\n\t\t  font-size:15px;\n\t\t  font-weight:500;\n\t\t  padding-top:5%;\n\t  }\n\t  .column2-container\n\t  {\n\t\t  height: calc(100% - 100px);\n\t\t  width: 100%;\n\t\t  padding:10px;\n\t      box-sizing: border-box;\n\t\t  overflow:auto;\n\t  }\n\t  \/*form style *\/\n\t  .student_tab_search{\n\t\tpadding:0px 10px;  \n\t   box-sizing: border-box;\n\t  }\n\t  \n\t\t.student_tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.student_tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.student_tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.student_tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:16px !important;\n\t\t\t    \n\t\t}\n\t\t.student_tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.student_tab_search .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.student_tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.student_tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio\n\t   {\n\t\t display:flex !important;\n\t\t border-bottom: 2px solid var(--header-line-color);\n\t\t \n\t   }\n\t .student_tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t.student_tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.student_tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.student_tab_search form[name=&quot;student_stateless_tab&quot;].label-left {\n\t\t\twidth: 1392px;\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n           width: 100% !important;\n        }\n\t\t.student_tab_search .flLeft.tempContDiv.zc-Radio {\n\t\t\tdisplay: grid !important;\n\t\t\twidth: 100% !important;\n\t\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\t}\n\t.student_tab_search .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\t\/* padding: 0 60px 0; *\/\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t.student_tab_search .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.student_tab_search .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t.student_tab_search label.choice-label-text\t\n    {\n\t  width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\t.student_tab_search .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t.column2-container .student_tab_search.divEmbedContainer\n\t{\n\t\theight:45px !important;\n\t}\n\t\/* Hide - Form Loader Icon *\/\n\t\t.student_tab_search i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n\t\t\n\t\t.no-data-container{\n\t\t\tpadding: 10px 20px;\n\t\t\tbox-sizing: border-box;\n\t\t\theight: 100%;\n\t\t}\n\t.no-data {\n\t\theight: 100%;\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tborder-radius: 5px;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\tfont-size: 20px;\n\t\tcolor: red;\n\t\tfont-weight: 600;\n\t}\n\t\n\t[displaytype=&quot;plain&quot;] .elemContainment .zcpage-elemContainer .column-container .zpelement-wrapper.zcpage-elemContainer {\n\t\tborder-bottom: unset !important;\n\t\tborder-right: unset !important;\n\t}\n\t\n\t.studentpage.divEmbedContainer {\n\t\theight: calc(100% - 45px) !important;\n\t}\n\n\t.mail-content\n\t{\n\t\twidth: 250px;\n\t\twhite-space: nowrap;\n\t\toverflow: hidden;\n\t\ttext-overflow: ellipsis;\n\t\tdisplay: block;\n\t}\n\t\n\t.profile-pic\n\t  {\n\t\t  align-items: center;\n\t\t  display: flex;\n\t\t  width:100px;\n\t\t  justify-content: center;\n\t   }\n\t   \n\t   span.image-div {\n\t\t\tdisplay: flex;\n\t\t\tgap: 10px;\n\t\t\tflex-direction: column;\n\t\t\tpadding: 5px 0;\n\t\t}\n\n\t   img.profile-photo {\n\t\t\twidth: 70px;\n\t\t\theight: 70px;\n\t\t\tborder-radius: 50%;\n\t\t}\n\t \n\t .name-div\n\t {\n\t\t font-size:20px;\n\t\t font-weight:bold;\n\t }\n\t \n\t .information-div-row2-header\n\t   {\n\t\t   color:#7F7F7F;\n\t   }\n\t   \n\t   .information-div-row2 {\n\t\t\tdisplay: flex;\n\t\t\tgap: 60px;\n\t\t\tfont-size: 15px;\n\t\t}\n\t\t\n\t\t.row2-subdiv {\n\t\t\tdisplay: flex;\n\t\t\tgap: 5px;\n\t\t}\n&lt;%\n\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t{\n\t}\n\telse\n\t{\n\t\t%&gt;\n.student_tab_search .flLeft.tempContDiv.zc-Radio{\n\t\t\t\t\t grid-template-columns: 75% 0% 0% 25%;\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t.student_tab_search .choice-table-cell span label {\n\t\t\t\t\twidth: 100%;\n\t\t\t\t\theight: 100%;\n\t\t\t\t\tfont-size: 17px !important;\n\t\t\t\t\tdisplay: flex;\n\t\t\t\t\tjustify-content: center;\n\t\t\t\t\tcursor:pointer;\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t.student_tab_search .customRadio{\n\t\t\t\t\tdisplay:none;\t\n\t\t\t\t}\n&lt;%\n\t}\n\t%&gt;\n.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-table .form-header{\n         display: none !important;\n      }\n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .zc-form-scroll-wrapper{\n  margin:unset !important;\n  }\n  \n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n\t  .student_tab_search .choice-table-cell input:checked~label {\n    font-weight: 800;\n\tcolor: var(--theme_brand_color);\n}\n&lt;\/style&gt;\n&lt;%\n\tif(photo.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;student-container&quot;&gt;\n   &lt;div class=&quot;column1-container&quot;&gt;\n        &lt;div class=&quot;information-div&quot;&gt;\n\t       &lt;span class=&quot;name-div&quot;&gt;&lt;%=photo.Student_Name%&gt;&lt;\/span&gt;\n\t\t   &lt;div class=&quot;information-div-row2&quot;&gt;\n\t\t       &lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Roll Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Registration_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Email ID :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Email%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;row2-subdiv&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;information-div-row2-header&quot;&gt;Contact Number :&lt;\/span&gt;\n\t\t\t\t\t&lt;span&gt;&lt;%=photo.Primary_Contact_Number%&gt;&lt;\/span&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;profile-pic&quot;&gt;\n&lt;%\n\t\tprofile_image1 = photo.Photo.replaceAll(&quot;\/sharedBy\/appLinkName\/viewLinkName\/fieldName\/image&quot;,&quot;\/file&quot; + zoho.appuri + &quot;All_Students\/&quot; + photo.ID + &quot;\/Photo\/image-download?filepath=&quot;);\n\t\tprofile_image = profile_image1.replaceAll(&quot;&lt;img&quot;,&quot;&lt;img class=&apos;profile-photo&apos;&quot;);\n\t\t%&gt;\n&lt;span class=&quot;image-div&quot;&gt;\n&lt;%=profile_image%&gt;\n&lt;\/span&gt;  \n\t\t&lt;\/div&gt;\n   &lt;\/div&gt;\n    &lt;div class=&quot;column2-container&quot;&gt;\n\t   &lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot;\n&lt;%\n\t\tif(input.Child_Mail == null || input.Child_Mail == &quot;&quot; || input.Child_Mail == &quot;null&quot;)\n\t\t{\n\t\t\t%&gt;\nformLinkName=&apos;student_stateless_tab&apos;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\nformLinkName=&apos;student_stateless_tab?Email=&lt;%=encodeUrl(photo.Email)%&gt;&apos;\n&lt;%\n\t\t}\n\t\t%&gt;\nparams=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t   &lt;div name=&quot;studentpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Home&apos; params=&quot;Child_Mail=&lt;%=encodeUrl(photo.Email)%&gt;&quot; class=&quot;studentpage&quot;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data-container&quot;&gt;\n\t\t&lt;div class=&quot;no-data&quot;&gt;You do not have access to view the Student Dashboard&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Subject_Marks_Student_Chart
		{
			displayname = "Subject Marks Student Chart"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart\"\n\n\ttype = 'Line'\n\txtitle = 'Exam'\n\tytitle = 'Total Marks'\n\tbgColor = 'rgb(255, 255, 255)'\n\ttheme = 'theme2'\n\tlegendPos = 'center.top'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Subject_Marks'\n\txfield = 'Exam_Marks.Exam_Name'\n\tyfields = 'sum:Marks_Secured'\n\t\tDelugeCriteria = 'Student.Email == zoho.loginuserid || Student.Father_s_Email == zoho.loginuserid &amp;&amp; Exam_Status != &quot;Yet to Submit Marks&quot;'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Report_Card(int studentID)
		{
			displayname = "Student Report Card"
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet99' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet99()\ncontent\n&lt;%{\n\tstudentRec = Student[ID == input.studentID];\n\teducationalYear = Educational_Year[Status == &quot;Current&quot;];\n\torgInfo = School_Details[ID != 0];\n\timagefile = orgInfo.Logo.getSuffix(&quot;fieldName\/image\/&quot;).getPrefix(&quot;\\&quot; lowqual&quot;);\n\tif(thisapp.portal.isUserInProfile(&quot;Admin&quot;) == true || thisapp.portal.isUserInProfile(&quot;Student&quot;) == true)\n\t{\n\t\tappurl = thisapp.getPortalUrl();\n\t}\n\telse\n\t{\n\t\tappurl = &quot;https:\/\/creatorapp.zoho.in&quot;;\n\t}\n\timageUrl = appurl + &quot;\/file&quot; + zoho.appuri + &quot;All_School_Details\/&quot; + orgInfo.ID + &quot;\/Logo\/image-download?filepath=\/&quot; + imagefile;\n\tmy_class = studentRec.Class_UID;\n\ttotalDays = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID].count();\n\ttotalBothDaysPresent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalMorningPresent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalAfternoonPresent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalDaysPresent = totalBothDaysPresent + (totalMorningPresent + totalAfternoonPresent) \/ 2;\n\ttotalBothDaysAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalMorningAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == true &amp;&amp; Is_Present_in_Afternoon == false].count();\n\ttotalAfternoonAbsent = Class_Attendance[Class == my_class &amp;&amp; Student == studentRec.ID &amp;&amp; Is_Present_in_Morning == false &amp;&amp; Is_Present_in_Afternoon == true].count();\n\ttotalDaysAbsent = totalBothDaysAbsent + (totalMorningAbsent + totalAfternoonAbsent) \/ 2;\n\tremarkRec = Student_Remarks[Student == studentRec.ID &amp;&amp; Educational_Year == educationalYear.ID];\n\t%&gt;\n&lt;style&gt;\n    * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none; \n      }\n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .report-card-container{\n          width: 100%;\n          position: relative;\n\t\t  background:#fff;\n\t\t  padding:20px 30px;\n      }\n\t  .report-card-header{\n\t\t  display: flex;\n\t\t\talign-items: center;\n\t\t\theight: 60px;\n\t\t\tjustify-content: center;\n\t\t\twidth: 100%;\n\/* \t\t\tgap: 50px; *\/\n\t\t\tposition:relative;\n\t\t\t\n\t\t  \n\t  }\n   .org-logo{\n\t\theight:50px;\n\/* \t\tborder-radius:20px; *\/\n\t\tobject-fit: contain;\n\t\tposition:absolute;\n\t\tleft:0;\n\t}\n\t.school-name {\n\t\tfont-size: 20px;\n\t\tfont-weight: 600;\n\t}\n\t.student-detail-header{\n\t\tfont-size: 16px;\n\t\tfont-weight: 500;\n\t}\n\t.detail-div-container{\n\t\tmargin-top:30px;\t\n\t}\n\t.detail-div-header{\n\t\tmargin-bottom:15px;\n\t}\n\ttable.student-information-table,table.activity-table,.attitude-table,.attendance-table,.academic-table {\n         border-collapse: collapse;\n    }\n\ttable.student-information-table td,table.activity-table td,table.activity-table th,.attendance-table td,table.attendance-table th,.attitude-table td,table.attitude-table th,.academic-table th,.academic-table td{\n\t\tpadding:5px;\n\t}\n\ttable.activity-table td,table.activity-table th,.attendance-table td,table.attendance-table th,.attitude-table td,table.attitude-table th,.academic-table th,.academic-table td{\n\t\tborder:1px solid #cdcdcd;\n\t}\n\t.attendance-table td,.academic-table th,.academic-table td,.activity-table td\n\t{\n\t\tpadding-right: 50px !important;\n\t}\n\ttable.student-information-table tr td:first-child, table.student-information-table tr td:nth-child(3){\n        width: 150px;\n\t\tfont-weight:600;\n    }\n\n\ttable.activity-table th,.attendance-table th,.attitude-table th,.academic-table th {\n    text-align: start;\n    }\n\/* \ttable.activity-table tr td:nth-child(2),table.activity-table tr th:nth-child(2){\n\t\twidth:100px;\n\t}\n\ttable.activity-table tr td:nth-child(1),table.activity-table tr th:nth-child(1){\n\t\twidth:250px;\n\t}\n\ttable.activity-table tr td:nth-child(3),table.activity-table tr th:nth-child(3){\n\t\twidth:400px;\n\t} *\/\n\t.no-data-div{\n\t\tpadding-left: 20px;\n    color: #797676;\n    font-size: 14px;\n   }\n&lt;\/style&gt;\n&lt;div class=&quot;report-card-container&quot;&gt;\n  &lt;div class=&quot;report-card-header&quot;&gt;\n     &lt;img class=&quot;org-logo&quot; src=&quot;&lt;%=imageUrl%&gt;&quot; class=&quot;org-logo&quot; \/&gt;\n\t &lt;p class=&apos;school-name&apos;&gt;&lt;%=orgInfo.School_Name%&gt; - STUDENT PROGRESS REPORT&lt;\/p&gt;\n  &lt;\/div&gt;\n  &lt;div class=&quot;student-detail detail-div-container&quot;&gt;\n      &lt;p class=&quot;detail-div-header&quot;&gt;STUDENT INFORMATION&lt;\/p&gt;\n\t  &lt;table class=&quot;student-information-table&quot;&gt;\n\t     &lt;tr&gt;\n\t\t   &lt;td&gt;Name&lt;\/td&gt;\n\t\t   &lt;td style=&apos;font-weight:600;padding-right: 100px;&apos;&gt;&lt;%=studentRec.Student_Name%&gt;&lt;\/td&gt;\n\t\t   &lt;td&gt;Academic Year&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=educationalYear.Academic_Year%&gt;&lt;\/td&gt;\n\t\t &lt;\/tr&gt;\n\t\t &lt;tr&gt;\n\t\t   &lt;td&gt;Roll No.&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=studentRec.Registration_Number%&gt;&lt;\/td&gt;\n\t\t   &lt;td&gt;Gender&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=studentRec.Gender%&gt;&lt;\/td&gt;\n\t\t &lt;\/tr&gt;\n\t\t &lt;tr&gt;\n\t\t   &lt;td&gt;Class&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=studentRec.Class_UID.Class_Name%&gt;&lt;\/td&gt;\n\t\t   &lt;td&gt;Parent\/Guardian&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=studentRec.Father_s_Name%&gt;&lt;\/td&gt;\n\t\t &lt;\/tr&gt;\n\t\t &lt;tr&gt;\n\t\t   &lt;td&gt;Category&lt;\/td&gt;\n\t\t   &lt;td&gt;&lt;%=studentRec.Student_Category%&gt;&lt;\/td&gt;\n\t\t &lt;\/tr&gt;\n\t  &lt;\/table&gt;\n  &lt;\/div&gt;\n  &lt;div class=&quot;academic-detail detail-div-container&quot;&gt;\n    &lt;p class=&quot;detail-div-header&quot;&gt;ACADEMICS&lt;\/p&gt;\n&lt;%\n\texamDet = Exam_Marks[Student == studentRec.ID &amp;&amp; Educational_Year == educationalYear.ID];\n\tif(examDet.count() != 0)\n\t{\n\t\t%&gt;\n&lt;table class=&quot;academic-table&quot;&gt;\n\t &lt;thead&gt;\n\t   &lt;th&gt;Subject&lt;\/th&gt;\n&lt;%\n\t\texamList = List();\n\t\tfor each  exam in Exam_Marks[Student == studentRec.ID &amp;&amp; Educational_Year == educationalYear.ID] sort by Added_Time desc\n\t\t{\n\t\t\texamList.add(exam);\n\t\t\t%&gt;\n&lt;th&gt;&lt;%=exam.Exam_Name.Assessment_Name%&gt;&lt;\/th&gt;\n&lt;%\n\t\t}\n\t\tgetSubjects = Subject_Marks[Exam_Marks in examList &amp;&amp; Student == studentRec.ID &amp;&amp; Exam_Status != &quot;Yet to Submit Marks&quot;].distinct(Subject_form);\n\t\t%&gt;\n&lt;th&gt;Comments&lt;\/th&gt;\n&lt;\/thead&gt;\n  &lt;tbody&gt;\n&lt;%\n\t\tfor each  subject in getSubjects\n\t\t{\n\t\t\tsubjectName = Subject_form[ID == subject].Subject_Name;\n\t\t\t%&gt;\n&lt;tr&gt;\n\t   &lt;td&gt;&lt;%=subjectName%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\tfor each  exam1 in examList\n\t\t\t{\n\t\t\t\tgetMark = Subject_Marks[Exam_Marks == exam1 &amp;&amp; Student == studentRec.ID &amp;&amp; Subject_form == subject];\n\t\t\t\t%&gt;\n&lt;td&gt;&lt;%=getMark.Marks_Secured%&gt;&lt;\/td&gt;\n&lt;%\n\t\t\t}\n\t\t\t%&gt;\n&lt;td&gt;&lt;%=getMark.Feedback%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;tr&gt;\n\t &lt;td style=&apos;font-weight:600&apos;&gt;Total&lt;\/td&gt;\n&lt;%\n\t\tfor each  exam in Exam_Marks[Student == studentRec.ID &amp;&amp; Educational_Year == educationalYear.ID] sort by Added_Time desc\n\t\t{\n\t\t\t%&gt;\n&lt;td style=&apos;font-weight:600&apos; colspan=&quot;2&quot;&gt;&lt;%=exam.Total_Marks_Scored%&gt;&lt;\/th&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n  &lt;\/tbody&gt;\n\t&lt;\/table&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;p class=&quot;no-data-div&quot;&gt;No Academics Data&lt;\/p&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n  &lt;div class=&quot;activities-detail detail-div-container&quot;&gt;\n    &lt;p class=&quot;detail-div-header&quot;&gt;EXTRACURRICULAR ACTIVITIES&lt;\/p&gt;\n&lt;%\n\tactivityDet = Student_Extracurricular_Activities[Event.Educational_Year == educationalYear.ID &amp;&amp; Student == studentRec.ID];\n\tif(activityDet.count() != 0)\n\t{\n\t\t%&gt;\n&lt;table class=&quot;activity-table&quot;&gt;\n\t &lt;thead&gt;\n\t  &lt;tr&gt;\n\t   &lt;th&gt;Activity&lt;\/th&gt;\n\t   &lt;th&gt;Scale(1-10)&lt;\/th&gt;\n\t   &lt;th&gt;Comments&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t &lt;\/thead&gt;\n\t  &lt;tbody&gt;\n&lt;%\n\t\tfor each  activity in activityDet\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;\n\t   &lt;td&gt;&lt;%=activity.Event.Event_Name%&gt;&lt;\/td&gt;\n\t   &lt;td&gt;&lt;%=activity.Points%&gt;&lt;\/td&gt;\n\t   &lt;td&gt;&lt;%=activity.Comments%&gt;&lt;\/td&gt;\n\t  &lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tbody&gt;\n\t&lt;\/table&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;p class=&quot;no-data-div&quot;&gt;No Extra Curricular Activity Data&lt;\/p&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\tif(remarkRec.count() != 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;attitude-detail detail-div-container&quot;&gt;\n   &lt;p class=&quot;detail-div-header&quot;&gt;ATTITUDE&lt;\/p&gt;\n   &lt;table class=&quot;activity-table&quot;&gt;\n    &lt;thead&gt;\n     &lt;tr&gt;\n\t   &lt;th&gt;Aspect&lt;\/th&gt;\n\t   &lt;th&gt;Scale(1-10)&lt;\/th&gt;\n\t   &lt;th&gt;Comments&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;\/thead&gt;\n\t  &lt;tbody&gt;\n&lt;%\n\t\tremarkDetail = Student_Remark_Details[Student_Remarks == remarkRec.ID];\n\t\tfor each  aspect in remarkDetail\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;\n\t\t&lt;td&gt;&lt;%=aspect.Aspect%&gt;&lt;\/td&gt;\n\t\t&lt;td&gt;&lt;%=aspect.Scale%&gt;&lt;\/td&gt;\n\t\t&lt;td &gt;&lt;%=aspect.Comments%&gt;&lt;\/td&gt; \n\t\t&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tbody&gt;\n   &lt;\/table&gt;\n  &lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;div class=&quot;attendance-detail detail-div-container&quot;&gt;\n   &lt;p class=&quot;detail-div-header&quot;&gt;ATTENDANCE&lt;\/p&gt;\n   &lt;table class=&quot;attendance-table&quot; &gt;\n    &lt;thead&gt;\n     &lt;tr&gt;\n\t   &lt;th&gt;Record&lt;\/th&gt;\n\t   &lt;th&gt;Days&lt;\/th&gt;\n\t   &lt;th&gt;Comments&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;\/thead&gt;\n\t  &lt;tbody&gt;\n\t    &lt;tr&gt;\n\t\t&lt;td&gt;Total Days&lt;\/td&gt;\n\t\t&lt;td&gt;&lt;%=totalDays%&gt;&lt;\/td&gt;\n\t\t&lt;td rowspan=&quot;3&quot;&gt;\n&lt;%\n\tif(remarkRec.count() != 0 &amp;&amp; remarkRec.Attendance_Comments != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;%=remarkRec.Attendance_Comments%&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n-\n&lt;%\n\t}\n\t%&gt;\n&lt;\/td&gt; \n\t\t&lt;\/tr&gt;\n\t\t &lt;tr&gt;\n\t\t&lt;td&gt;Days Present&lt;\/td&gt;\n\t\t&lt;td&gt;&lt;%=totalDaysPresent%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n\t\t &lt;tr&gt;\n\t\t&lt;td&gt;Days Absent&lt;\/td&gt;\n\t\t&lt;td&gt;&lt;%=totalDaysAbsent%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n\t  &lt;\/tbody&gt;\n   &lt;\/table&gt;\n  &lt;\/div&gt;\n&lt;%\n\tif(remarkRec.count() != 0 &amp;&amp; remarkRec.Overall_Comments != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;overall-comment detail-div-container&quot;&gt;\n   &lt;p class=&quot;detail-div-header&quot;&gt;OVERALL COMMENTS&lt;\/p&gt;\n   &lt;p&gt;&lt;%=remarkRec.Overall_Comments%&gt;&lt;\/p&gt;\n&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Gate_Pass_Slip(int gatePassRec)
		{
			displayname = "Gate Pass Slip"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet100' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet100()\ncontent\n&lt;%{\n\torgInfo = School_Details[ID != 0];\n\tgetKey = thisapp.getPublishKey();\n\timagefile = orgInfo.Logo.getSuffix(&quot;fieldName\/image\/&quot;).getPrefix(&quot;\\&quot; lowqual&quot;);\n\tisPortalUser = false;\n\tif(thisapp.portal.isUserInProfile(&quot;Admin&quot;) == true || thisapp.portal.isUserInProfile(&quot;Student&quot;) == true)\n\t{\n\t\tappurl = thisapp.getPortalUrl();\n\t\tisPortalUser = true;\n\t}\n\telse\n\t{\n\t\tappurl = &quot;https:\/\/creatorapp.zohopublic.in&quot;;\n\t}\n\timageUrl = appurl + &quot;\/file&quot; + zoho.appuri + &quot;All_School_Details\/&quot; + orgInfo.ID + &quot;\/Logo\/image-download\/&quot; + getKey + &quot;?filepath=\/&quot; + imagefile;\n\tgatePassRecord = Gate_Pass_Request[ID == input.gatePassRec];\n\t%&gt;\n&lt;style&gt;\n    * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none; \n      }\n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .gatepass-card-container{\n\/*           height: 100%; *\/\n          width: 100%;\n          position: relative;\n\t\t  background:#fff;\n\t\t  padding:20px 30px;\n      }\n\t  .gatepass-card-header{\n\t\t  display: flex;\n\t\t\talign-items: center;\n\t\t\theight: 60px;\n\t\t\tjustify-content: center;\n\t\t\twidth: 100%;\n\t\t\tgap: 20px;\n\t\t\tposition:relative;\n\t\t\t\n\t\t  \n\t  }\n   .org-logo{\n\t\theight:25px;\n\/* \t\tborder-radius:20px; *\/\n\t\tobject-fit: contain;\n\/* \t\tposition:absolute;\n\t\tleft:0; *\/\n\t}\n\t.school-name {\n\t\tfont-size: 20px;\n\t\tfont-weight: 600;\n\t}\n\t.gatepass-detail-div {\n    display: flex;\n    width: 100%;\n    justify-content: center;\n    gap: 50px;\n\tmargin-top: 20px;\n   }\n   table.gatepass-table td {\n    padding: 5px;\n   }\n   p.purpose-detail {\n    text-align: center;\n    margin-top: 25px;\n   }\n&lt;\/style&gt;\n&lt;div class=&quot;gatepass-card-container&quot;&gt;\n  &lt;div class=&quot;gatepass-card-header&quot;&gt;\n\n&lt;img class=&quot;org-logo&quot; src=&quot;&lt;%=imageUrl%&gt;&quot; class=&quot;org-logo&quot; \/&gt;\n\n&lt;p class=&apos;school-name&apos;&gt;&lt;%=orgInfo.School_Name%&gt; - STUDENT GATE PASS&lt;\/p&gt;\n  &lt;\/div&gt;\n  &lt;div class=&quot;gatepass-detail-div&quot;&gt;\n     &lt;div class=&quot;column1-div&quot;&gt;\n\t     &lt;table class=&quot;gatepass-table&quot;&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Student Name&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Student.Student_Name%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Warden&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Student.Warden.Name%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Person Name&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Person_Name%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Mobile Number&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Mobile_Number%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t &lt;\/table&gt; \n\t &lt;\/div&gt;\n\t  &lt;div class=&quot;column2-div&quot;&gt;\n\t     &lt;table class=&quot;gatepass-table&quot;&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Roll No.&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Student.Registration_Number%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Class&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Student.Class_UID.Class_Name%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Relationship&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Relationship%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t  &lt;tr&gt;&lt;td&gt;Time of Pickup&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=gatePassRecord.Out_Time%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t &lt;\/table&gt; \n\t &lt;\/div&gt;\n  &lt;\/div&gt;\n  &lt;p class=&quot;purpose-detail&quot;&gt;Purpose of Pickup : &lt;%=gatePassRecord.Reason%&gt;&lt;\/p&gt;\n  \n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Offer_Letter(int offerID)
		{
			displayname = "Offer Letter"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet101' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet101()\ncontent\n&lt;%{\n\tofferRec = Candidate[ID == input.offerID];\n\torgInfo = School_Details[ID != 0];\n\timagefile = orgInfo.Logo.getSuffix(&quot;fieldName\/image\/&quot;).getPrefix(&quot;\\&quot; lowqual&quot;);\n\tif(thisapp.portal.isUserInProfile(&quot;Admin&quot;) == true || thisapp.portal.isUserInProfile(&quot;Student&quot;) == true)\n\t{\n\t\tappurl = thisapp.getPortalUrl();\n\t}\n\telse\n\t{\n\t\tappurl = &quot;https:\/\/creatorapp.zoho.in&quot;;\n\t}\n\timageUrl = appurl + &quot;\/file&quot; + zoho.appuri + &quot;All_School_Details\/&quot; + orgInfo.ID + &quot;\/Logo\/image-download?filepath=\/&quot; + imagefile;\n\t%&gt;\n&lt;style&gt;\n    * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none; \n      }\n\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t  .offer-card-container{\n\/*           width: 100%; *\/\n          position: relative;\n\t\t  background:#fff;\n\t\t  padding:20px 30px;\n      }\n\t   .offer-card-header{\n\t\t  display: flex;\n\t\t\talign-items: center;\n\t\t\theight: 40px;\n\t\t\tjustify-content: center;\n\t\t\twidth: 100%;\n\t\t\tgap: 30px;\n\t\t\tposition:relative;\t\n\t\t  \n\t  }\n   .org-logo{\n\t\theight:25px;\n\/* \t\tborder-radius:20px; *\/\n\t\tobject-fit: contain;\n\/* \t\tposition:absolute;\n\t\tleft:0; *\/\n\t}\n\t.school-name {\n\t\tfont-size: 20px;\n\t\tfont-weight: 600;\n\t}\n\t.personal-detail-header{\n\t\tfont-size: 15px;\n\t\tfont-weight: 600;\n\t\ttext-align:center;\n\t}\n\t.terms-condition-div {\n\t\t\tpadding-left: 30px;\n\t\t}\n\t.terms-condition-div p {\n\t\tmargin-top: 15px !important;\n\t}\n\t.offer-content p{\n\t\tmargin-top:17px;\n\t}\n\t.personal-detail-div,.personal-detail-div p{\n\t\tmargin-top:20px;\n\t}\n\ttable.personal-detail-table td {\n    padding: 5px;\n    padding-right: 25px;\n    }\n\ttable.personal-detail-table{\n\t\tmargin-top:20px;\n\t}\n&lt;\/style&gt;\n\n&lt;div class=&quot;offer-card-container&quot;&gt;\n   &lt;div class=&quot;offer-card-header&quot;&gt;\n     &lt;img class=&quot;org-logo&quot; src=&quot;&lt;%=imageUrl%&gt;&quot; class=&quot;org-logo&quot; \/&gt;\n\t &lt;p class=&apos;school-name&apos;&gt;&lt;%=orgInfo.School_Name%&gt;&lt;\/p&gt;\n  &lt;\/div&gt;\n  &lt;div class=&quot;offer-content&quot;&gt;\n      &lt;p&gt;To&lt;\/p&gt;\n\t  &lt;span style=&apos;font-weight:600;margin-top:10px;&apos;&gt;&lt;%=offerRec.Name%&gt;&lt;\/span&gt;\n\t  &lt;p&gt;Ref. \/ MGRS \/ Appointment \/ &lt;%=zoho.currentdate.toString(&quot;MMMM YYYY&quot;)%&gt; &lt;\/p&gt;\n\t  &lt;p style=&apos;font-weight:600;&apos;&gt;Subject: Offer of Appointment to the post of &lt;%=offerRec.Designation.Designation%&gt;&lt;\/p&gt; \n\t  &lt;p&gt;With reference to your application and subsequent interview, you are hereby informed that you have \nbeen selected for the post of &lt;%=offerRec.Designation.Designation%&gt; in our school on the following terms and conditions. &lt;p&gt;\n      &lt;div class=&quot;terms-condition-div&quot;&gt;\n\t     &lt;p&gt;1)You shall be paid a consolidated pay of Rs  &lt;span style=&apos;font-weight:600;&apos;&gt;&lt;%=offerRec.Consolidated_Pay%&gt;&lt;\/span&gt;  Inclusive of E.P. \nF &amp; E.S.I &amp; Other taxes. &lt;\/p&gt;\n\t\t&lt;p&gt;2)You shall be on probation for the period of one academic year from the date of your \n\t\tappointment to the last working day of the Summer Vacation. &lt;\/p&gt;\n\t\t&lt;p&gt;3)During the entire tenure of your employment, your services may be terminated with three \n\t\tmonths notice on either side or payment of three months\u2019 salary in lieu of notice without \n\t\tassigning any reasons. Vacation period will not be considered for notice period. However, on \n\t\tdisciplinary grounds, the management reserves the right to terminate your services without \n\t\tany notice or pay in lieu. &lt;\/p&gt;\n\t\t&lt;p&gt;4)After the confirmation of your services, the conditions indicated in the above point (Point 3) \n\t\tabout notice and termination from services remains the same. &lt;\/p&gt;\n\t\t&lt;p&gt;5)Your leave entitlement will be as follows: \n\t\ta.School vacations as per state Govt. G.O or School Calendar \n\t\tb.Ten days casual leave in an academic year. &lt;\/p&gt;\n\t\t&lt;p&gt;6)You will be permitted one day casual leave for each month of academic year. No \n\t\taccumulation of casual leave is allowed or to be carried to the next year. Obtain prior \n\t\tsanction of leave in written before availing it. &lt;\/p&gt;\n\t\t&lt;p&gt;7)You shall be committed to serve the institution for the complete academic session. &lt;\/p&gt;\n\t\t&lt;p&gt;8)You will be permitted to give your acceptance to the undersigned on or before &lt;span style=&apos;font-weight:600;&apos;&gt;&lt;%=offerRec.Last_Date_of_Offer_Letter_Acceptance%&gt;&lt;\/span&gt;. \n\t\tYou should report on duty on &lt;span style=&apos;font-weight:600;&apos;&gt;&lt;%=offerRec.Joining_Date%&gt;&lt;\/span&gt;. In case acceptance is not received by the given \n\t\tdate, it will be presumed that you are not interested and this offer will be treated as \n\t\tcancelled. &lt;\/p&gt;\n\t\t&lt;p&gt;9)We welcome you to &lt;%=orgInfo.School_Name%&gt; Family and hope that our association will be \n\t\tmutually beneficial. &lt;\/p&gt;\n\t  &lt;\/div&gt;\n\t  &lt;p&gt;We wish you good luck. &lt;\/p&gt;\n\t  &lt;p&gt;Date : &lt;%=zoho.currentdate%&gt; &lt;\/p&gt;\n  &lt;\/div&gt;\n  &lt;div class=&quot;personal-detail-div&quot;&gt;\n     &lt;div class=&quot;personal-detail-header&quot;&gt;Appendix&lt;\/div&gt;\n\t &lt;p&gt;These are the personal details we have received from you as needed for processing your profile.&lt;\/p&gt;\n\t &lt;table class=&quot;personal-detail-table&quot;&gt;\n\t   &lt;tr&gt;&lt;td&gt;Date of Birth&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.Date_of_Birth%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;Aadhar No&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.Aadhar_No%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;PAN No&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.PAN_No%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;Account No&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.Account_No%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;Bank Name&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.Bank_Name%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;Branch&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.Branch%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t   &lt;tr&gt;&lt;td&gt;IFSC Code&lt;\/td&gt;&lt;td&gt;:&lt;\/td&gt;&lt;td&gt;&lt;%=offerRec.IFSC_Code%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t &lt;\/table&gt;\n  &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page All_Branches1
		{
			displayname = "All Branches"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet791' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet791()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\t * {\n            padding: 0;\n            margin: 0;\n            border: none;\n        }\n\t\t\n        .main-container{\n          height: 100%;\n          width: 100%;\n          padding: 10px 20px;\n\t\t  box-sizing:border-box;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n      }\n\t  \n\t  .main-container&gt;.pagereport{\n\t\t  height:100% !important;\n\t\t  box-shadow: 0px 0px 5px #cdcdcd;\n\t\t  border-radius:5px;\n\t\t  overflow:hidden;\n\t  }\n\t  div#zppagesLive,\n\t  div#elementsContainer,\n\t  .Layout.elemContainment,\n\t  div#row_1,\n\t  .zc-pb-formreport-placeholder{\n\t\t  height: 100% !important;\n\t\t}\n&lt;\/style&gt;\n&lt;div class=&quot;main-container&quot;&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;pagereport&quot; viewLinkName=&apos;All_Branches&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Print_Admission_Form(int SID)
		{
			displayname = "Print Admission Form"
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet102' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet102()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n        .zcs_body {\n            margin: 20px;\n        }\n        .zcs_container {\n            background-color: #fff;\n            padding: 20px;\n            border: 1px solid;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n        .zcs_header {\n            text-align: center;\n            margin-bottom: 20px;\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: space-around;\n        }\n        .zcs_header h1 {\n            font-size: 24px;\n            margin: 0;\n        }\n        .zcs_header p {\n            font-size: 14px;\n            margin: 5px 0;\n        }\n        .zcs_details {\n            margin-bottom: 20px;\n        }\n        .zcs_details p {\n            margin: 5px 0;\n            font-size: 12px;\n        }\n        .zcs_details strong {\n            display: inline-block;\n            width: 150px;\n        }\n        .zcs_footer {\n            margin-top: 20px;\n            font-size: 14px;\n        }\n\t\t.fill-blank {\n\t\t\tborder-bottom: 1px solid black;\n\t\t\tfont-weight: 500;\n\t\t\ttext-shadow: 0.1px 0.1px 0px rgba(0, 0, 0, 0.6);\n\t\t\t}\n\t\t.zcs_ol, .zcs_li {\n\t\t\tline-height: 1.4; \/* Adjust value as needed *\/\n\t\t\t}\n\t\t.zcs_li {\n\t\t\tmargin-bottom: 8px; \/* Adjust value as needed *\/\n\t\t\t}\n\t\t.zcs_photo-container {\n            display: flex;\n            justify-content: space-around;\n            padding: 10px;\n        }\n        .zcs_photo-box {\n            width: 100px;\n            height: 120px;\n            border: 1px solid black;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n        }\n        .zcs_photo-box img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n        .zcs_label {\n            text-align: center;\n            font-size: 14px;\n            margin-top: 4px;\n            font-weight: bold;\n        }\n    &lt;\/style&gt;\n    &lt;div class=&quot;zcs_body&quot;&gt;\n        &lt;div class=&quot;zcs_container&quot;&gt;\n&lt;%\n\tStudentDetails = Student[ID == input.SID];\n\tif(StudentDetails.count() &gt; 0)\n\t{\n\t\tSchoolDetails = School_Details[ID != 0];\n\t\t%&gt;\n&lt;div class=&quot;zcs_header&quot;&gt;\n\t\t\t&lt;div&gt;\n\t\t\t&lt;%=thisapp.schoolManagement.SchoolLogo(100,100)%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n                &lt;h1&gt;&lt;%=SchoolDetails.School_Name%&gt;&lt;\/h1&gt;\n                &lt;p&gt;&lt;%=SchoolDetails.Address.address_line_1%&gt;&lt;%=SchoolDetails.Address.address_line_2%&gt;,&lt;%=SchoolDetails.Affiliation%&gt; Affiliated&lt;br&gt; &lt;%=SchoolDetails.Contact_Number.replaceall(&quot;+91&quot;,&quot;&quot;,true)%&gt; (Aff.No.&lt;%=SchoolDetails.School_Registration_Number%&gt;)&lt;\/p&gt;\n                &lt;p&gt;Phone &lt;%=SchoolDetails.Contact_Number.replaceall(&quot;+91&quot;,&quot;&quot;,true)%&gt;&lt;br&gt;&lt;\/p&gt;\n                &lt;h2&gt;ADMISSION FORM&lt;\/h2&gt;\n                &lt;p&gt;For Academic Session &lt;%=StudentDetails.Registration.Educational_Year.Academic_Year%&gt;&lt;\/p&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n\t\t\t&lt;%=thisapp.Akz.PopulateImage(StudentDetails.ID,100,100,&quot;Student&quot;)%&gt;\n\t\t\t&lt;\/div&gt;\n            &lt;\/div&gt;\n            &lt;div class=&quot;zcs_details&quot;&gt;\n\t\t\t&lt;table style=&quot;width:100%;border-collapse:collapse;&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;td style=&quot;width: 100px;&quot;&gt;Reference No: &lt;\/td&gt;\n\t\t\t&lt;td class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Registration_Number%&gt;&lt;\/td&gt;\n\t\t\t&lt;td style=&quot;width: 100px;&quot;&gt;Admission No: &lt;\/td&gt;\n\t\t\t&lt;td class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Admission_Number%&gt;&lt;\/td&gt;\n\t\t\t&lt;td style=&quot;width: 50px;&quot;&gt;House : &lt;\/td&gt;\n\t\t\t&lt;td class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.House.House_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;\/table&gt;\n\t\t\t&lt;div class=&quot;zcs_Questions&quot;&gt;\n\t\t\t&lt;br&gt;\n&lt;ol class=&quot;zcs_ol&quot;&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;\n  \t&lt;ol type=&quot;A&quot; class=&quot;zcs_ol&quot;&gt;\n\t\t&lt;li class=&quot;zcs_li&quot;&gt;Name in Full(Capital Letters) &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Student_Name.upper()%&gt;&lt;\/span&gt;\n  \t\t\t&lt;ol type=&quot;I&quot; class=&quot;zcs_ol&quot;&gt;\n\t\t\t\t&lt;li class=&quot;zcs_li&quot;&gt;Sex : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Gender%&gt;&lt;\/span&gt;&lt;\/li&gt;\n          \t\t&lt;li class=&quot;zcs_li&quot;&gt;Nationality : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Nationality%&gt;&lt;\/span&gt;&lt;\/li&gt;\n\t\t\t\t&lt;li class=&quot;zcs_li&quot;&gt;Category : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Caste.Caste_Name%&gt;&lt;\/span&gt;&lt;\/li&gt;\n        \t&lt;\/ol&gt;\n      \t&lt;\/li&gt;\n      \t&lt;li class=&quot;zcs_li&quot;&gt;Aadhar Card No : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Aadhaar_Number%&gt;&lt;\/span&gt;&lt;\/li&gt;\n\t\t&lt;li class=&quot;zcs_li&quot;&gt;Class in which admission is sought : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Class_DB%&gt;&lt;\/span&gt;&lt;\/li&gt;\n\t\t&lt;li class=&quot;zcs_li&quot;&gt;Previous School (if any) : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Previous_School_Data.School%&gt;&lt;\/span&gt;&lt;\/li&gt;\n\t\t&lt;li class=&quot;zcs_li&quot;&gt;Medium of instruction in the previous school : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Previous_School_Data.Board%&gt;&lt;\/span&gt;&lt;\/li&gt;\n    &lt;\/ol&gt;\n  &lt;\/li&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;Date of Birth : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Date_of_Birth%&gt;&lt;\/span&gt;&lt;\/li&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;Father&apos;s Name : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Father_s_Name%&gt;&lt;\/span&gt;&lt;br&gt;\n  Qualification : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Father_s_Qualification%&gt;&lt;\/span&gt; Occupation : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Father_s_Occupation%&gt;&lt;\/span&gt; Mobile : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Father_s_Phone.replaceAll(&quot;+91&quot;,&quot;&quot;,true)%&gt;&lt;\/span&gt;\n  &lt;\/li&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;Mother&apos;s Name : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Mother_s_Name%&gt;&lt;\/span&gt;&lt;br&gt;\n  Qualification : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Mother_s_Qualification%&gt;&lt;\/span&gt; Occupation : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Mother_s_Occupation%&gt;&lt;\/span&gt; Mobile : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Mother_s_Phone.replaceAll(&quot;+91&quot;,&quot;&quot;,true)%&gt;&lt;\/span&gt;\n  &lt;\/li&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;Permanent Address : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Primary_Communication_Address%&gt;&lt;\/span&gt;&lt;\/li&gt;\n  &lt;div class=&quot;zcs_photo-container&quot;&gt;\n    &lt;div&gt;\n        &lt;div class=&quot;zcs_photo-box&quot;&gt;\n            &lt;%=thisapp.Akz.PopulateImage(StudentDetails.ID,100,100,&quot;Mother&quot;)%&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;zcs_label&quot;&gt;Mother&lt;\/div&gt;\n    &lt;\/div&gt;\n    &lt;div&gt;\n        &lt;div class=&quot;zcs_photo-box&quot;&gt;\n            &lt;%=thisapp.Akz.PopulateImage(StudentDetails.ID,100,100,&quot;Father&quot;)%&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;zcs_label&quot;&gt;Father&lt;\/div&gt;\n    &lt;\/div&gt;\n    &lt;div&gt;\n        &lt;div class=&quot;zcs_photo-box&quot;&gt;\n\t\t&lt;%=thisapp.Akz.PopulateImage(StudentDetails.ID,100,100,&quot;Guardian&quot;)%&gt;\n        &lt;\/div&gt;\n        &lt;div class=&quot;zcs_label&quot;&gt;Guardian&lt;\/div&gt;\n    &lt;\/div&gt;\n&lt;\/div&gt;\n  &lt;li class=&quot;zcs_li&quot;&gt;Residential\/Correspondence Address : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Primary_Communication_Address%&gt;&lt;\/span&gt;&lt;\/li&gt;\n&lt;%\n\t\tif(StudentDetails.Guardian_s_Name.first_name not in {&quot;&quot;,null})\n\t\t{\n\t\t\t%&gt;\n&lt;li class=&quot;zcs_li&quot;&gt;Guardian&apos;s Name : &lt;span class=&quot;fill-blank&quot;&gt; &lt;%=StudentDetails.Guardian_s_Name%&gt;&lt;\/span&gt; Relation : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Guardian_s_Relation%&gt;&lt;\/span&gt; Mobile : &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Guardian_s_Phone.replaceAll(&quot;+91&quot;,&quot;&quot;,true)%&gt;&lt;\/span&gt; &lt;\/li&gt;\n&lt;%\n\t\t}\n\t\tStudentSiblingDetails = StudentDetails.Sibling_Details;\n\t\tif(StudentSiblingDetails.count() &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;li class=&quot;zcs_li&quot;&gt;Name of other brothers &amp; sisters with age ( in the same school ) : &lt;ol class=&quot;zcs_ol&quot;&gt;\n&lt;%\n\t\t\tAllSiblingDetails = &quot;&quot;;\n\t\t\tfor each  SiblingInfo in StudentDetails.Sibling_Details\n\t\t\t{\n\t\t\t\tif(SiblingInfo.Same_School)\n\t\t\t\t{\n\t\t\t\t\t%&gt;\n&lt;li class=&quot;zcs_li&quot;&gt;&lt;span class=&quot;fill-blank&quot;&gt;&lt;%=SiblingInfo.Name + if(SiblingInfo.Age == null,&quot;&quot;,&quot; - &quot; + SiblingInfo.Age)%&gt;&lt;\/span&gt;&lt;\/li&gt;\n&lt;%\n\t\t\t\t}\n\t\t\t}\n\t\t\t%&gt;\n&lt;\/ol&gt;&lt;\/li&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;li class=&quot;zcs_li&quot;&gt;Mode of Transport to the school &lt;span class=&quot;fill-blank&quot;&gt;&lt;%=StudentDetails.Transport_Type%&gt;&lt;\/span&gt;&lt;\/li&gt;\n&lt;\/ol&gt;\n\t\t\t&lt;\/div&gt;\n            &lt;div class=&quot;zcs_footer&quot;&gt;\n                &lt;p&gt;I solemnly declare that I will abide by all the rules and regulation of the school and I also undertake to pay the school dues in time. I also understand that Fee once paid is non-refundable &amp; non-transferable in any circumstances. I also understand that non-payment of school fee for any quarter or for consecutive three months may lead to cancellation of my ward&apos;s admission.&lt;\/p&gt;\n            &lt;\/div&gt;\n        &lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Mark_Sheet
		{
			displayname = "Mark Sheet"
			Content="<zml    \n\t\t\tisPdfEnabled='true'\n\t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet103' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet103()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n:root{\n--jsHorizontalPagePadding:1.75cm;\n--jsVerticalPagePadding:1.75cm;\n}\n\n.js_page_container *{\nmargin:0;\npadding:0;\nbox-sizing:border-box;\n}\n\n.js_page_container{\nfont-family: &apos;Lato&apos;;\n}\n\n.js_page{\npadding:12px;\nbackground: white;\nwidth: 21cm;\nheight: 29.7cm;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n}\n\n.js_page:not(.js_page1){\npage-break-before:always;\n}\n\n.js_page_section{\nborder:0.5px solid #000;\nwidth: calc(21cm - var(--jsHorizontalPagePadding));\nheight: calc(29.7cm - var(--jsVerticalPagePadding));\npadding:20px;\ndisplay: flex;\nflex-direction: column;\n}\n\/*** Marksheet Header ****\/\n.jsc_markSheetHeader{\n\tdisplay:flex;\n\ttext-align:center;\n\tborder-bottom: 0.5px solid #000;\n\tpadding-bottom: 13px;\n}\n\n.jsc_markSheetHeader img{\n\twidth:90px;\n\taspect-ratio:1;\n\tmargin-left:45px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-right:60px;\n\tletter-spacing:.75px;\n}\n\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content h4{\n\tfont-size:17px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content &gt; *{\n\tline-height:20px;\n}\n\n\/**** Student Details ****\/\n.jsc_student_details{\n\tdisplay:flex;\n\tpadding: 15px 0;\n    justify-content: space-between;\n\talign-items:center;\n}\n\n.jsc_student_details table.jsc_student_details_table{\n\twidth:70%;\n\tflex:1;\n}\n\n\n.jsc_student_details table.jsc_student_details_table td{\n\tline-height:30px;\t\n}\n\n.jsc_student_details table.jsc_student_details_table td::before{\n\tcontent: attr(data-js-label);\n\tdisplay:inline-block;\n\tmargin-right:4px;\n\tfont-weight:600;\n}\n\n.jsc_student_details .jsc_student_image{\n\twidth: 2.5cm;\n    aspect-ratio: 7 \/ 9;\n    border: 1px solid #000;\n    object-fit: cover;\n    display: inline-block;\n}\n\n\n\/***** Score ******\/\n\n.jsc_score{\n\twidth:100%;\n\ttext-align:center;\n\tmargin-bottom:15px;\n}\n\n.jsc_scholastic_areas.jsc_score th{\n\t    width: calc(100% \/ 7);\n}\n\n.jsc_score th, .jsc_score td, .jsc_score {\n    border: 0.5px solid #000;\n    border-collapse: collapse;\n}\n\n.jsc_score th, .jsc_score td{\n\tline-height:28px;\n\tpadding:0 8px;\n}\n\n.jsc_score::before{\n\tcontent: attr(data-table-header);\n\tdisplay:block;\n}\n\n.jsc_table_header{\n\tmargin:10px 0 10px;\n\tfont-weight:400;\n\tfont-size:15px;\n}\n\n.jsc_footer{\n\tdisplay:flex;\n\tflex:1;\n}\n\n.jsc_footer .jsc_footer_item{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\ttext-align:center;\n}\n\n.jsc_footer .jsc_footer_item div:first-child{\n\tflex:1;\n}\n\n.jsc_co-scholastic_areas td:first-child{\n\twidth:30px;\n}\n\n.jsc_co-scholastic_areas td:nth-child(2){\n\t\ttext-align:left;\n}\n\n.jsc_co-scholastic_areas td:nth-child(3){\n\t\twidth:90px;\n}\n\n&lt;\/style&gt;\n&lt;div class=&quot;js_page_container&quot;&gt;\n&lt;div class=&quot;js_page js_page1&quot;&gt;\n&lt;div class=&quot;js_page_section&quot;&gt;\n\t&lt;div class=&quot;jsc_markSheetHeader&quot;&gt;\n\t\t&lt;img src=&quot;https:\/\/creatorapp.zohopublic.in\/file\/girimservices_in_zohotest\/education-erp-new-trail-app\/All_School_Details\/276743000000095056\/Logo\/image-download\/wQHXYMJm4StWZR1GJ90YMVgfrCDbOpefx6m93qRZEMyJ0pGwxNYm1jdXzaKXBSKXpqBpxMwHPYVpeZunpuR1Ttgg7atjv3FH8sj6?filepath=\/1741779052418_School_Logo_3.PNG&quot;\/&gt;\n\t\t&lt;div class=&quot;jsc_markSheetHeader_content&quot;&gt;\n\t\t\t&lt;h4&gt;Shiv Chand Public High School &lt;\/h4&gt;\n\t\t\t&lt;p&gt;Vill: Sakohpur, SBS Nagar, CBSE Affiliated&lt;\/p&gt;\n\t\t\t&lt;p&gt;C.B.S.E.&lt;\/p&gt;\n\t\t\t&lt;p&gt;Session 2024-2025&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;jsc_student_details&quot;&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Student&apos;s Name : &quot;&gt;EKJOT JANGRA&lt;\/td&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Class-Section : &quot;&gt;1st - A&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Father&apos;s Name : &quot;&gt;VIJAY KUMAR&lt;\/td&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Admission No : &quot;&gt;1384&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Mother&apos;s Name : &quot;&gt;MAMTA RANI&lt;\/td&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Roll No. : &quot;&gt;9&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td data-js-label=&quot;Date of Birth : &quot;&gt;13-02-2016&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t\t&lt;img class=&quot;jsc_student_image&quot; src=&quot;https:\/\/t4.ftcdn.net\/jpg\/06\/59\/57\/65\/360_F_659576586_9CSUewJar5TZDkEMJu3qHVaPJmywlDn1.jpg&quot;\/&gt;\n\t&lt;\/div&gt;\n\t&lt;h3 class=&quot;jsc_table_header&quot;&gt;Part-1: Scholastic Activities (Term 1)&lt;\/h3&gt;\n\t&lt;table class=&quot;jsc_scholastic_areas jsc_score&quot;&gt;\n\t\t&lt;tr&gt;\n\t\t\t&lt;th&gt;&lt;\/th&gt;\n\t\t\t&lt;th&gt;Unit&amp;nbsp;Test&amp;nbsp;1&lt;\/th&gt;\n\t\t\t&lt;th&gt;Portfolio&lt;\/th&gt;\n\t\t\t&lt;th style=&quot;line-height:20px;padding:5px 0;&quot;&gt;Subject&lt;br&gt;Enrichment&lt;\/th&gt;\n\t\t\t&lt;th&gt;Half&amp;nbsp;Yearly&lt;\/th&gt;\n\t\t\t&lt;th&gt;Term&amp;nbsp;1&lt;\/th&gt;\n\t\t\t&lt;th&gt;Grade&lt;\/th&gt;\n\t\t&lt;\/tr&gt;\n\t\t&lt;tr&gt;\n\t\t\t&lt;td&gt;English&lt;\/td&gt;\n\t\t\t&lt;td&gt;9.50&lt;\/td&gt;\n\t\t\t&lt;td&gt;9.50&lt;\/td&gt;\n\t\t\t&lt;td&gt;9.50&lt;\/td&gt;\n\t\t\t&lt;td&gt;9.50&lt;