			{
				type =  schedule
					status = inactive
				start = "2024-07-11 01:10:10"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						// for each  rec in Branch[ID != 0]
										// {
										// 	getRec = Income_Vs_Expense[Date_field == zoho.currentdate.subDay(1) && Branch == rec.ID];
										// 	expenseAmount = Add_Expense[Date_field == zoho.currentdate.subDay(1) && Branch == rec.ID].sum(Amount);
										// 	incomeAmount = Fee_Detail[Payment_Date == zoho.currentdate.subDay(1) && Branch == rec.ID].sum(Amount);
										// 	if(getRec.count() == 0)
										// 	{
										// 		amountDet = insert into Income_Vs_Expense
										// 		[
										// 			Added_User=zoho.loginuser
										// 			Revenue_Amount=incomeAmount
										// 			Expense_Amount=expenseAmount
										// 			Branch=rec.ID
										// 			Date_field=zoho.currentdate.subDay(1)
										// 		];
										// 	}
										// 	else
										// 	{
										// 		getRec.Expense_Amount=expenseAmount;
										// 		getRec.Revenue_Amount=incomeAmount;
										// 	}
										// }
										getRec = Income_Vs_Expense[Date_field == zoho.currentdate.subDay(1)];
										expenseAmount = Add_Expense[Date_field == zoho.currentdate.subDay(1)].sum(Amount);
										incomeAmount = Fee_Detail[Payment_Date == zoho.currentdate.subDay(1)].sum(Amount);
										if(getRec.count() == 0)
										{
											amountDet = insert into Income_Vs_Expense
											[
												Added_User=zoho.loginuser
												Revenue_Amount=incomeAmount
												Expense_Amount=expenseAmount
												Date_field=zoho.currentdate.subDay(1)
											];
										}
										else
										{
											getRec.Expense_Amount=expenseAmount;
											getRec.Revenue_Amount=incomeAmount;
										}
					)
					}
				}
			}
			Update_Offer_Status as "Update Offer Status"
			{
				type =  schedule
