			onSubmission9 as "onSubmission"
			{
				type =  form
				form = Room
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Student.size() == input.Capacity)
										{
											input.Room_Status = "Occupied";
										}
										else if(input.Student.size() > 0 && input.Student.size() < input.Capacity)
										{
											input.Room_Status = "Partially Occupied";
										}
										for each  stude in input.Student
										{
											warden = Staff[ID == input.block.Warden];
										}
										classDet = Class[ID != 0];
										if(classDet.count() == 0)
										{
											section = insert into Sections
											[
												Added_User=zoho.loginuser
												Section_Name="A"
											];
										}
										else
										{
											section = Sections[Section_Name == "A"].ID;
										}
										class = Class[ID != 0];
										if(class.count() == 0)
										{
											eduYear = Educational_Year[Status == "Current"];
											if(eduYear.count() == 0)
											{
												eduYear = Educational_Year[Status == "Upcoming"];
											}
											if(eduYear.count() != 0)
											{
												for each  data in Class_DB[ID != 0]
												{
													resp = insert into Class
													[
														Added_User=zoho.loginuser
														Section2=section
														Class_Name=data.Class + "- A"
														Educational_Year=eduYear
														Class=data.ID
														Status="In-Active"
													];
												}
											}
										}
										student = Student[ID != 0];
										rooms = Room[ID != 0];
										if(student.count() == 0 && rooms.count() == 1)
										{
											openUrl("#Page:Initial_Setup?zc_LoadIn=embed-innerdiv","popup window");
										}
						)
					}
				}

			}
