0 0 \/ 15%);\n        border-radius: 10px;\n        margin: 0px 10px;\n        padding: 15px;\n\t\tpadding-left:70px;\n        position:relative;\n\t\tbox-sizing: border-box;\n      }\n\t  .panels .panel span:nth-child(1){\n          font-size: 20px;\n\t\t  font-weight:700;\n      }\n      .panels .panel span:nth-child(2) {\n          font-size: 14px;\n\t\t  color:#7D7D7D;\n      }\n\t  \n      .panel{\n        gap:5px;\n      }\n\t  \n\t\/*form styles *\/\n\t\t.tab_search label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t.tab_search .formbutton {\n          padding: 0 !important;\n     }\n\t\t.tab_search .row\n\t\t{\n\t\t\tbackground:var(--main-container-color) !important;\n\t\t}\n\t\t.tab_search label.choice-label-text\n\t\t{\n\t\t\tfont-size:20px !important;\n\t\t}\n\t\t.tab_search .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t.tab_search .zc-footer-wrapper {\n          border-top: none !important;\n        }\n\t\t.tab_search .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t.tab_search .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t\n\t .tab_search .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t .tab_search .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t }\n\t .tab_search .form-field .tempContDiv .choice-table-cell {\n\t\t\tdisplay: flex;\n\t\t\tpadding: 0 60px 0;\n\t\t\tbox-sizing: border-box;\n\t\t}\n\t\t.tab_search .zc-form-fullheight .form-outer-wrapper .formContainer,.form-outer-wrapper .formContainer I don\u2019t \n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t\t.tab_search .customRadio:checked+label+choice-label-text\n\t\t{\n\t\t\tcolor:green;\n\t\t}\n\t\t.tab_search form[name=&quot;Report_Sear