	pages
	{
		page Search_Staff
		{
			displayname = "Search Staff"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet97' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet97()\ncontent\n&lt;%{\n\tallStaff = Staff[ID != 0];\n\tfor each  ele in allStaff\n\t{\n\t\tele.Current_Session=thisapp.schoolManagement.findTeacherLocation(null,ele.ID.toString());\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n\tform.form-table.label-left {\n    display: flex;\n}\n.form-group{\n\tmargin: unset !important;\n}\n.form-action.formbutton {\n    padding: 18px 0 !important;\n}\n\n.formbutton label.form-label {\n   \n    display: none !important;\n\t}\ninput.zc-live-primary-btn {\n    margin: 0 !important;\n}\n\n.zc-footer-wrapper {\n  border-top: unset !important;\n  position: absolute;\n    right: 10px;\n}\n\n.row.reportfullwidth.custom-report {\n\t   background: #f3f4f5;\n   }\n   \n   .zpelement-wrapper .zc-qv-custom-layout .zc-pb-tile-cnt-wrapper {\n    border-radius: 8px;\n\tborder-color: #e5e7ed;\n}\n\n.zpelement-wrapper .zc-qv-custom-layout .zc-pb-tile-cnt-wrapper:hover{\n\tborder-color: var(--theme_brand_color);\n}\n.zcp-col img.zc-image-view {\n    object-fit: cover;\n}\nform[name=&quot;Search_Staff1&quot;].label-left{\n\twidth: 100% !important;\n}\n\/* span.zc-conditionalformat {\n    font-size: 0px;\n    font-style: normal !important;\n}\nspan.zc-conditionalformat:before {\n    content: &apos;16:00 - 17:00 is happening in 11-Lab Block&apos;;\n    color: #6C6C6C;\n    font-size: 13px;\n    \n} *\/\n.zcp-dis-inlineblock.zcp-link.zc-pb-fs-height span {font-style: normal;}\n\t&lt;\/style&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;student_tab_search&quot; formLinkName=&apos;Search_Staff1&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t   &lt;div name=&quot;staffpage&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Staff_Details&apos; class=&quot;staffpage&quot; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Marks_Chart(int recid)
		{
			displayname = "Student Marks Chart"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart\"\n\n\ttype = 'Stacked Area'\n\tbgColor = 'rgb(255, 255, 255)'\n\ttheme = '#5051f9'\n\tlegendPos = 'center.top'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Subject_Marks'\n\txfield = 'Exam_Marks.Exam_Name'\n\tyfields = 'sum:Marks_Secured'\n\tgroupBy = 'Subject_form.Subject_Name'\n\t\tDelugeCriteria = 'Marks_Secured is not null &amp;&amp; Student.ID == input.recid'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
