			onValidation7 as "onValidation"
			{
				type =  form
				form = Subject_Marks
				record event = on edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Marks_Secured > input.Total_Marks)
										{
											alert "Please enter valid value for Marks Secured";
											cancel submit;
										}
										oldMarkFetch = Subject_Marks[ID == input.ID];
										oldMark = if(oldMarkFetch.count() == 0,0,oldMarkFetch.Marks_Secured);
										examMarks = Exam_Marks[ID == input.Exam_Marks];
										examMarks.Total_Marks_Scored=examMarks.Total_Marks_Scored + input.Marks_Secured - ifnull(oldMark,0);
										examMarks.Percentage=examMarks.Total_Marks_Scored / examMarks.Total * 100;
										passPercentageRecord = Exam_Schedule[Exam_Name == input.Exam_Marks.Exam_Name && Subject_form == input.Subject_form];
										passPercentage = passPercentageRecord.Minimum_Percentage_For_Pass;
										if(input.Marks_Secured < passPercentage / 100 * input.Total_Marks)
										{
											examMarks.Status="Fail";
											input.Exam_Status = "Fail";
										}
										else
										{
											if(examMarks.Status != "Fail")
											{
												examMarks.Status="Pass";
											}
											input.Exam_Status = "Pass";
										}
										student = Student[ID == examMarks.Student];
										exam = Exam[ID == examMarks.Exam_Name];
										if(exam.Annual_Exam == true)
										{
											allExams = Subject_Marks[Exam_Marks == input.Exam_Marks && Marks_Secured == null];
											if(allExams.count() == 0)
											{
												student.Annual_Exam_Result=examMarks.Status;
											}
										}
										// exam =  Subject_Marks [ Marks_Secured == "" && Exam_Marks == input.Exam_Marks ];
										// if ( exam.count() == 0 ) 
										// {
										// }
										allMarks = Subject_Marks[Exam_Marks.Exam_Name == input.Exam_Marks.Exam_Name && Exam_Status == "Yet to Submit Marks"];
										if(allMarks.count() == 0)
										{
											mainExam = Exam[ID == input.Exam_Marks.Exam_Name];
											mainExam.Status="Marks Entry Completed";
										}
										cumulativeRec = Cumulative_Ranking[Educational_Year == input.Exam_Marks.Educational_Year && Student == input.Student];
										totalPoints = 0;
										for each  exa in Exam_Marks[Student == input.Student && Educational_Year == input.Exam_Marks.Educational_Year]
										{
											totalPoints = totalPoints + exa.Total_Marks_Scored;
										}
										if(cumulativeRec.count() != 0)
										{
											cumulativeRec.Academic_Performance=totalPoints;
											cumulativeRec.Overall_Performance=cumulativeRec.Academic_Performance + cumulativeRec.Extracurricular + cumulativeRec.Attitude_Performance;
										}
										else
										{
											cumulativeRecord = insert into Cumulative_Ranking
											[
												Educational_Year=input.Exam_Marks.Educational_Year
												Overall_Performance=totalPoints
												Attitude_Performance=0
												Extracurricular=0
												Academic_Performance=totalPoints
												Student=input.Student
												Added_User=zoho.loginuser
											];
										}
										thisapp.updateRanking(input.Exam_Marks.Educational_Year);
						)
					}
				}

			}
			onLoad23 as "onLoad"
			{
				type =  form
				form = Student
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											// show Transport_Type;
										input.Hosteller = false;
										hide Library_Membership;
										hide Hidden;
										hide Admission_Number;
										if(input.Registration != null)
										{
											regi = Registration[ID == input.Registration];
											input.Registration_Number = regi.Registration_Number;
											disable Registration_Number;
											siblingCollection = Collection();
											preSchoolCollection = Collection();
											if(regi.Has_Siblings1 == true)
											{
												for each  sibling in regi.Sibling_Details
												{
													siblings = Student.Sibling_Details();
													siblings.Name=sibling.Name;
													siblings.Age=sibling.Age;
													siblings.Same_School=sibling.Same_School;
													siblings.Student=sibling.Student;
													siblingCollection.insert(siblings);
												}
											}
											if(regi.Studied_in_another_school == true)
											{
												for each  rec in regi.Previous_School_Data
												{
													school = Student.Previous_School_Data();
													school.School=rec.School;
													school.Year_field=rec.Year_field;
													school.Board=rec.Board;
													school.Standard=rec.Standard;
													school.Final_Exam_Percentage=rec.Final_Exam_Percentage;
													preSchoolCollection.insert(school);
												}
											}
											input.Student_Name = regi.Student_Name;
											input.Emergency_Contact_Number = regi.Emergency_Contact_Number;
											input.Gender = regi.Gender;
											input.Parents_Address = regi.Address;
											input.Mother_s_Name = regi.Mother_s_Name;
											input.Mother_s_Email = regi.Mother_s_Email;
											input.Mother_s_Occupation = regi.Mother_s_Occupation;
											input.Mother_s_Phone = regi.Mother_s_Phone;
											input.Mother_s_Qualification = regi.Mother_s_Qualification;
											input.Mother_s_Aadhaar_Number = regi.Mother_s_Aadhaar_Number;
											// 	input.Mother_s_Photo = regi.Mother_s_Photo;
											input.Father_s_Phone = regi.Father_s_Phone;
											input.Father_s_Name = regi.Father_s_Name;
											input.Father_s_Email = regi.Father_s_Email;
											input.Father_s_Qualification = regi.Father_s_Qualification;
											input.Father_s_Aadhaar_Number = regi.Father_s_Aadhaar_Number;
											input.Father_s_Occupation = regi.Father_s_Occupation;
											// 	input.Father_s_Photo = regi.Father_s_Photo;
											input.Guardian_s_Name = regi.Guardian_s_Name;
											input.Guardian_s_Relation = regi.Guardian_s_Relation;
											input.Guardian_s_Occupation = regi.Guardian_s_Occupation;
											input.Guardian_s_Phone = regi.Guardian_s_Phone;
											input.Guardian_s_Aadhaar_Number = regi.Guardian_s_Aadhaar_Number;
											input.Guardian_s_Email = regi.Guardian_s_Email;
											input.Primary_Contact_Number = regi.Primary_Contact_Number;
											input.Primary_Contact_Email = regi.Primary_Contact_Email;
											input.Primary_Communication_Address = regi.Address;
											// 	input.Photo = regi.Photo;
											input.Date_of_Birth = regi.Date_of_Birth;
											input.Studied_in_another_school_prior_to_this = regi.Studied_in_another_school;
											input.Aadhaar_Number = regi.Aadhaar_Number;
											if(input.Studied_in_another_school_prior_to_this)
											{
												show Previous_School_Data;
												input.Previous_School_Data.insert(preSchoolCollection);
											}
											input.Has_Siblings = regi.Has_Siblings1;
											if(input.Has_Siblings)
											{
												show Sibling_Details;
												input.Sibling_Details.insert(siblingCollection);
											}
											// 	input.Branch_UID = regi.Branch;
											disable Class_UID;
											hide Sibling_Details.Student;
											// 	disable Branch_UID;
										}
										// if(input.Branch_UID != null)
										// {
										// 	stops = Bus_Route_SubForm[Route.Branch == input.Branch_UID].Bus_Stops.getAll();
										// 	input.Pickup_Point:ui.add(stops);
										// }
						)
					}
				}

			}
