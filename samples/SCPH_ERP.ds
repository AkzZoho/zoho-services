				width = medium
			)
			Exit_Time
			(
    			type = time
				displayname = "Exit Time"
				timedisplayoptions = "hh:mm" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have To_Visit
			(
				type = picklist
				displayname = "To Visit"
				maxchar = 100
				values = {"Student","Staff","Office"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Staff
			(
				type = picklist	
				values  = Staff.ID
    			displayformat = [" " + Name.first_name + " " + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Student
			(
				type = picklist	
				values  = Student.ID
    			displayformat = [" " + Student_Name.first_name + " " + Student_Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Reason_For_Visit
			(
    			type = textarea
				displayname = "Reason For Visit"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Visitor Inside the Campus","Visitor Exited"}
				initial value = "Visitor Inside the Campus"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	reports
	{
		default list All_Expenses
		{
			displayName = "All Expenses"
			show all rows from Add_Expense    
			(
				Date_field as "Date"
				Amount
				(
					display = total	
				)
				Payment_Method as "Payment Method"
				Category
				Expense_Purpose as "Expense Purpose"
				Receipt
				Paid_by as "Paid by"
				Paid_to as "Paid to"
			)
			group by
			(
				Category ascending
			)
			sort by
			(
				Date_field descending
			)
		}
		default list All_Expense_Categories
		{
			displayName = "All Expense Categories"
			show all rows from Expense_Category    
			(
				Category
			)
		}
		custom Staff_Details
		{
			displayName = "Staff Details"
			show all rows from Staff    
			(
				Photo
