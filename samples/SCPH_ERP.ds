			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet7' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet7()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n\t\t* {\n\t\t   padding: 0;\n\t\t   margin: 0;\n\t\t   border: none;\n\t\t   box-sizing: border-box;\n\t\t}\n\t  \n\t \tdiv#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t.parent-div{\n\t\t\theight:100%;\n\t\t}\n\t\t\n\t\tiframe{\n\t\t\theight: 100%;\n    \t\twidth: 100%;\n\t\t}\n\t&lt;\/style&gt;\n    &lt;div name=&apos;pageTest&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;Student_Dashboard1&apos; params=&apos;Child_Mail=&lt;%=zoho.loginuserid%&gt;&apos;&gt;&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
