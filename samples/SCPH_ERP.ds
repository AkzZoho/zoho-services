		page Initial_Setup
		{
			displayname = "Initial Setup"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet37' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet37()\ncontent\n&lt;%{\n\tschoolInfo = School_Details[ID != 0];\n\teducationYear = Educational_Year[ID != 0];\n\t\/\/ \tblock = Block1[ID != 0];\n\t\/\/ \trooms = Room[ID != 0];\n\tisSetupCompleted = false;\n\tisSchoolDetailFilled = false;\n\tisEducationalYearFilled = false;\n\tisBlocksFilled = true;\n\tif(schoolInfo.count() == 0)\n\t{\n\t\tprogressaTab = 1;\n\t\tformLink = &quot;School_Details&quot;;\n\t}\n\telse if(educationYear.count() == 0)\n\t{\n\t\tprogressaTab = 2;\n\t\tformLink = &quot;Educational_Year&quot;;\n\t\tisSchoolDetailFilled = true;\n\t}\n\t\/\/ \telse if(block.count() == 0)\n\t\/\/ \t{\n\t\/\/ \t\tprogressaTab = 3;\n\t\/\/ \t\tformLink = &quot;Block1&quot;;\n\t\/\/ \t\tisSchoolDetailFilled = true;\n\t\/\/ \t\tisEducationalYearFilled = true;\n\t\/\/ \t}\n\t\/\/ \telse if(rooms.count() == 0)\n\t\/\/ \t{\n\t\/\/ \t\tprogressaTab = 4;\n\t\/\/ \t\tformLink = &quot;Room&quot;;\n\t\/\/ \t\tisSchoolDetailFilled = true;\n\t\/\/ \t\tisEducationalYearFilled = true;\n\t\/\/ \t\tisBlocksFilled = true;\n\t\/\/ \t}\n\telse\n\t{\n\t\tisSetupCompleted = true;\n\t\tmoduleRec = insert into Modules\n\t\t[\n\t\t\tAdded_User=zoho.loginuser\n\t\t\tAdmission=&quot;Yes&quot;\n\t\t\tCommuncications=&quot;Yes&quot;\n\t\t\tEntry_Exit=&quot;Yes&quot;\n\t\t\tEvents=&quot;Yes&quot;\n\t\t\tExams=&quot;Yes&quot;\n\t\t\tFees=&quot;Yes&quot;\n\t\t\tHostel=&quot;Yes&quot;\n\t\t\tLMS=&quot;Yes&quot;\n\t\t\tLibrary=&quot;Yes&quot;\n\t\t\tQuestion_Paper=&quot;Yes&quot;\n\t\t\tService_Request=&quot;Yes&quot;\n\t\t\tTransport=&quot;Yes&quot;\n\t\t];\n\t}\n\t%&gt;\n&lt;style&gt;\n\t\t:root{\n\t\t\t--normal-line-clr : #cecece;\n\t\t\t--icon-border-clr : #cecece;\n\t\t\t--progress-line-clr : var(--theme_brand_color);\n\t\t\t--total-tabs : 4;\n\t\t\t--progress-stage : &lt;%=progressaTab%&gt;;\n\t\t\t--image-invert-clr: #dcdc5b;\n\t\t}\n\t\t\n\t\t*{\n\t\t\tpadding:0;\n\t\t\tmargin:0;\n\t\t\tbox-sizing:border-box;\n\t\t}\n\t\t\n\t\tdiv#zppagesLive, \n\t\tdiv#elementsContainer, \n\t\t.Layout.elemContainment, \n\t\tdiv#row_1, \n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight:100% !important;\t\n\t\t}\n\t\t\n\t\t.zcpopup.compact .popupbox-wrapper .popupClose{\n\t\t\tdisplay: none !important;\n\t\t}\n\t\t\n\t\t.zcpopup.compact .popupbox-wrapper .popupbox {\n\t\t\twidth: 90%;\n\t\t\theight: 100%;\n\t\t\tborder-radius: 8px;\n\t\t}\n\t\t\n\t\t.setup-cotainer{\n\t\t\theight:100%;\n\t\t\twidth:100%;\n\t\t}\n\t\t\n\t\t.setup-header{\n\t\t\theight:100px;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tpadding: 0px 100px;\n\t\t\tborder-bottom: 1px solid #cdcdcd;\n\t\t}\n\t\t\n\t\t.setup-header .step {\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t\talign-items: center;\n\t\t\twidth: 100%;\n\t\t\tposition:relative;\n\t\t\tz-index:0;\n\t\t}\n\n\t\t.setup-header .step img {\n\t\t\theight: 55px;\n\t\t\tborder-radius: 50%;\n\t\t\tborder: 3px solid var(--icon-border-clr);\n\t\t\tpadding: 10px;\n\t\t\tbackground: white;\n\t\t}\n\t\t\n\t\t.step.completed img {\n\t\t\tfilter: brightness(1) invert(1);\n\t\t\tbackground: var(--image-invert-clr);\n\t\t\tborder-color: var(--image-invert-clr);\n\t\t}\n\n\t\t.step.current {\n\t\t\t--icon-border-clr: var(--theme_brand_color);\n\t\t}\n\t\t\n\t\t.icon-container {\n\t\t\tborder: 5px solid white;\n\t\t}\n\n\t\t.normal-line,\n\t\t.progress-line{\n\t\t\tposition: absolute;\n\t\t\theight: 3px;\n\t\t\tleft: 50%;\n\t\t\ttop: 32px;\n\t\t}\n\n\t\t.normal-line{\n\t\t\tbackground: var(--normal-line-clr);\n\t\t\twidth: calc(100% * calc(var(--total-tabs) - 1));\n\t\t\tz-index: -2;\n\t\t}\n\t\t\n\t\t.progress-line{\n\t\t\tbackground: var(--progress-line-clr);\n&lt;%\n\tif(progressaTab == 4)\n\t{\n\t\t%&gt;\nwidth: calc(100% * var(--progress-stage) - 100%);\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\nwidth: calc(100% * var(--progress-stage) - 70%);\n&lt;%\n\t}\n\t%&gt;\nz-index: -2;\n\t\t}\n\t\t\n\t\t.setup-content{\n\t\t\theight:calc(100% - 100px);\n\t\t\tdisplay: flex;\n\t\t\tjustify-content: center;\n\t\t\tpadding: 20px 0px;\n\t\t\toverflow: auto;\n\t\t}\n\t\t\n\t\t.setup-content .form-table.label-left{\n\t\t\twidth: 100% !important;\n\t\t}\n\t\t\n\t\t.setup-content&gt;div {\n\t\t\twidth: 80% !important;\n\t\t\theight: fit-content !important;\n\t\t\tborder-radius: 5px;\n\t\t}\n\t\t\n\t\t.completed-setup {\n\t\t\theight: 100%;\n\t\t\tdisplay: flex;\n\t\t\talign-items: center;\n\t\t\tjustify-content: center;\n\t\t\tflex-direction: column;\n\t\t}\n\t\t\n\t\tspan.tick-icon.fa.fa-check {\n\t\t\tfont-size: 3rem;\n\t\t\tborder-radius: 50%;\n\t\t\tpadding: 8px;\n\t\t\tbackground: #75db4c;\n\t\t\tcolor: white;\n\t\t\tmargin-bottom: 30px;\n\t\t}\n\t\t\n\t\t.setup-msg\n\t\t{\n\t\t\tfont-size: 1.8rem;\n    \t\tmargin-bottom: 20px;\n\t\t}\n\t\t\n\t\ta.go-to-app {\n\t\t\tfont-size: 20px;\n\t\t\tbackground: var(--theme_brand_color);\n\t\t\tcolor: white;\n\t\t\tpadding: 5px 10px;\n\t\t\tborder-radius: 3px;\n\t\t}\n\t&lt;\/style&gt;\n\t&lt;div class=&quot;setup-cotainer&quot;&gt;\n&lt;%\n\tif(isSetupCompleted == false)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;setup-header&quot;&gt;\n&lt;%\n\t\tif(isSchoolDetailFilled == false)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step current&quot;&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step completed&quot;&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&quot;icon-container&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/ios-glyphs\/2x\/school-building.png&quot;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;span&gt;School Details&lt;\/span&gt;\n\t\t\t\t&lt;div class=&quot;normal-line&quot;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;progress-line&quot;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\tif(isSchoolDetailFilled == false &amp;&amp; isEducationalYearFilled == false)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step&quot;&gt;\n&lt;%\n\t\t}\n\t\telse if(isSchoolDetailFilled == true &amp;&amp; isEducationalYearFilled == true)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step completed&quot;&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step current&quot;&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&quot;icon-container&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/external-bearicons-glyph-bearicons\/2x\/external-Year-time-and-date-bearicons-glyph-bearicons.png&quot;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;span&gt;Educational Year&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\tif(isSchoolDetailFilled == true &amp;&amp; isEducationalYearFilled == true &amp;&amp; isBlocksFilled == false)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step current&quot;&gt;\n&lt;%\n\t\t}\n\t\telse if(isSchoolDetailFilled == true &amp;&amp; isEducationalYearFilled == true &amp;&amp; isBlocksFilled == true)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step completed&quot;&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step&quot;&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&quot;icon-container&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/sf-black-filled\/2x\/block.png&quot;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;span&gt;Block&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n&lt;%\n\t\tif(isSchoolDetailFilled == true &amp;&amp; isEducationalYearFilled == true &amp;&amp; isBlocksFilled == true)\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step current&quot;&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;step&quot;&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;div class=&quot;icon-container&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/glyph-neue\/2x\/room.png&quot;&gt;&lt;\/div&gt;\n\t\t\t\t&lt;span&gt;Room&lt;\/span&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t\t&lt;div class=&quot;setup-content&quot;&gt;\n\t\t\t&lt;div name=&quot;innerdiv&quot; elName=&apos;zc-component&apos; formLinkName=&apos;&lt;%=formLink%&gt;&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;completed-setup&quot;&gt;\n\t\t\t\t\t&lt;span class=&quot;tick-icon fa fa-check&quot;&gt;&lt;\/span&gt;\n\t\t\t\t\t&lt;span class=&quot;setup-msg&quot;&gt;Initial Setup Completed&lt;\/span&gt;\n\t\t\t\t\t&lt;a href=&quot;#Script:page.dialog.close&quot; class=&quot;go-to-app&quot;&gt;Go to Dashboard&lt;\/a&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Initial_Setup_Div
		{
			displayname = "Initial Setup Div"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet38' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet38()\ncontent\n&lt;%{\n\topenUrl(&quot;#Page:Initial_Setup?zc_LoadIn=embed-innerdiv&quot;,&quot;popup window&quot;);\n\t%&gt;\n&lt;style&gt;\n\t\tdiv#zppagesLive, \n\t\tdiv#elementsContainer, \n\t\t.Layout.elemContainment, \n\t\tdiv#row_1, \n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight:100% !important;\t\n\t\t}\n\t\t\n\t\t.zcpopup.compact .popupbox-wrapper .popupClose{\n\t\t\tdisplay: none !important;\n\t\t}\n\t\t\n\t\t.zcpopup.compact .popupbox-wrapper .popupbox {\n\t\t\twidth: 90%;\n\t\t\theight: 100%;\n\t\t\tborder-radius: 8px;\n\t\t}\n\t\t\n\t\t.setup-popup{\n\t\t\theight:100% !important;\n\t\t}\n\t&lt;\/style&gt;\n\t&lt;div name=&apos;setupdiv&apos; class=&quot;setup-popup&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Initial_Setup&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Overview(recId, state, templateId, templateType)
		{
			displayname = "Overview"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet39' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet39()\ncontent\n&lt;%{\n\tif(input.templateId == null || input.templateId == &quot;&quot;)\n\t{\n\t\tinput.templateId = 1;\n\t}\n\tif(input.recId == null || input.recId == &quot;&quot;)\n\t{\n\t\tinput.recId = 1;\n\t}\n\t%&gt;\n&lt;%=thisapp.Template.template(input.templateId.toNumber(),input.templateType,input.state,input.recId.toNumber())%&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_LMS_Left_Pane
		{
			displayname = "Staff LMS Left Pane"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet40' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet40()\ncontent\n&lt;%{\n\tlogin = zoho.loginuserid;\n\tstaffClass = Lesson_Plan_Mapping[Staff.Email_ID == login].Class.Class_Name.getAll();\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;style&gt;\n\t\t\/*form styles *\/\n\t\t.stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\t\t\n\t\t.stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t margin-right: 10px;\n\t }\n\t \n\t.stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.stateless-form .customRadio:checked+label+choice-label-text\n\t{\n\t\tcolor:green;\n\t}\n\t\n\t.stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t\theight: 100%;\n\t\toverflow: auto;\n\t}\n\t\t\n\t.stateless-form .zc-form-fullheight,\n\t.stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.stateless-form form.form-table .choice-label-text {\n\t\t\tfont-size: 15px !important;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: #000000;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 0px 15px;\n\t\t\t box-sizing: border-box;\n\t\t\twidth: 100%;\n\t\t    display: flex;\n\/* \t\t    justify-content: center; *\/\n\t\t}\n\t\t\n\t.stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t}\n\t\n\t.stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\twidth: 100%;\n\t\tmargin-bottom: 15px;\n\t}\n\t\n\t.stateless-form .choice-table-cell input~label {\n       position: relative;\n\t   cursor:pointer;\n\t   font-size: 16px;\n\t   width: 100%;\n\t   padding: 5px 0 5px 10px;\n\t    box-sizing: border-box;\n\t}\n\t\n\t.stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.stateless-form.divEmbedContainer {\n\t\theight: 100% !important;\n\t\twidth: 250px;\n\t\tpadding: 10px;\n\t\t box-sizing: border-box;\n\t\tbackground: white;\n\t\tz-index: 1;\n\t\tborder-radius: 5px 0px 0px 5px;\n\t}\n\t\n\t.stateless-form .customRadio {\n\t  display: none;\n\t}\n\t\/* Hide - Form Loader Icon *\/\n\t.stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay:none;\n\t }\n\t \n\t .container-wrapper{\n\t\theight: calc(100%);\n\t\tbackground: var(--main-container-color);\n\t\tdisplay: flex;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\toverflow: hidden;\n\t\twidth: calc(100%);\n\t\tborder-radius: 5px;\n\t}\n\t\n\t\/* stateless - new design *\/\n\t.stateless-form .choice-table-cell span {\n\t\tdisplay: contents;\n\t}\n\t\n\t.stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tbackground: var(--header-checked-line-color);\n\t\twidth: 100%;\n\t\theight: 100%;\n\t\tposition: absolute;\n\t\tz-index: -1;\n\t\tright: 0;\n\t\ttop:0;\n\t\tborder-radius: 3px;\n\t}\n\n\t.stateless-form .choice-table-cell input:checked~label {\n\t\tcolor: white !important;\n\t\tz-index:0;\n\t}\n\t\n\t.frame-div{\n\t\twidth:100%;\n\t}\n\t\n\t.container-wrapper .content-div\n\t{\n\t\theight: 100%;\n\t\twidth: calc(100% - 280px);\n\t}\n\t\n\t.left-pane{\n\t\theight:100%;\n\t\tposition:relative;\n\t\twidth:280px;\n\t\tpadding-right:30px;\n\t\t box-sizing: border-box;\n\t\ttransition:width 0.5s ease-in;\n\t}\n\t\t\n\t .panels{\n          display: flex;\n          padding: 10px 0;\n\t\t   box-sizing: border-box;\n\t\t  gap:10px;\n      }\n\t  \n\t  label[for=&quot;open-close-btn&quot;]{\n\t\t  \tposition: absolute;\n\t\t\ttop: 50%;\n\t\t\tright: 6px;\n\t\t\tz-index: 3;\n\t\t\tfont-size: 20px;\n\t\t\tbackground: #ececec;\n\t\t\tpadding: 0px 5px;\n\t\t\t box-sizing: border-box;\n\t\t\tborder-radius: 3px;\n\t\t\tcolor: #12bdcf;\n\t\t\tfont-weight: bold;\n\t\t\tcursor: pointer;\n\t  }\n\t  \n\t   label[for=&quot;open-close-btn&quot;] span{\n\t\t   transition:transform 0.5s ease-in;\n\t   }\n\t   \n\t  input#open-close-btn {\n\t\t  display: none;\n\t  }\n\t  \n\t  input#open-close-btn:checked+.left-pane\n\t  {\n\t\twidth:30px;  \n\t  }\n\t  \n\t  .left-pane&gt;.stateless-form\n\t  {\n\t\t   transition:opacity 0.1s ease-in 0.5s;\n\t  }\n\t  \n\t  input#open-close-btn:checked+.left-pane&gt;.stateless-form{\n\t\t  opacity:0;\n\t\t  transition:opacity 0s ease-in 0s !important;\n\t  }\n\t  \n\t  input#open-close-btn:checked+.left-pane label[for=&quot;open-close-btn&quot;] span\n\t  {\n\t\t  transform:rotate(180deg);\n\t  }\n\t  \n\t  input#open-close-btn:checked~.content-div{\n\t\t  width:calc(100% - 30px);\n\t  }\n\t  \n\t  .stateless-form .form-outer-wrapper\n\t  {\n\t\t  -webkit-animation:unset !important ;\n\t\t   animation-name:unset !important;\n\t  }\n\t  \n\t  .stateless-form .form-group .form-field {\n\t\t\ttransition: unset !important;\n\t\t\t-webkit-transition: unset !important;\n\t\t\t-moz-transition: unset !important;\n\t\t}\n\t\t\n\t\tdiv[pagelinkname=&quot;Staff_LMS_Left_Pane&quot;] .zc-pb-embed-placeholder-content\n\t\t{\n\t\t\t padding: 5px 10px 10px 10px;\n\t\t\t  box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.container-wrapper .zc-pb-embed-placeholder-content{\n\t\t\tpadding:unset !important;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.stateless-form .zc-form-fullheight,\n\t\t.stateless-form .zc-form-fullheight .form-outer-wrapper,\n\t\t.stateless-form .form-outer-wrapper&gt;.row{\n\t\t\theight:100% !important;\n\t\t}\n\t\t\n\t\t.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n\t\tdiv[name=&quot;chart-div&quot;]{\n\t\t\tpadding-top:40px !important;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t&lt;\/style&gt;\n\t\n\t&lt;div class=&quot;container-wrapper&quot;&gt;\n\t&lt;input type=&quot;checkbox&quot; id=&quot;open-close-btn&quot; &gt;\n&lt;%\n\tif(staffClass.size() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;left-pane&quot;&gt;\n\t\t\t&lt;div class=&quot;stateless-form&quot; elName=&apos;zc-component&apos; formLinkName=&apos;Staff_Classes&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;label for=&quot;open-close-btn&quot;&gt;&lt;span class=&quot;fa fa-angle-left&quot;&gt;&lt;\/span&gt;&lt;\/label&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;div elName=&apos;zc-component&apos; name=&apos;content-div&apos; class=&apos;content-div&apos;&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Info_Parent_View(Child_Mail)
		{
			displayname = "Student Info - Parent View"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet41' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet41()\ncontent\n&lt;%{\n\teducationYear = Educational_Year[Educational_Year_Start_Date &lt; zoho.currentdate &amp;&amp; Educational_Year_End_Date &gt; zoho.currentdate].Academic_Year;\n\tclass = Student[Email == input.Child_Mail].Class_UID.Class_Name;\n\t%&gt;\n&lt;style&gt;\n    * {\n\t   padding: 0;\n\t   margin: 0;\n\t   border: none;\n\t   box-sizing: border-box;\n      }\n\t  \n\t div#zppagesLive,\n\t div#elementsContainer,\n\t .Layout.elemContainment,\n\t div#row_1,\n\t .zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t }\n\t\t\n\t.parent-view{\n          height: 100%;\n          width: 100%;\n          position: relative;\n\t\t  background:var(--main-container-color) ;\n\t\t  display: flex;\n\t\t  flex-direction:column;\n\t\t  padding:5px 10px;\n     }\n\t \n\t .parent-view .row1{\n\t\t height: 350px;\n\t\t display:flex;\n\t\t gap:10px;\n\t }\n\t \n\t .parent-view .row1&gt;div{\n\t\t height:100% !important;\n\t\t border-radius: 5px;\n\t\t overflow:hidden;\n\t\t box-shadow:0px 0px 5px #cdcdcd;\n\t }\n\t \n\t .staff-info{\n\t\t width:30%;\n\t }\n\t .consent-report{\n\t\t width:70%;\n\t }\n\t \n\t .zc-signature-field-group .signature-outer {\n\t\t\tbox-sizing: content-box !important;\n\t\t}\n&lt;\/style&gt;\n\n&lt;div class=&quot;parent-view&quot;&gt;\n\t&lt;div class=&quot;row1&quot;&gt;\n\t\t&lt;div elName=&apos;zc-component&apos; class=&quot;consent-report&quot; viewLinkName=&apos;Consent_Form_Parents1&apos; params=&apos;zc_Header=true&amp;zc_RecSelect=false&amp;zc_MoreAction=false&amp;zc_AddRec=false&amp;zc_ColMenu=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;div elName=&apos;zc-component&apos; class=&quot;staff-info&quot; viewLinkName=&apos;Teaching_Staff?Subject_field.Educational_Year=&lt;%=educationYear%&gt;&amp;Class=&lt;%=class%&gt;&apos; params=&apos;zc_Header=true&amp;zc_RecSelect=false&amp;zc_MoreAction=false&amp;zc_AddRec=false&amp;zc_ColMenu=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Hostel_Extended_View(quick_link)
		{
			displayname = "Hostel Extended View"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet42' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet42()\ncontent\n&lt;%{\n\tif(input.quick_link == &quot;etsy234&quot;)\n\t{\n\t\tbackicon = true;\n\t\tadd_menu_item = true;\n\t}\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getLoaderStyle()%&gt;\n&lt;style&gt;\n      * {\n            padding: 0;\n            margin: 0;\n            border: none;\n            box-sizing: border-box;\n        }\n\n\t\t div#zppagesLive,\n\t\tdiv#elementsContainer,\n\t\t.Layout.elemContainment,\n\t\tdiv#row_1,\n\t\t.zc-pb-formreport-placeholder{\n\t\t\theight: 100% !important;\n\t\t}\n\t\t\n\t\t.add_menu_item .form-header,.borrow_book .form-header\n\t\t{\n\t\t\tbackground:#fff !important;\n\t\t}\n\t\t\n\t\t .back-icon\n        {\n            position: absolute;\n            top: 20px;\n            left: 10px;\n            z-index: 1;\n            width: 30px;\n        }\n\t\t\n\t\t.row2-container{\n\t\t\theight:100%;\n\t\t}\n\t\t\n\t\t.pagereport{\n\t\t\theight:100% !important;\n\t\t}\n&lt;\/style&gt;\n &lt;div class=&quot;row2-container&quot;&gt;\n&lt;%\n\tif(backicon == true)\n\t{\n\t\t%&gt;\n&lt;a href=&quot;#Page:Hostel_Dashboard_Test&quot;&gt;&lt;img src=&quot;https:\/\/img.icons8.com\/ios-filled\/2x\/less-than.png&quot; class=&quot;back-icon&quot;&gt;&lt;\/a&gt;\n&lt;%\n\t}\n\tif(add_menu_item == true)\n\t{\n\t\t%&gt;\n&lt;div elName=&apos;zc-component&apos; class=&quot;add_menu_item&quot; formLinkName=&apos;Hostel_Menu&apos;&gt;&lt;\/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Student_Pass_Percentage(Class, ExamName, Subject)
		{
			displayname = "Student Pass Percentage"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<chart \n\telementName=\"Chart\"\n\n\ttype = 'Donut'\n\tbgColor = 'rgba(0, 0, 0, 0)'\n\ttheme = '#5555d9'\n\tlegendPos = 'right.center'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'Subject_Marks'\n\txfield = 'Exam_Status'\n\tyfields = 'count:Exam_Status'\n\t\tDelugeCriteria = 'Subject_form.Subject_Name == input.Subject &amp;&amp; Student.Class_UID == input.Class &amp;&amp; Exam_Marks.Exam_Name == input.ExamName'\n\/>\n\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page My_Class_Info
		{
			displayname = "My Class Info"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet44' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet44()\ncontent\n&lt;%{\n\tlogin = zoho.loginuserid;\n\tclass = Class[Class_Teacher.Email_ID == login];\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n\n&lt;style&gt;\n\t.container-wrapper{\n\t\tpadding:10px 20px;\n\t\t box-sizing: border-box;\n\t\theight:100%;\n\t\tbackground: var(--main-container-color);\n\t}\n\n\t.container-wrapper .pagereport{\n\t\theight:100% !important;\n\t\tborder-radius:5px;\n\t\toverflow:hidden;\n\t\tbox-shadow:0px 0px 5px #cdcdcd;\n\t}\n\t\n\t.report-container1,\n\t.report-container2{\n\t\theight:50% !important;\n\t}\n\t\n\t.report-container1{\n\t\tpadding-bottom:5px;\n\t\t box-sizing: border-box;\n\t}\n\t\n\t.report-container2{\n\t\tpadding-top:5px;\n\t\t box-sizing: border-box;\n\t}\n\t\n\ta.take-attendance:hover {\n\t\tbackground: white;\n\t\tcolor: var(--theme_brand_color);\n\t}\n\n\ta.take-attendance {\n\t\tposition: absolute;\n\t\tz-index: 1;\n\t\theight: 30px;\n\t\tbackground: var(--theme_brand_color);\n\t\tborder: 1px solid var(--theme_brand_color);\n\t\tcolor: white;\n\t\ttop: 20px;\n\t\tright: 145px;\n\t\tborder-radius: 3px;\n\t\tpadding: 5px 8px;\n\t\t box-sizing: border-box;\n\t\tcursor: pointer;\n\t\ttransition: all 0.1s ease-in;\n\t}\n\t\n\t.no-data-container{\n\t\theight:100%;\n\t\twidth:100%;\n\t\tdisplay:flex;\n\t\tjustify-content:center;\n\t\talign-items:center;\n\t}\n\t\n\t.report-container1{\n\t\tdisplay:flex;\n\t\tgap:10px;\n\t}\n\t\n\t.report1{\n\t\twidth:100%;\n\t}\n\t\n\t.report3{\n\t\twidth:calc(100% - 450px);\n\t}\n\t\n\t\t  div.view-outer-wrapper:is([id*=&quot;Gate_Pass_Request_Class_Teacher&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:last-of-type a.zc-custom-btn {\n    color: #ef2929;\n    border-color: #ef2929;\n}\n\n\tdiv.view-outer-wrapper:is([id*=&quot;Gate_Pass_Request_Class_Teacher&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:last-of-type a.zc-custom-btn:hover{\n\tbackground: #ef2929;\n    color: #fff;\n    border-color: #ef2929;\n}\n\ndiv.view-outer-wrapper:is([id*=&quot;Gate_Pass_Request_Class_Teacher&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:nth-last-of-type(2) a.zc-custom-btn {\n    color: #0ca829;\n    border-color: #0ca829;\n}\n\n\tdiv.view-outer-wrapper:is([id*=&quot;Gate_Pass_Request_Class_Teacher&quot;]) .zc-reporttype-list .list-view-inner .handsontable .wtHolder .wtHider .htCore tbody tr td.zcReport_CustomAction:nth-last-of-type(2) a.zc-custom-btn:hover{\n\tbackground: #0ca829;\n    color: #fff;\n    border-color: #0ca829;\n}\n&lt;\/style&gt;\n\n&lt;div class=&quot;container-wrapper&quot;&gt;\n&lt;%\n\tif(class.count() &gt; 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;report-container1&quot;&gt;\n\t\t&lt;div class=&quot;pagereport report1&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Student_Attendances&apos; params=&apos;zc_Header=true&amp;zc_MoreAction=false&amp;zc_Footer=false&amp;zc_AddRec=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&apos;&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-data&quot;&gt;You Are Not A Class Teacher&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Staff_Other_Info
		{
			displayname = "Staff Other Info"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet45' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet45()\ncontent\n&lt;%{\n\t%&gt;\n&lt;%=thisapp.Styles.getReportStyle()%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n\n&lt;style&gt;\n\t.container-wrapper{\n\t\tpadding:10px 20px;\n\t\theight:100%;\n\t\tbox-sizing: border-box;\n\t\tbackground: var(--main-container-color);\n\t}\n\n\t.container-wrapper .pagereport{\n\t\theight:100% !important;\n\t\tborder-radius:10px;\n\t\toverflow:hidden;\n\t\tbox-shadow:0px 0px 5px #cdcdcd;\n\t}\n\t\n\t.report-container1,\n\t.report-container2{\n\t\theight:50% !important;\n\t}\n\t\n\t.report-container1{\n\t\tpadding-bottom:5px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\t.report-container2{\n\t\tpadding-top:5px;\n\t\tbox-sizing: border-box;\n\t}\n&lt;\/style&gt;\n&lt;div class=&quot;container-wrapper&quot;&gt;\n\t&lt;div class=&quot;report-container1&quot;&gt;\n\t\t&lt;div class=&quot;pagereport report1&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;My_Questions&apos; params=&apos;zc_Header=true&amp;zc_MoreAction=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_DuplRec=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;report-container2&quot;&gt;\n\t\t&lt;div class=&quot;pagereport report2&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Question_Paper_Upload&apos; params=&apos;zc_Header=true&amp;zc_MoreAction=false&amp;zc_Footer=false&amp;zc_AddRec=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page LMS_Detail(class)
		{
			displayname = "LMS Detail"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet110' elementName=\"HTML Snippet 1\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet110()\ncontent\n&lt;%{\n\tlogin = zoho.loginuserid;\n\tclassname = input.class.toList(&quot;\/&quot;).get(0);\n\tsubjectname = input.class.toList(&quot;\/&quot;).get(1).trim();\n\tclassid = Class[Class_Name == classname.trim()].ID;\n\tlatestExam = Exam_Marks[Status != &quot;Yet to Submit Marks&quot; &amp;&amp; Class == classname] sort by Added_Time desc range from 0 to 1;\n\tstudentclass = input.class.toList(&quot;\/&quot;).get(0);\n\tstudentsubject = input.class.toList(&quot;\/&quot;).get(1).trim();\n\t%&gt;\n&lt;%=thisapp.Styles.getColors()%&gt;\n\t&lt;style&gt;\n\t\t\n\t\t.lms-detail{\n\t\t\theight:100%;\t\n\t\t\tpadding:10px;\n\t\t\t box-sizing: border-box;\n\t\t\toverflow: auto;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd inset;\n\t\t}\n\t\t\n\t\t.lms-detail&gt;.row1,\n\t\t.lms-detail&gt;.row2{\n\t\t\tdisplay:flex;\n\t\t\tgap:10px;\t\n\t\t}\n\t\t\n\t\t.lms-detail&gt;.row2&gt;div,\n\t\t.lesson-plan,\n\t\t.student-chart\n\t\t{\n\t\t\tbackground:white;\n\t\t\tborder-radius:5px;\n\t\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t\t\twidth:50%;\t\n\t\t\toverflow: hidden;\n\t\t}\n\t\t\n\t\t.student-chart{\n\t\t\theight:100%;\t\n\t\t\tposition:relative;\n\t\t}\n\t\t\n\t\t.lesson-plan{\n\/\/ \t\t\tpadding:10px;\n\t\t\t box-sizing: border-box;\n\t\t}\n\t\t\n\t\t.lesson-plan&gt;h3\n\t\t{\n\t\t\ttext-overflow: ellipsis;\n\t\t\tmax-width: 400px;\n\t\t\toverflow: hidden;\n\t\t\tline-height: inherit;\n\t\t\twhite-space: nowrap;\n\t\t\tletter-spacing: .1px;\n\t\t\tfont-weight: 400;\n\t\t\tcolor: black;\n\t\t\tfont-size: 18px;\n\t\t}\n\t\t\n\t\t\n\t.lesson-plan-content .content{\n\t\tpadding-top:10px;\n\t\t box-sizing: border-box;\n\t}\n\t\n\t.lesson-plan-content{\n\t\theight:calc(100% - 20px);\n\t\toverflow: auto;\n    \tpadding-top: 10px;\n\t\t box-sizing: border-box;\n\t}\n\t\n\t.lms-detail&gt;.row1{\n\t\theight: 340px;\t\n\t}\n\t\n\t.lms-detail .row2{\n\t\tpadding-top:10px;\n\t\tmin-height: 300px;\n\t\theight:calc(100% - 340px);\n\t\t box-sizing: border-box;\n\t}\n\t\n\t.lms-detail .row2&gt;div {\n\t\theight: 100% !important;\n\t}\n\t\n\t.zc-pb-tile-card\n\t{\n\t\tbackground: var(--main-container-color) !important;\n\t}\n\t\n\t.no-lesson-plan {\n\t  height: 100%;\n\t  display: flex;\n\t  justify-content: center;\n\t  align-items: center;\n\t}\n\t\n\t.exam-filter {\n\t\tz-index: 1;\n\t\theight: 40px !important;\n\t\tposition:absolute;\n\t\tright:10px;\n\t\ttop:10px;\n\t}\n\t\n\t.exam-filter .zc-footer-wrapper{\n\t\tdisplay:none;\n\t}\n\t\n\t.exam-filter form[name=&quot;Exam_Filter&quot;].label-left {\n\t\twidth: auto !important;\n\t}\n\t\n\t.exam-filter .form-outer-wrapper .formContainer {\n\t\tpadding: 0px !important;\n\t}\n\t\n\t.exam-filter .form-group{\n\t\tmargin:unset !important;\t\n\t}\n\t\n\t.exam-filter .zc_picklist_label\n\t{\n\t\tpadding-right: 10px !important;\n\t\t box-sizing: border-box;\n    \twidth: auto !important;\n\t}\n\t\n\t.exam-filter .zc-form-fullheight,\n\t.exam-filter .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t.exam-filter .select2-search-choice-close,\n\t.exam-filter .cogLoader.fa.fa-spinner.fa-spin{\n\t\tdisplay: none !important;\t\n\t}\n\t\n\tdiv[name=&quot;chart-div&quot;] .svgarea{\n\t\ttop: 15px !important;\n\t}\n\t\n\t.lesson-plan-content .timeline-outer:not(:last-child){\n\t\tborder-bottom: 1px solid #e1e1e1\n\t\t\n\t}\n\t&lt;\/style&gt;\n\t&lt;div class=&quot;lms-detail&quot;&gt;\n\t&lt;div class=&quot;row1&quot;&gt;\n\t&lt;div class=&quot;student-chart&quot;&gt;\n\t\t&lt;div class=&quot;pagereport report1&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Class_Student_List?Class=&lt;%=studentclass%&gt;&apos; params=&apos;zc_ReportName=true&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=false&amp;zc_Search=true&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;lesson-plan&quot;&gt;\n\t\t&lt;div class=&quot;sub-header&quot;&gt;&lt;h3 class=&quot;common-header&quot;&gt;Lesson Plan&lt;\/h3&gt;&lt;\/div&gt;\n\t\t&lt;div class=&quot;lesson-plan-content&quot;&gt;\n&lt;%\n\tlessonplans = Lesson_Plan_Mapping[Staff.Email_ID == login &amp;&amp; Subject_field.Subject_Name == subjectname];\n\tif(Lesson_Plan[Lesson_Plan_Mapping in lessonplans.ID.getall()].count() == 0)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;no-lesson-plan&quot;&gt;No Lesson Plans Available&lt;\/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\tfor each  lessonplan in lessonplans.Lesson_Plan\n\t\t{\n\t\t\t%&gt;\n&lt;div class=&quot;timeline-outer&quot;&gt;\n\t\t\t\t\t\t&lt;div class=&quot;timeline-inner&quot;&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-date&quot;&gt;&lt;%=lessonplan.Module.Module_Name%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t\t&lt;span class=&quot;timeline-value&quot;&gt;&lt;%=lessonplan.Module_Contents%&gt;&lt;\/span&gt;\n\t\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t\t}\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Room_Allottment
		{
