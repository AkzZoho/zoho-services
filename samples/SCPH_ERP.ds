			hideAndDisableFields as "hideAndDisableFields"
			{
				type =  form
				form = Room_Selection
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Student;
										hide Request_Type;
										getRoom = Room[Room_Status != "Occupied" && block.Block_Type == "Hostel"].ID.getAll();
										input.Room:ui.add(getRoom);
						)
					}
				}

			}
			onSubmission24 as "onSubmission"
			{
				type =  form
				form = Room_Selection
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						room = Room[ID == input.Room];
										room.Student.add(input.Student);
										allStudents = room.Student;
										allStudents.add(input.Student);
										room.Student=allStudents;
										if(input.Request_Type == "Room Change")
										{
											oldRoom = Room[Student == input.Student && Room_Type1.Room_Type == "Hostel"];
											oldRoom.Student.remove(input.Student);
											if(oldRoom.Student.size() > 0)
											{
												oldRoom.Room_Status="Partially Occupied";
											}
											else
											{
												oldRoom.Room_Status="Empty";
											}
										}
										if(room.Student.size() < room.Capacity)
										{
											room.Room_Status="Partially Occupied";
										}
										else
										{
											room.Room_Status="Occupied";
										}
										student = Student[ID == input.Student];
										student.Hostel_Room_Allotted=true;
										wardenList = Block1[ID == input.Room.block].Warden;
										if(wardenList.size() > 0)
										{
											student.Warden=wardenList.get(0);
										}
										roomRequests = Room_Requests[Student == input.Student && Status == "Raised"];
										roomRequests.Status="Approved";
										block = Block1[ID == input.Room.block];
										sendmail
										[
											from :zoho.adminuserid
											to :input.Student.Primary_Contact_Email
											subject :"Regarding Room Request"
											message :"Dear Parent, <br> I am writing to inform you that your Room Request has been approved. <br><br><br> Room Number - " + input.Room.Room_Number + "<br> Block - " + block.Block_Name + "<br>Regards, <br> Hostel Admin"
										]
										openUrl("#Script:page.parent.refresh","parent window");
					)
					}
				}
			}
			onLoad3 as "onLoad"
			{
				type =  form
				form = Vehicle
				record event = on add or edit

				on load
				{
					actions 
