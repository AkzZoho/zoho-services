			Populate_Default_Fields as "Populate Default Fields"
			{
				type =  form
				form = Student_Fee_Subform
				record event = on add or edit

				on add row of Concession_Details
				{
					actions 
					{
						custom deluge script
						(
											row.Fee_Head=input.Fee_Head;
						)
					}
				}

			}
			Populate_Concession_Amoun as "Populate Concession Amount"
			{
				type =  form
				form = Student_Fee_Subform
				record event = on edit

				on user input of Concession_Details.Concession
				{
					actions 
					{
						custom deluge script
						(
											if(row.Concession != null)
										{
											if(row.Concession.Concession_Percentage == 0)
											{
												enable row.Concession_Amount;
											}
											else
											{
												ConcessionPercentage = Concession_Master[ID == row.Concession].Concession_Percentage;
												row.Concession_Amount=(ifnull(input.Fee_Amount,0) * ConcessionPercentage) / 100;
												if(row.Concession_Amount > input.Fee_Amount)
												{
													alert "The Concession amount is greater than Fee Amount";
													row.Concession_Amount=input.Fee_Amount;
												}
											}
										}
										input.Total_Concession_Amount = input.Concession_Details.sum(Concession_Amount);
										input.Net_Amount = input.Fee_Amount - ifnull(input.Total_Concession_Amount,0);
										input.Balance_Amount = input.Net_Amount - input.Paid_Amount;
										if(input.Balance_Amount == 0)
										{
											input.Disable_Concession = true;
										}
						)
					}
				}

			}
			Calculate_Concession_Tota as "Calculate Concession Total"
			{
				type =  form
				form = Student_Fee_Subform
				record event = on edit

				on user input of Concession_Details.Concession_Amount
				{
					actions 
					{
						custom deluge script
						(
											input.Total_Concession_Amount = input.Concession_Details.sum(Concession_Amount);
										input.Net_Amount = input.Fee_Amount - ifnull(input.Total_Concession_Amount,0);
										input.Balance_Amount = input.Net_Amount - input.Paid_Amount;
										if(input.Balance_Amount == 0)
										{
											input.Disable_Concession = true;
										}
						)
					}
				}

			}
