 	forms
	{
		form Educational_Year
		{
			displayname = "Academic Year"
			success message = "Educational Year Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Academic_Year
			(
    			type = text
				displayname = "Academic Year"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Educational_Year_Start_Date
			(
    			type = date
				displayname = "Academic Year Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Educational_Year_End_Date
			(
    			type = date
				displayname = "Academic Year End Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Current","Upcoming","Past"}
				initial value = "Current"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
