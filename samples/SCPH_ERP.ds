				custom action "Create/Edit Blueprint"
				(
	  			workflow = uploadQuestionPaper
				show action in edit record menu = true
				column header = "Create/Edit Blueprint"
				condition = (Question_Paper_Status != "Question Paper Generated" && Question_Paper_Status != "Question Paper Uploaded")
				)
				Exam_Name.Class
				custom action "Generate Question Paper"
				(
	  			workflow = generateQuestionPaper
				show action in edit record menu = true
				column header = "Generate Question Paper"
				condition = (Question_Paper_Status == "Blueprint Submitted")
				)
