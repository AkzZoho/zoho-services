t;\/div&gt;\n\t\t &lt;div class=&quot;report-container-div&quot;&gt;\n\t\t &lt;div class=&quot;row2-container&quot;&gt;\n\t\t  &lt;div name=&quot;reportdiv&quot; class=&apos;reportdiv&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;Return_Books&apos; params=&apos;zc_Footer=false&amp;zc_SecHeader=true&amp;zc_AddRec=false&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&amp;zc_ColMenu=false&amp;zc_SaveRec=false&amp;zc_MoreAction=false&amp;zc_ShowAs=false&amp;zc_Print=false&amp;zc_Search=true&amp;zc_RecSelect=false&apos;&gt;&lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t\t  &lt;div class=&quot;row2-container&quot;&gt;\n\t\t  &lt;div name=&quot;reportdiv&quot; class=&apos;reportdiv&apos; elName=&apos;zc-component&apos; viewLinkName=&apos;Library_In_Visitors&apos; params=&apos;zc_Footer=false&amp;zc_SecHeader=true&amp;zc_AddRec=false&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&amp;zc_ColMenu=false&amp;zc_SaveRec=false&amp;zc_MoreAction=false&amp;zc_ShowAs=false&amp;zc_Print=false&amp;zc_Search=true&amp;zc_RecSelect=false&apos;&gt;&lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t\t &lt;\/div&gt;\n\t  &lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
