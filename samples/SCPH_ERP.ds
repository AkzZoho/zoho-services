			onSubmission27 as "onSubmission"
			{
				type =  form
				form = Student
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											modules = Modules[ID != 0];
										if(modules.Hostel == "Yes" && input.Hosteller == true)
										{
											resp = insert into Room_Requests
											[
												Added_User=zoho.loginuser
												Student=input.ID
												Request_Type="New Room Request"
												Reason="New Request"
												Status="Raised"
											];
										}
										if(modules.Transport == "Yes" && input.Requested_for_Bus == true)
										{
											respe = insert into Transport_Request
											[
												Added_User=zoho.loginuser
												Student=input.ID
												Bus_Stops=input.Pickup_Point
												Status="Raised"
											];
										}
										input.Status = "Active";
						)
					}
				}

			}
