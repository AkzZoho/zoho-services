			Field_Scripts as "Field Scripts"
			{
				type =  form
				form = Staff
				record event = on add or edit

				field rules
				{
					actions  (Marital_Status == "Married")
					{
						show Spouse_Contact_Number,Spouse_Name;
					}
					actions  (Has_Experience == true)
					{
						show Experience_Info,Experience;
					}
					actions  (Has_Special_Medical_Issues == true)
					{
						show Medical_Info;
					}
					actions 
					{
						hide Membership,Status,Current_Session,Department1;
					}
				}

			}
			hideAndShowFields as "hideAndShowFields"
			{
				type =  form
				form = Student
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide Sibling_Details,Medical_Condition,Previous_School_Data,Hostel_Room_Allotted,Warden,Bus_allotted,Status,Annual_Exam_Result,Registration,Class_DB,Class_DB1,Requested_for_Bus,Admission_Number,Hidden,Pricing_Type;
					}
					actions  (Has_Siblings == true)
					{
						show Sibling_Details;
					}
					actions  (Has_Special_Medical_Issues == true)
					{
						show Medical_Condition;
					}
					actions  (Studied_in_another_school_prior_to_this == true)
					{
						show Previous_School_Data;
					}
					actions  (Requested_for_Bus == true)
					{
						hide Hosteller;
					}
					actions  (Hosteller == true)
					{
						hide Requested_for_Bus,Pickup_Point;
					}
					actions  (Transport_Type == "School Transport")
					{
						show Transport_Service_Type,Pickup_Point;
					}
				}

			}
