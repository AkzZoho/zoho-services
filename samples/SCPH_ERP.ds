alse&amp;zc_AddRec=true&amp;zc_Search=true&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;row2&quot;&gt;\n\t\t&lt;div name=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Room_Requests1&apos; class=&quot;pagereport report3&quot; params=&apos;zc_ReportName=true&amp;zc_RecSelect=true&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=true&amp;zc_Search=true&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;row3&quot;&gt;\n\t\t&lt;div class=&quot;header&quot;&gt;\n\t\t\t&lt;div name=&quot;pagereport&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Hostel&apos; class=&quot;pagereport report2&quot; params=&apos;zc_ReportName=true&amp;zc_RecSelect=false&amp;zc_Footer=false&amp;zc_ColMenu=false&amp;zc_EditRec=false&amp;zc_DuplRec=false&amp;zc_DelRec=false&amp;zc_AddRec=false&amp;zc_Search=true&amp;zc_MoreAction=false&apos;&gt;&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
