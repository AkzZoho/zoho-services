			onSubmission42 as "onSubmission"
			{
				type =  form
				form = Mark_Attendance1
				button = Submit
				on click
				{
					actions 
					{
					on click
					(
						if(input.Absentees.size() == 0)
										{
											student = Class_Attendance[Student.Class_UID == input.Class && Date_field == zoho.currentdate && Student.Status == "Active"];
										}
										else
										{
											student = Class_Attendance[Student.Class_UID == input.Class && Date_field == zoho.currentdate && Student.Status == "Active" && Student not in input.Absentees];
										}
										for each  stud in student
										{
											if(input.Attendance_Time == "Morning")
											{
												stud.Is_Present_in_Morning=true;
											}
											else
											{
												stud.Is_Present_in_Afternoon=true;
											}
										}
										openUrl("#Page:My_Class_Info?zc_LoadIn=embed-staffpage","same window");
					)
					}
				}
			}
