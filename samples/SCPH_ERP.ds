			createDailySessions as "createDailySessions"
			{
				type =  schedule
				form = Educational_Year
				start = Educational_Year_Start_Date at "08:10:00"
				end   = Educational_Year_End_Date
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						// 4265137000001695066
										val = zoho.currentdate.addDay(7);
										curEduYear = Educational_Year[Status == "Current"];
										if(val.weekday() != 1)
										{
											allClasses = Class[Educational_Year == curEduYear];
											// 	clas = Class[ID == 4254807000205968003];
											for each  clas in allClasses
											{
												resp = insert into Sessions
												[
													Added_User=zoho.loginuser
													Class=clas
													Educational_Year=curEduYear
													Date_field=val
												];
												allSession = Collection();
												tim = Time_Table[Class == clas];
												counter = 0;
												prevRoomID = null;
												for each  rec in tim.Time_Table_Subform
												{
													info rec.Time;
													info rec.Friday.Subject_Name;
													counter = counter + 1;
													if(val.weekday() == 2)
													{
														les = Lesson_Plan_Mapping[Class == clas.ID && Subject_field == rec.Monday1];
														for each  sube in les
														{
															prevRoom = Room[ID == prevRoomID];
															mainSubject = Subject_form[ID == sube.Subject_field];
															if(mainSubject.Subject_Name != "Lunch")
															{
																availableRoom = null;
																existingSession = Session_Subform[Subject_form == sube.Subject_field && Staff == sube.Staff && Sessions.Date_field == val && Session_Name == rec.Time];
																// prefered room check
																isRoomAvailable = Session_Subform[Session_Name == rec.Time && Sessions.Date_field == val && Room == sube.Preferred_Room];
																nonAvailableRooms = Session_Subform[Session_Name == rec.Time && Sessions.Date_field == val].Room.getAll();
																if(isRoomAvailable.count() != 0)
																{
																	if(prevRoom == null)
																	{
																		sameFloorRooms = Room[Floor_Number == sube.Preferred_Room.Floor_Number && block == sube.Preferred_Room.block && ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																		if(sameFloorRooms.count() == 0)
																		{
																			sameBlockRooms = Room[block == sube.Preferred_Room.block && ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																			if(sameBlockRooms.count() == 0)
																			{
																				availableRoms = Room[ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																				if(availableRoms.count() == 0)
																				{
																				}
																				else
																				{
																					availableRoom = availableRoms.ID;
																				}
																			}
																			else
																			{
																				availableRoom = sameBlockRooms.ID;
																			}
																		}
																		else
																		{
																			availableRoom = sameFloorRooms.ID;
																		}
																	}
																	else
																	{
																		sameFloorRooms = Room[Floor_Number == prevRoom.Floor_Number && block == prevRoom.block && ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																		if(sameFloorRooms.count() == 0)
																		{
																			sameBlockRooms = Room[block == prevRoom.block && ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																			if(sameBlockRooms.count() == 0)
																			{
																				availableRoms = Room[ID != nonAvailableRooms && Room_Type1.Room_Type == "Class"];
																				if(availableRoms.count() == 0)
																				{
																				}
																				else
																				{
																					availableRoom = availableRoms.ID;
																				}
																			}
																			else
																			{
																				availableRoom = sameBlockRooms.ID;
																			}
																		}
																		else
																		{
																			availableRoom = sameFloorRooms.ID;
																		}
																	}
																}
																else
																{
																	availableRoom = sube.Preferred_Room;
																}
																prevRoomID = availableRoom;
																if(existingSession.count() == 0)
																{
																	timeList = rec.Time.toList("-");
																	startTime = (val.toDate() + " " + timeList.get(0).trim()).toTime();
																	endTime = (val.toDate() + " " + timeList.get(1).trim()).toTime();
																	sessionInsert = insert into Session_Subform
																	[
																		Added_User=zoho.loginuser
																		Session_Mode="Offline"
																		Session_Type="Regular"
																		Session_Name=rec.Time
																		Subject_form=sube.Subject_field
																		Staff=sube.Staff
																		Room=availableRoom
																		Sessions=resp
																		lmp=sube
																		Session_Start_Time=startTime
																		Session_End_Time=endTime
																	];
																	for each  stu in sube.Student
