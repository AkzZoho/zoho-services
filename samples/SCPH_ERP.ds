			on_success5 as "on success"
			{
				type =  form
				form = Fee_Detail
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											getIncomeRec = Income_Vs_Expense[Date_field == input.Payment_Date];
										if(getIncomeRec.count() == 0)
										{
											expenseAmount = Add_Expense[Date_field == input.Payment_Date].sum(Amount);
											incomeAmount = Fee_Detail[Payment_Date == input.Payment_Date].sum(Amount);
											amountDet = insert into Income_Vs_Expense
											[
												Added_User=zoho.loginuser
												Revenue_Amount=incomeAmount
												Expense_Amount=expenseAmount
												Date_field=input.Payment_Date
											];
										}
										else
										{
											getIncomeRec.Revenue_Amount=Fee_Detail[Payment_Date == input.Payment_Date].sum(Amount);
										}
						)
					}
				}

			}
