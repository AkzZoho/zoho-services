			on_Load4 as "on Load"
			{
				type =  form
				form = Staff
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Candidate != null)
										{
											candidateRec = Candidate[ID == input.Candidate];
											imagefile = candidateRec.Photo.getSuffix("fieldName/image/").getPrefix("\" lowqual");
											if(thisapp.portal.isUserInProfile("Admin") == true || thisapp.portal.isUserInProfile("Student") == true)
											{
												appurl = thisapp.getPortalUrl();
											}
											else
											{
												appurl = "https://creatorapp.zoho.in";
											}
											imageUrl = appurl + "/file" + zoho.appuri + "All_Candidates/" + candidateRec.ID + "/Photo/image-download?filepath=/" + imagefile;
											input.Aadhar_No = candidateRec.Aadhar_No;
											input.PAN_No = candidateRec.PAN_No;
											input.Account_No1 = candidateRec.Account_No;
											input.Bank_Name = candidateRec.Bank_Name;
											input.IFSC_Code = candidateRec.IFSC_Code;
											input.Branch = candidateRec.Branch;
											input.Consolidated_Pay = candidateRec.Consolidated_Pay;
											input.Contact_Number = candidateRec.Contact_Number;
											input.Email_ID = candidateRec.Email_ID;
											input.Name = candidateRec.Name;
											input.Staff_Type = candidateRec.Staff_Type;
											input.Role = candidateRec.Designation;
											input.Address.address_line_1 = candidateRec.Address.address_line_1;
											input.Address.address_line_2 = candidateRec.Address.address_line_2;
											input.Address.district_city = candidateRec.Address.district_city;
											input.Address.state_province = candidateRec.Address.state_province;
											input.Address.postal_Code = candidateRec.Address.postal_Code;
											input.Address.country = candidateRec.Address.country;
											input.Gender = candidateRec.Gender;
											input.Date_of_Birth = candidateRec.Date_of_Birth;
											input.Photo = "<img src=\"" + imageUrl + "\"></img>";
											input.Date_of_Joining = candidateRec.Joining_Date;
											// 	input.Branch1 = candidateRec.Branch1;
											// 	disable Branch1;
										}
						)
					}
				}

			}
