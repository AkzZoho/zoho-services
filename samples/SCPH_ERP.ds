			dateValidationOnInputStar as "dateValidationOnInputStartDate"
			{
				type =  form
				form = Exam
				record event = on add or edit

				on user input of Assessment_Start_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.Assessment_Start_Date < zoho.currentdate)
										{
											input.Assessment_Start_Date = null;
											alert "Please enter valid future date!";
										}
										if(input.Assessment_End_Date < input.Assessment_Start_Date)
										{
											input.Assessment_Start_Date = null;
											alert "Please enter valid Assesment Start date!";
										}
										for each  data in input.Exam_Schedule
										{
											if(input.Assessment_Start_Date != null && input.Assessment_End_Date != null && data.Exam_Start_Time != null)
											{
												if(data.Exam_Start_Time < input.Assessment_Start_Date || data.Exam_Start_Time.toString("dd-MMM-yyyy").toTime() > input.Assessment_End_Date)
												{
													data.Exam_Start_Time=null;
												}
											}
										}
						)
					}
				}

			}
