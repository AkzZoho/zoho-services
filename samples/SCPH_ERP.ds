			Validation_of_Repair_Crea as "Validation of Repair Creation"
			{
				type =  form
				form = Vehicle_Repair_Details
				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											VehicleInfo = Vehicle[ID == input.Vehicle];
										if(VehicleInfo.count() > 0)
										{
											currentCapacity = Vehicle[Bus_Route == VehicleInfo.Bus_Route && Status != "Under Maintenance"].Students.getAll().size();
											totalCapacity = Vehicle[Bus_Route == VehicleInfo.Bus_Route && ID != VehicleInfo.ID && Status != "Under Maintenance"].sum(Vehicle_Total_Capacity);
											info currentCapacity;
											info totalCapacity;
											if(totalCapacity > 0 && totalCapacity >= currentCapacity)
											{
												studentList = VehicleInfo.Students;
												temp = 0;
												studentSize = VehicleInfo.Students.size();
												for each  bus in Vehicle[Bus_Route == VehicleInfo.Bus_Route && ID != VehicleInfo.ID && Status != "Under Maintenance"] sort by Vacancy desc
												{
													cbCapacity = bus.Vehicle_Total_Capacity - bus.Students.size();
													tempCurrentBusStudentList = bus.Students;
													studentsCounter = if(cbCapacity <= studentSize - temp,cbCapacity,studentSize - temp);
													tempCurrentBusStudentList.addAll(studentList.sublist(temp,temp + studentsCounter));
													bus.Students=tempCurrentBusStudentList;
													if(cbCapacity >= studentSize - temp)
													{
														VehicleInfo.Status="Under Maintenance";
														break;
													}
													temp = temp + cbCapacity;
												}
											}
											else if(totalCapacity <= 0)
											{
												alert "We cannot find any other bus in this route";
												cancel submit;
											}
											else
											{
												alert "Total Capacity Reached Cannot Remove Bus from Service";
												cancel submit;
											}
										}
										// cancel submit;
						)
					}
				}

			}
