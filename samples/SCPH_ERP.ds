		default list My_Class_Attendances
		{
			displayName = "My Class Attendances"
			show all rows from Class_Attendance  [Class.Class_Teacher == thisapp.schoolManagement.getStaffId()]  
			(
				Class
				Student
				Date_field as "Date"
				Is_Present_in_Morning as "Morning Attendance"
				(
						displaytrue = "true"
						displayfalse = "false"
				)
				Is_Present_in_Afternoon as "Afternoon Attendance"
				(
						displaytrue = "true"
						displayfalse = "false"
				)
				Type_field as "Type"
				custom action "Absent (Morning)"
				(
	  			workflow = morningAttendance
				show action in view header = true
				show action in edit record menu = true
				column header = "Absent (Morning)"
				condition = (Is_Present_in_Morning == true && Date_field is today)
				)
				custom action "Absent (Evening)"
				(
	  			workflow = eveningAttendance
				show action in view header = true
				show action in edit record menu = true
				column header = "Absent (Evening)"
				condition = (Is_Present_in_Afternoon == true && Date_field is today)
				)
				Student_Attendance as "Student Attendance"
				Student.Photo
				Student_Attendance.Morning_Attendance_Taken as "Morning Attendance Taken"
				Student_Attendance.Evening_Attendance_Taken as "Evening Attendance Taken"
			)
		}
