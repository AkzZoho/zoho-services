			onSubmission6 as "onSubmission"
			{
				type =  form
				form = Create_Event
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.Educational_Year = Educational_Year[Educational_Year_Start_Date <= input.Event_Start_Date1 && Educational_Year_End_Date >= input.Event_Start_Date1].ID;
										if(input.Selection_Type == "Class")
										{
											studentList = Student[Class_UID in input.Class].ID.getAll();
										}
										else if(input.Selection_Type = "Students")
										{
											studentList = input.Student;
										}
										for each  rec in studentList
										{
											performanceRec = insert into Student_Extracurricular_Activities
											[
												Event=input.ID
												Student=rec
												Added_User=zoho.loginuser
											];
										}
										openUrl("#Script:page.reload","same window");
						)
					}
				}

			}
