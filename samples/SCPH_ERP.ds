		form Vehicle
		{
			success message = "Transport Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Vehicle
			(
				type = picklist	
				values  = Vehicle_DB.ID
    			displayformat = [Vehicle_Name]
				allow new entries
				[
					displayname = "Add New Vehicle"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Bus_Name
			(
    			type = text
				displayname = "Vehicle Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Bus_Registration_Number
			(
    			type = text
				displayname = "Vehicle Registration Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Bus_Route
			(
				type = picklist	
				displayname = "Bus Route"
				values  = Route.ID
    			displayformat = [Route_Name]
				allow new entries
				[
					displayname = "Add Route"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Vehicle_Total_Capacity
			(
				type = number
				displayname = "Vehicle Total Capacity"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Driver
			(
				type = picklist	
				values  = Staff[Staff_Type == "Driver"].ID
    			displayformat = [" " + Name.first_name + " " + Name.last_name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Incharge1
			(
				type = list	
				displayname = "Incharges"
				values  = Staff.ID
    			displayformat = [" " + Name.first_name + " " + Name.last_name]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Students
			(
				type = list	
				values  = Student[Student_Category == "Day Scholar"].ID
    			displayformat = [" " + Student_Name.first_name + " " + Student_Name.last_name]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Morning_Start_Time
			(
    			type = time
				displayname = "Morning Start Time"
				mins_displayinterval = 5
				timedisplayoptions = "hh:mm" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Evening_Start_Time
			(
    			type = time
				displayname = "Evening Start Time"
				mins_displayinterval = 5
				timedisplayoptions = "hh:mm" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			Vacancy
			(
    			type = formula
				value =  input.Vehicle_Total_Capacity - input.Students.size()
				visibility = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Under Maintenance","Vehicle Capacity Reached","Available"}
				initial value = "Available"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Bus_Stops
			(
				type = list	
				displayname = "Bus Stops"
				values  = Bus_Stops.ID
    			displayformat = [Stop_Name]
				sortorder = ascending
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Repair_Details
			(
				type = grid
				displayname = "Repair Details"
				values  = Vehicle_Repair_Details.ID
    			bidirectional = Vehicle
	 			row = 2
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
