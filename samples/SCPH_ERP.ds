			on_success1 as "on success"
			{
				type =  form
				form = Student_Remarks
				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											for each  rec in input.Remark_Details
										{
											cumulativeRec = Cumulative_Ranking[Educational_Year == input.Educational_Year && Student == input.Student];
											totalPoints = 0;
											for each  point in Student_Remark_Details[Student_Remarks == input.ID && Scale != ""]
											{
												totalPoints = totalPoints + point.Scale.toNumber();
											}
											if(cumulativeRec.count() != 0)
											{
												cumulativeRec.Attitude_Performance=totalPoints;
												cumulativeRec.Overall_Performance=cumulativeRec.Academic_Performance + cumulativeRec.Extracurricular + cumulativeRec.Attitude_Performance;
											}
											else
											{
												cumulativeRecord = insert into Cumulative_Ranking
												[
													Educational_Year=input.Educational_Year
													Overall_Performance=totalPoints
													Attitude_Performance=totalPoints
													Extracurricular=0
													Academic_Performance=0
													Student=input.Student
													Added_User=zoho.loginuser
												];
											}
										}
										thisapp.updateRanking(input.Educational_Year);
										openUrl("#Script:page.reload","same window");
						)
					}
				}

			}
