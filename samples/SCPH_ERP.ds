n\t#report_2 .divEmbedContainer{\n\t\tmin-height:unset !important;\n\t}\n\t\n\t#report_1 div[elname=&quot;recordcontainerwrapper&quot;]&gt;div,\n\t#report_2 div[elname=&quot;recordcontainerwrapper&quot;]&gt;div{\n\t\theight:100%;\n\t}\n\t\n\t#report_1 div[elname=&quot;recordcontainerwrapper&quot;]&gt;div iframe,\n\t#report_2 div[elname=&quot;recordcontainerwrapper&quot;]&gt;div iframe{\n\t\theight:calc(100% - 20px) !important;\n\t}\n\t\n\t.container-wrapper{\n\t\theight:100%;\n\t\twidth:100%;\n\t\tpadding:10px 20px;\n\t\tbox-sizing: border-box;\n\t\tbackground: var(--main-container-color);\n\t}\n\t\n\t.second-row{\n\t\theight:100%;\n\t\twidth:100%;\n\t}\n\t\n\t\t\/*form styles *\/\n\t\t.nav-stateless-form label.form-label.zc-dem-clearfix.zc-Radio-label.zc_picklist_label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.nav-stateless-form .form-group {\n          margin-bottom:0px !important;\n        }\n\t\t\n\t\t.nav-stateless-form .formbutton {\n\t\t\t  padding: 0 !important;\n\t\t }\n\t\t\t\n\t\t.nav-stateless-form .divEmbedContainer {\n         padding-top: 0px !important;\n        }\n\t\t\n\t\t.nav-stateless-form .zc-footer-wrapper {\n          border-top: none !important;\n\t\t  display:none;\n        }\n\t\t\n\t\t.nav-stateless-form .choice-table-cell span .customRadio+label\n\t\t{\n\t\t\tdisplay:none !important;\n\t\t}\n\t\t\n\t\t.nav-stateless-form .choice-table-cell span\n\t\t{\n\t\t\tpadding:0px !important;\n\t\t}\n\t   \n\t .nav-stateless-form .form-group.clearfix.zc-Radio-group.zc-radio-field-group\n\t {\n\t\t width:100% !important;\n\t }\n\t \n\t .nav-stateless-form .form-field .tempContDiv .choice-table-row\n\t {\n\t\t display:flex;\n\t\t justify-content: space-around;\n\t\t margin-right: 10px;\n\t }\n\t \n\t.nav-stateless-form .zc-form-fullheight .form-outer-wrapper .formContainer,\n\t.nav-stateless-form .form-outer-wrapper .formContainer\n\t{\n\t\tpadding:0px !important;\n\t}\n\t\n\t.nav-stateless-form .customRadio:checked+label+choice-label-text\n\t{\n\t\tcolor:green;\n\t}\n\t\n\t.nav-stateless-form form.form-table {\n\t\twidth: 100% !important;\n\t}\n\t\n\t\t.nav-stateless-form form.form-table {\n\t\t\theight: 30px !important;\n\t\t}\n\t\t\n\t\t.nav-stateless-form form.form-table .zc-form-fullheight{\n\t\t\tbackground:transparent !important;\n\t\t}\n\t\t\n\t.nav-stateless-form form.form-table .zc-form-fullheight .form-outer-wrapper {\n\t\t\tanimation: unset !important;\n\t\t}\n\t\t\n\t\t.nav-stateless-form form.form-table .choice-label-text {\n\t\t\tfont-size: 17px !important;\n\t\t\tmix-blend-mode: normal;\n\t\t\tpadding: 0px 15px;\n\t\t\tbox-sizing: border-box;\n\t\t\twidth: 100%;\n\t\t  display: flex;\n\t\t  justify-content: center;\n\t\t}\n\t\t\n\t.nav-stateless-form .flLeft.tempContDiv.zc-Radio {\n\t\twidth: 100% !important;\n\t\tborder-bottom: 2px solid var(--header-line-color);\n\t\tdisplay:flex !important;\n\t}\n\t\n\t.nav-stateless-form .form-field .tempContDiv .choice-table-cell {\n\t\tdisplay: flex;\n\t\tpadding: 0px;\n\t\tjustify-content: center;\n\t\twidth: 100%;\n\t}\n\t\n\t.nav-stateless-form .choice-table-cell input~label {\n       position: relative;\n\t}\n\n\t.nav-stateless-form .choice-table-cell input:checked~label:before {\n\t\tcontent: &quot;&quot;;\n\t\tborder-bottom: 2px solid var(--header-checked-line-color);\n\t\ttop: 100%;\n\t\twidth: 100%;\n\t\tposition: absolute;\n\t}\n\t\n\t.nav-stateless-form .choice-table-cell span\n\t{\n\t\twidth:100%;\n\t}\n\t\n\t.nav-stateless-form.divEmbedContainer {\n\t\theight: 30px !important;\n\t}\n\t\n\t.nav-stateless-form .zc-form-fullheight,\n\t.nav-stateless-form .zc-form-fullheight .form-outer-wrapper{\n\t\tbackground:transparent !important;\n\t}\n\t\n\t\t.nav-stateless-form .choice-table-cell input:checked~label {\n\t\t\tcolor:var(--theme_brand_color);\n\t\t\tfont-weight: 700;\n\t\t}\n\t\t\n\/* \t\t.nav-stateless-form .choice-table-cell input:not(:checked) ~ label:hover {\n\t\t\t transform: perspective(200px) translateZ(25px);\n\t\t\t color: var(--report-header-background-color);\n\t\t} *\/\n\t\/* Hide - Form Loader Icon *\/\n\t\t.nav-stateless-form i.cogLoader.fa.fa-spinner.fa-spin{\n\t\t\tdisplay:none;\n\t\t}\n\t\t\n\t\/* Report Styles *\/\n\t.pagereport{\n\t\theight: calc(100% - 30px) !important;\n\t\tpadding-top: 10px;\n\t\tbox-sizing: border-box;\n\t}\n\n\t.pagereport&gt;.view-outer-wrapper\n\t{\n\t\tborder-radius: 8px;\n\t\toverflow: hidden;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t}\n\t\n\tdiv#report_1 .zc-pb-tile-card ,\n\tdiv#report_2 .zc-pb-tile-card \n\t{\n\t\toverflow:hidden;\n\t}\n\t\n\tdiv#row_1 {\n\t\tpadding: 10px 20px;\n\t\tbox-sizing: border-box;\n\t\tbackground: var(--main-container-color);\n\t}\n\t\n\tdiv#row_1 .column-container:first-child{\n\t\tpadding-right:5px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\tdiv#row_1 .column-container:last-child{\n\t\tpadding-left:5px;\n\t\tbox-sizing: border-box;\n\t}\n\t\n\tdiv#row_1 .column-container&gt;.zpelement-wrapper{\n\t\tborder:unset !important;\n\t\tborder-radius: 5px;\n\t\toverflow: hidden;\n\t\tbox-shadow: 0px 0px 5px #cdcdcd;\n\t}\n\t\n\t.zc-dem-container .inner .form-outer-wrapper form.form-table{\n\t\t\tborder-radius: unset !important;\n\t\t}\n.inner .zc-page-content-wrapper .zc-pb-page-content-wrapper .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-table .form-header{\n         display: none !important;\n      }\n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .zc-form-scroll-wrapper{\n  margin:unset !important;\n  }\n  \n  .divEmbedContainer:is(.checkout,.student_tab_search,.stateless-form,.exam-filter) .form-outer-wrapper.form-outer-wrapper {\n            height: 100% !important;\n      }\n&lt;\/style&gt;\n&lt;div class=&apos;container-wrapper&apos;&gt;\n\t&lt;div class=&apos;second-row&apos;&gt;\n\t\t&lt;div class=&quot;nav-stateless-form&quot; elName=&apos;zc-component&apos; formLinkName=&apos;Inventory_Nav&apos; params=&apos;zc_Header=false&apos;&gt;&l