			approveRoomChangeRequest as "approveRoomChangeRequest"
			{
				type =  functions
				form = Room
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						input.Student.removeElement(input.Room_change_Requested_by);
										student = Student[ID == input.Room_change_Requested_by];
										student.Hostel_Room_Allotted=false;
										input.Room_change_requested = false;
										if(input.Student.size() > 0)
										{
											input.Room_Status = "Partially Occupied";
										}
										else
										{
											input.Room_Status = "Empty";
										}
					)
					}
				}
			}
