			Generate_Classes as "Generate Classes"
			{
				type =  form
				form = Staff_Classes
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											clear Radio;
										login = zoho.loginuserid;
										staffClass = Lesson_Plan_Mapping[Staff.Email_ID == login];
										classes = list();
										for each  class in staffClass
										{
											for each  cls in class.Class
											{
												classes.add(cls.Class_Name + " / " + class.Subject_field.Subject_Name);
											}
										}
										classes = classes.sort();
										input.Radio:ui.add(classes);
										if(classes.size() > 0)
										{
											Radio.select(classes.get(0));
										}
						)
					}
				}

			}
