			addSubjectData as "addSubjectData"
			{
				type =  form
				form = Subject_form
				record event = on add or edit

				on add row of Lesson_Plan_Mapping
				{
					actions 
					{
						custom deluge script
						(
											if(input.Class == null)
										{
											alert "Please enter For Class value";
											input.Lesson_Plan_Mapping.clear();
										}
										else
										{
											staffList = Staff[Staff_Type == "Teaching Staff"].ID.getAll();
											roomList = Room[Room_Type1.Room_Type == "Class"].ID.getAll();
											row.Subject_field=input.ID;
											row.Staff:ui.add(staffList);
											row.Preferred_Room:ui.add(roomList);
											row.Class:ui.add(input.Class);
											row.Class=input.Class;
										}
						)
					}
				}

			}
