			onUserInputOfTeacherSelec as "onUserInputOfTeacherSelection"
			{
				type =  form
				form = Substitution
				record event = on add

				on user input of Teacher_Selection
				{
					actions 
					{
						custom deluge script
						(
											session = Session_Subform[ID == input.Session_Subform];
										mainSession = Sessions[ID == session.Sessions];
										sess = Session_Subform[Sessions.Date_field == mainSession.Date_field && Session_Name == session.Session_Name].Staff.getAll();
										allStaff = Staff[Status == "Active" && Staff_Type == "Teaching Staff"].ID.getAll();
										allStaff.removeAll(sess);
										associatedStaffs = Lesson_Plan_Mapping[Class == mainSession.Class].Staff.getAll();
										associatedStaffs.removeAll(sess);
										if(input.Teacher_Selection == "All Teachers")
										{
											input.Teacher:ui.add(allStaff);
										}
										else if(input.Teacher_Selection == "Teachers associated with the class")
										{
											if(associatedStaffs.size() == 0)
											{
												alert "All the associated staffs are busy";
												input.Teacher_Selection = "All Teachers";
												input.Teacher:ui.add(allStaff);
											}
											else
											{
												input.Teacher:ui.add(associatedStaffs);
											}
										}
						)
					}
				}

			}
