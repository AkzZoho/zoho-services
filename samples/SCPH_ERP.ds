		custom Announcements
		{
			displayName = "Announcements"
			show all rows from Communication_Form  [ID == thisapp.Akz.Last4Announcements()]  
			(
				Communication_Type as "Communication Type"
				Class
				Event
				Student
				Subject_field as "Subject"
				Message
				(
					displayformat = html
				)
				Mode_of_Communication as "Mode of Communication "
				Added_Time as "Added Time"
				(
					displayformat = dateonly
				)
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = '#FFFFFF'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '17px'\n	paddingLeft = '17px'\n	paddingRight = '0px'\n	paddingBottom = '17px'\n\n		width = '24%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<image  \n		marginLeft = '1px'\n	marginRight = '1px' \n	marginBottom = '1px'\n	marginTop = '1px'\n\n	color = 'theme'\n	bgColor = '#B5B5F7'\n	width = '80px'\n	height = '80px'\n	type = 'icon'\n	value = 'media-2-speaker-01'\n	size = '40px'\n	cornerRadius = '40px'\n	iconType = 'outline'\n/>\n</pc>\n</pr>\n</pc><pc \n		padding = '0px'\n\n		width = '76%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='37.3167px'\n>\n	<pc \n		paddingTop = '5px'\n	paddingLeft = '10px'\n	paddingRight = '10px'\n	paddingBottom = '5px'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '0px'\n	marginTop = '0px'\n	color = '#000000'\n	size = '16px'\n	uppercase = 'false' \n	underline = 'false' \n	bold = 'true' \n	italic = 'false' \n	type = 'field'\n\n\n\n	  \n      	lineHeight = '22'\n      	  numOfLines = '1'\n	  value = 'Subject_field'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='39.9667px'\n>\n	<pc \n		paddingTop = '5px'\n	paddingLeft = '10px'\n	paddingRight = '10px'\n	paddingBottom = '5px'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '0px'\n	marginTop = '0px'\n	color = '#000000'\n	size = '16px'\n	uppercase = 'false' \n	underline = 'false' \n	bold = 'false' \n	italic = 'false' \n	type = 'field'\n\n\n\n	  \n      	lineHeight = '22'\n      	  numOfLines = '3'\n	  value = 'Message'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '5px'\n	paddingLeft = '10px'\n	paddingRight = '10px'\n	paddingBottom = '5px'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '0px'\n	marginTop = '0px'\n	color = '#868686'\n	size = '15px'\n	uppercase = 'false' \n	underline = 'false' \n	bold = 'false' \n	italic = 'false' \n	type = 'field'\n\n\n\n	  \n      	lineHeight = '21'\n      	  numOfLines = '1'\n	  value = 'Added_Time'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
