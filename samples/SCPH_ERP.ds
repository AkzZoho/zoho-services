			hideAndDisableFields5 as "hideAndDisableFields"
			{
				type =  form
				form = Select_Bus
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Student;
										student = Student[ID == input.Student];
										vehicles = Vehicle[Bus_Stops == student.Pickup_Point && Status == "Available"].ID.getAll();
