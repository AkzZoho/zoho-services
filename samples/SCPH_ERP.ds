																			Added_User=zoho.loginuser
																			Student=stu
																			Status="Absent"
																			Session_Subform=sessionInsert
																			Date_field=val.toDate()
																		];
																	}
																}
															}
														}
													}
													if(val.weekday() == 3)
													{
														les = Lesson_Plan_Mapping[Class == clas.ID && Subject_field == rec.Tuesday1];
														for each  sube in les
