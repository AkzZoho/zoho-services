			checkForNotCompletedHomew as "checkForNotCompletedHomework"
			{
				type =  schedule
				form = Assignments
					status = inactive
				start = Submission_Date_and_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						allHomeWork = Assignments_Subform[Status == "Homework Created" && Home_Work == input.Assignments];
										if(allHomeWork.count() != 0)
										{
											for each  data in allHomeWork
											{
												data.Status="Overdue";
											}
										}
					)
					}
				}
			}
			sendSessionNotification as "sendSessionNotification"
			{
				type =  schedule
				form = Session_Subform
				start = before 5 minutes from Session_Start_Time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						resp = zoho.pushNotification(input.Staff.Email_ID,"Class Details","Your next Class is " + input.Subject_form.Subject_Name,"Session_Subform_Report",input.ID);
										lmpVal = Lesson_Plan_Mapping[ID == input.lmp];
										for each  ele in lmpVal.Student
										{
											resp = zoho.pushNotification(ele.Email,"Class Details","Your next Class is " + input.Subject_form.Subject_Name,"Session_Details_Students",input.ID);
										}
					)
					}
				}
			}
			chectStudentsOnLeave as "chectStudentsOnLeave"
			{
				type =  schedule
					status = inactive
				start = "2024-03-20 01:00:00"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						allLeaves = Student_Leave_Request[From_Date <= zoho.currentdate && To_Date >= zoho.currentdate && Status == "Approved"];
										for each  req in allLeaves
										{
											attData = Student_Attendance_New[Date_field == zoho.currentdate && Student == req.Student];
											for each  val in attData
											{
												val.Status="On Leave";
											}
										}
					)
					}
				}
			}
			Hostel_Attendance as "Hostel Attendance"
			{
				type =  schedule
					status = inactive
				start = "2024-07-02 05:00:00"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						for each  rec in Student[Hosteller == true && Hostel_Room_Allotted == true]
										{
											previousStatus = Hostel_Attendance[Attendance_Date == zoho.currentdate.subDay(1)].Status;
											if(previousStatus == "" || previousStatus == null)
											{
												previousStatus = "In";
											}
											insert into Hostel_Attendance
											[
												Added_User=zoho.loginuser
												Attendance_Date=zoho.currentdate
												Student=rec.ID
												Status=previousStatus
											]
