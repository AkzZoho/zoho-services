						custom deluge script
						(
											OldStops = input.Bus_Stops;
										stops = Bus_Route_SubForm[Route == input.Bus_Route].Bus_Stops.getAll();
										input.Bus_Stops:ui.add(stops);
										input.Bus_Stops = OldStops;
						)
					}
				}

			}
			checkIfLeadExists as "checkIfLeadExists"
			{
				type =  form
				form = Registration
				record event = on add

				on user input of Primary_Contact_Number
				{
					actions 
					{
						custom deluge script
						(
											lead = Lead[Phone_Number == input.Primary_Contact_Number];
										leads = lead.ID.getall();
										if(leads.size() > 1)
										{
											info leads;
											show Select_Lead;
											input.Select_Lead:ui.add(leads);
										}
										else if(leads.size() == 1)
										{
											input.Select_Lead = lead.ID;
											registrationsCount = Registration[Added_Time in this year].count();
											registrationsCount = registrationsCount + 1;
											RegistrationId = "Redgis-" + zoho.currentdate.getYear() + registrationsCount;
											input.Student_Name = lead.Student_Name;
											input.Father_s_Name = lead.Father_Name;
											input.Father_s_Phone = lead.Phone_Number;
											input.Gender = lead.Gender;
											input.Address = lead.Address;
											input.Lead = lead.ID;
											input.Registration_ID = RegistrationId;
											input.Applying_for_Class = lead.Applying_for_Class;
											show Basic_Details;
											show Section;
											show Previous_School_Data;
											show Has_Siblings;
											show Sibling_Details;
											show Primary_Contact_Email;
											show Emergency_Contact_Number;
											show Parents_Details;
											show Section1;
											// 	show Interview_Details;
										}
										else
										{
											resp = insert into Lead
											[
												Added_User=zoho.loginuser
												Student_Name=input.Student_Name
												Father_Name=input.Father_s_Name
												Phone_Number=input.Father_s_Phone
												Gender=input.Gender
												Address=input.Address
												Applying_for_Class=input.Applying_for_Class
											];
											input.Lead = resp;
											show Basic_Details;
											show Section;
											show Previous_School_Data;
											show Has_Siblings;
											show Sibling_Details;
											show Primary_Contact_Email;
											show Emergency_Contact_Number;
											show Parents_Details;
											show Section1;
											// 	show Interview_Details;
										}
						)
					}
				}

			}
