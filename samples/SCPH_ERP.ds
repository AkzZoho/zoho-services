			response as "response"
			{
				type =  form
				form = Trigger_Form
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Action_Type == "Logged in user data")
										{
											success message thisapp.apiJson.getStudentInfoJson("Logged in user data");
										}
										else if(input.Action_Type == "Logged for Lesson Plan")
										{
											success message thisapp.apiJson.getLessonPlanJson("Logged for Lesson Plan");
										}
										else if(input.Action_Type == "communications and consent")
										{
											success message thisapp.apiJson.getCommunicationConsentJson("communications and consent");
										}
										else if(input.Action_Type == "get class Students")
										{
											success message thisapp.apiJson.getClassStudentsJson(input.classId);
										}
										else if(input.Action_Type == "get Home Details")
										{
											success message thisapp.apiJson.getTimeTable();
										}
										else if(input.Action_Type == "get session Details")
										{
											success message thisapp.apiJson.getCurrentSession(input.Session_Name,input.Class_Name,input.Date_field);
										}
										else if(input.Action_Type == "get substituation Details")
										{
											success message thisapp.apiJson.getSubstituationValues(input.substituation_session_ID);
										}
										else if(input.Action_Type == "get Assignment Details")
										{
											success message thisapp.apiJson.getAssignmentValue("get Assignment Details");
										}
										else if(input.Action_Type == "get Check Details")
										{
											try 
											{
												if(input.Check_Status == "checkIn")
												{
													thisapp.schoolManagement.staffLogIn();
												}
												else
												{
													thisapp.schoolManagement.staffLogOut();
												}
											}
											catch (e)
											{
											}
										}
										delete from Trigger_Form[ID != 0];
						)
					}
				}

			}
