			onUserInputOfMarks1 as "onUserInputOfMarks"
			{
				type =  form
				form = Create_Question_Paper
				record event = on add or edit

				on user input of Questions2.Marks
				{
					actions 
					{
						custom deluge script
						(
											if(row.Marks != null)
										{
											totalMarks = 0;
											for each  rec in input.Questions2
											{
												totalMarks = totalMarks + (rec.Total_Number_of_Questions - rec.Number_of_Optional_Questions) * rec.Marks.Marks;
											}
											requiredMarks = Exam_Schedule[ID == input.Exam_Schedule];
											input.totalmarks = "Total Marks According to the blueprint - " + totalMarks + " Total Marks Required - " + requiredMarks.Total_Marks;
										}
						)
					}
				}

			}
			onAdditionOfRow1 as "onAdditionOfRow"
			{
				type =  form
				form = Create_Question_Paper
				record event = on add or edit

				on add row of Questions2
				{
					actions 
					{
						custom deluge script
						(
											modules = Subject_Modules[Subject_form == input.Subject_form].ID.getAll();
										row.Module:ui.add(modules);
						)
					}
				}

			}
			onDeletionOfRow1 as "onDeletionOfRow"
			{
				type =  form
				form = Create_Question_Paper
				record event = on add or edit

				on delete row of Questions2
				{
					actions 
					{
						custom deluge script
						(
											totalMarks = 0;
										for each  rec in input.Questions
										{
											totalMarks = totalMarks + (rec.Total_Number_of_Questions - rec.Number_of_Optional_Questions) * rec.Marks.Marks;
										}
										totalMarks = totalMarks - (row.Total_Number_of_Questions - row.Number_of_Optional_Questions) * row.Marks.Marks;
										requiredMarks = Exam_Schedule[ID == input.Exam_Schedule];
										input.totalmarks = "Total Marks According to the blueprint - " + totalMarks + " Total Marks Required - " + requiredMarks.Total_Marks;
						)
					}
				}

			}
