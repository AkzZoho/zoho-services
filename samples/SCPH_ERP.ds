			addSubformValues as "addSubformValues"
			{
				type =  form
				form = Time_Table
				record event = on add or edit

				on user input of Break_2_Time
				{
					actions 
					{
						custom deluge script
						(
											clear Time_Table_Subform;
										totalSessions = 0;
										timeList = List();
										timeCollection = Collection();
										eduYear = Educational_Year[Status == "Current"];
										subjects = Lesson_Plan_Mapping[Class == input.Class && Subject_field.Educational_Year == eduYear].Subject_field.getAll();
										a = zoho.currentdate + " " + input.Start_Time.toString();
										b = zoho.currentdate + " " + input.Break_1.toString();
										c = a.toTime().timeBetween(b.toTime());
										d = zoho.currentdate + " " + c.toString();
										e = d.toTime().getHour() * 60 + d.toTime().getMinutes();
										session1periods = e / input.Period_Duration_in_Mins;
										s = "";
										s = s.leftpad(session1periods.floor() - 1);
										s = s.toList(" ");
										currentTime = a;
										totalSessions = session1periods + totalSessions;
										for each  data in s
										{
											if(session1periods != 1)
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString("HH:mm");
												currentTime = currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString();
												timeList.add(time);
												table = Time_Table.Time_Table_Subform();
												table.Time=time;
												table.Class=input.Class;
												timeCollection.insert(table);
												session1periods = session1periods - 1;
											}
											else
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + b.toTime().toString("HH:mm");
												timeList.add(time);
												table = Time_Table.Time_Table_Subform();
												table.Time=time;
												table.Class=input.Class;
												timeCollection.insert(table);
											}
										}
										secondSessionStartTime = zoho.currentdate + " " + input.Break_1.toString();
										secondSessionStartTime = secondSessionStartTime.toTime().addMinutes(input.Break_Duration_in_Mins);
										lunchTime = zoho.currentdate + " " + input.Break_2_Time.toString();
										timeBetweenLunchAndSecondSessionStartTime = secondSessionStartTime.toTime().timeBetween(lunchTime.toTime());
										timeBetweenLunchAndSecondSessionStartTimeTemp = zoho.currentdate + " " + timeBetweenLunchAndSecondSessionStartTime.toString();
										timeBetweenLunchAndSecondSessionStartTimeMins = timeBetweenLunchAndSecondSessionStartTimeTemp.toTime().getHour() * 60 + timeBetweenLunchAndSecondSessionStartTimeTemp.toTime().getMinutes();
										session2periods = timeBetweenLunchAndSecondSessionStartTimeMins / input.Period_Duration_in_Mins;
										s = "";
										s = s.leftpad(session2periods.floor() - 1);
										s = s.toList(" ");
										currentTime = secondSessionStartTime;
										totalSessions = session2periods + totalSessions;
										for each  data in s
										{
											if(session2periods != 1)
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString("HH:mm");
												currentTime = currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString();
												timeList.add(time);
												table = Time_Table.Time_Table_Subform();
												table.Time=time;
												table.Class=input.Class;
												timeCollection.insert(table);
												session2periods = session2periods - 1;
											}
											else
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + lunchTime.toTime().toString("HH:mm");
												timeList.add(time);
												table = Time_Table.Time_Table_Subform();
												table.Time=time;
												table.Class=input.Class;
												timeCollection.insert(table);
											}
										}
										// thirdSessionStartTime = zoho.currentdate + " " + input.Lunch_Time.toString();
										// thirdSessionStartTime = thirdSessionStartTime.toTime().addMinutes(input.Lunch_Duration_in_Mins);
										// break2TIme = zoho.currentdate + " " + input.Break_2_Time.toString();
										// timeBetweenbreak2TImeAndthirdSessionStartTime = thirdSessionStartTime.toTime().timeBetween(break2TIme.toTime());
										// timeBetweenbreak2TImeAndthirdSessionStartTimeTemp = zoho.currentdate + " " + timeBetweenbreak2TImeAndthirdSessionStartTime.toString();
										// timeBetweenbreak2TImeAndthirdSessionStartTimeMins = timeBetweenbreak2TImeAndthirdSessionStartTimeTemp.toTime().getHour() * 60 + timeBetweenbreak2TImeAndthirdSessionStartTimeTemp.toTime().getMinutes();
										// session3periods = timeBetweenbreak2TImeAndthirdSessionStartTimeMins / input.Period_Duration_in_Mins;
										// s = "";
										// s = s.leftpad(session3periods.floor() - 1);
										// s = s.toList(" ");
										// currentTime = thirdSessionStartTime;
										// totalSessions = session3periods + totalSessions;
										// for each  data in s
										// {
										// 	if(session3periods != 1)
										// 	{
										// 		time = currentTime.toTime().toString("HH:mm") + " - " + currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString("HH:mm");
										// 		currentTime = currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString();
										// 		timeList.add(time);
										// 		table = Time_Table.Time_Table_Subform();
										// 		table.Time=time;
										// 		timeCollection.insert(table);
										// 		session3periods = session3periods - 1;
										// 	}
										// 	else
										// 	{
										// 		time = currentTime.toTime().toString("HH:mm") + " - " + break2TIme.toTime().toString("HH:mm");
										// 		timeList.add(time);
										// 		table = Time_Table.Time_Table_Subform();
										// 		table.Time=time;
										// 		timeCollection.insert(table);
										// 	}
										// }
										fourthSessionStartTime = zoho.currentdate + " " + input.Break_2_Time.toString();
										fourthSessionStartTime = fourthSessionStartTime.toTime().addMinutes(input.Break_Duration_in_Mins);
										endTime = zoho.currentdate + " " + input.End_Time.toString();
										timeBetweenfourthSessionStartTimeAndEndTime = fourthSessionStartTime.toTime().timeBetween(endTime.toTime());
										timeBetweenfourthSessionStartTimeAndEndTimeTemp = zoho.currentdate + " " + timeBetweenfourthSessionStartTimeAndEndTime.toString();
										timeBetweenfourthSessionStartTimeAndEndTimeMins = timeBetweenfourthSessionStartTimeAndEndTimeTemp.toTime().getHour() * 60 + timeBetweenfourthSessionStartTimeAndEndTimeTemp.toTime().getMinutes();
										session4periods = timeBetweenfourthSessionStartTimeAndEndTimeMins / input.Period_Duration_in_Mins;
										s = "";
										s = s.leftpad(session4periods.floor() - 1);
										s = s.toList(" ");
										currentTime = fourthSessionStartTime;
										totalSessions = session4periods + totalSessions;
										for each  data in s
										{
											if(session4periods.floor() != 1)
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString("HH:mm");
												currentTime = currentTime.toTime().addMinutes(input.Period_Duration_in_Mins).toString();
												timeList.add(time);
												session4periods = session4periods - 1;
												table = Time_Table.Time_Table_Subform();
												table.Class=input.Class;
												table.Time=time;
												timeCollection.insert(table);
											}
											else
											{
												time = currentTime.toTime().toString("HH:mm") + " - " + endTime.toTime().toString("HH:mm");
												timeList.add(time);
												table = Time_Table.Time_Table_Subform();
												table.Time=time;
												table.Class=input.Class;
												timeCollection.insert(table);
											}
										}
										input.Time_Table_Subform.insert(timeCollection);
						)
					}
				}

			}
