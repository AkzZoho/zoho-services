			extendReturn as "extendReturn"
			{
				type =  functions
				form = Borrowed_Books_Subform
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						//
										student = Student[ID == input.Borrow_Books.Student];
										membership = Membership[ID == student.Library_Membership];
										if(membership.count() != 0)
										{
											input.Expected_Return_Date = zoho.currentdate.addDay(membership.Extended_Days);
										}
										else
										{
											input.Expected_Return_Date = zoho.currentdate.addDay(15);
										}
										input.Status = "Extended";
					)
					}
				}
			}
