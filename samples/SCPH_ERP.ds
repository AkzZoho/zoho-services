													report_name = "#Report:Return_Books?Borrow_Books.Student=" + input.Search_Box + "&Borrow_Books.Student_op=26";
													report_name = report_name + "&zc_Footer=false&zc_SecHeader=true&zc_AddRec=false&zc_EditRec=false&zc_DelRec=false&zc_DuplRec=false&zc_EditBulkRec=false&zc_ColMenu=false&zc_SaveRec=false&zc_MoreAction=false&zc_ShowAs=false&zc_Print=false&zc_LoadIn=embed-reportdiv&zc_Search=false";
												}
												else if(input.Report_Name == "All_Resources")
												{
													report_name = "#Report:All_Resources?Name=" + input.Search_Box + "&Name_op=26";
													report_name = report_name + "&zc_Footer=false&zc_SecHeader=true&zc_AddRec=false&zc_EditRec=false&zc_DelRec=false&zc_DuplRec=false&zc_EditBulkRec=false&zc_ColMenu=false&zc_SaveRec=false&zc_MoreAction=false&zc_ShowAs=false&zc_Print=false&zc_LoadIn=embed-reportdiv&zc_Search=false";
												}
											}
											else
											{
												report_name = "#Report:" + input.Report_Name + "?" + input.Field_Name + "=" + input.Search_Box + "&" + input.Field_Name + "_op=26&zc_Header=true&zc_ReportName=true&zc_MoreAction=false&zc_Search=false&zc_LoadIn=embed-reportdiv";
											}
										}
										openUrl(report_name,"same window");
