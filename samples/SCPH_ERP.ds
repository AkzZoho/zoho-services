			Avoid_Multiple_Fee_Compon as "Avoid Multiple Fee Components"
			{
				type =  form
				form = Fee
				record event = on add or edit

				on user input of Components.Fee_Component
				{
					actions 
					{
						custom deluge script
						(
											if(row.Fee_Component != null)
										{
											ExistingComponents = List();
											ExistingComponents.addAll(input.Components.Fee_Component.getall());
											ExistingComponents.removeElement(row.Fee_Component);
											if(ExistingComponents.contains(row.Fee_Component))
											{
												AllowedComponents = Fee_Component[ID not in input.Components.Fee_Component.getall()];
												row.Fee_Component:ui.add(AllowedComponents.ID.getall());
												alert "Already Selected";
												row.Fee_Component=null;
											}
										}
						)
					}
				}

