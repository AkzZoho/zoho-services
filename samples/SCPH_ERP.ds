			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet104' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet104()\ncontent\n&lt;%{\n\t%&gt;\n&lt;style&gt;\n\t.zcs_relatedblockbutton\n\t{\n\t\tcolor: var(--theme_brand_color);\n  \t\tborder-color: var(--theme_brand_color);\n\t}\n\t.zcs_relatedblockbutton:hover {\n\t\tbackground-color: var(--live_primary_btn_h_bClr);\n\t\tcolor: var(--button_text_light_color);\n\t\tborder-color: var(--live_primary_btn_h_bClr);\n\t\t-webkit-transition:\n\t\tall .2s ease-in-out;\n\t\t-moz-transition: all .2s ease-in-out;\n\t\t-ms-transition: all .2s ease-in-out;\n\t\t-o-transition: all .2s ease-in-out;\n\t\ttransition:\n\t\tall .2s ease-in-out;\n\t}\n\t&lt;\/style&gt;\n&lt;div style=&quot;height:85vh;&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;All_Student_Fee_Details&apos; params=&apos;zc_Header=true&apos;&gt;&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
