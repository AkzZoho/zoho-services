		reports
		{
			report My_Class_Attendances
			{
				quickview
				(
					layout
					(
		 				type = 9
						datablock1
						(
			 				display type = auto
							layout type = 31
							fields
							(
								Student
								Class
								Date_field as "Date"
								Type_field as "Type"
							)
						)
					)
					menu
    				(
    	 				header
    	 				(
			 				"Absent (Morning)"
			 				"Absent (Evening)"
    		 				Edit 
    	 				)
						record
						(
							"Absent (Morning)"
							"Absent (Evening)"
    					)
    				)
    				action
    				(
						on long press
						(
							"Absent (Morning)"
							"Absent (Evening)"
    					)
						on left swipe
						(
							"Absent (Evening)"
    					)
						on right swipe
						(
							"Absent (Evening)"
    					)
     				)
				)

				detailview
				(
					layout
					(
		 				type = 1
						datablock1
						(
							layout type = -2
							fields
							(
								Student
								Class
								Date_field as "Date"
