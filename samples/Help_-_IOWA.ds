		{
			Add_Incident_to_SDP as "Add Incident to SDP"
			{
				type =  form
				form = Request_Support
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											thisapp.SDP.Add_Incident(input.ID);
						)
					}
				}

			}
		}






