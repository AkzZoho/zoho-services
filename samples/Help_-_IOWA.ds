 application "Help - IOWA"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Kolkata"
 	time format = "24-hr"
 	forms
	{
		form Employee
		{
			success message = "Employee Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Name
			(
    			type = name
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Epayment_Setup_Request
		{
			displayname = "Epayment Setup Request"
			success message = "Epayment Setup Request Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Agency
			(
				type = picklist
				maxchar = 100
				values = {"Choice 1","Choice 2","Choice 3"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Functionality_needed
			(
				type = radiobuttons
				displayname = "Functionality needed?"
				maxchar = 100
				values = {"Add new service","Add product to existing service"}
				layout = 2
	 			row = 1
	 			column = 1   
				width = medium
			)
			Biller_ID
			(
    			type = text
				displayname = "Biller ID"
				maxchar = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			Application_ID
			(
				type = number
				displayname = "Application ID"
				maxchar = 3
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Name_of_Application
			(
    			type = text
				displayname = "Name of Application"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Products
			(
				type = grid
				displayname = "Products:"
				values  = Products.ID
