		form New_Server_Setup
		{
			displayname = "New Server Setup"
			success message = "New Server Setup Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Requester
			(
				type = picklist	
				values  = Employee.ID
    			displayformat = [" " + Name.prefix + " " + Name.first_name + " " + Name.last_name + " " + Name.suffix]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Agency
			(
				type = picklist	
				values  = Service_Catalog_Request.ID
    			displayformat = [Department]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Project_Name
			(
    			type = text
				displayname = "Project Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Project_Manager_Name
			(
    			type = text
				displayname = "Project Manager Name"
	 			row = 1
	 			column = 1   
