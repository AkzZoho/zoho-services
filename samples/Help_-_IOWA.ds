			)
			must have Developer_Contact_for_the_project
			(
    			type = text
				displayname = "Developer Contact for the project"
    			description
    			[
    				type = help_text
    			 	message = "Enter the name of the person who is the Developer Contact"
    			]
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Contact_Email_developer
			(
    			type = email
				displayname = "Contact Email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Contact_Phone_Number_developer
			(
    			type = phonenumber
				displayname = "Contact Phone Number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Is_there_sensitive_data_involved
			(
				type = radiobuttons
				displayname = "Is there sensitive data involved?"
				maxchar = 100
				values = {"Yes","No"}
				layout = 2
	 			row = 1
	 			column = 1   
				width = medium
			)
			Please_explain_the_type_of_sensitive_data_involved
			(
    			type = text
				displayname = "Please explain the type of sensitive data involved."
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Describe_the_applications_or_services_that_will_be_hosted_on_the_server
			(
    			type = textarea
				displayname = "Describe the applications or services that will be hosted on the server."
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have List_all_accounts_requiring_administrative_server_access
			(
    			type = textarea
				displayname = "List all accounts requiring administrative server access"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Other_users_that_need_to_have_access_to_the_server
			(
    			type = text
				displayname = "Other users that need to have access to the server"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Firewall_Conduit_ACL_Requirements
			(
				type = grid
				displayname = "Firewall Conduit/ACL Requirements"
				values  = Firewall_Conduit_ACL_Requirements.ID
    			description
    			[
    				type = help_text
    			 	message = "If this is a replacement server, please give more details about the ACL's in Additional Requirements."
    			]
	 			row = 2
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Additional_Requirements
			(
    			type = text
				displayname = "Additional Requirements"
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Desired_Hostname
			(
    			type = text
				displayname = "Desired Hostname"
	 			row = 3
	 			column = 1   
				width = medium
			)
			Attach_additional_requirements_from_Vendor
			(
    			type = upload file
				displayname = "Attach additional requirements from Vendor"
    			file count = 10
				browse = local_drive
	 			row = 3
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
