	 			column = 1   
				width = medium
			)
			must have Requested_Completion_Date
			(
    			type = date
				displayname = "Requested Completion Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Operating_System_Type
			(
				type = picklist
				displayname = "Operating System Type"
				maxchar = 100
				values = {"Redhat Enterprise Linux","Windows"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			Active_Directory_Domain
			(
    			type = text
				displayname = "Active Directory Domain"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Please_explain_if_the_current_version_of_the_OS_can_t_be_used_or_if_you_selected_other
			(
    			type = text
				displayname = "Please explain if the current version of the OS can't be used or if you selected other."
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have CPU_Count_1_16
			(
    			type = text
				displayname = "CPU Count (1-16)"
    			description
    			[
    				type = help_text
    			 	message = "Enter the socket and core requirement if known."
    			]
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Memory_GB
			(
    			type = text
				displayname = "Memory (GB)"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Disk_space_needed_for_application_and_data
			(
    			type = text
				displayname = "Disk space needed for application and data"
    			description
