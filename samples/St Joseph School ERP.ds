		page Dashboard
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/Logo&quot;);\n\t%&gt;\n&lt;style&gt;\n.zcsBody *,.zcsBody *::after,.zcsBody *::before{\n\tmargin:0;\n\tpadding:0;\n\tbox-sizing:border-box;\n}\n\n.zcsBody {\n  --header-height: 6.5rem;\n  color:#1f1c2e;\n  overflow:hidden;\n}\n.zcsBody .zcsRow1 {\n  height: var(--header-height);\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n}\n\n\/*** Header (Row 1) Styles ****\/\n.zcsBody .zcsRow1 .zcsRow1_left{\n\tdisplay:flex;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left img.zcsRow1_left_logo{\n\theight: calc(0.8 * var(--header-height));\n\taspect-ratio:1;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div{\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-left:1.5rem;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div h4{\n\tfont-size:1.4rem;\n\tmargin-bottom:0.4rem;\n\tfont-weight:normal;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div h5{\n\tfont-size:1.1rem;\n\tfont-weight:normal;\n}\n.zcsRow1_right{\n\tpadding-right: 15px;\n}\n\n.zcsRow1_right_select {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 8px;\n}\n\n.zcsRow1_right_select label {\n  font-weight: 500;\n  font-size: 16px;\n  color: #1a1a1a;\n}\n\n.zcsRow1_right_students {\n  display: flex;\n  gap: 10px;\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n.zcsRow1_right_students li a {\n  text-decoration: none;\n}\n\n.initials-logo {\n  width: 40px;\n  height: 40px;\n  background-color: #5f4dde;\n  font-weight: 700;\n  font-size: 14px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);\n  transition: all 0.2s ease;\n}\n\n.zcs_active_student .initials-logo {\n  background-color: #fff;\n  border: 2px solid #5f4dde;\n}\n\n.initials-logo {\n\twidth: 40px;\n\theight: 40px;\n\tborder-radius: 50%;\n\tbackground: linear-gradient(135deg, #6a6ff1, #434fb9);\n\tcolor: white;\n\tdisplay: flex;\n\talign-items: center;\n\tjustify-content: center;\n\tfont-weight: 600;\n\tfont-size: 14px;\n\tfont-family: &apos;Inter&apos;, sans-serif;\n\tbox-shadow: 0 2px 6px rgba(0,0,0,0.1);\n\tuser-select: none;\n}\n\n.zcsRow1_right_students a {\n\tmargin-right: 8px;\n\ttext-decoration: none;\n}\n\n.zcsRow1_right_students a:hover .initials-logo {\n\tbox-shadow: 0 0 0 2px #6a6ff1;\n}\n\n.zcs-label-top {\n\tfont-size: 14px;\n\tfont-weight: 600;\n\tcolor: #333;\n}\n.zc-footer-wrapper{\n\tdisplay:none !important;\n}\n.popupbox{\n\twidth:80% !important;\n}\n#row_2{\n\toverflow:hidden !important;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;zcsBody&quot;&gt;\n\t&lt;div class=&quot;zcsRow1&quot;&gt;\n\t&lt;!----------------------- Dashboard Header -----------------------&gt; \n\t\t&lt;div class=&quot;zcsRow1_left&quot;&gt;\n\t\t\t&lt;div class=&quot;zcsRow1_left_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n\t\t\t\t&lt;h4&gt;St. Joseph\u2019s Public School&lt;\/h4&gt;\n\t\t\t\t&lt;h5&gt;Admin Dashboard&lt;\/h5&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;!------------------------ Select Students -----------------------&gt;\t\n\t\t&lt;div class=&quot;zcsRow1_right&quot;&gt;\n\t\t\t&lt;div class=&quot;zcsRow1_right_select&quot;&gt;\n\t\t\t\t&lt;div elName=&apos;zc-component&apos; formLinkName=&apos;Dashboard_Search&apos; params=&apos;zc_Header=false&apos;&gt;&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row><row>\n\t<column\n   \t\t width=\"25%\"\n   \t>\n\t<panel elementName=\"Panel\"\n \n >\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '0px'\n\tbgColor = '#FFFFFF'\n\n    action = 'OpenReport'\n\t\tparameters = 'zc_AddRec=false&amp;Admission_Date_op=52' \n\t\tcomponentLinkName = 'Students'\n\t\ttarget = 'popup'\n\t\tpopupWidth = '90%'\n\t  \tpopupHeight = '90%'\n\t\twidth = '100%'\n\t\thAlign = 'center'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '15px'\n\n\t\twidth = '25%'\n\t\thAlign = 'center'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<image  \n\t\tmarginLeft = '0px'\n\tmarginRight = '7px' \n\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\n\tcolor = '#FFFFFF'\n\tbgColor = 'theme'\n\twidth = '44px'\n\theight = '44px'\n\ttype = 'icon'\n\tvalue = 'users-2-meeting'\n\tsize = '18px'\n\tcornerRadius = '22px'\n\ticonType = 'outline'\n\/>\n<\/pc>\n<\/pr>\n<\/pc><pc \n\t\tpadding = '15px'\n\n\t\twidth = '75%'\n\t\thAlign = 'right'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\tpadding = '5px'\n\n\t\thAlign = 'center'\n>\n\t<pr \n\t>\n\t<pc \n\t\n\t\thAlign = 'left'\n>\n\t<text \n\n\tmarginLeft = '0px'\n\tmarginRight = '0px' \n\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\tcolor = '#595959'\n\tsize = '12px'\n\ttype = 'Text'\n\n\n\n\t  \n\t  value = 'Admissions (This Year)'\n>\n<\/text>\n\n<\/pc>\n<\/pr><pr \n\t>\n\t<pc \n\t\n\t\thAlign = 'left'\n>\n\t<text \n\n\tmarginLeft = '0px'\n\tmarginRight = '0px' \n\tmarginBottom = '0px'\n\tmarginTop = '5px'\n\tcolor = '#000000'\n\tsize = '20px'\n\tbold = 'true' \n\ttype = 'Form Data'\n\n\tdisplayType = 'actual'\n\tthousandsSeperator = 'LOCALE'\n\tdecimalSeperator = 'DOT'\n\tnumberScale = 'none'\n\n\n\t  \n\t\tcriteria = 'Admission_Date in this year'\n\t  value = 'thisapp.Student_Form.ID.count'\n>\n<\/text>\n\n<\/pc>\n<\/pr>\n<\/pc>\n<\/pr>\n<\/pc>\n<\/pr>\n<\/pc>\n<\/pr>\n<\/panel>\n<\/column><column\n   \t\t width=\"25%\