			Calculate_Total_Past_Due_ as "Calculate Total Past Due & Total Book Fee"
			{
				type =  form
				form = Update_Amount
				record event = on add or edit

				on delete row of Student_Specific_Update_Amount_Details
				{
					actions 
					{
						custom deluge script
						(
											if(input.Amount_Type == "Past Due")
										{
											input.Total_Past_Due_Amount = input.Total_Past_Due_Amount - row.Past_Due_Amount;
										}
										else if(input.Amount_Type == "Book Fee")
										{
											input.Total_Book_Fee_Amount = input.Total_Book_Fee_Amount - row.Book_Fee_Amount;
										}
						)
					}
				}

			}
			Validate_Past_Due_Book_Fe as "Validate Past Due & Book Fee Amount"
			{
				type =  form
				form = Update_Amount
				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Amount_Type == "Past Due")
										{
											//--------------------- Validate Past Due Amount -----------------------
											past_due_flag = false;
											for each  pastDue in input.Student_Specific_Update_Amount_Details
											{
												if(pastDue.Past_Due_Amount == null)
												{
													past_due_flag = true;
													break;
												}
											}
											if(past_due_flag)
											{
												alert "Kindly enter a value for past due amount!";
												cancel submit;
											}
										}
										else if(input.Amount_Type == "Book Fee")
										{
											//--------------------- Validate Book Fee Amount ---------------------
											book_fee_flag = false;
											for each  bookFee in input.Student_Specific_Update_Amount_Details
											{
												if(bookFee.Book_Fee_Amount == null)
												{
													book_fee_flag = true;
													break;
												}
											}
											if(book_fee_flag)
											{
												alert "Kindly enter a value for book fee amount!";
												cancel submit;
											}
										}
						)
					}
				}

			}
