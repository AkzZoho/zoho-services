			Calculate_Past_Due_Book_F as "Calculate Past Due & Book Fee Amount"
			{
				type =  form
				form = Update_Amount
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											fet_installment = Term_Fees_Form[ID == input.Installment_ID];
										if(input.Amount_Type == "Past Due")
										{
											fet_installment.Total_Past_Due=input.Total_Past_Due_Amount;
										}
										else if(input.Amount_Type == "Book Fee")
										{
											fet_installment.Total_Book_Fee=input.Total_Book_Fee_Amount;
										}
										fet_installment.Total_Final_Term_Fee=ifnull(fet_installment.Total_Term_Fee,0) + ifnull(fet_installment.Total_Book_Fee,0) + ifnull(fet_installment.Total_Past_Due,0);
										fet_installment.Total_Balance_Amount=fet_installment.Total_Final_Term_Fee;
										//------------------------ Update Final Fee in Student Fees Details -----------------------
										fet_student_fee = Student_Fees_Form[ID == input.Installment_ID.Fee_ID];
										fet_student_fee.Total_Book_Fee=fet_student_fee.Total_Book_Fee + fet_installment.Total_Book_Fee;
										fet_student_fee.Final_Fee=fet_student_fee.Final_Fee + fet_student_fee.Total_Book_Fee;
										for each  student in input.Student_Specific_Update_Amount_Details
										{
											StudentSpecificData = Student_Specific_Term_Fee[Term_Fees_Form == fet_installment.ID && Student == student.Student];
											student_specific_fee = Student_Fee[Student_Fees_Form_ID == fet_student_fee.ID && Student == student.Student];
											if(input.Amount_Type == "Past Due")
											{
												StudentSpecificData.Past_Due=student.Past_Due_Amount;
											}
											else if(input.Amount_Type == "Book Fee")
											{
												StudentSpecificData.Book_Fee=student.Book_Fee_Amount;
												student_specific_fee.Book_Fee=ifnull(student_specific_fee.Book_Fee,0) + student.Book_Fee_Amount;
												student_specific_fee.Net_Amount=student_specific_fee.Net_Amount + ifnull(student_specific_fee.Book_Fee,0);
											}
											StudentSpecificData.Final_Term_Fee=ifnull(StudentSpecificData.Term_Fee,0) + ifnull(StudentSpecificData.Book_Fee,0) + ifnull(StudentSpecificData.Past_Due,0);
											StudentSpecificData.Balance_Amount=StudentSpecificData.Final_Term_Fee;
										}
										openUrl("#Script:page.parent.refresh","same window");
						)
					}
				}

			}
			Update_Status as "Update Status"
			{
				type =  form
				form = Fees_Receipt
				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											fet_installment = Term_Fees_Form[ID == input.Installment_ID];
										if(input.Total_Amount_Paid.round(0) == input.Total_Payable_Amount.round(0))
										{
											fet_installment.Status="Paid";
										}
										else if(input.Total_Amount_Paid.round(0) < input.Total_Payable_Amount.round(0))
										{
											fet_installment.Status="Partially Paid";
										}
										fet_installment.Amount_Paid=ifnull(fet_installment.Amount_Paid,0) + input.Total_Amount_Paid;
										fet_installment.Total_Balance_Amount=ifnull(fet_installment.Total_Balance_Amount,0) - input.Total_Amount_Paid;
										for each  student in input.Student_Fee_Amount_Details
										{
											student_term_fee = Student_Specific_Term_Fee[Term_Fees_Form == input.Installment_ID && Student == student.Student];
											student_term_fee.Balance_Amount=ifnull(student_term_fee.Balance_Amount,0) - student.Amount_Paid;
										}
										fet_student_fee = Student_Fees_Form[ID == input.Fee_ID];
										fet_student_fee.Status="Partially Paid";
										if(fet_installment.Installment_No == "3rd")
										{
											fet_student_fee.Status="Paid";
										}
										openUrl("#Script:page.parent.refresh","same window");
						)
					}
				}

			}
