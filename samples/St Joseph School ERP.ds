			Populate_Based_on_Parent as "Populate Based on Parent"
			{
				type =  form
				form = Student_Fees_Form
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											if(input.Parents != null)
										{
											AlreadyCreated = Student_Fees_Form[Parents == input.Parents];
											if(AlreadyCreated.count() > 0)
											{
												AlreadyCreatedStudents = AlreadyCreated.Student_Specific_Fee.Student.getall();
												if(AlreadyCreatedStudents.size() == Parents.Children.getall().size())
												{
													openUrl("#Script:dialog.close","same window");
													openUrl("#Form:Alert_Form?zc_Header=false","popup window");
												}
												else
												{
													disable Student_Specific_Fee.Class;
													disable Student_Specific_Fee.Student;
													StudentstoPopulate = Collection();
													for each  student in Student_Form[Status == "Active" && Parents_Details_Form_ID == input.Parents && ID not in AlreadyCreated.Student_Specific_Fee.Student.getall()]
													{
														NewRow = Student_Fees_Form.Student_Specific_Fee();
														NewRow.Student=student.ID;
														NewRow.Class=student.Class;
														NewRow.Amount=Class_Fee_Setup[Class == student.Class.Class].Total_Fees;
														StudentstoPopulate.insert(NewRow);
													}
													input.Student_Specific_Fee.insert(StudentstoPopulate);
													input.Total_Fee = input.Student_Specific_Fee.sum(Amount);
												}
											}
											else
											{
												disable Student_Specific_Fee.Class;
												disable Student_Specific_Fee.Student;
												StudentstoPopulate = Collection();
												for each  student in Student_Form[Status == "Active" && Parents_Details_Form_ID == input.Parents]
												{
													NewRow = Student_Fees_Form.Student_Specific_Fee();
													NewRow.Student=student.ID;
													NewRow.Class=student.Class;
													NewRow.Amount=Class_Fee_Setup[Class == student.Class.Class].Total_Fees;
													StudentstoPopulate.insert(NewRow);
												}
												input.Student_Specific_Fee.insert(StudentstoPopulate);
												input.Total_Fee = input.Student_Specific_Fee.sum(Amount);
											}
										}
						)
					}
				}

			}
