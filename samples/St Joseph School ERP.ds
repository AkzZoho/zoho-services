		default list Student_Fees_Details
		{
			displayName = "Student Fees Details"
			show all rows from Student_Fees_Form    
			(
				Fee_ID as "Fee ID"
				Parents
				Total_Fee as "Total Fee"
				Total_Discount as "Total Discount"
				Final_Fee as "Final Fee"
				Status
				custom action "Apply Discount"
				(
	  			workflow = Apply_Discount
				show action in edit record menu = true
				column header = "Apply Discount"
				condition = (Status == "Pending" && Total_Discount is null)
				)
				Total_Book_Fee as "Total Book Fee"
				Academic_Year as "Academic Year"
				Total_Previous_Year_Due as "Total Previous Year Due"
				Added_Time as "Added Time"
				custom action "Print Fee Card"
				(
	  			workflow = Print_Fee_Card
				show action in edit record menu = true
				column header = "Print Fee Card"
				condition = (Status == "Partially Paid" || Status == "Paid")
				)
			)
			group by
			(
				Academic_Year descending
			)
			sort by
			(
				Added_Time descending
			)
			conditional formatting
			(
				"Pending"
				{
				condition = (Status == "Pending")
				fields = [Status]
				format = "color:#efb116;"
				}
				"Overdue"
				{
				condition = (Status == "Overdue")
				fields = [Status]
				format = "color:#ef1616;"
				}
				"Paid"
				{
				condition = (Status == "Paid")
				fields = [Status]
				format = "color:#4ea64c;"
				}
				"Partially Paid"
				{
				condition = (Status == "Partially Paid")
				fields = [Status]
				format = "color:#398ef3;"
				}
			)
		}
