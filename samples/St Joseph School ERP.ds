			)
			must have Mother_s_Mobile
			(
    			type = phonenumber
				displayname = "Mother's Mobile"
	 			row = 1
	 			column = 2   
				width = medium
				personal data = true
			)
			Other_Details
			(
				type = section
				displayname = "Other Details"
				visibility = true
	 			row = 2
	 			column = 0   
				width = medium
			)
			must have Full_Address
			(
    			type = address
				displayname = "Full Address"
     			capture_coordinates = true
     			adjust_using_map = false
