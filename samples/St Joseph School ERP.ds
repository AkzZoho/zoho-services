			Add_Discount as "Add Discount"
			{
				type =  form
				form = Student_Fees_Form
				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											//-------------------------- Update Student Specific Fee ------------------------
										for each  student_fee in input.Student_Specific_Fee
										{
											student_fee.Discount=input.Total_Discount / input.Student_Specific_Fee.count();
											student_fee.Net_Amount=student_fee.Net_Amount - student_fee.Discount;
											//----------------------- Update Student Specific Term Fee ----------------------
											for each  student_term_fee in Student_Specific_Term_Fee[Term_Fees_Form.Fee_ID == input.ID && Student == student_fee.Student]
											{
												student_term_fee.Discount=student_fee.Discount / 3;
												student_term_fee.Final_Term_Fee=student_term_fee.Final_Term_Fee - student_term_fee.Discount;
											}
										}
										//----------------------- Update Students Term Fee -----------------------
										for each  term in Term_Fees_Form[Fee_ID == input.ID]
										{
											term.Total_Discount=input.Total_Discount / 3;
											term.Total_Final_Term_Fee=term.Total_Final_Term_Fee - term.Total_Discount;
										}
						)
					}
				}

			}
