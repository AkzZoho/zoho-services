		default list Term_Fees_Details
		{
			displayName = "Term Fees Details"
			show all rows from Term_Fees_Form    
			(
				Installment_ID as "Term_ID"
				(
					width = 118px
				)
				Parents
				(
					width = 132px
				)
				Installment_No as "Term"
				(
					width = 118px
				)
				Due_Date as "Due Date"
				(
					width = 113px
				)
				Total_Term_Fee as "Total Term Fee"
				Total_Past_Due as "Total Past Due"
				Total_Book_Fee as "Total Book Fee"
				Total_Final_Term_Fee as "Total Final Term Fee"
				(
					width = 160px
				)
				Status
				(
					width = 126px
				)
				Start_Date as "Start Date"
				(
					width = 118px
				)
				custom action "Update Past Due"
				(
	  			workflow = Update_Past_Due
				show action in edit record menu = true
				column header = "Update Past Due"
				condition = (Status != "Partially Paid" && Status != "Paid" && Total_Past_Due is null && Installment_No != "1" && Amount_Paid <= 0)
				)
				custom action "Update Book Fee"
				(
	  			workflow = Update_Book_Fee
				show action in edit record menu = true
				column header = "Update Book Fee"
				condition = (Status != "Partially Paid" && Status != "Paid" && Total_Book_Fee is null && Amount_Paid <= 0)
				)
				custom action "Add Payment"
				(
	  			workflow = Add_Payment
				show action in edit record menu = true
				column header = "Add Payment"
				condition = (Status == "Pending" || Status == "Overdue" || Status == "Partially Paid" && Due_Date > zoho.currenttime)
				)
				Fee_ID as "Fee ID"
				Total_Balance_Amount as "Total Balance Amount"
				Amount_Paid as "Amount Paid"
				Academic_Year as "Academic Year"
				Total_Discount as "Total Discount"
			)
			group by
			(
				Fee_ID descending
			)
			conditional formatting
			(
				"Pending"
				{
				condition = (Status == "Pending")
				fields = [Status]
				format = "color:#efb116;"
				}
				"Overdue"
				{
				condition = (Status == "Overdue")
				fields = [Status]
				format = "color:#ef1616;"
				}
				"Paid"
				{
				condition = (Status == "Paid")
				fields = [Status]
				format = "color:#4ea64c;"
				}
				"Partially Paid"
				{
				condition = (Status == "Partially Paid")
				fields = [Status]
				format = "color:#398ef3;"
				}
			)
		}
		default list Students
		{
			displayName = "Students"
			show all rows from Student_Form    
			(
				Name
				Date_of_Birth as "Date of Birth"
				Gender
				Mother_Language as "Mother Language"
				Class
				Nationality
				State
				Religion
				Aadhaar_Number as "Aadhaar Number"
				Student_PEN as "Student PEN"
				Student_Photo as "Student Photo"
				Medium_of_Instruction as "Medium of Instruction"
				First_Language as "1st Language"
				Second_Language as "2nd Language"
				Status
				custom action "Active"
				(
	  			workflow = Active
				show action in edit record menu = true
				column header = "Active"
				condition = (Status == "Inactive")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to activate this student?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Inactive"
				(
	  			workflow = Inactive
				show action in edit record menu = true
				column header = "Inactive"
				condition = (Status == "Active")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to inactivate this student?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Print Admission Form"
				(
	  			workflow = Print_Admission_Form
				show action in edit record menu = true
				column header = "Print Admission Form"
				)
				custom action "Print Consent Form"
				(
	  			workflow = Print_Consent_Form1
				show action in edit record menu = true
				column header = "Print Consent Form"
				)
				Admission_Date as "Admission Date"
				Admission_Number as "Admission Number"
			)
			group by
			(
				Class ascending
			)
			conditional formatting
			(
				"Active"
				{
				condition = (Status == "Active")
				fields = [Status]
				format = "color:#4ea64c;"
				}
				"Inactive"
				{
				condition = (Status == "Inactive")
				fields = [Status]
				format = "color:#ef1616;"
				}
			)
		}
