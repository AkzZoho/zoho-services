	     			  type = address_line_2
	     			  displayname = "Address Line 2"
     			) 
     			district_city
     			(
	     			  type = district_city
	     			  displayname = "City / District"
     			) 
     			state_province
     			(
	     			  type = state_province
	     			  displayname = "State / Province"
     			) 
     			postal_Code
     			(
	     			  type = postal_Code
	     			  displayname = "Postal Code"
     			) 
     			country
     			(
	     			  type = country
	     			  displayname = "Country"
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "latitude"
	     			 visibility = false
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "longitude"
	     			 visibility = false
     			) 
	 			row = 2
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Email
			(
    			type = email
				maxchar = 80
	 			row = 2
	 			column = 2   
				width = medium
				personal data = true
			)
			must have unique Mobile_Number_Apaar_ID
			(
    			type = phonenumber
				displayname = "Mobile Number (Apaar ID)"
	 			row = 2
	 			column = 2   
				width = medium
				personal data = true
			)
			Hidden_Section
			(
				type = section
				displayname = "Hidden Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			Children
			(
				type = list	
				values  = Student_Form.ID
    			bidirectional = Parents_Details_Form_ID
    			displayformat = [Name]
