	pages
	{
		page Fees_Receipt_Page(int receipt_ID)
		{
			displayname = "Fees Receipt Page"
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"card\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet1' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1()\ncontent\n&lt;%{\n\treceipt = Fees_Receipt[ID == input.receipt_ID];\n\tfee_installment = Term_Fees_Form[ID == receipt.Installment_ID];\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;creator.zoho.in&quot;,&quot;creatorapp.zohopublic.in\/file&quot;).replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/&quot; + org.ID + &quot;\/Logo&quot;).replaceAll(&quot;\/image\/&quot;,&quot;\/image-download\/XGD9BYAdnDHEmCrtpDfK1RUMCtB5Jmav111fV7Rpw5xyykOPgZxOHFYQb5JXjdYf8T5HzkZsYXQ4dPDA68hO8fqCRuT4KFDGGUAu?filepath=&quot;);\n\t%&gt;\n&lt;style&gt;\n:root{\n--jsHorizontalPagePadding:1.75cm;\n--jsVerticalPagePadding:1.75cm;\n}\n\n.js_page_container *{\nmargin:0;\npadding:0;\nbox-sizing:border-box;\n}\n\n.js_page_container{\nfont-family: &apos;Lato&apos;;\n}\n\n.js_page{\npadding:12px;\nbackground: white;\nwidth: 20cm;\nheight: 25cm;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n}\n\n.js_page:not(.js_page1){\npage-break-before:always;\n}\n\n.js_page_section{\nborder:0.5px solid #000;\nwidth: 100%;\npadding:20px;\ndisplay: flex;\nflex-direction: column;\nposition:relative;\n}\n\n\/*** Marksheet Header ****\/\n.jsc_markSheetHeader{\n\tdisplay:flex;\n\ttext-align:center;\n\tpadding-bottom: 13px;\n}\n\n.jsc_markSheetHeader img{\n\twidth:90px;\n\taspect-ratio:1;\n\tmargin-left:45px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-right:60px;\n\tletter-spacing:.75px;\n}\n\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content h4{\n\tfont-size:17px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content &gt; *{\n\tline-height:20px;\n}\n\n.js_page_section h4.jsc_fee_receipt_header{\n\t text-transform: uppercase;\n\t line-height:35px;\n\t border-top:0.5px solid #000;\n\t border-bottom:0.5px solid #000;\n\t text-align:center;\n\t margin-top:12px;\n\t font-size:18px\n\t letter-spacing:1px;\n}\n\n\/**** Student Details ****\/\n.jsc_student_details{\n\tdisplay:flex;\n\tpadding: 15px 0;\n    justify-content: space-between;\n\talign-items:center;\n}\n\n.jsc_student_details table.jsc_student_details_table{\n\tflex:1;\n\tmargin:0 auto;\n}\n\n\n.jsc_student_details table.jsc_student_details_table td{\n\tline-height:30px;\n\twidth:50%;\n}\n\n\/****** Fees table ******\/\n\n table.jsc_fees td:nth-child(4), table.jsc_fees th:nth-child(4){\n    text-align: right;\n\tborder-left:0.5px solid #000;\n}\n\ntable.jsc_fees, table.jsc_fees td, table.jsc_fees th{\n  border-collapse: collapse;\n  padding:8px;\n}\n\ntable.jsc_fees thead th{\n\t     line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n }\n \n table.jsc_fees td:nth-child(1), table.jsc_fees th:nth-child(1), table.jsc_fees td:nth-child(2), table.jsc_fees th:nth-child(2){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:20%;\n }\n  table.jsc_fees td:nth-child(3), table.jsc_fees th:nth-child(3){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:40%;\n }\n\ntable.jsc_fees tfoot tr{\n\t\t line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n}\n\ntable.jsc_fees_2, table.jsc_fees_2 td, table.jsc_fees_2 th{\n  border-collapse: collapse;\n  padding:8px;\n}\n table.jsc_fees_2 td:nth-child(1), table.jsc_fees_2 th:nth-child(1){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:80%;\n }\n \n.jsc_footer{\n\tdisplay:flex;\n\tlist-style-type: none;\n\twidth: 100%;\n    justify-content: space-between;\n    margin-top: 1rem;\n}\n\n.jsc_footer label{\n\tfont-weight:bold;\n}\n\n.jsc_sign{\n\ttext-align: right;\n\tmargin-top: 30px;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;js_page_container&quot;&gt;\n&lt;div class=&quot;js_page js_page1&quot;&gt;\n&lt;div class=&quot;js_page_section&quot;&gt;\n\t&lt;div class=&quot;jsc_markSheetHeader&quot;&gt;\n\t\t&lt;div class=&quot;zcs_school_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t\t&lt;div class=&quot;jsc_markSheetHeader_content&quot;&gt;\n\t\t\t&lt;h4&gt;&lt;%=org.Name%&gt;&lt;\/h4&gt;\n\t\t\t&lt;p&gt;&lt;%=org.Address.address_line_2%&gt;, &lt;%=org.Address.district_city%&gt; - &lt;%=org.Address.postal_Code%&gt;.&lt;\/p&gt;\n\t\t\t&lt;p&gt;Phone: &lt;%=org.Phone_Primary%&gt; \/ &lt;%=org.Phone_Secondary%&gt;&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;h4 class=&quot;jsc_fee_receipt_header&quot;&gt;Fee Receipt&lt;\/h4&gt;\n\t&lt;div class=&quot;jsc_student_details&quot;&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Month&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Payment_Date.toString(&quot;MMM-yy&quot;)%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Receipt No.&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Receipt_ID%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Father&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Parents.Father_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Mother&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Parents.Mother_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Dated&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Payment_Date%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Term&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=receipt.Installement_No%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t&lt;\/div&gt;\n\t&lt;table class=&quot;jsc_fees&quot;&gt;\n\t&lt;thead&gt;\n\t&lt;tr&gt;\n\t\t&lt;th&gt;Student Name&lt;\/th&gt;\n\t\t&lt;th&gt;Class&lt;\/th&gt;\n\t\t&lt;th&gt;Fee Head&lt;\/th&gt;\n\t\t&lt;th&gt;Amount&lt;\/th&gt;\n\t&lt;\/tr&gt;\n\t&lt;\/thead&gt;\n\t&lt;tbody&gt;\n&lt;%\n\tfee_installment = Term_Fees_Form[ID == receipt.Installment_ID];\n\tfor each  StudentInfo in fee_installment.Student_Term_Fees\n\t{\n\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;&lt;%=StudentInfo.Student.Name%&gt;&lt;\/td&gt;&lt;td&gt;&lt;%=StudentInfo.Student.Class.Class%&gt; - &lt;%=StudentInfo.Student.Class.Section%&gt;&lt;\/td&gt;&lt;td&gt;Term &lt;%=receipt.Installement_No%&gt; Fee&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=StudentInfo.Term_Fee.round(0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t\tif(StudentInfo.Past_Due &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;Past Due&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=ifnull(StudentInfo.Past_Due.round(0),0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\tif(StudentInfo.Book_Fee &gt; 0)\n\t\t{\n\t\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;Book Fee&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=ifnull(StudentInfo.Book_Fee.round(0),0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;tr&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tbody&gt;\n\t&lt;tfoot&gt;\n\t\t&lt;tr&gt;\n\t\t\t&lt;td style=&quot;border-right:0 !important;&quot;&gt;&lt;\/td&gt;\n\t\t\t&lt;td style=&quot;border-right:0 !important;&quot;&gt;&lt;\/td&gt;\n\t\t\t&lt;td&gt;Total Amount&lt;br&gt;Paid Amount&lt;br&gt;Balance Due&lt;\/td&gt;\n\t\t\t&lt;td&gt;\u20B9 &lt;%=receipt.Total_Payable_Amount.round(0)%&gt;&lt;br&gt;\u20B9 &lt;%=receipt.Total_Amount_Paid.round(0)%&gt;&lt;br&gt;\u20B9 &lt;%=receipt.Total_Payable_Amount.round(0) - receipt.Total_Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n\t&lt;\/tfoot&gt;\n&lt;\/table&gt;\n&lt;h3 style=&quot;margin-top:35px;margin-bottom:5px;&quot;&gt;Payment History&lt;\/h3&gt;\n\t&lt;table class=&quot;jsc_fees_2&quot;&gt;\n\t&lt;tbody&gt;\n\t\t&lt;tr&gt;\n\t\t&lt;td&gt;Amount Paid on &lt;%=receipt.Payment_Date%&gt; By &lt;%=receipt.Payment_Mode%&gt;&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=receipt.Total_Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n&lt;\/tbody&gt;\n&lt;\/table&gt;\n&lt;div class=&quot;jsc_sign&quot;&gt;Auth. Sign. &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
			script
			{
				/* Write your script logic here. You can assign values to the page variables you've created in the previous tab. Enter 'input.' to list the created page variables. */
			}
		}
		page Admission_Form_Page(int admission_ID, string form_Type)
		{
			displayname = "Admission Form Page"
			Content="<zml    \t\t\n\t\t\tisPrintEnabled='true'\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet2' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet2()\ncontent\n&lt;%{\n\tadmission = Student_Form[ID == input.admission_ID];\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/Logo&quot;);\n\troman_numbers = {&quot;1&quot;:&quot;(i)&quot;,&quot;2&quot;:&quot;(ii)&quot;,&quot;3&quot;:&quot;(iii)&quot;,&quot;4&quot;:&quot;(iv)&quot;,&quot;5&quot;:&quot;(v)&quot;};\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n  &lt;meta charset=&quot;UTF-8&quot;&gt;\n  &lt;title&gt;St. Joseph\u2019s Grammar High School - Admission Form&lt;\/title&gt;\n  &lt;style&gt;\n    .zcs_admission_body {\n      font-family: Arial, sans-serif;\n      margin: 20px;\n\t  padding: 20px;\n    }\n    .zcs_admission_header {\n\t\tdisplay: flex;\n\t\tjustify-content: space-around;\n\t\ttext-align: center;\n\t\t\n    }\n\t.zcs_school_logo {\n\t\twidth: 148px;\n\t\theight: 148px;\n\t}\n\t.zcs_school_logo img{\n\t\theight: 100%;\n\t}\n\t\n\t.zcs_school_details {\n\t\talign-content: center;\n\t}\n\t\n    .zcs_admission_header h2 {\n      margin: 0;\n      color: red;\n    }\n\t.zcs_admission_number {\n\t\ttext-align: right;\n   \t\tmargin: 20px 10px 0px 0px;\n\t}\n\t.zcs_admission_number_value, .zcs_apaar_id_value {\n\t\tfont-weight: 700;\n\t}\n    .zcs_form_table {\n      width: 100%;\n      border-collapse: collapse;\n    }\n\t.zcs_table_section {\n\t\ttext-align: left;\n    \tfont-size: 18px;\n\t\tborder: none !important;\n\t}\n    .zcs_form_table td, .zcs_form_table th {\n      padding: 8px;\n\t  text-align:left;\n      border: 1px solid #ccc;\n    }\n    .zcs_photo-box {\n      border: 1px solid #000;\n      width: 120px;\n      height: 140px;\n      text-align: center;\n      vertical-align: middle;\n      line-height: 150px;\n      font-weight: bold;\n    }\n    .zcs_declaration, .zcs_signature_block, .zcs_order_section {\n      margin-top: 20px;\n\t  font-size: 14px;\n    }\n\t.zcs_apaar_id {\n\t\tmargin-top: 10px;\n\t}\n\t\n\t.zcs_apaar_id p {\n\t\tmargin: 0;\n\t\tfont-size: 14px;\n\t}\n\t\n\t.zcs_signature_block {\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t}\n  &lt;\/style&gt;\n&lt;div class=&quot;zcs_admission_body&quot;&gt;\n\n&lt;div class=&quot;zcs_admission_header&quot;&gt;\n\t&lt;div class=&quot;zcs_school_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t&lt;div class=&quot;zcs_school_details&quot;&gt;\n\t  &lt;h2&gt;&lt;%=org.Name%&gt;&lt;\/h2&gt;\n\t  &lt;p&gt;(Recognised by the Govt. of T.S.)&lt;\/p&gt;\n\t  &lt;p&gt;&lt;%=org.Address.address_line_2%&gt;, &lt;%=org.Address.district_city%&gt; - &lt;%=org.Address.postal_Code%&gt;.&lt;\/p&gt;\n&lt;%\n\tif(input.form_Type == &quot;Admission&quot;)\n\t{\n\t\t%&gt;\n&lt;h3&gt;APPLICATION FOR ADMISSION&lt;\/h3&gt;\n&lt;%\n\t}\n\telse if(input.form_Type == &quot;Consent&quot;)\n\t{\n\t\t%&gt;\n&lt;h3&gt;CONSENT FORM&lt;\/h3&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;div&gt;\n\t&lt;div class=&quot;zcs_photo-box&quot;&gt;Photo&lt;\/div&gt;\n\t&lt;div class=&quot;zcs_admission_number&quot;&gt;Admission No. : &lt;span class=&quot;zcs_admission_number_value&quot;&gt;&lt;%=admission.Admission_Number%&gt;&lt;\/span&gt;&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n\n&lt;table class=&quot;zcs_form_table&quot;&gt;\n\t&lt;tr&gt;\n\t\t&lt;th class=&quot;zcs_table_section&quot;&gt;Student Details : &lt;\/th&gt;\n\t&lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;1. Name : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Name%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;2. Date of Birth : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Date_of_Birth%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;3. Gender : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Gender%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;4. Class : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Class.Class%&gt; - &lt;%=admission.Class.Section%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;5. Medium of Innstruction : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Medium_of_Instruction%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n&lt;%\n\tif(input.form_Type == &quot;Admission&quot;)\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n\t\t&lt;td&gt;6. Mother Language : &lt;\/td&gt;\n\t\t&lt;th&gt;&lt;%=admission.Mother_Language%&gt;&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;7. Nationality &amp; State : &lt;\/td&gt;\n\t\t&lt;th&gt;&lt;%=admission.Nationality%&gt;, &lt;%=admission.State%&gt;&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;8. Religion &amp; Caste : &lt;\/td&gt;\n\t\t&lt;th&gt;&lt;%=admission.Religion%&gt;, &lt;%=admission.Caste%&gt;&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;9. Aadhar Card Number : &lt;\/td&gt;\n\t\t&lt;th&gt;&lt;%=admission.Aadhaar_Number%&gt;&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;10. 1st &amp; 2nd Language : &lt;\/td&gt;\n\t\t&lt;th&gt;&lt;%=admission.First_Language%&gt;, &lt;%=admission.Second_Language%&gt;&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;11. Personal Marks of Identification : &lt;\/td&gt;\n\t\t&lt;th&gt;\n&lt;%\n\t\tmark_count = 0;\n\t\tfor each  mark in admission.Personal_Marks_of_Identifications\n\t\t{\n\t\t\tmark_count = mark_count + 1;\n\t\t\t%&gt;\n&lt;%=roman_numbers.get(mark_count.toString())%&gt;. &lt;%=mark.Identification_Mark%&gt; - &lt;%=mark.Description_if_needed%&gt;&lt;br&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n\t  &lt;tr&gt;\n\t\t&lt;td&gt;12. Previous School Details : &lt;\/td&gt;\n\t\t&lt;th&gt;\n&lt;%\n\t\tprev_school_count = 0;\n\t\tfor each  prev_school in admission.Previous_School_Details\n\t\t{\n\t\t\tprev_school_count = prev_school_count + 1;\n\t\t\t%&gt;\n&lt;%=roman_numbers.get(prev_school_count.toString())%&gt;. &lt;%=prev_school.School.School_Name%&gt;, &lt;%=prev_school.From_Class%&gt; - &lt;%=prev_school.To_Class%&gt;&lt;br&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/th&gt;\n\t  &lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;tr&gt;\n  \t&lt;th class=&quot;zcs_table_section&quot; style=&quot;padding-top: 20px;&quot;&gt;Parents Details : &lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;1. Father&apos;s Name : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Parents_Details_Form_ID.Father_s_Name%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;2. Father&apos;s Mobile : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Parents_Details_Form_ID.Father_s_Mobile%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;3. Mother&apos;s Name : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Parents_Details_Form_ID.Mother_s_Name%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;4. Mother&apos;s Mobile : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Parents_Details_Form_ID.Mother_s_Mobile%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n  &lt;tr&gt;\n    &lt;td&gt;5. Full Address : &lt;\/td&gt;\n\t&lt;th&gt;&lt;%=admission.Parents_Details_Form_ID.Full_Address%&gt;&lt;\/th&gt;\n  &lt;\/tr&gt;\n&lt;\/table&gt;\n&lt;%\n\tif(input.form_Type == &quot;Consent&quot;)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_apaar_id&quot;&gt;\n\t\t\t&lt;p&gt;Mobile Number (Apaar ID) : &lt;span class=&quot;zcs_apaar_id_value&quot;&gt;&lt;%=admission.Mobile_Number_Apaar_ID%&gt;&lt;\/span&gt;&lt;\/p&gt;\n\t\t\t&lt;p&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&amp;#9745;&lt;\/span&gt; I acknowledge and agree to the use of this mobile number for both Apaar ID and DigiLocker services.&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\telse if(input.form_Type == &quot;Admission&quot;)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_declaration&quot;&gt;\n\t\t  &lt;p&gt;I declare that the statement given above is correct and that the pupil has not attended any other school besides those mentioned above.&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;div class=&quot;zcs_signature_block&quot;&gt;\n\t&lt;div class=&quot;zcs_headmaster_signature&quot;&gt;\n\t\t&lt;p&gt;Signature of the Headmaster: _______________________&lt;br&gt;&lt;br&gt;\n\t\tStation: _______________________&lt;br&gt;&lt;br&gt;\n\t\tDated: _______________________&lt;\/p&gt;\n\t&lt;\/div&gt;\n\t&lt;div class=&quot;zcs_parent_signature&quot;&gt;\n\t\t&lt;p&gt;Signature of Parent\/Guardian: _______________________&lt;br&gt;&lt;br&gt;\n\t\tStation: _______________________&lt;br&gt;&lt;br&gt;\n\t\tDated: _______________________&lt;\/p&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n\n\n&lt;\/div&gt;\n&lt;\/html&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Parent_Details(string admissionnumber, int selectedstudentid)
		{
			displayname = "Parent Details"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet5' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet5()\ncontent\n&lt;%{\n\tif(input.admissionnumber not in {&quot;&quot;,null})\n\t{\n\t\tSelectedStudentInfo = Student_Form[Admission_Number == input.admissionnumber];\n\t\tif(SelectedStudentInfo.count() &gt; 0)\n\t\t{\n\t\t\tinput.selectedstudentid = SelectedStudentInfo.ID;\n\t\t}\n\t}\n\telse if(input.selectedstudentid != null)\n\t{\n\t\tSelectedStudentInfo = Student_Form[ID == input.selectedstudentid];\n\t\tif(SelectedStudentInfo.count() &gt; 0)\n\t\t{\n\t\t\tinput.admissionnumber = SelectedStudentInfo.Admission_Number;\n\t\t}\n\t}\n\tParentInfo = Parents_Details_Form[ID == SelectedStudentInfo.Parents_Details_Form_ID];\n\t\/\/----------------------------------- Images ------------------------------\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/Logo&quot;);\n\tPDFIcon = Images[name == &quot;pdficon&quot;].Image;\n\tPDFIcon = PDFIcon.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tDownloadIcon = Images[name == &quot;downloadicon&quot;].Image;\n\tDownloadIcon = DownloadIcon.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tPrintIcon = Images[name == &quot;printicon&quot;].Image;\n\tPrintIcon = PrintIcon.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tPastDueIconInfo = Images[name == &quot;updatepastdueicon&quot;].Image;\n\tPastDueIcon = PastDueIconInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tBookFeeIconInfo = Images[name == &quot;bookfeeicon&quot;].Image;\n\tBookFeeIcon = BookFeeIconInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tMakePaymentIconInfo = Images[name == &quot;makepaymenticon&quot;].Image;\n\tMakePaymentIcon = MakePaymentIconInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tPrintReceiptIconInfo = Images[name == &quot;printreceipticon&quot;].Image;\n\tPrintReceiptIcon = PrintReceiptIconInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tPenEditIconInfo = Images[name == &quot;penediticon&quot;].Image;\n\tPenEditIcon = PenEditIconInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\tparentdashboard_student_bgInfo = Images[name == &quot;parentdashboard_student_bg&quot;].Image;\n\tparentdashboard_student = parentdashboard_student_bgInfo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri).replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;All_Images\/Image&quot;);\n\t\/\/------------------------- Add Payment ----------------------------\n\tfetTermFee = Term_Fees_Form[Academic_Year == SelectedStudentInfo.Academic_Year &amp;&amp; Parents == ParentInfo.ID &amp;&amp; Status != &quot;Paid&quot;];\n\taddPaymentStatus = &quot;&quot;;\n\tif(fetTermFee.count() == 0)\n\t{\n\t\taddPaymentStatus = &quot;disabled&quot;;\n\t}\n\t\/\/----------------------- Student Profile --------------------------\n\tstudent_photo = &quot;&quot;;\n\tif(SelectedStudentInfo.count() &gt; 0)\n\t{\n\t\tif(!SelectedStudentInfo.Student_Photo.isEmpty())\n\t\t{\n\t\t\tstudent_photo = SelectedStudentInfo.Student_Photo;\n\t\t\tstudent_photo = student_photo.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\t\t\tstudent_photo = student_photo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Students\/Student_Photo&quot;);\n\t\t}\n\t\telse\n\t\t{\n\t\t\tstudent_photo = &quot;&lt;div class=&apos;zcs_name_profile&apos;&gt;&quot; + thisapp.studentProfile(SelectedStudentInfo.Name) + &quot;&lt;\/div&gt;&quot;;\n\t\t}\n\t}\n\t%&gt;\n&lt;style&gt;\n\/*------------------------- Common Styles --------------------------*\/\n.zcsBody *,.zcsBody *::after,.zcsBody *::before{\n\tmargin:0;\n\tpadding:0;\n\tbox-sizing:border-box;\n}\n\n.zcsBody {\n  --header-height: 6.5rem;\n  height: 100vh;\n  padding:1rem;\n  color:#1f1c2e;\n}\n\n.zcsBody ul{\n\t  list-style-type: none;\n}\n\n\/*** Header (Row 1) Styles ****\/\n.zcsBody .zcsRow1 {\n  height: var(--header-height);\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n}\n\/*----------------------- Dashboard Logo &amp; Header --------------------*\/\n.zcsBody .zcsRow1 .zcsRow1_left{\n\tdisplay:flex;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left img.zcsRow1_left_logo{\n\theight: calc(0.8 * var(--header-height));\n\taspect-ratio:1;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div{\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-left:1.5rem;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div h4{\n\tfont-size:1.4rem;\n\tmargin-bottom:0.4rem;\n\tfont-weight:normal;\n}\n\n.zcsBody .zcsRow1 .zcsRow1_left &gt; div h5{\n\tfont-size:1.1rem;\n\tfont-weight:normal;\n}\n\/*------------------------ Add Payment ----------------------*\/\n.zcs_payment a {\n\ttext-decoration: none;\n    padding: 8px 10px;\n    border-radius: 8px;\n    border: 1px solid #ccc;\n    font-size: 13px;\n    color: #3f51b5;\n    font-weight: 600;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    background-color: #fff;\n    transition: background 0.2s ease;\n}\n\n.zcs_payment a img {\n\theight: 18px;\n    width: 18px;\n    object-fit: contain;\n    position: relative;\n    display: inline-block;\n\tmargin-right: 5px;\n}\n\/*----------------------- Select Student --------------------*\/\n.zcsRow1_right{\n\/\/ \tpadding-right: 15px;\n\tdisplay: flex;\n\tgap: 40px;\n\talign-items: center;\n}\n\n.zcsRow1_right_select {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 8px;\n}\n\n.zcsRow1_right_select label {\n  font-weight: 500;\n  font-size: 16px;\n  color: #1a1a1a;\n}\n\n.zcsRow1_right_students {\n  display: flex;\n  gap: 10px;\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n.zcsRow1_right_students li a {\n  text-decoration: none;\n}\n\n.initials-logo {\n  width: 40px;\n  height: 40px;\n  background-color: #5f4dde;\n  font-weight: 700;\n  font-size: 14px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);\n  transition: all 0.2s ease;\n}\n\n.zcs_active_student .initials-logo {\n  background-color: #fff;\n  border: 2px solid #2a2069;\n  box-shadow: 1px 1px 5px #353535;\n}\n\n.initials-logo {\n\twidth: 40px;\n\theight: 40px;\n\tborder-radius: 50%;\n\tbackground: linear-gradient(135deg, #6a6ff1, #434fb9);\n\tcolor: white;\n\tdisplay: flex;\n\talign-items: center;\n\tjustify-content: center;\n\tfont-weight: 600;\n\tfont-size: 14px;\n\tfont-family: &apos;Inter&apos;, sans-serif;\n\tbox-shadow: 0 2px 6px rgba(0,0,0,0.1);\n\tuser-select: none;\n}\n\n.zcsRow1_right_students a {\n\tmargin-right: 8px;\n\ttext-decoration: none;\n}\n\n.zcsRow1_right_students a:hover .initials-logo {\n\tbox-shadow: 0 0 0 2px #6a6ff1;\n}\n\n.zcs-label-top {\n\tfont-size: 14px;\n\tfont-weight: 600;\n\tcolor: #333;\n}\n\n\/*** Row 2 ****\/\n.zcsBody .zcsRow2 {\n  height: calc(2.4 * var(--header-height));\n}\n.zcsBody .zcsRow2{\n\tdisplay:flex;\n\tgap:1rem;\n}\n\n.zcsBody .zcsRow2 &gt; div{\n\tborder-radius: 1.5rem;\n\tborder: 1px solid #F1F1F1;\n\tbackground: #FCFBFE;\n}\n\/*----------------------- Student Profile Card --------------------*\/\n.zcsBody .zcsRow2 &gt; div.zcsRow2_profile{\n\twidth: 37%;\n\tposition: relative;\n    background: linear-gradient(120deg, #4500a3, #090021);\n    color: white;\n    padding: 20px;\n\tdisplay: flex;\n    flex-direction: column;\n    justify-content: space-between;\n}\n\n.zcsbackground_img img{\n\twidth:100%;\n}\n\n.zcsbackground_img {\n\tposition: absolute;\n    width: 100%;\n    height: 100%;\n    top: 0px;\n    left: 0px;\n\tpointer-events: none;\n\toverflow:hidden;\n}\n\n.zcs_student_profile {\n\tdisplay: flex;\n}\n\n.zcs_student_photo {\n    width: 106px;\n    height: 106px;\n    border-radius: 10px;\n    margin-right: 20px;\n}\n.zcs_name_profile {\n    background-color: grey;\n    border: 1px solid white;\n    border-radius: 10px;\n    font-size: 28px;\n    font-weight: 600;\n\twidth: 100%;\n\theight: 100%;\n\tdisplay: flex;\n\tjustify-content: center;\n\talign-items: center;\n}\n.zcs_profile_info {\n\tdisplay: flex;\n    flex-direction: column;\n    gap: 10px;\n}\n.zcs_admission_no {\n    background-color: white;\n    color: #5968BD;\n    font-weight: 800;\n    padding: 5px 8px;\n    border-radius: 5px;\n    width: fit-content;\n\tfont-size: 15px;\n}\n.zcs_student_name {\n\tfont-size: 25px;\n\tfont-weight: 600;\n}\n.zcs_student_class {\n\tfont-size: 19px;\n\tfont-weight: 300;\n}\n.zcs_edit {\n\tbackground-color: #4054B2;\n    width: fit-content;\n    padding: 8px;\n    border-radius: 8px;\n    font-size: 15px;\n    font-weight: 500;\n}\n.zcs_edit a {\n\tcolor: #fff; \/* white *\/\n\ttext-decoration: none;\n\tdisplay: flex;\n\talign-items: center;\n\tgap: 6px;\n}\n\n.zcs_edit a:hover {\n\topacity: 0.9;\n}\n.zcs_edit a img {\n\theight: 18px;\n\twidth: 18px;\n\tobject-fit: contain;\n}\n\/*----------------------- Student &amp; Parents Details --------------------*\/\n.zcsBody .zcsRow2 &gt; div.zcsRow2_details{\n\twidth:37%;\n}\n.zcsRow2_details {\n\t\theight: 100%;\n\t}\n\t.zcs_tabbed {\n\/\/ \t\toverflow-x: hidden; \/* so we could easily hide the radio inputs *\/\n\t\tpadding: 20px;\n\t\theight: 100%;\n\t}\n.zcs_tab_container {\n    display: flex;\n    margin: 0;\n\tborder-radius: 10px;\n\tbackground-color:rgba(99, 165, 19, 0.20);\n}\n.zcs_tabRadio {\n\t\/* hiding the inputs *\/\n\tdisplay: none;\n}\n.zcs_tabs {\n\tdisplay: flex;\n\tgap: 20px;\n\tborder-bottom: 1px solid #ccc;\n\tpadding-bottom: 5px;\n    margin-bottom: 15px;\n}\n.zcs_tabLabel {\n    border: 3px solid transparent;\n    font-size: 16px;\n    cursor: pointer;\n    transition: all 0.3s;\n}\n.zcs_tab:hover label {\n\/\/ \t border-bottom-color: #ffffff;\n    color: var(--primary_color);\n}\n\n.zcs_tab_content {\n\topacity:0;\n\theight:0vh;\n\/\/ \toverflow:scroll;\n}\n.embdDIv\n{\n\theight:140px !important;\n}\t\t\t\t\t\t\t\t\t\t\t  \t\t\t\t\t\t\t\t\t \t\t\t\t\t\t\t\t\t \n\n\n\/* As we cannot replace the numbers with variables or calls to element properties, the number of this selector parts is our tab count limit *\/\n.zcs_tabRadio:nth-of-type(1):checked ~ .zcs_tabs .zcs_tab:nth-of-type(1) label,\n.zcs_tabRadio:nth-of-type(2):checked ~ .zcs_tabs .zcs_tab:nth-of-type(2) label\n{\n    color: var(--primary_color);\n\tborder-bottom: 1px solid var(--primary_color);\n    padding-bottom: 6px;\n}\n\n.zcs_tabRadio:nth-of-type(1):checked ~ .zcs_tab_content:nth-of-type(1),\n.zcs_tabRadio:nth-of-type(2):checked ~ .zcs_tab_content:nth-of-type(2)\n{\n\topacity:1;\n\theight:100%;\n\tborder-radius:10px;\n\toverflow-y: auto;\n    max-height: calc(100% - 32px);\n    scrollbar-width: none;\n}\n.zcs_student_table, .zcs_parents_table {\n\twidth: 100%;\n    text-align: left;\n}\n.zcs_student_table td, .zcs_parents_table td {\n\tcolor: grey;\n\tpadding-bottom: 15px;\n\twidth: 45%\n}\n.zcs_student_table th, .zcs_parents_table th {\n\tfont-weight: 600;\n    padding-bottom: 15px;\n\twidth: 55%;\n}\n\/*----------------------- Student Documents --------------------*\/\n.zcsBody .zcsRow2 &gt; div.zcsRow2_documents{\n\twidth: 26%;\n\tpadding: 20px;\n}\n.zcs_document_header {\n\tfont-size: 16px;\n\tfont-weight: 500;\n\tborder-bottom: 1px solid #ccc;\n    padding-bottom: 5px;\n    margin-bottom: 10px;\n}\n.zcs_document_list {\n\toverflow-y: auto;\n    max-height: calc(100% - 32px);\n    scrollbar-width: none;\n}\n.zcs_document {\n\tpadding: 5px;\n\tmargin-bottom: 10px;\n\tbackground-color: #F4F6F9;\n    border-radius: 5px;\n    border: 1px #E6E6E6 solid;\n\tdisplay: flex;\n\tjustify-content: space-between;\n}\n.zcs_document_name {\n\tfont-size: 13px;\n\tfont-weight: 600;\n\tdisplay: flex;\n\tgap: 5px;\n\talign-items: center;\n}\n.zcs_document_name a img, .zcs_document_download a img {\n\theight: 28px;\n    width: 28px;\n    object-fit: contain;\n}\n\/**** Row 3 ****\/\n.zcsBody .zcsRow3 {\n  min-height: calc(100vh - 4 * var(--header-height));\n}\n\n\/*------------------------ Fee Details ----------------------*\/\n.zcs_fee_details_title {\n\tfont-size: 22px;\n\tfont-weight: 400;\n\tpadding: 15px;\n}\n.zcs_table_container {\n      width: 100%;\n      overflow-x: auto;\n    }\n\n    .zcs_fee_details_table {\n      width: 100%;\n      border-collapse: separate;\n      border-spacing: 0;\n      border-radius: 14px;\n      overflow: hidden;\n      box-shadow: 0 1px 2px rgba(0,0,0,0.05);\n    }\n\n    .zcs_fee_details_thead {\n      background: linear-gradient(90deg, #6a6ff1, #434fb9);\n      color: #fff;\n      text-align: center;\n    }\n    \n    .zcs_fee_details_thead th {\n      padding: 16px 12px;\n      font-weight: 600;\n      font-size: 14px;\n    }\n\t.zcs_fee_details_tbody {\n\t\ttext-align: center;\n\t}\n    .zcs_fee_details_tbody td {\n      padding: 16px 12px;\n      font-size: 16px;\n      font-weight: 500;\n      border-bottom: 1px solid #f0f0f0;\n      vertical-align: middle;\n\t  text-align: center;\n    }\n\n    .zcs_term_title {\n      font-weight: 700;\n      color: #3f51b5;\n      font-size: 16px;\n    }\n\n    .zcs_term_date {\n      color: #787878;\n      font-size: 14px;\n    }\n\n    .zcs_action_wrapper {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      flex-wrap: wrap;\n\t  justify-content: center;  \/* horizontal center *\/\n    }\n\n    .zcs_action_wrapper a {\n      text-decoration: none;\n      padding: 8px 10px;\n      border-radius: 8px;\n      border: 1px solid #ccc;\n      font-size: 13px;\n      color: #3f51b5;\n      font-weight: 600;\n      display: flex;\n      align-items: center;\n      gap: 4px;\n      background-color: #fff;\n      transition: background 0.2s ease;\n    }\n\n    .zcs_action_wrapper a:hover {\n      background-color: #f0f0f0;\n    }\n\t\n    .zcs_action_wrapper a img {\n\t\theight: 18px;\n\t\twidth: 18px;\n\t\tobject-fit: contain;\n\t\tposition: relative;\n\t\tdisplay: inline-block;\n\t}\n\n    .zcs_alt_row {\n      background-color: #f9f9fb;\n    }\n\t.disabled {\n\t\tpointer-events: none; \n\t\topacity: 0.5;        \n\t\tborder-color: #e0e0e0;\n\t\tcolor: #999;\n\t\tbackground-color: #f5f5f5;\n\t}\n\t.zcs_action_wrapper a .zcs_tooltiptext {\n\t  visibility: hidden;\n\t  width: 120px;\n\t  background-color: black;\n\t  color: #fff;\n\t  text-align: center;\n\t  border-radius: 6px;\n\t  padding: 5px 10px;\n\t  font-size: 10px;\n\t  \/* Position the tooltip *\/\n\t  position: absolute;\n\t  z-index: 1;\n\t  margin-bottom: 40px;\n\t}\n\t.zcs_action_wrapper a:hover .zcs_tooltiptext {\n\t\tvisibility: visible;\n\t}\n&lt;\/style&gt;\n&lt;div class=&quot;zcsBody&quot;&gt;\n&lt;!------------------------------------ Headers --------------------------------------&gt;\n\t&lt;div class=&quot;zcsRow1&quot;&gt;\n\t&lt;!----------------------- Dashboard Header -----------------------&gt; \n\t\t&lt;div class=&quot;zcsRow1_left&quot;&gt;\n\t\t\t&lt;div class=&quot;zcsRow1_left_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t\t\t&lt;div&gt;\n\t\t\t\t&lt;h4&gt;St. Joseph\u2019s Public School&lt;\/h4&gt;\n\t\t\t\t&lt;h5&gt;Parent&amp;nbsp;Dashboard&lt;\/h5&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;!------------------------ Select Students -----------------------&gt;\n&lt;%\n\tif(ParentInfo.count(Children) &gt; 1)\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcsRow1_right&quot;&gt;\n\t\t\t&lt;div class=&quot;zcsRow1_right_select&quot;&gt;\n\t\t\t\t&lt;label class=&quot;zcs-label-top&quot;&gt;Select Student&lt;\/label&gt;\n\t\t\t\t&lt;ul class=&quot;zcsRow1_right_students&quot;&gt;\n&lt;%\n\t\tfor each  student in ParentInfo.Children\n\t\t{\n\t\t\tactiveStudent = &quot;&quot;;\n\t\t\tif(student == SelectedStudentInfo)\n\t\t\t{\n\t\t\t\tactiveStudent = &quot;zcs_active_student&quot;;\n\t\t\t}\n\t\t\tif(!student.Student_Photo.isEmpty())\n\t\t\t{\n\t\t\t\tstudent_profile = student.Student_Photo;\n\t\t\t\tstudent_profile = student_profile.replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\t\t\t\tstudent_profile = student_profile.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Students\/Student_Photo&quot;);\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tstudent_profile = &quot;&lt;div class=&apos;zcs_student_profile_icon&apos;&gt;&quot; + thisapp.studentProfile(student.Name) + &quot;&lt;\/div&gt;&quot;;\n\t\t\t}\n\t\t\t%&gt;\n&lt;li class=&quot;&lt;%=activeStudent%&gt;&quot;&gt;\n\t\t\t\t\t&lt;a href=&quot;#Page:Parent_Details?selectedstudentid=&lt;%=student%&gt;&quot;&gt;&lt;div class=&quot;initials-logo&quot;&gt;&lt;%=student_profile%&gt;&lt;\/div&gt;&lt;\/a&gt;\n\t\t\t\t\t&lt;\/li&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/ul&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;zcs_payment&quot;&gt;\n\t\t\t\t&lt;a href=&quot;#Form:Fees_Receipt?Installment_ID=&lt;%=fetTermFee.ID%&gt;&amp;zc_LoadIn=dialog&quot;&gt;&lt;%=MakePaymentIcon%&gt;&lt;span&gt;Add Payment&lt;\/span&gt;&lt;\/a&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n&lt;!------------------------------------ Student Details --------------------------------------&gt;\t\n\t&lt;div class=&quot;zcsRow2&quot;&gt;\n&lt;!--------------------------- Profile Card -------------------------&gt;\n\t\t&lt;div class=&quot;zcsRow2_profile&quot;&gt;\n\t\t\t&lt;div class=&quot;zcsbackground_img&quot;&gt;\n\t\t\t&lt;%=parentdashboard_student%&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t\n\t\t\t&lt;div class=&quot;zcs_student_profile&quot;&gt;\n\t\t\t\t&lt;div class=&quot;zcs_student_photo&quot;&gt;&lt;%=student_photo%&gt;&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;zcs_profile_info&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_admission_no&quot;&gt;&lt;%=input.admissionnumber%&gt;&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_student_name&quot;&gt;&lt;%=SelectedStudentInfo.Name%&gt;&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_student_class&quot;&gt;2025-26 | &lt;%=SelectedStudentInfo.Class.Class%&gt; - &lt;%=SelectedStudentInfo.Class.Section%&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;zcs_edit_profile&quot;&gt;\n\t\t\t\t&lt;div class=&quot;zcs_edit&quot;&gt;\n\t\t\t\t&lt;a href=&quot;#Form:Student_Form?recLinkID=&lt;%=input.selectedstudentid%&gt;&amp;viewLinkName=Students&amp;zc_LoadIn=dialog&quot;&gt;\n\t\t\t\t&lt;%=PenEditIcon%&gt; Edit Profile\n\t\t\t\t&lt;\/a&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;!--------------------- Student &amp; Parent Details ---------------------&gt;\n\t\t&lt;div class=&quot;zcsRow2_details&quot;&gt;\n\t\t\t&lt;div class=&quot;zcs_tabbed&quot;&gt;\n\t\t\t\t&lt;input type=&quot;radio&quot; id=&quot;zcs_tab1&quot; class=&quot;zcs_tabRadio&quot; name=&quot;css-tabs&quot; checked&gt;\n\t\t\t\t&lt;input type=&quot;radio&quot; id=&quot;zcs_tab2&quot; class=&quot;zcs_tabRadio&quot; name=&quot;css-tabs&quot;&gt;\n\t\t\t\t\n\t\t\t\t&lt;ul class=&quot;zcs_tabs&quot;&gt;\n\t\t\t\t\t\t&lt;li class=&quot;zcs_tab&quot;&gt;&lt;label class=&quot;zcs_tabLabel&quot; for=&quot;zcs_tab1&quot;&gt;Student Details&lt;\/label&gt;&lt;\/li&gt;\n\t\t\t\t\t\t&lt;li class=&quot;zcs_tab&quot;&gt;&lt;label class=&quot;zcs_tabLabel&quot; for=&quot;zcs_tab2&quot;&gt;Parents Details&lt;\/label&gt;&lt;\/li&gt;\n\t\t\t\t&lt;\/ul&gt;\n\t\t\t\t&lt;div class=&quot;zcs_tab_content&quot;&gt;\n\t\t\t\t\t&lt;table class=&quot;zcs_student_table&quot;&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Date of Birth&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Date_of_Birth%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Gender&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Gender%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Nationality&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Nationality%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Religion&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Religion%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Aadhaar&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Aadhaar_Number%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Medium of Instruction&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Medium_of_Instruction%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Mother Language&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Mother_Language%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;State&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.State%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Caste&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=SelectedStudentInfo.Caste%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;zcs_tab_content&quot;&gt;\n\t\t\t\t\t&lt;table class=&quot;zcs_parents_table&quot;&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Father&apos;s Name&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=ParentInfo.Father_s_Name%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Father&apos;s Mobile&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=ParentInfo.Father_s_Mobile%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Mother&apos;s Name&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=ParentInfo.Mother_s_Name%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Mother&apos;s Mobile&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=ParentInfo.Mother_s_Mobile%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t\t\t&lt;td&gt;Apaar ID&lt;\/td&gt;\n\t\t\t\t\t\t\t&lt;th&gt;&lt;%=ParentInfo.Mobile_Number_Apaar_ID%&gt;&lt;\/th&gt;\n\t\t\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t\t&lt;\/table&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;!----------------------------- Documents ----------------------------&gt;\n\t\t&lt;div class=&quot;zcsRow2_documents&quot;&gt;\n\t\t\t&lt;div class=&quot;zcs_document_header&quot;&gt;Documents&lt;\/div&gt;\n\t\t\t&lt;div class=&quot;zcs_document_list&quot;&gt;\n\t\t\t\t&lt;div class=&quot;zcs_document&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_name&quot;&gt;\n\t\t\t\t\t\t&lt;a href=&quot;#&quot;&gt;&lt;%=PDFIcon%&gt;&lt;\/a&gt;\n\t\t\t\t\t\t&lt;p&gt;Admission Form&lt;p&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_download&quot;&gt;&lt;a target=&quot;_blank&quot; href=&quot;https:\/\/creatorapp.zoho.in\/export&lt;%=zoho.appuri%&gt;print\/Admission_Form_Page\/?admission_ID=&lt;%=SelectedStudentInfo.ID%&gt;&amp;form_Type=Admission&quot;&gt;&lt;%=PrintIcon%&gt;&lt;\/a&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n\t\t\t\t&lt;div class=&quot;zcs_document&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_name&quot;&gt;\n\t\t\t\t\t\t&lt;a href=&quot;#&quot;&gt;&lt;%=PDFIcon%&gt;&lt;\/a&gt;\n\t\t\t\t\t\t&lt;p&gt;Consent Form&lt;p&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_download&quot;&gt;&lt;a target=&quot;_blank&quot; href=&quot;https:\/\/creatorapp.zoho.in\/export&lt;%=zoho.appuri%&gt;print\/Admission_Form_Page\/?admission_ID=&lt;%=SelectedStudentInfo.ID%&gt;&amp;form_Type=Consent&quot;&gt;&lt;%=PrintIcon%&gt;&lt;\/a&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\tfor each  document in Document[Student_Form_ID.Admission_Number == input.admissionnumber]\n\t{\n\t\t%&gt;\n&lt;div class=&quot;zcs_document&quot;&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_name&quot;&gt;\n\t\t\t\t\t\t&lt;a href=&quot;#&quot;&gt;&lt;%=PDFIcon%&gt;&lt;\/a&gt;\n\t\t\t\t\t\t&lt;p&gt;&lt;%=document.Document_Type%&gt;&lt;p&gt;\n\t\t\t\t\t&lt;\/div&gt;\n\t\t\t\t\t&lt;div class=&quot;zcs_document_download&quot;&gt;&lt;a target=&quot;_blank&quot; href=&quot;&lt;%=zoho.appuri%&gt;report\/Documents\/&lt;%=document.ID%&gt;\/Document\/download-file?filepath=\/&lt;%=document.Document%&gt;&amp;mediaType=3&quot;&gt;&lt;%=DownloadIcon%&gt;&lt;\/a&gt;&lt;\/div&gt;\n\t\t\t\t&lt;\/div&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/div&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;!------------------------------------ Fee Details --------------------------------------&gt;\n\t&lt;div class=&quot;zcsRow3&quot;&gt;\n\t\t&lt;div class=&quot;zcs_fee_details_title&quot;&gt;Fee Details&lt;\/div&gt;\n\t\t&lt;div class=&quot;zcs_table_container&quot;&gt;\n    &lt;table class=&quot;zcs_fee_details_table&quot;&gt;\n      &lt;thead class=&quot;zcs_fee_details_thead&quot;&gt;\n        &lt;tr&gt;\n          &lt;th&gt;TERM&lt;\/th&gt;\n          &lt;th&gt;TOTAL FEE&lt;\/th&gt;\n          &lt;th&gt;FEE OUTSTANDING&lt;\/th&gt;\n          &lt;th&gt;LAST DATE&lt;\/th&gt;\n          &lt;th&gt;ACTION&lt;\/th&gt;\n        &lt;\/tr&gt;\n      &lt;\/thead&gt;\n      &lt;tbody class=&quot;zcs_fee_details_tbody&quot;&gt;\n&lt;%\n\tfetTermFees = Term_Fees_Form[Parents == ParentInfo &amp;&amp; Academic_Year == SelectedStudentInfo.Academic_Year];\n\ttermFees = Student_Specific_Term_Fee[Term_Fees_Form.Fee_ID == fetTermFees.Fee_ID &amp;&amp; Student == input.selectedstudentid];\n\tif(termFees.count() &gt; 0)\n\t{\n\t\tfor each  term in termFees\n\t\t{\n\t\t\t\/\/-------------------- Disable Actions --------------------\n\t\t\tpastDueStatus = &quot;&quot;;\n\t\t\tbookFeeStatus = &quot;&quot;;\n\t\t\taddPaymentStatus = &quot;&quot;;\n\t\t\tfeeReceiptStatus = &quot;&quot;;\n\t\t\tif(term.Past_Due != 0)\n\t\t\t{\n\t\t\t\tpastDueStatus = &quot;disabled&quot;;\n\t\t\t}\n\t\t\tif(term.Book_Fee != 0)\n\t\t\t{\n\t\t\t\tbookFeeStatus = &quot;disabled&quot;;\n\t\t\t}\n\t\t\tif(term.Term_Fees_Form.Status != &quot;Paid&quot;)\n\t\t\t{\n\t\t\t\tfeeReceiptStatus = &quot;disabled&quot;;\n\t\t\t}\n\t\t\t%&gt;\n&lt;tr&gt;\n          &lt;td&gt;\n            &lt;div class=&quot;zcs_term_title&quot;&gt;Term &lt;%=term.Term_Fees_Form.Installment_No%&gt;&lt;\/div&gt;\n            &lt;div class=&quot;zcs_term_date&quot;&gt;&lt;%=term.Term_Fees_Form.Start_Date%&gt;&lt;\/div&gt;\n          &lt;\/td&gt;\n\t\t  &lt;td&gt;\u20B9 &lt;%=term.Final_Term_Fee%&gt;&lt;\/td&gt;\n          &lt;td&gt;\u20B9 &lt;%=term.Balance_Amount%&gt;&lt;\/td&gt;\n          &lt;td&gt;&lt;%=term.Term_Fees_Form.Due_Date%&gt;&lt;\/td&gt;\n          &lt;td&gt;\n            &lt;div class=&quot;zcs_action_wrapper&quot;&gt;\n              &lt;a class=&quot;&lt;%=pastDueStatus%&gt;&quot; href=&quot;#Form:Update_Amount?Installment_ID=&lt;%=fetTermFees.ID%&gt;&amp;Amount_Type=Past Due&amp;Selected_Student=&lt;%=input.selectedstudentid%&gt;&amp;zc_LoadIn=dialog&quot;&gt;&lt;%=PastDueIcon%&gt;&lt;span class=&quot;zcs_tooltiptext&quot;&gt;Update Past Due&lt;\/span&gt;&lt;\/a&gt;\n              &lt;a class=&quot;&lt;%=bookFeeStatus%&gt;&quot; href=&quot;#Form:Update_Amount?Installment_ID=&lt;%=fetTermFees.ID%&gt;&amp;Amount_Type=Book Fee&amp;Selected_Student=&lt;%=input.selectedstudentid%&gt;&amp;zc_LoadIn=dialog&quot;&gt;&lt;%=BookFeeIcon%&gt;&lt;span class=&quot;zcs_tooltiptext&quot;&gt;Update Book Fee&lt;\/span&gt;&lt;\/a&gt;\n              &lt;a class=&quot;&lt;%=feeReceiptStatus%&gt;&quot; target=&quot;_blank&quot; href=&quot;https:\/\/creatorapp.zoho.in\/export&lt;%=zoho.appuri%&gt;pdf\/Term_Fees_Receipt\/?termfeeid=&lt;%=term.ID%&gt;&quot;&gt;&lt;%=PrintReceiptIcon%&gt;&lt;span class=&quot;zcs_tooltiptext&quot;&gt;Download Fee Receipt&lt;\/span&gt;&lt;\/a&gt;\n            &lt;\/div&gt;\n          &lt;\/td&gt;\n        &lt;\/tr&gt;\n&lt;%\n\t\t}\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;tr&gt;&lt;td colspan=&quot;5&quot;&gt;&lt;div style=&quot;color: grey;&quot;&gt;Term fees yet to be provided.&lt;\/div&gt;&lt;\/td&gt;&lt;tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tbody&gt;\n    &lt;\/table&gt;\n  &lt;\/div&gt;\n\t&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
			script
			{
				/* Write your script logic here. You can assign values to the page variables you've created in the previous tab. Enter 'input.' to list the created page variables. */
