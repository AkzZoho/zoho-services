		page Term_Fees_Receipt(int termfeeid)
		{
			displayname = "Term Fees Receipt"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet9' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet9()\ncontent\n&lt;%{\n\t\/\/ \ttermfeeid = 276743000001093904;\n\tStudentTermFeeInfo = Student_Specific_Term_Fee[ID == input.termfeeid];\n\tTermFeeInfo = Term_Fees_Form[ID == StudentTermFeeInfo.Term_Fees_Form];\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;creator.zoho.in&quot;,&quot;creatorapp.zohopublic.in\/file&quot;).replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/&quot; + org.ID + &quot;\/Logo&quot;).replaceAll(&quot;\/image\/&quot;,&quot;\/image-download\/XGD9BYAdnDHEmCrtpDfK1RUMCtB5Jmav111fV7Rpw5xyykOPgZxOHFYQb5JXjdYf8T5HzkZsYXQ4dPDA68hO8fqCRuT4KFDGGUAu?filepath=&quot;);\n\t%&gt;\n&lt;style&gt;\n:root{\n--jsHorizontalPagePadding:1.75cm;\n--jsVerticalPagePadding:1.75cm;\n}\n\n.js_page_container *{\nmargin:0;\npadding:0;\nbox-sizing:border-box;\n}\n\n.js_page_container{\nfont-family: &apos;Lato&apos;;\n}\n\n.js_page{\npadding:12px;\nbackground: white;\nwidth: 21cm;\nheight: 25cm;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n}\n\n.js_page:not(.js_page1){\npage-break-before:always;\n}\n\n.js_page_section{\nborder:0.5px solid #000;\nwidth: calc(21cm - var(--jsHorizontalPagePadding));\nheight: calc(25cm - var(--jsVerticalPagePadding));\npadding:20px;\ndisplay: flex;\nflex-direction: column;\nposition:relative;\n}\n\n\/*** Marksheet Header ****\/\n.jsc_markSheetHeader{\n\tdisplay:flex;\n\ttext-align:center;\n\tpadding-bottom: 13px;\n}\n\n.jsc_markSheetHeader img{\n\twidth:90px;\n\taspect-ratio:1;\n\tmargin-left:45px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-right:60px;\n\tletter-spacing:.75px;\n}\n\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content h4{\n\tfont-size:17px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content &gt; *{\n\tline-height:20px;\n}\n\n.js_page_section h4.jsc_fee_receipt_header{\n\t text-transform: uppercase;\n\t line-height:35px;\n\t border-top:0.5px solid #000;\n\t border-bottom:0.5px solid #000;\n\t text-align:center;\n\t margin-top:12px;\n\t font-size:18px\n\t letter-spacing:1px;\n}\n\n\/**** Student Details ****\/\n.jsc_student_details{\n\tdisplay:flex;\n\tpadding: 15px 0;\n    justify-content: space-between;\n\talign-items:center;\n}\n\n.jsc_student_details table.jsc_student_details_table{\n\tflex:1;\n\tmargin:0 auto;\n}\n\n\n.jsc_student_details table.jsc_student_details_table td{\n\tline-height:30px;\n\twidth:50%;\n}\n\n\/****** Fees table ******\/\n\n table.jsc_fees td:nth-child(4), table.jsc_fees th:nth-child(4){\n    text-align: right;\n\tborder-left:0.5px solid #000;\n}\n\ntable.jsc_fees, table.jsc_fees td, table.jsc_fees th{\n  border-collapse: collapse;\n  padding:8px;\n}\n\ntable.jsc_fees thead th{\n\t     line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n }\n \n table.jsc_fees td:nth-child(1), table.jsc_fees th:nth-child(1), table.jsc_fees td:nth-child(2), table.jsc_fees th:nth-child(2){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:20%;\n }\n  table.jsc_fees td:nth-child(3), table.jsc_fees th:nth-child(3){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:40%;\n }\n\ntable.jsc_fees tfoot tr{\n\t\t line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n}\n\ntable.jsc_fees_2, table.jsc_fees_2 td, table.jsc_fees_2 th{\n  border-collapse: collapse;\n  padding:8px;\n}\n table.jsc_fees_2 td:nth-child(1), table.jsc_fees_2 th:nth-child(1){\n\t \tborder-right:0.5px solid #000;\n\t\twidth:80%;\n }\n \n.jsc_footer{\n\tdisplay:flex;\n\tlist-style-type: none;\n\twidth: 100%;\n    justify-content: space-between;\n    margin-top: 1rem;\n}\n\n.jsc_footer label{\n\tfont-weight:bold;\n}\n\n.jsc_sign{\n\tposition:absolute;\n\tright:20px;\n\tbottom:20px;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;js_page_container&quot;&gt;\n&lt;div class=&quot;js_page js_page1&quot;&gt;\n&lt;div class=&quot;js_page_section&quot;&gt;\n\t&lt;div class=&quot;jsc_markSheetHeader&quot;&gt;\n\t\t&lt;div class=&quot;zcs_school_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t\t&lt;div class=&quot;jsc_markSheetHeader_content&quot;&gt;\n\t\t\t&lt;h4&gt;&lt;%=org.Name%&gt;&lt;\/h4&gt;\n\t\t\t&lt;p&gt;&lt;%=org.Address.address_line_2%&gt;, &lt;%=org.Address.district_city%&gt; - &lt;%=org.Address.postal_Code%&gt;.&lt;\/p&gt;\n\t\t\t&lt;p&gt;Phone: &lt;%=org.Phone_Primary%&gt; \/ &lt;%=org.Phone_Secondary%&gt;&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;h4 class=&quot;jsc_fee_receipt_header&quot;&gt;Fee Receipt&lt;\/h4&gt;\n\t&lt;div class=&quot;jsc_student_details&quot;&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Month&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=TermFeeInfo.Start_Date.toString(&quot;MMM-yy&quot;)%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Term ID&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=TermFeeInfo.Installment_ID%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Father&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=TermFeeInfo.Parents.Father_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Mother&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=TermFeeInfo.Parents.Mother_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Term&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=TermFeeInfo.Installment_No%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t&lt;\/div&gt;\n\t&lt;table class=&quot;jsc_fees&quot;&gt;\n\t&lt;thead&gt;\n\t&lt;tr&gt;\n\t\t&lt;th&gt;Student Name&lt;\/th&gt;\n\t\t&lt;th&gt;Class&lt;\/th&gt;\n\t\t&lt;th&gt;Fee Head&lt;\/th&gt;\n\t\t&lt;th&gt;Amount&lt;\/th&gt;\n\t&lt;\/tr&gt;\n\t&lt;\/thead&gt;\n\t&lt;tbody&gt;\t&lt;tr&gt;&lt;td&gt;&lt;%=StudentTermFeeInfo.Student.Name%&gt;&lt;\/td&gt;&lt;td&gt;&lt;%=StudentTermFeeInfo.Student.Class.Class%&gt; - &lt;%=StudentTermFeeInfo.Student.Class.Section%&gt;&lt;\/td&gt;&lt;td&gt;Term &lt;%=TermFeeInfo.Installment_No%&gt; Fee&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=StudentTermFeeInfo.Term_Fee.round(0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\tif(StudentTermFeeInfo.Past_Due &gt; 0)\n\t{\n\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;Past Due&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=ifnull(StudentTermFeeInfo.Past_Due.round(0),0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t}\n\tif(StudentTermFeeInfo.Book_Fee &gt; 0)\n\t{\n\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;&lt;\/td&gt;&lt;td&gt;Book Fee&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=ifnull(StudentTermFeeInfo.Book_Fee.round(0),0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;tr&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;td style=&quot;border-bottom: 0.5px solid #000;&quot;&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;\/tbody&gt;\n\t&lt;tfoot&gt;\n\t\t&lt;tr&gt;\n\t\t\t&lt;td style=&quot;border-right:0 !important;&quot;&gt;&lt;\/td&gt;\n\t\t\t&lt;td style=&quot;border-right:0 !important;&quot;&gt;&lt;\/td&gt;\n\t\t\t&lt;td&gt;Total Amount&lt;br&gt;Paid Amount&lt;br&gt;Balance Due&lt;\/td&gt;\n\t\t\t&lt;td&gt;\u20B9 &lt;%=StudentTermFeeInfo.Final_Term_Fee.round(0)%&gt;&lt;br&gt;\u20B9 &lt;%=StudentTermFeeInfo.Final_Term_Fee.round(0) - StudentTermFeeInfo.Balance_Amount.round(0)%&gt;&lt;br&gt;\u20B9 &lt;%=StudentTermFeeInfo.Balance_Amount.round(0)%&gt;&lt;\/td&gt;\n\t\t&lt;\/tr&gt;\n\t&lt;\/tfoot&gt;\n\t\n&lt;\/table&gt;\n&lt;h3 style=&quot;margin-top:35px;margin-bottom:5px;&quot;&gt;Payment History&lt;\/h3&gt;\n\t&lt;table class=&quot;jsc_fees_2&quot;&gt;\n\t&lt;tbody&gt;\n&lt;%\n\tfor each  FeePaid in Student_Specific_Fee_Payment[Fees_Receipt_ID in TermFeeInfo.Fees_Receipts &amp;&amp; Student == StudentTermFeeInfo.Student]\n\t{\n\t\t%&gt;\n&lt;tr&gt;&lt;td&gt;Amount Paid on &lt;%=FeePaid.Fees_Receipt_ID.Payment_Date%&gt; By &lt;%=FeePaid.Fees_Receipt_ID.Payment_Mode%&gt;&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=FeePaid.Amount_Paid.round(0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tbody&gt;\n&lt;\/table&gt;\n&lt;div class=&quot;jsc_sign&quot;&gt;Auth. Sign. &lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Fee_Card(int Fee_ID)
		{
			displayname = "Fee Card"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet10' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet10()\ncontent\n&lt;%{\n\tstudent_fee = Student_Fees_Form[ID == input.Fee_ID];\n\torg = Organization[ID != 0];\n\torg_logo = org.Logo;\n\torg_logo = org_logo.replaceAll(&quot;creator.zoho.in&quot;,&quot;creatorapp.zohopublic.in\/file&quot;).replaceAll(&quot;\/sharedBy\/appLinkName\/&quot;,zoho.appuri);\n\torg_logo = org_logo.replaceAll(&quot;viewLinkName\/fieldName&quot;,&quot;Organization_Details\/&quot; + org.ID + &quot;\/Logo&quot;).replaceAll(&quot;\/image\/&quot;,&quot;\/image-download\/XGD9BYAdnDHEmCrtpDfK1RUMCtB5Jmav111fV7Rpw5xyykOPgZxOHFYQb5JXjdYf8T5HzkZsYXQ4dPDA68hO8fqCRuT4KFDGGUAu?filepath=&quot;);\n\t%&gt;\n&lt;style&gt;\n:root{\n--jsHorizontalPagePadding:1.75cm;\n--jsVerticalPagePadding:1.75cm;\n}\n\n.js_page_container *{\nmargin:0;\npadding:0;\nbox-sizing:border-box;\n}\n\n.js_page_container{\nfont-family: &apos;Lato&apos;;\n}\n\n.js_page{\npadding:12px;\nbackground: white;\nwidth: 20cm;\nheight: 25cm;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n}\n\n.js_page:not(.js_page1){\npage-break-before:always;\n}\n\n.js_page_section{\nborder:0.5px solid #000;\nwidth: 100%;\n\/\/ height: calc(25cm - var(--jsVerticalPagePadding));\npadding:20px;\ndisplay: flex;\nflex-direction: column;\nposition:relative;\n}\n\n\/*** Marksheet Header ****\/\n.jsc_markSheetHeader{\n\tdisplay:flex;\n\ttext-align:center;\n\tpadding-bottom: 13px;\n}\n\n.jsc_markSheetHeader img{\n\twidth:90px;\n\taspect-ratio:1;\n\tmargin-left:45px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content{\n\tflex:1;\n\tdisplay:flex;\n\tflex-direction:column;\n\tjustify-content:center;\n\tmargin-right:60px;\n\tletter-spacing:.75px;\n}\n\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content h4{\n\tfont-size:17px;\n}\n\n.jsc_markSheetHeader .jsc_markSheetHeader_content &gt; *{\n\tline-height:20px;\n}\n\n.js_page_section h4.jsc_fee_receipt_header{\n\t text-transform: uppercase;\n\t line-height:35px;\n\t border-top:0.5px solid #000;\n\t border-bottom:0.5px solid #000;\n\t text-align:center;\n\t margin-top:12px;\n\t font-size:18px\n\t letter-spacing:1px;\n}\n\n\/**** Student Details ****\/\n.jsc_student_details{\n\tdisplay:flex;\n\tpadding: 15px 0;\n    justify-content: space-between;\n\talign-items:center;\n}\n\n.jsc_student_details table.jsc_student_details_table{\n\tflex:1;\n\tmargin:0 auto;\n}\n\n\n.jsc_student_details table.jsc_student_details_table td{\n\tline-height:30px;\n\twidth:50%;\n}\n\n\/****** Fees table ******\/\n\ntable.jsc_fees, table.jsc_fees td, table.jsc_fees th{\n  border-collapse: collapse;\n  padding:8px;\n}\n\ntable.jsc_fees thead th{\n\t     line-height: 2rem;\n\t\t border:0.5px solid #000;\n }\n \n.jsc_fees td {\n\tborder: 0.5px solid #000;\n}\n\ntable.jsc_fees tfoot tr{\n\t\t line-height: 2rem;\n\t\t border-top:0.5px solid #000;\n\t\t border-bottom:0.5px solid #000;\n}\n \n.jsc_footer{\n\tdisplay:flex;\n\tlist-style-type: none;\n\twidth: 100%;\n    justify-content: space-between;\n    margin-top: 1rem;\n}\n\n.jsc_footer label{\n\tfont-weight:bold;\n}\n\n.jsc_payment_history td:nth-child(1) {\n\tborder-right:0.5px solid #000;\n\twidth:80%;\n\tpadding: 5px 0px;\n }\n\n.jsc_sign{\n\/\/ \tposition:absolute;\n\ttext-align: right;\n    margin-top: 30px;\n}\n&lt;\/style&gt;\n&lt;div class=&quot;js_page_container&quot;&gt;\n&lt;div class=&quot;js_page js_page1&quot;&gt;\n&lt;div class=&quot;js_page_section&quot;&gt;\n\t&lt;div class=&quot;jsc_markSheetHeader&quot;&gt;\n\t\t&lt;div class=&quot;zcs_school_logo&quot;&gt;&lt;%=org_logo%&gt;&lt;\/div&gt;\n\t\t&lt;div class=&quot;jsc_markSheetHeader_content&quot;&gt;\n\t\t\t&lt;h4&gt;&lt;%=org.Name%&gt;&lt;\/h4&gt;\n\t\t\t&lt;p&gt;&lt;%=org.Address.address_line_2%&gt;, &lt;%=org.Address.district_city%&gt; - &lt;%=org.Address.postal_Code%&gt;.&lt;\/p&gt;\n\t\t\t&lt;p&gt;Phone: &lt;%=org.Phone_Primary%&gt; \/ &lt;%=org.Phone_Secondary%&gt;&lt;\/p&gt;\n\t\t&lt;\/div&gt;\n\t&lt;\/div&gt;\n\t&lt;h4 class=&quot;jsc_fee_receipt_header&quot;&gt;FEE CARD&lt;\/h4&gt;\n\t&lt;div class=&quot;jsc_student_details&quot;&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Month&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Added_Time.toString(&quot;MMM-yy&quot;)%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Fee ID&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Fee_ID%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Father&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Parents.Father_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Mother&apos;s Name&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Parents.Mother_s_Name%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t\t&lt;table class=&quot;jsc_student_details_table&quot;&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Dated&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Added_Time%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;Academic Year&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;: &lt;%=student_fee.Academic_Year.Academic_Year%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t&lt;tr&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t\t&lt;td&gt;&amp;nbsp;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n\t\t&lt;\/table&gt;\n\t&lt;\/div&gt;\n\t&lt;table class=&quot;jsc_fees&quot;&gt;\n\t&lt;thead&gt;\n\t&lt;tr&gt;\n\t\t&lt;th&gt;Student Name&lt;\/th&gt;\n\t\t&lt;th&gt;Class&lt;\/th&gt;\n\t\t&lt;th&gt;Fee Head&lt;\/th&gt;\n\t\t&lt;th&gt;Actual Amount&lt;\/th&gt;\n\t\t&lt;th&gt;Paid Amount&lt;\/th&gt;\n\t&lt;\/tr&gt;\n\t&lt;\/thead&gt;\n\t&lt;tbody&gt;\n&lt;%\n\tfor each  student_info in student_fee.Student_Specific_Fee\n\t{\n\t\ttotalPayment = Student_Specific_Fee_Payment[Fees_Receipt_ID.Fee_ID == input.Fee_ID &amp;&amp; Student == student_info.Student];\n\t\tstudent_term_one = Student_Specific_Term_Fee[Term_Fees_Form.Fee_ID == input.Fee_ID &amp;&amp; Term_Fees_Form.Installment_No == &quot;1&quot; &amp;&amp; Student == student_info.Student];\n\t\tstudent_term_two = Student_Specific_Term_Fee[Term_Fees_Form.Fee_ID == input.Fee_ID &amp;&amp; Term_Fees_Form.Installment_No == &quot;2&quot; &amp;&amp; Student == student_info.Student];\n\t\tstudent_term_three = Student_Specific_Term_Fee[Term_Fees_Form.Fee_ID == input.Fee_ID &amp;&amp; Term_Fees_Form.Installment_No == &quot;3&quot; &amp;&amp; Student == student_info.Student];\n\t\ttotal_actual_amount = 0;\n\t\tpayment_one = Student_Specific_Fee_Payment[Fees_Receipt_ID.Fee_ID == input.Fee_ID &amp;&amp; Fees_Receipt_ID.Installement_No == &quot;1&quot; &amp;&amp; Student == student_info.Student];\n\t\tpayment_two = Student_Specific_Fee_Payment[Fees_Receipt_ID.Fee_ID == input.Fee_ID &amp;&amp; Fees_Receipt_ID.Installement_No == &quot;2&quot; &amp;&amp; Student == student_info.Student];\n\t\tpayment_three = Student_Specific_Fee_Payment[Fees_Receipt_ID.Fee_ID == input.Fee_ID &amp;&amp; Fees_Receipt_ID.Installement_No == &quot;3&quot; &amp;&amp; Student == student_info.Student];\n\t\ttotal_paid_amount = 0;\n\t\t%&gt;\n&lt;tr&gt;\n\t\t\t\t\t&lt;td rowspan=&quot;3&quot;&gt;&lt;%=student_info.Student.Name%&gt; &lt;\/td&gt;\n\t\t\t\t\t&lt;td rowspan=&quot;3&quot;&gt;&lt;%=student_info.Student.Class.Class%&gt; - &lt;%=student_info.Student.Class.Section%&gt;&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;Term 1 Fee&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;\u20B9 &lt;%=student_term_one.Final_Term_Fee.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\tif(payment_one.count() &gt; 0)\n\t\t{\n\t\t\ttotal_actual_amount = total_actual_amount + payment_one.Payable_Amount.round(0);\n\t\t\ttotal_paid_amount = total_paid_amount + payment_one.Amount_Paid.round(0);\n\t\t\t%&gt;\n&lt;td&gt;\u20B9 &lt;%=payment_one.Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;td&gt;-&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t&lt;td&gt;Term 2 Fee&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;\u20B9 &lt;%=student_term_two.Final_Term_Fee.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\tif(payment_two.count() &gt; 0)\n\t\t{\n\t\t\ttotal_actual_amount = total_actual_amount + payment_two.Payable_Amount.round(0);\n\t\t\ttotal_paid_amount = total_paid_amount + payment_two.Amount_Paid.round(0);\n\t\t\t%&gt;\n&lt;td&gt;\u20B9 &lt;%=payment_two.Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;td&gt;-&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t&lt;td&gt;Term 3 Fee&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;\u20B9 &lt;%=student_term_three.Final_Term_Fee.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\tif(payment_three.count() &gt; 0)\n\t\t{\n\t\t\ttotal_actual_amount = total_actual_amount + payment_three.Payable_Amount.round(0);\n\t\t\ttotal_paid_amount = total_paid_amount + payment_three.Amount_Paid.round(0);\n\t\t\t%&gt;\n&lt;td&gt;\u20B9 &lt;%=payment_three.Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;td&gt;-&lt;\/td&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;\n\t\t\t\t\t&lt;td&gt;&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;&lt;b&gt;Total Actual Amount :&lt;\/b&gt;&lt;br&gt; \u20B9 &lt;%=total_actual_amount%&gt;&lt;\/td&gt;\n\t\t\t\t\t&lt;td&gt;&lt;b&gt;Total Paid Amount :&lt;\/b&gt;&lt;br&gt; \u20B9 &lt;%=total_paid_amount%&gt;&lt;\/td&gt;\n\t\t\t\t&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;&lt;td colspan=&quot;5&quot;&gt;&lt;b&gt;Rupess in Words :&lt;\/b&gt; &lt;%=total_paid_amount.toWords(&quot;en-gb&quot;).proper()%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;&lt;td colspan=&quot;5&quot;&gt;&lt;b&gt;Discount :&lt;\/b&gt; \u20B9 &lt;%=student_info.Discount.round(0)%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n\t\t\t\t&lt;tr&gt;&lt;td colspan=&quot;5&quot;&gt;&lt;b&gt;Balance Fee for the Academic Year 2025-2026 :&lt;\/b&gt; \u20B9 &lt;%=total_actual_amount - total_paid_amount%&gt;&lt;\/td&gt;&lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tbody&gt;\n&lt;\/table&gt;\n&lt;h3 style=&quot;margin-top:35px;margin-bottom:5px;&quot;&gt;Payment History&lt;\/h3&gt;\n\t&lt;table class=&quot;jsc_payment_history&quot;&gt;\n\t&lt;tbody&gt;\n&lt;%\n\tfor each  payment in Fees_Receipt[Fee_ID == input.Fee_ID]\n\t{\n\t\t%&gt;\n&lt;tr&gt;\n\t\t\t&lt;td&gt;Amount Paid on &lt;%=payment.Payment_Date%&gt; By &lt;%=payment.Payment_Mode%&gt;&lt;\/td&gt;&lt;td&gt;\u20B9 &lt;%=payment.Total_Amount_Paid.round(0)%&gt;&lt;\/td&gt;\n\t\t\t&lt;\/tr&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;\/tbody&gt;\n&lt;\/table&gt;\n&lt;div class=&quot;jsc_sign&quot;&gt;Auth. Sign.&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Academic_Years_Page
		{
			displayname = "Academic Years"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet11' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet11()\ncontent\n&lt;%{\n\t%&gt;\n&lt;div style=&quot;height:90vh;&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Academic_Years&apos; params=&apos;zc_AddRec=false&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&apos;&gt;Loading View...&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Terms_Page
		{
			displayname = "Terms"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet12' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet12()\ncontent\n&lt;%{\n\t%&gt;\n&lt;div style=&quot;height:90vh;&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Term_Fees_Dates&apos; params=&apos;zc_AddRec=false&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&apos;&gt;Loading View...&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
		page Class_Fee_Setups_Page
		{
			displayname = "Class Fee Setups"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width=\"100%\"\n   \t>\n\t<dsp id='html_snippet13' elementName=\"HTML Snippet\"\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet13()\ncontent\n&lt;%{\n\t%&gt;\n&lt;div style=&quot;height:90vh;&quot; elName=&apos;zc-component&apos; viewLinkName=&apos;Class_Fee_Setups&apos; params=&apos;zc_AddRec=false&amp;zc_EditRec=false&amp;zc_DelRec=false&amp;zc_DuplRec=false&amp;zc_EditBulkRec=false&apos;&gt;Loading View...&lt;\/div&gt;\n&lt;%\n\n}%&gt;]]>\n<\/dsp>\n<\/column>\n<\/row>\n<\/layout>\n<\/zml>"
		}
	}


		 functions
		 {
			 Deluge
			 {
				 string studentProfile(string student_name)
                 {
                 	eventCode = "";
                 	// List of words to exclude (e.g., "and", "of", etc.)
                 	excludeWords = {"AND","OF","THE","IN","AT","ON","FOR","WITH"};
                 	// Remove special characters and convert to a clean list of words
                 	cleanName = student_name.toUpperCase().trim().replaceAll("[^A-Z ]","");
                 	words = cleanName.toList(" ");
                 	info words;
                 	if(words.size() == 1)
                 	{
                 		// First 2 letters if it's a single word
                 		eventCode = words.get(0).subString(0,2);
                 	}
                 	else
                 	{
                 		for each  word in words
                 		{
                 			if(!excludeWords.contains(word) && word != "")
                 			{
                 				// Skip excluded words
                 				eventCode = eventCode + word.subString(0,1);
                 			}
                 		}
                 	}
                 	return eventCode;
                 }
