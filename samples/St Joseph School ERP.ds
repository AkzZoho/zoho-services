			Generate_Fees_Temporary_ as "Generate Fees ( Temporary )"
			{
				type =  functions
				form = Term_Fees_Date
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						for each  rec in Student_Fees_Form[Status != "Paid"]
										{
											CurrentFeeIntallmentAlready_Created = Term_Fees_Form[Fee_ID == rec.ID && Installment_No == input.Term_No];
											if(CurrentFeeIntallmentAlready_Created.count() == 0)
											{
												installment_amount = rec.Total_Fee / 3;
												NewTerm_Fee = insert into Term_Fees_Form
												[
													Academic_Year=rec.Academic_Year
													Start_Date=input.Start_Date
													Parents=rec.Parents
													Fee_ID=rec.ID
													Installment_No=input.Term_No
													Due_Date=input.Due_Date
													Total_Term_Fee=installment_amount
													Total_Final_Term_Fee=installment_amount
													Total_Balance_Amount=installment_amount
													Total_Book_Fee=0
													Total_Past_Due=0
													Status="Pending"
													Added_User=zoho.loginuser
												];
												StudentCount = rec.count(Student_Specific_Fee);
												// 		PerStudentAmount = installment_amount / StudentCount;
												for each  StudentSpecificFee in Student_Fee[ID in rec.Student_Specific_Fee]
												{
													PerStudentAmount = StudentSpecificFee.Amount / 3;
													insert into Student_Specific_Term_Fee
													[
														Added_User=zoho.loginuser
														Academic_Year=StudentSpecificFee.Academic_Year
														Term_Fees_Form=NewTerm_Fee
														Student=StudentSpecificFee.Student
														Class=StudentSpecificFee.Class
														Term_Fee=PerStudentAmount
														Book_Fee=0
														Final_Term_Fee=PerStudentAmount
														Balance_Amount=PerStudentAmount
														Past_Due=0
													]
												}
											}
										}
					)
					}
				}
			}
