		form Parents_Details_Form
		{
			displayname = "Parents Details Form"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Father_s_Name
			(
    			type = text
				displayname = "Father's Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Father_s_Occupation
			(
    			type = text
				displayname = "Father's Occupation"
	 			row = 1
	 			column = 1   
				width = medium
			)
			unique Father_s_Aadhaar_Number
			(
				type = number
				displayname = "Father's Aadhaar Number"
				maxchar = 12
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Father_s_Mobile
			(
    			type = phonenumber
				displayname = "Father's Mobile"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Mother_s_Name
			(
