		form Document
		{
			success message = "Document Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Document_Type
			(
				type = picklist
				displayname = "Document Type"
				maxchar = 100
				values = {"Transfer Certificate","Leaving Certificate","Elementary School Certificate","Record Sheet"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Document
			(
    			type = upload file
				browse = local_drive
	 			row = 1
	 			column = 1   
				width = medium
			)
			Number
			(
				type = number
	 			row = 1
	 			column = 1   
				width = medium
			)
			Date_field
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Student_Form_ID
			(
				type = picklist	
				displayname = "Student Form ID"
				values  = Student_Form.ID
    			bidirectional = Documents
    			displayformat = [ID]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Fees_Receipt
		{
			title 
    		{
				displayname = "Fees Receipt"
    			on add = "Payment"
   	 			on edit = "Fees Receipt"
			}
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Auto_Number
			(
    			type = autonumber
				displayname = "Auto Number"
				start index = 1001
	 			row = 1
	 			column = 1   
				width = medium
			)
			Parents
			(
				type = picklist	
				values  = Parents_Details_Form.ID
    			displayformat = [Father_s_Name + " - " + Mother_s_Name]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Installment_ID
			(
				type = picklist	
				displayname = "Term ID"
				values  = Term_Fees_Form.ID
    			bidirectional = Fees_Receipts
    			displayformat = [Installment_ID]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Academic_Year
			(
				type = picklist	
				displayname = "Academic Year"
				values  = Academic_Year.ID
    			displayformat = [Academic_Year]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Receipt_ID
			(
    			type = formula
				displayname = "Receipt ID"
				value =  "SJSFR - " + input.Auto_Number
				visibility = false
				display type = text
				format = plaintext
	 			row = 1
	 			column = 2   
				width = medium
			)
			Fee_ID
			(
				type = picklist	
				displayname = "Fee ID"
				values  = Student_Fees_Form.ID
    			displayformat = [Fee_ID]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			Installement_No
			(
				type = picklist
				displayname = "Term"
				maxchar = 100
				values = {"1","2","3"}
	 			row = 1
	 			column = 2   
				width = medium
			)
			Total_Payable_Amount
			(
				displayname = "Total Payable Amount"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Student_Fee_Amount_Details
			(
				type = grid
				displayname = "Student Fee Amount Details"
				values  = Student_Specific_Fee_Payment.ID
    			bidirectional = Fees_Receipt_ID
	 			row = 2
	 			column = 1   
				width = medium
			)
			Section1
			(
				type = section
				displayname = "Section"
	 			row = 3
	 			column = 0   
				width = medium
			)
			must have Payment_Date
			(
    			type = date
				displayname = "Payment Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Payment_Mode
			(
				type = picklist
				displayname = "Payment Mode"
				maxchar = 100
				values = {"Cash","Online","Card"}
	 			row = 3
	 			column = 1   
				width = medium
			)
			must have Total_Amount_Paid
			(
				displayname = "Total Amount Paid"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
