			Hide_Show_Fields as "Hide/Show Fields"
			{
				type =  form
				form = Update_Amount
				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Student_Specific_Update_Amount_Details.Academic_Year;
										hide Student_Specific_Update_Amount_Details.Term_ID;
										disable Student_Specific_Update_Amount_Details.Student;
										disable Student_Specific_Update_Amount_Details.Class;
										if(input.Installment_ID != null)
										{
											input.Academic_Year = input.Installment_ID.Academic_Year;
										}
										if(input.Amount_Type == "Past Due")
										{
											hide Student_Specific_Update_Amount_Details.Book_Fee_Amount;
											show Total_Past_Due_Amount;
											hide Total_Book_Fee_Amount;
											fet_installment = Term_Fees_Form[Fee_ID == input.Installment_ID.Fee_ID && Status == "Partially Paid"];
											// 	fet_receipt = Fees_Receipt[ID == fet_installment.Fees_Receipt_ID];
											input.Total_Past_Due_Amount = fet_installment.Total_Balance_Amount;
										}
										else if(input.Amount_Type == "Book Fee")
										{
											hide Student_Specific_Update_Amount_Details.Past_Due_Amount;
											hide Total_Past_Due_Amount;
											show Total_Book_Fee_Amount;
										}
										//----------------------- Autopopulate Student Specific Update Amount Details ------------------------
										if(input.Selected_Student != null)
										{
											student_update_amount_Row = Update_Amount.Student_Specific_Update_Amount_Details();
											student_update_amount_Row.Academic_Year=input.Academic_Year;
											student_update_amount_Row.Term_ID=input.Installment_ID;
											student_update_amount_Row.Student=input.Selected_Student;
											student_update_amount_Row.Class=input.Selected_Student.Class;
											input.Student_Specific_Update_Amount_Details.insert(student_update_amount_Row);
										}
										else
										{
											for each  student in Student_Form[Status == "Active" && Parents_Details_Form_ID == input.Installment_ID.Parents]
											{
												student_update_amount_Row = Update_Amount.Student_Specific_Update_Amount_Details();
												student_update_amount_Row.Academic_Year=input.Academic_Year;
												student_update_amount_Row.Term_ID=input.Installment_ID;
												student_update_amount_Row.Student=student.ID;
												student_update_amount_Row.Class=student.Class;
												input.Student_Specific_Update_Amount_Details.insert(student_update_amount_Row);
											}
										}
						)
					}
				}

			}
