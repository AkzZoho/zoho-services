		workflow
		{
		form
		{
			Validate_Father_s_Aadhar_ as "Validate Father's Aadhar Number"
			{
				type =  form
				form = Parents_Details_Form
				record event = on add or edit

				on user input of Father_s_Aadhaar_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Father_s_Aadhaar_Number != null)
										{
											if(input.Father_s_Aadhaar_Number.toString().len() < 12)
											{
												alert "Aadhar Number should contains 12 digits!";
												input.Father_s_Aadhaar_Number = null;
											}
										}
						)
					}
				}

			}
			Validate_Mother_s_Aadhaar as "Validate Mother's Aadhaar Number"
			{
				type =  form
				form = Parents_Details_Form
				record event = on add or edit

				on user input of Mother_s_Aadhaar_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Mother_s_Aadhaar_Number != null)
										{
											if(input.Mother_s_Aadhaar_Number.toString().len() < 12)
											{
												alert "Aadhar Number should contains 12 digits!";
												input.Mother_s_Aadhaar_Number = null;
											}
										}
						)
					}
				}

			}
			Hide_Disable_Fields as "Hide & Disable Fields"
			{
				type =  form
				form = Student_Fees_Form
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide Hidden_Section,Fee_Installment;
					}
					actions 
					{
						disable Final_Fee,Parents,Total_Fee,Academic_Year;
					}
					actions 
					{
					hide add row of Student_Specific_Fee;
					}
					actions 
					{
					hide delete row of Student_Specific_Fee;
					}
				}

			}
			Hide_Fields2 as "Hide Fields"
			{
				type =  form
				form = Term_Fees_Form
				record event = on add or edit

				field rules
				{
					actions 
					{
						hide Hidden_Section;
					}
				}

			}
			Validate_Aadhar_Number as "Validate Aadhar Number"
			{
				type =  form
				form = Student_Form
				record event = on add or edit

				on user input of Aadhaar_Number
				{
					actions 
					{
						custom deluge script
						(
											if(input.Aadhaar_Number != null)
										{
											if(input.Aadhaar_Number.toString().len() < 12)
											{
												alert "Aadhar Number should contains 12 digits!";
												input.Aadhaar_Number = null;
											}
										}
						)
					}
				}

			}
			Validate_Date_of_Birth1 as "Validate Date of Birth"
			{
				type =  form
				form = Student_Form
				record event = on add or edit

				on user input of Date_of_Birth
				{
					actions 
					{
						custom deluge script
						(
											if(input.Date_of_Birth != null)
										{
											if(input.Date_of_Birth.addYear(3) > zoho.currentdate)
											{
												alert "Students are eligible for enrollment from the age of 3!";
												input.Date_of_Birth = null;
											}
										}
						)
					}
				}

			}
			Validate_Discount as "Validate Discount"
			{
				type =  form
				form = Student_Fees_Form
				record event = on add or edit

				on user input of Total_Discount
				{
					actions 
					{
						custom deluge script
						(
											if(input.Total_Discount != null)
										{
											if(input.Total_Fee == null)
											{
												alert "Kindly enter total fee first!";
												input.Total_Discount = null;
											}
											else
											{
												if(input.Total_Discount <= 0)
												{
													alert "Enter a valid discount!";
													input.Total_Discount = null;
												}
											}
										}
										input.Final_Fee = ifnull(input.Total_Fee,0) - ifnull(input.Total_Discount,0);
						)
					}
				}

			}
