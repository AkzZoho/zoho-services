			Autofill_Academic_Year as "Autofill Academic Year"
			{
				type =  form
				form = Academic_Year
				record event = on add

				on user input of Year_field
				{
					actions 
					{
						custom deluge script
						(
											if(input.Year_field != null)
										{
											if(2000 > input.Year_field)
											{
												alert "Year should not be lesser than 2000!";
												input.Year_field = null;
											}
											else
											{
												nextYear = input.Year_field.toNumber() + 1;
												input.Academic_Year = input.Year_field + "-" + nextYear;
												if(input.Year_field == zoho.currentdate.getYear())
												{
													input.Status = "Current";
												}
												else if(input.Year_field < zoho.currentdate.getYear())
												{
													input.Status = "Previous";
												}
												else if(input.Year_field > zoho.currentdate.getYear())
												{
													input.Status = "Next";
												}
											}
										}
										else
										{
											input.Academic_Year = null;
										}
						)
					}
				}

			}
