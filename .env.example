# ============================
# LLM Provider Keys (configure what you use)
# ============================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZOHO_CATALYST_AI_TOKEN=

# Preferred provider order (comma-separated): openai,anthropic,zoho,stub
LLM_PREFERENCE=openai,anthropic,zoho,stub

# ============================
# Server
# ============================
PORT=3001
NODE_ENV=development
MAX_UPLOAD_MB=25

# ============================
# Catalyst (populated automatically in deployed env)
# ============================
CATALYST_PROJECT_ID=
CATALYST_PROJECT_KEY=
