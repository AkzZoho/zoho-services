# ============================
# LLM Provider Keys (configure what you use)
# ============================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Preferred provider order (comma-separated): openai,anthropic,stub
LLM_PREFERENCE=openai,anthropic,stub

# ============================
# Server
# ============================
PORT=3001
NODE_ENV=development
MAX_UPLOAD_MB=25

# Optional: comma-separated list of allowed origins for CORS.
# Leave blank to allow all origins (fine for local dev / read-only APIs).
# Example: CORS_ALLOWED_ORIGINS=

# ============================
# Admin
# ----------------------------
# Required for POST /api/admin/* endpoints (e.g. tool-visibility persistence
# to client/.env). Must match the client's VITE_ADMIN_PASSWORD.
# Leave blank to disable server-side admin write-back.
# ============================
ADMIN_PASSWORD=https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=
